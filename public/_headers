# Headers globales de seguridad + cache moderado para HTML
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  X-XSS-Protection: 1; mode=block
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Content Security Policy
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://app.cal.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://app.cal.com; frame-src 'self' https://www.googletagmanager.com https://www.google.com https://maps.google.com https://app.cal.com https://cal.com; worker-src 'self' blob:

# Cache agresivo para assets estáticos fingerprinted
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache para imágenes
/*.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.jpg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.ico
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# No cache para API routes
/api/*
  Cache-Control: no-store, no-cache, must-revalidate

