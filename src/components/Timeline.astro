---
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";
import Upheading from "./Upheading.astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  subtitle?: string;
  sectionId?: string;
  phases?: TimelinePhase[];
  ctaHeading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const iconByKey = {
  scale: Scale,
  barChart3: BarChart3,
  badgeCheck: BadgeCheck,
  target: Target,
  trendingUp: TrendingUp,
  calendarClock: CalendarClock,
  chartNoAxesColumn: ChartNoAxesColumn,
  lineChart: LineChart,
  layers3: Layers3,
} as const;

const defaultPhases: TimelinePhase[] = [
  {
    title: "Diagnóstico técnico y análisis de mercado",
    intro:
      "Identifica los errores que te invisibilizan y conoce las oportunidades de mercado que ahora pierdes. Recibes un mapa de los problemas técnicos de tu web y un estudio de las búsquedas de tus clientes.",
    bullets: [
      {
        icon: "scale",
        emphasis: "Mide tu autoridad.",
        text: "Compara tu situación real frente a tus competidores.",
      },
      {
        icon: "barChart3",
        emphasis: "Cuantifica tu mercado.",
        text: "Descubre el volumen de búsqueda real en tu zona.",
      },
      {
        icon: "badgeCheck",
        emphasis: "Decide con criterio.",
        text: "Verifica la viabilidad del proyecto antes de invertir.",
      },
    ],
    outro: "Accede a tu auditoría gratuita y prioriza tus próximas acciones.",
  },
  {
    title: "Estrategia de posicionamiento web SEO",
    intro:
      "Sustituye la incertidumbre por una hoja de ruta técnica. Con el diagnóstico en la mano, diseccionamos las acciones necesarias para captar clientes en tu zona y sector.",
    bullets: [
      {
        icon: "target",
        emphasis: "Prioriza tus objetivos.",
        text: "Identifica qué búsquedas atacar primero para acelerar el retorno.",
      },
      {
        icon: "trendingUp",
        emphasis: "Proyecta tu tráfico.",
        text: "Obtén una estimación realista del volumen de visitas según tu mercado.",
      },
      {
        icon: "calendarClock",
        emphasis: "Define un cronograma de ejecución.",
        text: "Visualiza qué cambios técnicos se aplican cada mes y el plazo estimado para consolidarlos.",
      },
    ],
    outro:
      "Valida la estrategia. Audita cada paso del plan antes de ejecutarlo. Si una acción no alinea con tus objetivos de negocio, se descarta.",
  },
  {
    title: "Ejecución y resultados medibles",
    intro:
      "Mientras gestionas tu negocio, tu web escala posiciones y consolida su autoridad en Google. Obtén métricas de negocio, no solo de tráfico.",
    bullets: [
      {
        icon: "chartNoAxesColumn",
        emphasis: "Controla las conversiones.",
        text: "Mide cuántas visitas se transforman en llamadas reales o formularios completados.",
      },
      {
        icon: "lineChart",
        emphasis: "Sigue la evolución de posiciones.",
        text: "Visualiza qué términos has conquistado y cuáles son los siguientes objetivos.",
      },
      {
        icon: "layers3",
        emphasis: "Construye crecimiento acumulado.",
        text: "Construye un activo que mantiene su valor. A diferencia de la publicidad, tu posicionamiento persiste y se refuerza mes a mes.",
      },
    ],
    outro:
      "Impulsa tu impacto local. Capta el volumen de búsquedas de tu sector en Barcelona y convierte a los usuarios en clientes.",
  },
];

const {
  upheading,
  heading,
  subtitle = "Tres fases para ejecutar, medir y escalar. Visualiza el retorno de tu inversión en Barcelona mediante informes claros y objetivos cumplidos.",
  sectionId = "proceso",
  phases = defaultPhases,
  ctaHeading = "Identifica el potencial de tu negocio en Barcelona.",
  ctaText = "Recibe gratis un análisis de tu situación actual valorado en 200 € y descubre cómo captar a los clientes que hoy pierdes.",
  ctaHref = "https://wa.me/34692051399?text=Hola%20Salva%2C%20he%20visto%20tu%20web.%20Tengo%20un%20negocio%20en%20Barcelona%20y%20me%20gustar%C3%ADa%20saber%20si%20el%20SEO%20puede%20ayudarme%20a%20conseguir%20m%C3%A1s%20clientes.",
  ctaLabel = "Pide tu auditoría gratuita por WhatsApp",
} = Astro.props;

const phaseGridColsClass =
  phases.length >= 4
    ? "lg:grid-cols-4"
    : phases.length === 2
      ? "lg:grid-cols-2"
      : "lg:grid-cols-3";
---

<div
    id={sectionId}
    class="relative bg-gradient-to-b from-white via-petrol-50/30 to-white py-24 sm:py-32"
>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
        {upheading && <Upheading as="h2" text={upheading} class="mb-2 text-center text-pretty sm:text-right" />}
        <p
            class:list={["mx-auto max-w-[60ch] text-center text-3xl font-semibold tracking-tight text-pretty text-petrol-900 sm:ml-auto sm:mr-0 sm:text-right sm:text-4xl", !upheading && "mb-2"]}
        >
            {heading}
        </p>
        <p class="mb-16 mx-auto max-w-[55ch] text-center text-lg text-petrol-900 text-pretty sm:ml-auto sm:mr-0 sm:text-right">
            {subtitle}
        </p>
        <div
            class:list={["mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 overflow-hidden lg:mx-0 lg:max-w-none", phaseGridColsClass]}
        >
            {phases.map((phase, idx) => (
                <div>
                    <div class="flex items-center text-sm/6 font-semibold text-sky-500">
                        <span
                            aria-hidden="true"
                            class="mr-4 inline-flex size-6 flex-none items-center justify-center rounded-full bg-sky-500 text-xs font-semibold text-white"
                        >
                            {idx + 1}
                        </span>
                        <span><h3 class="inline font-bold">{phase.title}</h3></span>
                        <div
                            aria-hidden="true"
                            class="absolute -ml-2 h-0.5 w-screen -translate-x-full bg-gradient-to-r from-sky-500/40 to-gray-900/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
                        >
                        </div>
                    </div>
                    <p class="mt-6 text-base/7 text-petrol-900">
                        {phase.intro}
                    </p>
                    <ul class="mt-4 space-y-2 text-base/7 text-petrol-900">
                        {phase.bullets.map((bullet) => {
                            const Icon = iconByKey[bullet.icon];
                            return (
                                <li class="flex items-start gap-2">
                                    <Icon aria-hidden="true" class="mt-1 size-5 shrink-0 text-sky-600" />
                                    <span><strong>{bullet.emphasis}</strong> {bullet.text}</span>
                                </li>
                            );
                        })}
                    </ul>
                    <p class="mt-4 text-base/7 text-petrol-900">
                        {phase.outro}
                    </p>
                </div>
            ))}
        </div>
        <div class="mt-16 text-center">
            <p class="text-xl font-semibold text-petrol-900">
                {ctaHeading}
            </p>
            <p class="mx-auto mt-3 max-w-[50ch] text-base text-petrol-900">
                {ctaText}
            </p>
            <a
                href={ctaHref}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="mt-3 inline-block text-base font-semibold text-sky-600 underline decoration-sky-500/70 underline-offset-4 transition hover:text-sky-700"
            >
                {ctaLabel}
            </a>
        </div>
    </div>
</div>
