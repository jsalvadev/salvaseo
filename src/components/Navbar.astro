---
import { siteConfig } from '../data/site'

interface Props {
  forceScrolled?: boolean
}

const { forceScrolled = false } = Astro.props
const { brand, contact, navigation } = siteConfig
---

<header id='site-header' class='fixed inset-x-0 top-0 z-50' data-force-scrolled={forceScrolled ? 'true' : undefined}>
  <nav
    aria-label='Navegación principal'
    class='container-site flex items-center justify-between py-2'>

    <!-- Logo -->
    <div class='flex lg:flex-1'>
      <a href='/' class='-m-1.5 p-1.5 flex items-center gap-x-2.5'>
        <span class='sr-only'>{brand.name}</span>
        <img
          src='/logo.webp'
          alt={`${brand.name} Logo`}
          width='32'
          height='33'
          loading='eager'
          class='h-8 w-auto'
        />
        <span class='brand-wordmark text-xl text-cream'>{brand.name}</span>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <div class='flex lg:hidden'>
      <button
        type='button'
        command='show-modal'
        commandfor='mobile-menu'
        class='hamburger-btn -m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-cream transition-colors duration-200 hover:text-cream focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal focus-visible:ring-offset-2'>
        <span class='sr-only'>Abrir menú</span>
        <svg
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='1.5'
          aria-hidden='true'
          class='size-6'>
          <path
            d='M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5'
            stroke-linecap='round'
            stroke-linejoin='round'></path>
        </svg>
      </button>
    </div>

    <!-- Desktop nav -->
    <div class='hidden lg:flex lg:gap-x-10 lg:items-center'>
      <a href='/' class='nav-link text-base font-semibold'>Inicio</a>

      {navigation.primary.slice(0, 1).map((link) => (
        <a href={link.href} class='nav-link text-base font-semibold'>
          {link.label}
        </a>
      ))}

      <!-- Services dropdown -->
      <div class='relative group'>
        <button
          type='button'
          class='nav-link flex items-center gap-x-1 text-base font-semibold'>
          Servicios
          <svg
            viewBox='0 0 20 20'
            fill='currentColor'
            aria-hidden='true'
            class='size-4 dropdown-chevron transition-transform duration-200'>
            <path
              fill-rule='evenodd'
              d='M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z'
              clip-rule='evenodd'></path>
          </svg>
        </button>
        <div class='services-dropdown absolute left-0 z-10 w-72 pt-3'>
          <div class='overflow-hidden rounded-base bg-white shadow-xl ring-1 ring-teal/15 py-1.5'>
            {navigation.services.map((service) => (
              <a
                href={service.href}
                class='group/item flex items-center gap-3 px-4 py-2.5 text-base text-cream hover:bg-cream hover:text-sage transition-colors duration-150'>
                <span class='h-1.5 w-1.5 flex-shrink-0 rounded-full bg-teal/30 transition-colors duration-150 group-hover/item:bg-teal'></span>
                {service.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      {navigation.primary.slice(1).map((link) => (
        <a href={link.href} class='nav-link text-base font-semibold'>
          {link.label}
        </a>
      ))}

      <a href='/#calculadora' class='nav-link text-base font-semibold inline-flex items-center gap-1.5'>
        Calculadora
        <span class='calc-badge'>Nuevo</span>
      </a>

      <div class='nav-divider h-4 w-px bg-teal/15 transition-colors duration-300' aria-hidden='true'></div>

      <a
        href={`tel:${contact.phone.e164}`}
        class='nav-phone inline-flex items-center gap-1.5 text-base font-semibold text-teal'>
        <svg class='h-3.5 w-3.5 flex-shrink-0' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'>
          </path>
        </svg>
        {contact.phone.display}
      </a>
    </div>
  </nav>

  <!-- Mobile menu dialog -->
  <el-dialog>
    <dialog id='mobile-menu' class='backdrop:bg-transparent lg:hidden'>
      <div tabindex='0' class='fixed inset-0 focus:outline-none'>
        <el-dialog-panel
          class='fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-cream p-6 sm:max-w-sm sm:ring-1 sm:ring-surface/10'>

          <div class='flex items-center justify-between'>
            <a href='/' class='-m-1.5 p-1.5 flex items-center gap-x-2.5'>
              <span class='sr-only'>{brand.name}</span>
              <img
                src='/logo.webp'
                alt={`${brand.name} Logo`}
                width='48'
                height='49'
                loading='lazy'
                class='h-10 w-auto'
              />
              <span class='brand-wordmark text-xl text-cream'>{brand.name}</span>
            </a>
            <button
              type='button'
              command='close'
              commandfor='mobile-menu'
              class='-m-2.5 rounded-md p-2.5 text-cream/60 transition-colors duration-200 hover:text-cream focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal'>
              <span class='sr-only'>Cerrar menú</span>
              <svg
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.5'
                aria-hidden='true'
                class='size-6'>
                <path
                  d='M6 18 18 6M6 6l12 12'
                  stroke-linecap='round'
                  stroke-linejoin='round'></path>
              </svg>
            </button>
          </div>

          <div class='mt-8 flow-root'>
            <div class='space-y-0.5'>
              <p class='px-3 pb-2 text-xs font-semibold uppercase tracking-[0.15em] text-cream/40'>
                Menú
              </p>
              <a
                href='/'
                class='block rounded-base px-3 py-2.5 text-base font-semibold text-cream transition-colors duration-150 hover:bg-sage/8 hover:text-sage'>
                Inicio
              </a>
              {navigation.primary.slice(0, 1).map((link) => (
                <a
                  href={link.href}
                  class='block rounded-base px-3 py-2.5 text-base font-semibold text-cream transition-colors duration-150 hover:bg-sage/8 hover:text-sage'>
                  {link.label}
                </a>
              ))}
              <details>
                <summary
                  class='flex cursor-pointer list-none items-center justify-between rounded-base px-3 py-2.5 text-base font-semibold text-cream transition-colors duration-150 hover:bg-sage/8 hover:text-sage'>
                  Servicios
                  <svg
                    viewBox='0 0 20 20'
                    fill='currentColor'
                    aria-hidden='true'
                    class='size-5'>
                    <path
                      fill-rule='evenodd'
                      d='M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z'
                      clip-rule='evenodd'></path>
                  </svg>
                </summary>
                <div class='mt-1 ml-3 border-l border-surface/20 pl-3 space-y-0.5'>
                  {navigation.services.map((service) => (
                    <a
                      href={service.href}
                      class='block rounded-base px-3 py-2 text-base font-semibold text-cream/70 transition-colors duration-150 hover:bg-sage/8 hover:text-sage'>
                      {service.label}
                    </a>
                  ))}
                </div>
              </details>
              {navigation.primary.slice(1).map((link) => (
                <a
                  href={link.href}
                  class='block rounded-base px-3 py-2.5 text-base font-semibold text-cream transition-colors duration-150 hover:bg-sage/8 hover:text-sage'>
                  {link.label}
                </a>
              ))}
              <a
                href='/#calculadora'
                class='flex items-center gap-2 rounded-base px-3 py-2.5 text-base font-semibold text-cream transition-colors duration-150 hover:bg-sage/8 hover:text-sage'>
                Calculadora
                <span class='calc-badge'>Nuevo</span>
              </a>

              <div class='mt-4 border-t border-surface/15 pt-5'>
                <p class='px-3 pb-2 text-xs font-semibold uppercase tracking-[0.15em] text-cream/40'>
                  Contacto
                </p>
                <a
                  href={`tel:${contact.phone.e164}`}
                  class='flex items-center gap-2.5 rounded-base px-3 py-3 text-base font-semibold text-cream/70 transition-colors duration-150 hover:bg-sage/8 hover:text-cream'>
                  <svg class='h-5 w-5 flex-shrink-0' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      stroke-width='2'
                      d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'>
                    </path>
                  </svg>
                  {contact.phone.display}
                </a>
              </div>
            </div>
          </div>

        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>

<script>
  // Scroll-aware header
  const header = document.getElementById('site-header')
  const force = header?.dataset.forceScrolled === 'true'
  const onScroll = () => {
    if (header) header.classList.toggle('is-scrolled', force || window.scrollY > 60)
  }
  onScroll()
  window.addEventListener('scroll', onScroll, { passive: true })

  // Close mobile menu on anchor link click
  document.addEventListener('DOMContentLoaded', () => {
    const mobileDialog = document.getElementById('mobile-menu') as HTMLDialogElement
    document.querySelectorAll('#mobile-menu a').forEach(link => {
      link.addEventListener('click', () => {
        setTimeout(() => {
          if (mobileDialog?.open) mobileDialog.close()
        }, 100)
      })
    })
  })
</script>
