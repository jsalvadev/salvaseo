---
interface Props {
  text?: string
  class?: string
  color?: 'base' | 'surface' | 'sage' | 'cream' | 'white'
}

const {
  text = 'Agenda una llamada gratis',
  class: className = '',
  color = 'cream',
} = Astro.props

const base = 'rounded-md px-3.5 py-3 text-sm font-bold shadow-xs transition-all cursor-pointer'
const colors = {
  base:    'bg-base    text-cream  hover:bg-base/80',
  surface: 'bg-surface text-cream  hover:bg-surface/80',
  sage:    'bg-sage    text-cream  hover:bg-sage/80',
  cream:   'bg-cream   text-base   hover:bg-cream/80',
  white:   'bg-white   text-base   hover:bg-white/80',
}

function openCalendar() {
  if (typeof Cal !== 'undefined' && Cal.ns["30min"]) {
    Cal.ns["30min"]("open");
  } else {
    window.open("https://cal.com/salvaseo/30min", "_blank");
  }
}
---

<button
  type="button"
  data-cal-link="salvaseo/30min"
  data-cal-namespace="30min"
  data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
  class={`${base} ${colors[color]} ${className}`}
  onclick="openCalendar()"
>
  {text}
</button>
