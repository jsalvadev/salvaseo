---
import { buildWhatsAppHref } from '../data/site'

interface Props {
  text?: string;
  class?: string;
  href?: string;
}

const { text = 'Hablamos por WhatsApp', class: className = '', href = buildWhatsAppHref() } = Astro.props;
---

<a
  href={href}
  target='_blank'
  rel='noopener noreferrer nofollow'
  class={`rounded-md bg-sky-500 px-3.5 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-sky-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-500 ${className}`}>
  {text}
</a>
