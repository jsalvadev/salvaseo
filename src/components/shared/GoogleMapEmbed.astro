---
interface Props {
  title?: string
  ariaLabelledbyId?: string
  sectionClass?: string
  heightClass?: string
  mapSrc?: string
}

const {
  title = 'SalvaSEO - Consultor SEO en Barcelona',
  ariaLabelledbyId = 'mapa-consultor-seo',
  sectionClass = 'w-full bg-white',
  heightClass = 'h-[450px]',
  mapSrc =
    'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d95780.47772184572!2d2.057787979258769!3d41.39276744295528!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b687095c96ad7%3A0x4a8991093774db69!2sSalvaSEO%20-%20Consultor%20SEO%20en%20Barcelona!5e0!3m2!1sen!2ses!4v1776793398418!5m2!1sen!2ses'
} = Astro.props
---

<section class={sectionClass} aria-labelledby={ariaLabelledbyId}>
  <p id={ariaLabelledbyId} class='sr-only'>
    Ubicación de SalvaSEO en Google Maps
  </p>
  <iframe
    src={mapSrc}
    class:list={['block w-full border-0', heightClass]}
    allowfullscreen=''
    loading='lazy'
    referrerpolicy='no-referrer-when-downgrade'
    title={title}
  ></iframe>
</section>
