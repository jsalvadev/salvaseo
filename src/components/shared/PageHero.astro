---
import Breadcrumb from '../Breadcrumb.astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  theme?: 'dark' | 'sage'
  watermark?: string
  watermarkSide?: 'left' | 'right'
  eyebrow: string
  eyebrowStyle?: 'plain' | 'lined'
  description: string
  decorationStyle?: 'grid' | 'lines'
  breadcrumbItems?: BreadcrumbItem[]
}

const {
  theme = 'dark',
  watermark = '',
  watermarkSide = 'left',
  eyebrow,
  eyebrowStyle = 'plain',
  description,
  decorationStyle = 'grid',
  breadcrumbItems,
} = Astro.props

const isDark = theme === 'dark'
---

<section class:list={[
  'relative overflow-hidden',
  isDark ? 'isolate bg-gradient-to-b from-base to-surface/80' : 'bg-sage',
]}>

  {decorationStyle === 'grid' && (
    <Fragment>
      <svg aria-hidden="true" class="absolute inset-0 -z-10 size-full mask-[radial-gradient(100%_100%_at_top_right,white,transparent)] stroke-cream/5">
        <defs>
          <pattern id="ph-grid" width="200" height="200" x="50%" y="-1" patternUnits="userSpaceOnUse">
            <path d="M100 200V.5M.5 .5H200" fill="none" />
          </pattern>
        </defs>
        <svg x="50%" y="-1" class="overflow-visible fill-cream/[0.02]">
          <path d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z" stroke-width="0" />
        </svg>
        <rect width="100%" height="100%" fill="url(#ph-grid)" stroke-width="0" />
      </svg>
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -top-20 -right-10 h-[400px] w-[500px] rounded-full bg-cream/10 blur-3xl"></div>
        <div class="absolute bottom-0 -left-20 h-[300px] w-[380px] rounded-full bg-sage/15 blur-3xl"></div>
      </div>
    </Fragment>
  )}

  {decorationStyle === 'lines' && (
    <svg class="pointer-events-none absolute inset-0 w-full h-full" aria-hidden="true" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="68%" y1="0%" x2="95%"  y2="100%" stroke="rgba(250,234,177,0.06)" stroke-width="1"/>
      <line x1="74%" y1="0%" x2="104%" y2="100%" stroke="rgba(250,234,177,0.035)" stroke-width="1"/>
      <line x1="61%" y1="0%" x2="88%"  y2="100%" stroke="rgba(250,234,177,0.04)" stroke-width="1"/>
    </svg>
  )}

  {watermark && (
    <div
      class:list={[
        'font-heading pointer-events-none absolute top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-white/[0.04]',
        watermarkSide === 'right' ? '-right-6' : '-left-6',
      ]}
      aria-hidden="true"
    >
      {watermark}
    </div>
  )}

  {breadcrumbItems && (
    <Breadcrumb items={breadcrumbItems} dark />
  )}

  <div class="container-site">
    <div class:list={[
      'min-h-[80vh] flex items-center',
      breadcrumbItems ? 'pt-10 pb-24 lg:pt-12 lg:pb-28' : 'py-24 sm:py-32 lg:py-24',
    ]}>
      <div class="w-full grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">

        <div class="lg:col-span-7">

          {eyebrowStyle === 'lined' ? (
            <div class="flex items-center gap-3">
              <span class="block h-px w-10 bg-cream shrink-0" aria-hidden="true"></span>
              <h1 class="text-xs font-bold tracking-[0.18em] uppercase text-cream" data-animate>{eyebrow}</h1>
            </div>
          ) : (
            <h1 class="text-xs font-bold text-cream" data-animate>{eyebrow}</h1>
          )}

          <slot name="heading" />

          {isDark ? (
            <div class="mt-6 flex items-center">
              <div class="h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35"></div>
              <div class="h-px w-10 bg-cream/60"></div>
            </div>
          ) : (
            <div class="mt-5 mb-7 flex items-center" aria-hidden="true">
              <div class="h-[3px] w-16 bg-cream rounded-full"></div>
              <div class="h-px w-24 bg-gradient-to-r from-sand/50 to-transparent"></div>
            </div>
          )}

          <p
            data-animate
            class:list={[
              'leading-[1.75] max-w-2xl',
              isDark ? 'mt-8 text-base/8 text-cream/70 text-pretty' : 'text-[1.0625rem] text-white/75 mb-8',
            ]}
          >
            <Fragment set:html={description} />
          </p>

          <div class:list={['flex flex-col sm:flex-row gap-4 items-start', isDark ? 'mt-10' : '']}>
            <slot name="cta" />
          </div>

        </div>

        <div class:list={[
          'lg:col-span-5',
          isDark ? 'mt-16 sm:mt-24 lg:mt-0' : 'hidden lg:flex lg:items-center',
        ]}>
          <slot name="visual" />
        </div>

      </div>
    </div>
  </div>

</section>
