---
import Upheading from './Upheading.astro'
import type { FaqItem } from '../data/faq-home'

interface Props {
  upheading?: string
  heading: string
  intro?: string
  items: FaqItem[]
}

const { upheading, heading, intro, items } = Astro.props
---

<div class='bg-white'>
  <div class='mx-auto max-w-7xl px-6 py-16 sm:py-24 lg:px-8'>
    {upheading && <Upheading as='h2' text={upheading} />}
    <p class='text-4xl font-semibold tracking-tight text-petrol-900 sm:text-5xl'>
      {heading}
    </p>
    {intro && (
      <p class='mt-6 max-w-2xl text-base/7 text-petrol-700'>
        <Fragment set:html={intro} />
      </p>
    )}
    <div class='mt-20'>
      <dl class='space-y-16 sm:grid sm:grid-cols-2 sm:space-y-0 sm:gap-x-6 sm:gap-y-16 lg:gap-x-10'>
        {items.map((item) => (
          <div>
            <dt class='text-base/7 font-semibold text-petrol-900'>
              <h3>{item.question}</h3>
            </dt>
            <dd class='mt-2 text-base/7 text-petrol-700'>
              <Fragment set:html={item.answer} />
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</div>
