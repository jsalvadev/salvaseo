---
interface Props {
  color?: string
  fadeColor?: string
  thick?: boolean
  size?: 'sm' | 'md'
  class?: string
  [key: string]: unknown
}

const {
  color = 'var(--color-cream)',
  fadeColor,
  thick = false,
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props

const resolvedFade = fadeColor ?? color
const solidW = size === 'sm' ? 'w-12' : 'w-16'
const fadeW  = size === 'sm' ? 'w-20' : 'w-24'
const solidH = thick ? 'h-[3px] rounded-full' : 'h-px'
---

<div
  class={`flex items-center ${className}`}
  aria-hidden='true'
  {...rest}
>
  <div class={`${solidH} ${solidW}`} style={`background-color: ${color}`}></div>
  <div
    class={`h-px ${fadeW}`}
    style={`background: linear-gradient(to right, color-mix(in srgb, ${resolvedFade} 40%, transparent), transparent)`}
  ></div>
</div>
