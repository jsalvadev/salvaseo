---
import { Check } from '@lucide/astro'

interface PricingTier {
  name: string
  price: string
  unit: string
  description: string
  features: string[]
  cta: string
  ctaHref: string
  featured?: boolean
  commitment: string
  commitmentMonths: number
  savings?: string
}

const tiers: PricingTier[] = [
  {
    name: 'Visibilidad Local',
    price: '350 €',
    unit: '/mes + IVA',
    description: 'Deja de ser invisible en tu zona y empieza a recibir llamadas de clientes que tienes a la vuelta de la esquina.',
    commitment: 'Compromiso recomendado: 3 meses',
    commitmentMonths: 3,
    features: [
      'Auditoría de competencia y visibilidad local',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Alta en directorios locales y coherencia de nombre, dirección y teléfono',
      'Publicaciones mensuales en GBP',
      'Monitorización y respuesta a reseñas',
      'Mapa de visibilidad real por barrios y zonas de Barcelona',
      'Informe mensual con seguimiento de posiciones en Maps',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20Plan%20Visibilidad%20Local%20de%20350%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Visibilidad Total',
    price: '550 €',
    unit: '/mes + IVA',
    description: 'Sal de la sombra en toda la ciudad. Una estrategia de asalto para dominar las búsquedas más rentables de Barcelona.',
    commitment: 'Compromiso recomendado: 4 meses',
    commitmentMonths: 4,
    featured: true,
    features: [
      'Auditoría SEO on-page de la web',
      'Estudio de palabras clave transaccionales',
      'Optimización de encabezados, titles y descriptions',
      'Creación de páginas de servicio optimizadas',
      'Optimización técnica de velocidad y experiencia de carga',
      'Datos estructurados para destacar en resultados de Google',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Publicaciones mensuales en GBP enlazadas a páginas de servicio',
      'Informe mensual unificado con seguimiento en Maps + orgánico',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20Plan%20Visibilidad%20Total%20de%20550%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
]

const TOTAL_SEGMENTS = 6
---

<section
  id='paquetes'
  class='relative overflow-hidden bg-base'>

  <!-- Dot-grid texture -->
  <div class='pointer-events-none absolute inset-0 dot-grid-28' aria-hidden='true'></div>

  <!-- Ghost "€" watermark -->
  <div
    class='font-heading pointer-events-none absolute -right-8 top-0 select-none leading-none text-wm-xl font-bold text-white/[0.025]'
    aria-hidden='true'
    >
    €
  </div>

  <!-- Ambient sage glow behind featured card -->
  <div
    class='pointer-events-none absolute right-1/4 top-1/2 h-[700px] w-[700px] -translate-y-1/2 rounded-full opacity-[0.04]'
    style='background: radial-gradient(circle, var(--color-sage) 0%, transparent 65%);'
    aria-hidden='true'>
  </div>

  <!-- Bottom fade to next section -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sage/15 to-transparent'
    aria-hidden='true'>
  </div>

  <div class='relative container-site pb-24 sm:pb-32 pt-[calc(var(--navbar-height,4.5rem)+3rem)] sm:pt-[calc(var(--navbar-height,4.5rem)+4rem)] lg:pt-[calc(var(--navbar-height,4.5rem)+5rem)]'>

    <!-- ── Hero header ──────────────────────────────────── -->
    <header class='mb-14 lg:mb-18 max-w-4xl'>

      <!-- Eyebrow -->
      <div class='animate-fade-in-up [animation-delay:0ms] flex items-center gap-4 mb-7'>
        <span class='block h-px w-10 bg-sage' aria-hidden='true'></span>
        <p class='text-xs font-bold tracking-[0.2em] uppercase text-sage'>
          Precio SEO mensual — Tarifas y paquetes
        </p>
      </div>

      <!-- H1 -->
      <h1 class='animate-fade-in-up [animation-delay:60ms] font-heading text-h1 font-bold leading-[0.97] tracking-tight text-cream text-pretty mb-7'>
        Invierte solo en lo<br class='hidden sm:block' />
        que necesitas<span class='text-sage'>.</span>
      </h1>

      <!-- Rule + lead text -->
      <div class='animate-fade-in-up [animation-delay:120ms]'>
        <div class='flex items-center mb-4'>
          <div class='h-[3px] w-10 bg-sage rounded-full'></div>
          <div class='h-px w-24 bg-gradient-to-r from-sage/20 to-transparent'></div>
        </div>
        <p class='text-base leading-relaxed text-cream/60 max-w-sm'>
          Dos paquetes. Precio fijo mensual. Sin permanencia ni letra pequeña.
        </p>
      </div>

    </header>

    <!-- ── Pricing cards ────────────────────────────────── -->
    <div class='grid grid-cols-1 gap-5 lg:grid-cols-2 lg:gap-7 max-w-5xl'>
      {tiers.map((tier) => (
        <article
          data-animate
          class:list={[
            'group relative flex flex-col rounded-2xl overflow-hidden transition-all duration-300',
            tier.featured
              ? 'bg-surface shadow-2xl shadow-black/40 ring-1 ring-sage/[0.15]'
              : 'bg-white/[0.02] ring-1 ring-white/[0.07] hover:ring-white/[0.13] hover:shadow-xl hover:shadow-black/25',
          ]}>

          <!-- Featured: sage top accent strip -->
          {tier.featured && (
            <div
              class='h-[3px] w-full shrink-0'
              style='background: linear-gradient(90deg, var(--color-sage) 0%, color-mix(in srgb, var(--color-sage) 40%, transparent) 60%, transparent 100%);'
              aria-hidden='true'>
            </div>
          )}

          <div class='flex-1 p-8 xl:p-10'>

            <!-- Plan label + badge -->
            <div class='flex items-center justify-between mb-5'>
              <div>
                <p class:list={[
                  'text-xs font-bold tracking-[0.16em] uppercase mb-0.5',
                  tier.featured ? 'text-sage/60' : 'text-cream/35',
                ]}>
                  Plan
                </p>
                <h2 class:list={[
                  'text-sm font-bold uppercase tracking-[0.1em]',
                  tier.featured ? 'text-cream/80' : 'text-cream/70',
                ]}>
                  {tier.name}
                </h2>
              </div>
              {tier.featured && (
                <span class='inline-flex items-center rounded-full bg-sage/[0.12] px-3 py-1 text-xs font-bold uppercase tracking-wide text-sage ring-1 ring-sage/[0.25]'>
                  ★ Recomendado
                </span>
              )}
            </div>

            <!-- Price — visual centrepiece -->
            <div class='mb-3 flex items-baseline gap-2'>
              <span class='font-heading text-h1 font-bold leading-none tracking-tight text-cream'>
                {tier.price}
              </span>
              <span class:list={[
                'text-sm font-semibold',
                tier.featured ? 'text-cream/35' : 'text-cream/40',
              ]}>
                {tier.unit}
              </span>
            </div>

            <!-- Commitment bar -->
            <div class='mb-7'>
              <div class='flex gap-1.5 mb-1.5'>
                {Array.from({ length: TOTAL_SEGMENTS }).map((_, i) => (
                  <div
                    class:list={[
                      'h-1 flex-1 rounded-full',
                      i < tier.commitmentMonths
                        ? 'bg-sage'
                        : tier.featured ? 'bg-white/[0.08]' : 'bg-white/[0.05]',
                    ]}
                  />
                ))}
              </div>
              <p class='text-xs font-semibold uppercase tracking-wide text-cream/35'>
                {tier.commitmentMonths} de {TOTAL_SEGMENTS} meses recomendados
              </p>
            </div>

            <!-- Description -->
            <p
              class:list={[
                'text-sm leading-relaxed pb-6 mb-6 border-b',
                tier.featured
                  ? 'text-cream/65 border-white/[0.08]'
                  : 'text-cream/55 border-white/[0.05]',
              ]}>
              <Fragment set:html={tier.description} />
            </p>

            <!-- Features -->
            <ul class='space-y-2.5'>
              {tier.features.map((feature) => (
                <li class='flex items-start gap-3'>
                  <span
                    class:list={[
                      'mt-0.5 flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full',
                      tier.featured ? 'bg-sage/[0.2] text-sage' : 'bg-cream/[0.06] text-cream/50',
                    ]}>
                    <Check class='h-2.5 w-2.5' aria-hidden='true' />
                  </span>
                  <span class:list={[
                    'text-sm leading-relaxed',
                    tier.featured ? 'text-cream/70' : 'text-cream/55',
                  ]}>
                    <Fragment set:html={feature} />
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA -->
          <div class='p-8 xl:p-10 pt-0'>
            <a
              href={tier.ctaHref}
              target='_blank'
              rel='noopener noreferrer nofollow'
              class:list={[
                'block w-full rounded-xl px-6 py-4 text-center text-xs font-bold uppercase tracking-[0.1em] transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 active:scale-[0.98]',
                tier.featured
                  ? 'bg-sage text-white shadow-lg shadow-sage/[0.2] hover:bg-sage/90 focus-visible:outline-sage'
                  : 'bg-cream/[0.08] text-cream/80 ring-1 ring-cream/[0.1] hover:bg-cream/[0.12] hover:text-cream focus-visible:outline-cream',
              ]}>
              {tier.cta}
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer note -->
    <p
      class='animate-fade-in-up [animation-delay:400ms] mt-8 max-w-5xl text-sm text-cream/40'>
      Precios sin IVA. Sin permanencia ni letra pequeña. ¿Quieres saber más antes de decidir? Lee sobre mi metodología como <a href='/' class='text-sage hover:text-sage/70 underline decoration-sage/[0.25] underline-offset-2 transition-colors'>consultor SEO en Barcelona</a>.
    </p>

  </div>
</section>
