---
import Upheading from '../../Upheading.astro'
import { Check } from '@lucide/astro'

interface PricingTier {
  name: string
  price: string
  unit: string
  description: string
  features: string[]
  cta: string
  ctaHref: string
  featured?: boolean
  commitment: string
  commitmentMonths: number
}

const tiers: PricingTier[] = [
  {
    name: 'Local Básico',
    price: '300 €',
    unit: '/mes + IVA',
    description: 'Para negocios locales que quieren visibilidad en Google Maps sin complicarse.',
    commitment: 'Compromiso recomendado: 3 meses',
    commitmentMonths: 3,
    features: [
      'Auditoría de visibilidad local',
      'Creación u optimización de Google Business Profile',
      'Alta en 10-15 directorios locales',
      'Publicaciones mensuales en GBP',
      'Monitorización y respuesta a reseñas',
      'Informe mensual de resultados',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Local%20B%C3%A1sico%20de%20300%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Local + Web',
    price: '450 €',
    unit: '/mes + IVA',
    description: 'Para negocios que quieren dominar Google Maps y mejorar su posicionamiento orgánico.',
    commitment: 'Compromiso recomendado: 4 meses',
    commitmentMonths: 4,
    featured: true,
    features: [
      'Todo lo del paquete Local Básico',
      'Auditoría SEO on-page de la web',
      'Investigación de palabras clave locales',
      'Optimización de meta titles, descriptions y H1s',
      '1 contenido nuevo al mes (600-1.000 palabras)',
      'Schema markup LocalBusiness + Service',
      'Informe mensual de resultados',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Local%20%2B%20Web%20de%20450%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Dominio Local',
    price: '650 €',
    unit: '/mes + IVA',
    description: 'Para negocios en sectores competidos que necesitan una estrategia SEO completa.',
    commitment: 'Compromiso recomendado: 6 meses',
    commitmentMonths: 6,
    features: [
      'Todo lo del paquete Local + Web',
      'Auditoría SEO completa (técnica + competencia)',
      'Plan estratégico a 6 meses con objetivos',
      '2 contenidos nuevos al mes',
      'Link building local (3-5 enlaces/mes)',
      'Optimización técnica continua (Core Web Vitals)',
      'Estrategia activa de captación de reseñas',
      'Informe mensual de resultados + análisis estratégico',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Dominio%20Local%20de%20650%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
]

const TOTAL_SEGMENTS = 6
---

<div id='paquetes' class='bg-white py-24 sm:py-32' style='scroll-margin-top: var(--navbar-height)'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='mx-auto max-w-4xl text-center'>
      <Upheading as='h2' text='Presupuesto SEO Barcelona' class='text-center' />
      <p class='mt-2 text-4xl font-semibold tracking-tight text-balance text-petrol-900 sm:text-5xl'>
        El paquete que se ajusta a tu negocio
      </p>
    </div>
    <p class='mx-auto mt-6 max-w-2xl text-center text-lg font-medium text-pretty text-petrol-700 sm:text-xl/8'>
      Tres paquetes diseñados para negocios locales en Barcelona. Empieza con lo básico, ve resultados, y escala cuando tenga sentido.
    </p>

    <div class='isolate mx-auto mt-16 grid max-w-md grid-cols-1 gap-y-8 sm:mt-20 lg:mx-0 lg:max-w-none lg:grid-cols-3'>
      {tiers.map((tier, index) => (
        <div
          class:list={[
            'flex flex-col justify-between rounded-3xl p-8 xl:p-10',
            tier.featured
              ? 'bg-sky-600 ring-2 ring-white/50 lg:z-10 lg:rounded-b-none'
              : 'ring-1 ring-petrol-200 lg:mt-8',
            index === 0 && 'lg:rounded-r-none',
            index === 2 && 'lg:rounded-l-none',
          ]}>
          <div>
            <!-- Commitment bar -->
            <div class='mb-6'>
              <div class='flex gap-1'>
                {Array.from({ length: TOTAL_SEGMENTS }).map((_, i) => (
                  <div
                    class:list={[
                      'h-1.5 flex-1 rounded-full',
                      i < tier.commitmentMonths
                        ? tier.featured ? 'bg-white' : 'bg-sky-500'
                        : tier.featured
                          ? 'bg-white/25'
                          : 'bg-petrol-100',
                    ]}
                  />
                ))}
              </div>
              <p class:list={[
                'mt-2 text-xs',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
                {tier.commitmentMonths} de {TOTAL_SEGMENTS} meses recomendados
              </p>
            </div>

            <div class='flex items-center justify-between gap-x-4'>
              <h3
                class:list={[
                  'text-lg/8 font-semibold',
                  tier.featured ? 'text-white' : 'text-petrol-900',
                ]}>
                {tier.name}
              </h3>
            </div>
            {tier.featured && (
              <div class='mt-2'>
                <span class='inline-block rounded-full bg-white px-3 py-0.5 text-xs font-semibold text-sky-600'>
                  Recomendado
                </span>
              </div>
            )}
            <p
              class:list={[
                'mt-4 text-sm/6',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
              {tier.description}
            </p>
            <p class='mt-6 flex items-baseline gap-x-1'>
              <span
                class:list={[
                  'font-semibold tracking-tight',
                  tier.featured ? 'text-5xl text-white' : 'text-4xl text-petrol-900',
                ]}>
                {tier.price}
              </span>
              <span
                class:list={[
                  'text-sm/6 font-semibold',
                  tier.featured ? 'text-white/70' : 'text-petrol-600',
                ]}>
                {tier.unit}
              </span>
            </p>
            <ul
              role='list'
              class:list={[
                'mt-8 space-y-3 text-sm/6',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
              {tier.features.map((feature) => (
                <li class='flex gap-x-3'>
                  <Check
                    class:list={[
                      'h-6 w-5 flex-none',
                      tier.featured ? 'text-white' : 'text-sky-600',
                    ]}
                    aria-hidden='true'
                  />
                  {feature}
                </li>
              ))}
            </ul>
          </div>
          <div class='mt-8'>
            <hr class:list={[
              'mb-6 border-0 h-px',
              tier.featured ? 'bg-white/20' : 'bg-petrol-100',
            ]} />
            <a
              href={tier.ctaHref}
              target='_blank'
              rel='noopener noreferrer nofollow'
              class:list={[
                'block rounded-md px-3 py-2 text-center text-sm/6 font-semibold shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2',
                tier.featured
                  ? 'bg-white text-sky-600 hover:bg-sky-50 focus-visible:outline-white'
                  : 'bg-sky-50 text-sky-600 ring-1 ring-sky-200 ring-inset hover:ring-sky-300 focus-visible:outline-sky-600',
              ]}>
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class='mx-auto mt-10 max-w-2xl text-center text-sm text-petrol-500'>
      Todos los precios + IVA. Sin permanencia contractual. El presupuesto final se define tras el diagnóstico inicial gratuito.
    </p>
  </div>
</div>
