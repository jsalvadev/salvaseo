---
import { Check } from '@lucide/astro'
import CalButton from '../../CalButton.astro'

interface PricingTier {
  name: string
  price: string
  unit: string
  description: string
  features: string[]
  cta: string
  featured?: boolean
  commitment: string
  commitmentMonths: number
  savings?: string
}

const tiers: PricingTier[] = [
  {
    name: 'Visibilidad Local',
    price: '350 €',
    unit: '/mes + IVA',
    description: 'Deja de ser invisible en tu zona y empieza a recibir llamadas de clientes que tienes a la vuelta de la esquina.',
    commitment: 'Compromiso recomendado: 3 meses',
    commitmentMonths: 3,
    features: [
      'Auditoría de competencia y visibilidad local',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Alta en directorios locales y coherencia de nombre, dirección y teléfono',
      'Publicaciones mensuales en GBP',
      'Monitorización y respuesta a reseñas',
      'Mapa de visibilidad real por barrios y zonas de Barcelona',
      'Informe mensual con seguimiento de posiciones en Maps',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Agenda tu sesión gratuita',
  },
  {
    name: 'Visibilidad Total',
    price: '550 €',
    unit: '/mes + IVA',
    description: 'Sal de la sombra en toda la ciudad. Una estrategia de asalto para dominar las búsquedas más rentables de Barcelona.',
    commitment: 'Compromiso recomendado: 4 meses',
    commitmentMonths: 4,
    featured: true,
    features: [
      'Auditoría SEO on-page de la web',
      'Estudio de palabras clave transaccionales',
      'Optimización de encabezados, titles y descriptions',
      'Creación de páginas de servicio optimizadas',
      'Optimización técnica de velocidad y experiencia de carga',
      'Datos estructurados para destacar en resultados de Google',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Publicaciones mensuales en GBP enlazadas a páginas de servicio',
      'Informe mensual unificado con seguimiento en Maps + orgánico',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Agenda tu sesión gratuita',
  },
]

const TOTAL_SEGMENTS = 6
---

<section
  id='paquetes'
  class='relative overflow-hidden'
  style='background: linear-gradient(160deg, #181C14 0%, #1c2018 25%, #1f2319 50%, #1a1e16 75%, #181C14 100%);'>

  <!-- Dot-grid texture -->
  <div class='pointer-events-none absolute inset-0 dot-grid-28' aria-hidden='true'></div>

  <!-- Top-left corner lines -->
  <div class='pointer-events-none absolute top-0 left-0' aria-hidden='true'>
    <div class='w-px h-56 bg-gradient-to-b from-sage/40 to-transparent'></div>
    <div class='absolute top-0 left-0 w-56 h-px bg-gradient-to-r from-sage/40 to-transparent'></div>
  </div>

  <!-- Bottom-right corner lines -->
  <div class='pointer-events-none absolute bottom-0 right-0' aria-hidden='true'>
    <div class='absolute bottom-0 right-0 w-px h-36 bg-gradient-to-t from-sage/20 to-transparent'></div>
    <div class='absolute bottom-0 right-0 w-36 h-px bg-gradient-to-l from-sage/20 to-transparent'></div>
  </div>

  <!-- Ghost "★" watermark -->
  <div
    class='font-heading pointer-events-none absolute -right-8 top-0 select-none leading-none text-wm-xl font-bold text-white/[0.025]'
    aria-hidden='true'>
    ★
  </div>

  <!-- Ambient sage glow — centred, subtle -->
  <div
    class='pointer-events-none absolute left-1/2 top-1/2 h-[1000px] w-[700px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.045]'
    style='background: radial-gradient(ellipse, var(--color-sage) 0%, transparent 65%);'
    aria-hidden='true'>
  </div>

  <!-- Bottom separator -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sage/15 to-transparent'
    aria-hidden='true'>
  </div>

  <div class='relative container-site pb-24 sm:pb-32 pt-[calc(var(--navbar-height,4.5rem)+3rem)] sm:pt-[calc(var(--navbar-height,4.5rem)+4rem)] lg:pt-[calc(var(--navbar-height,4.5rem)+5rem)]'>

    <!-- ── Hero header ──────────────────────────────────── -->
    <header class='mb-16 lg:mb-20 max-w-4xl'>

      <div class='animate-fade-in-up [animation-delay:0ms] mb-6'>
        <p class='text-xs font-bold tracking-[0.2em] uppercase text-cream/60'>
          Precios SEO en Barcelona
        </p>
      </div>

<h1 class='animate-fade-in-up [animation-delay:60ms] font-heading text-h1 font-bold leading-[0.95] tracking-tight text-cream text-pretty mb-7'>
        Tu plan para<br class='hidden sm:block' />
        ser visible<span class='text-sage'>.</span>
      </h1>

      <div class='mt-6 flex items-center'>
        <div class='h-px w-32 bg-gradient-to-r from-sage/5 to-sage/35'></div>
        <div class='h-px w-10 bg-sage/60'></div>
      </div>

      </header>

    <!-- ── Pricing cards ────────────────────────────────── -->
    <div class='grid grid-cols-1 gap-5 lg:grid-cols-2 lg:gap-6 max-w-5xl'>
      {tiers.map((tier) => (
        <article
          data-animate
          class:list={[
            'group relative flex flex-col rounded-2xl overflow-hidden transition-transform duration-300 hover:-translate-y-1',
            tier.featured
              ? 'shadow-[0_28px_80px_-8px_rgba(0,0,0,0.6),0_0_0_1px_rgba(236,223,204,0.18)]'
              : 'ring-1 ring-white/[0.07] shadow-[0_8px_40px_-4px_rgba(0,0,0,0.4)] hover:ring-sage/[0.18]',
          ]}
          style={tier.featured
            ? 'background: #ECDFCC;'
            : 'background: linear-gradient(145deg, rgba(255,255,255,0.045) 0%, rgba(255,255,255,0.02) 60%, rgba(255,255,255,0.01) 100%);'
          }>

          <!-- Featured: sage top strip -->
          {tier.featured && (
            <div
              class='h-[3px] w-full shrink-0'
              style='background: linear-gradient(90deg, var(--color-sage) 0%, color-mix(in srgb, var(--color-sage) 50%, transparent) 60%, transparent 100%);'
              aria-hidden='true'>
            </div>
          )}

          <!-- Non-featured: subtle sage hairline -->
          {!tier.featured && (
            <div
              class='h-px w-full shrink-0'
              style='background: linear-gradient(90deg, transparent 0%, rgba(105,117,101,0.3) 25%, rgba(105,117,101,0.3) 75%, transparent 100%);'
              aria-hidden='true'>
            </div>
          )}

          <div class='flex-1 p-8 xl:p-10'>

            <!-- Plan label + badge -->
            <div class='flex items-start justify-between mb-7'>
              <div>
                <p class:list={[
                  'text-xs font-bold tracking-[0.22em] uppercase mb-1',
                  tier.featured ? 'text-[#697565]/65' : 'text-cream/45',
                ]}>
                  Plan
                </p>
                <h2 class:list={[
                  'font-bold tracking-tight text-base',
                  tier.featured ? 'text-[#1a1e16]' : 'text-cream/85',
                ]}>
                  {tier.name}
                </h2>
              </div>

              {tier.featured && (
                <span class='mt-0.5 inline-flex items-center gap-1 rounded-full bg-[#1a1e16]/[0.07] px-2.5 py-1 text-xs font-bold uppercase tracking-[0.1em] text-[#1a1e16]/60 ring-1 ring-[#1a1e16]/[0.1]'>
                  ★ Recomendado
                </span>
              )}
            </div>

            <!-- Price — visual centrepiece -->
            <div class='mb-5 flex items-baseline gap-2.5'>
              <span
                class:list={[
                  'font-heading text-h1 font-bold leading-[0.9] tracking-tight',
                  tier.featured ? 'text-[#1a1e16]' : 'text-cream',
                ]}>
                {tier.price}
              </span>
              <span
                class:list={[
                  'text-sm font-semibold self-end mb-1',
                  tier.featured ? 'text-[#1a1e16]/50' : 'text-cream/50',
                ]}>
                {tier.unit}
              </span>
            </div>

            <!-- Commitment bar -->
            <div class='mb-7'>
              <div class='flex gap-1 mb-2'>
                {Array.from({ length: TOTAL_SEGMENTS }).map((_, i) => (
                  <div
                    class:list={[
                      'h-1.5 flex-1 rounded-full',
                      i < tier.commitmentMonths
                        ? tier.featured ? 'bg-sage' : 'bg-sage/80'
                        : tier.featured ? 'bg-[#1a1e16]/[0.1]' : 'bg-white/[0.06]',
                    ]}
                  />
                ))}
              </div>
              <p class:list={[
                'text-xs font-semibold uppercase tracking-[0.13em]',
                tier.featured ? 'text-[#1a1e16]/45' : 'text-cream/40',
              ]}>
                {tier.commitmentMonths} de {TOTAL_SEGMENTS} meses recomendados
              </p>
            </div>

            <!-- Description -->
            <div class:list={[
              'pt-6 border-t mb-7',
              tier.featured ? 'border-[#1a1e16]/[0.1]' : 'border-white/[0.07]',
            ]}>
              <p class:list={[
                'text-base leading-relaxed',
                tier.featured ? 'text-[#1a1e16]/70' : 'text-cream/68',
              ]}>
                <Fragment set:html={tier.description} />
              </p>
            </div>

            <!-- Features -->
            <ul class='space-y-2.5'>
              {tier.features.map((feature) => (
                <li class='flex items-start gap-3'>
                  <span
                    class:list={[
                      'mt-[3px] flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full',
                      tier.featured
                        ? 'bg-sage/[0.18] text-sage'
                        : 'bg-sage/[0.12] text-sage/75',
                    ]}>
                    <Check class='h-2.5 w-2.5' aria-hidden='true' />
                  </span>
                  <span class:list={[
                    'text-sm leading-relaxed',
                    tier.featured ? 'text-[#1a1e16]/78' : 'text-cream/72',
                  ]}>
                    <Fragment set:html={feature} />
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA -->
          <div class='p-8 xl:p-10 pt-0'>
            <CalButton
              text={tier.cta}
              color={tier.featured ? 'base' : 'cream'}
              uppercase
              class='block w-full text-center'
            />
          </div>
        </article>
      ))}
    </div>


  </div>
</section>
