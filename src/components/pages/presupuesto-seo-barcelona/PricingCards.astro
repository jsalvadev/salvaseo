---
import { Check } from '@lucide/astro'

interface PricingTier {
  name: string
  price: string
  unit: string
  description: string
  features: string[]
  cta: string
  ctaHref: string
  featured?: boolean
  commitment: string
  commitmentMonths: number
  savings?: string
  hidden?: boolean
}

const tiers: PricingTier[] = [
  {
    name: 'Solo Ficha',
    price: '350 €',
    unit: '/mes IVA incl.',
    description: 'Servicio de <a href="/seo-local-barcelona/" class="underline decoration-sky-200 underline-offset-2 hover:text-petrol-900 transition-colors">SEO local</a> para negocios que necesitan visibilidad y tráfico desde Google Maps y el Local Pack.',
    commitment: 'Compromiso recomendado: 3 meses',
    commitmentMonths: 3,
    features: [
      'Auditoría de competencia y visibilidad local',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Alta en directorios locales y coherencia de nombre, dirección y teléfono',
      'Publicaciones mensuales en GBP',
      'Monitorización y respuesta a reseñas',
      'Mapa de visibilidad real por barrios y zonas de Barcelona',
      'Informe mensual con seguimiento de posiciones en Maps',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Solo%20Ficha%20de%20350%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Web + Ficha',
    price: '550 €',
    unit: '/mes IVA incl.',
    description: '<a href="/posicionamiento-web-barcelona/" class="underline decoration-sky-200 underline-offset-2 hover:text-petrol-900 transition-colors">Posicionamiento web</a> + <a href="/seo-local-barcelona/" class="underline decoration-sky-200 underline-offset-2 hover:text-petrol-900 transition-colors">SEO local</a>: domina Google Maps y los resultados orgánicos al mismo tiempo.',
    commitment: 'Compromiso recomendado: 4 meses',
    commitmentMonths: 4,
    featured: true,
    features: [
      'Auditoría SEO on-page de la web',
      'Estudio de palabras clave transaccionales',
      'Optimización de encabezados, titles y descriptions',
      'Creación de páginas de servicio optimizadas',
      'Optimización técnica de velocidad y experiencia de carga',
      'Datos estructurados para destacar en resultados de Google',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Publicaciones mensuales en GBP enlazadas a páginas de servicio',
      'Informe mensual unificado con seguimiento en Maps + orgánico',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Web%20%2B%20Ficha%20de%20550%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
    hidden: false,
  },
  {
    name: 'Ficha + Web',
    price: '800 €',
    unit: '/mes + IVA',
    description: 'Google Maps + posicionamiento orgánico. El proyecto SEO más completo para dominar las búsquedas locales en Barcelona.',
    commitment: 'Compromiso recomendado: 6 meses',
    commitmentMonths: 6,
    featured: false,
    hidden: true,
    features: [],
    cta: 'Solicita tu diagnóstico',
    ctaHref: '',
  },
]

const TOTAL_SEGMENTS = 6
---

<div
  id='paquetes'
  class='relative overflow-hidden bg-petrol-50 py-24 sm:py-32'
  style='scroll-margin-top: var(--navbar-height)'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(26,60,74,0.06) 1px, transparent 1px); background-size: 28px 28px;'>
  </div>

  <!-- Faded watermark -->
  <div
    class='pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none overflow-hidden'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(12rem, 26vw, 22rem); color: rgba(249,115,22,0.04); line-height: 1; white-space: nowrap;'>
    SEO
  </div>

  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 xl:gap-24 items-start'>

      <!-- LEFT: sticky headline block -->
      <div class='lg:sticky lg:top-28'>
        <div class='flex items-center gap-3 mb-8' data-animate>
          <span class='block h-px w-10 bg-orange-500' aria-hidden='true'></span>
          <h2 class='text-[0.7rem] font-bold uppercase tracking-[0.22em] text-orange-500'>
            Precio SEO mensual: tarifas y paquetes
          </h2>
        </div>

        <!-- Titan One headline -->
        <p
          data-animate
          style='font-family: "Titan One", cursive;'
          class='leading-[0.9] tracking-tight'>
          <span class='block text-[clamp(2.2rem,5vw,3.8rem)] text-petrol-700 mb-1'>
            Invierte solo en
          </span>
          <span class='block text-[clamp(3rem,6.5vw,5rem)] text-petrol-900'>
            lo que necesitas<span class='text-orange-400'>.</span>
          </span>
        </p>

        <!-- Accent rule -->
        <div class='mt-6 flex items-center' data-animate>
          <div class='h-[3px] w-12 bg-orange-500 rounded-full'></div>
          <div class='h-px w-20 bg-gradient-to-r from-orange-500/40 to-transparent'></div>
        </div>
      </div>

      <!-- RIGHT: description -->
      <div class='flex items-start lg:pt-8' data-animate data-animate-delay='80'>
        <p class='text-lg font-medium text-pretty text-petrol-700 sm:text-xl/8 leading-relaxed'>
          Solo ficha de Google, solo web, o ambas con descuento. Cada presupuesto para SEO se adapta al sector, la competencia y los objetivos de cada cliente.
        </p>
      </div>
    </div>

    <div class='isolate mx-auto mt-16 grid max-w-md grid-cols-1 gap-y-8 sm:mt-20 lg:max-w-3xl lg:grid-cols-2 lg:gap-x-8'>
      {tiers.filter(t => !t.hidden).map((tier) => (
        <div
          class:list={[
            'flex flex-col justify-between rounded-3xl p-8 xl:p-10',
            tier.featured
              ? 'bg-gradient-to-b from-sky-500 to-sky-700 ring-2 ring-white/20 shadow-2xl shadow-sky-900/20 lg:z-10'
              : 'bg-white ring-1 ring-petrol-100 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-lg',
          ]}>
          <div>
            <!-- Commitment bar -->
            <div class='mb-6'>
              <div class='flex gap-1'>
                {Array.from({ length: TOTAL_SEGMENTS }).map((_, i) => (
                  <div
                    class:list={[
                      'h-1.5 flex-1 rounded-full',
                      i < tier.commitmentMonths
                        ? tier.featured ? 'bg-sky-200' : 'bg-sky-500'
                        : tier.featured
                          ? 'bg-white/20'
                          : 'bg-petrol-100',
                    ]}
                  />
                ))}
              </div>
              <p class:list={[
                'mt-2 text-sm',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
                {tier.commitmentMonths} de {TOTAL_SEGMENTS} meses recomendados
              </p>
            </div>

            <div class='flex items-center justify-between gap-x-4'>
              <h3
                class:list={[
                  'text-lg/8 font-semibold',
                  tier.featured ? 'text-white' : 'text-petrol-900',
                ]}>
                {tier.name}
              </h3>
            </div>
            {tier.featured && (
              <div class='mt-2 flex flex-wrap gap-2'>
                <span class='inline-block rounded-full bg-white px-3 py-0.5 text-xs font-semibold text-sky-600'>
                  Recomendado
                </span>
                {tier.savings && (
                  <span class='inline-block rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-semibold text-white shadow-sm'>
                    {tier.savings}
                  </span>
                )}
              </div>
            )}
            <p
              class:list={[
                'mt-4 text-base/6',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
              <Fragment set:html={tier.description} />
            </p>
            <p class='mt-6 flex items-baseline gap-x-1'>
              <span
                class:list={[
                  'font-semibold tracking-tight',
                  tier.featured ? 'text-5xl text-white' : 'text-4xl text-petrol-900',
                ]}>
                {tier.price}
              </span>
              <span
                class:list={[
                  'text-sm/6 font-semibold',
                  tier.featured ? 'text-white/70' : 'text-petrol-600',
                ]}>
                {tier.unit}
              </span>
            </p>
            <ul
              role='list'
              class:list={[
                'mt-8 space-y-3 text-base/6',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
              {tier.features.map((feature) => (
                <li class='flex gap-x-3'>
                  <Check
                    class:list={[
                      'h-6 w-5 flex-none',
                      tier.featured ? 'text-white' : 'text-sky-600',
                    ]}
                    aria-hidden='true'
                  />
                  <Fragment set:html={feature} />
                </li>
              ))}
            </ul>
          </div>
          <div class='mt-8'>
            <hr class:list={[
              'mb-6 border-0 h-px',
              tier.featured ? 'bg-white/20' : 'bg-petrol-100',
            ]} />
            <a
              href={tier.ctaHref}
              target='_blank'
              rel='noopener noreferrer nofollow'
              class:list={[
                'block rounded-md px-3 py-2 text-center text-base/6 font-semibold shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2',
                tier.featured
                  ? 'bg-white text-sky-600 hover:bg-sky-50 focus-visible:outline-white'
                  : 'bg-sky-50 text-sky-600 ring-1 ring-sky-200 ring-inset hover:bg-sky-100 hover:ring-sky-300 focus-visible:outline-sky-600',
              ]}>
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p
      class='mx-auto mt-10 max-w-2xl text-center text-base text-petrol-600'
      data-animate>
      IVA incluido. El presupuesto final se concreta tras el diagnóstico inicial.
    </p>
  </div>
</div>
