---
import Upheading from '../../Upheading.astro'
import { Check } from '@lucide/astro'

interface PricingTier {
  name: string
  price: string
  unit: string
  description: string
  features: string[]
  cta: string
  ctaHref: string
  featured?: boolean
  commitment: string
  commitmentMonths: number
  savings?: string
}

const tiers: PricingTier[] = [
  {
    name: 'Solo Ficha',
    price: '350 €',
    unit: '/mes + IVA',
    description: 'Para negocios que necesitan visibilidad en Google Maps y el Local Pack.',
    commitment: 'Compromiso recomendado: 3 meses',
    commitmentMonths: 3,
    features: [
      'Auditoría de competencia y visibilidad local',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Alta en directorios locales y consistencia NAP',
      'Publicaciones mensuales en GBP',
      'Monitorización y respuesta a reseñas',
      'Mapa de visibilidad local por zonas (geo-grid)',
      'Informe mensual con tracking de posiciones en Maps',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Solo%20Ficha%20de%20350%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Solo Web',
    price: '550 €',
    unit: '/mes + IVA',
    description: 'Para negocios que necesitan posicionar su web en Google con páginas de servicio y SEO técnico.',
    commitment: 'Compromiso recomendado: 4 meses',
    commitmentMonths: 4,
    features: [
      'Auditoría SEO on-page de la web',
      'Investigación de palabras clave transaccionales',
      'Optimización de encabezados, titles y descriptions',
      'Creación de páginas de servicio optimizadas',
      'Reestructuración de la arquitectura web si es necesario',
      'Optimización técnica (Core Web Vitals)',
      'Schema markup LocalBusiness + Service',
      'Optimización de contenidos con análisis TF*IDF',
      'Informe mensual con tracking de posiciones orgánicas',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Solo%20Web%20de%20550%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Ficha + Web',
    price: '800 €',
    unit: '/mes + IVA',
    description: 'Google Maps + Posicionamiento Web Orgánico. La combinación más completa para dominar las búsquedas locales.',
    commitment: 'Compromiso recomendado: 6 meses',
    commitmentMonths: 6,
    featured: true,
    savings: 'Ahorras 100 €/mes',
    features: [
      '<strong>Todo lo del paquete Solo Ficha</strong>',
      '<strong>Todo lo del paquete Solo Web</strong>',
      'Análisis de competencia local + orgánica cruzado',
      'Investigación de keywords locales + transaccionales',
      'Enlazado interno entre páginas de servicio y ficha',
      'Publicaciones en GBP enlazadas a páginas de servicio',
      'Alineación de categorías y servicios GBP con páginas web',
      'Schema markup cruzado ficha ↔ web (reseñas + servicios)',
      'Informe mensual unificado con tracking Maps + orgánico',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20paquete%20Ficha%20%2B%20Web%20de%20800%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
]

const TOTAL_SEGMENTS = 6
---

<div id='paquetes' class='bg-white py-24 sm:py-32' style='scroll-margin-top: var(--navbar-height)'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='mx-auto max-w-4xl text-center'>
      <Upheading as='h2' text='Presupuesto SEO Barcelona' class='text-center' />
      <p class='mt-2 text-4xl font-semibold tracking-tight text-balance text-petrol-900 sm:text-5xl'>
        Elige lo que necesitas, sin pagar de más
      </p>
    </div>
    <p class='mx-auto mt-6 max-w-2xl text-center text-lg font-medium text-pretty text-petrol-700 sm:text-xl/8'>
      Solo ficha de Google, solo web, o ambas con descuento. Tú decides el alcance; nosotros ejecutamos.
    </p>

    <div class='isolate mx-auto mt-16 grid max-w-md grid-cols-1 gap-y-8 sm:mt-20 lg:mx-0 lg:max-w-none lg:grid-cols-3'>
      {tiers.map((tier, index) => (
        <div
          class:list={[
            'flex flex-col justify-between rounded-3xl p-8 xl:p-10',
            tier.featured
              ? 'bg-sky-600 ring-2 ring-white/50 lg:z-10'
              : 'ring-1 ring-petrol-200 lg:mt-8',
            // drop internal corner on the right only for non-featured last card
            // (first card no longer loses its right rounding)
            index === 2 && !tier.featured && 'lg:rounded-l-none',
            // ensure featured card retains full rounding
            tier.featured && 'lg:rounded-b-3xl',
          ]}>
          <div>
            <!-- Commitment bar -->
            <div class='mb-6'>
              <div class='flex gap-1'>
                {Array.from({ length: TOTAL_SEGMENTS }).map((_, i) => (
                  <div
                    class:list={[
                      'h-1.5 flex-1 rounded-full',
                      i < tier.commitmentMonths
                        ? tier.featured ? 'bg-white' : 'bg-sky-500'
                        : tier.featured
                          ? 'bg-white/25'
                          : 'bg-petrol-100',
                    ]}
                  />
                ))}
              </div>
              <p class:list={[
                'mt-2 text-xs',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
                {tier.commitmentMonths} de {TOTAL_SEGMENTS} meses recomendados
              </p>
            </div>

            <div class='flex items-center justify-between gap-x-4'>
              <h3
                class:list={[
                  'text-lg/8 font-semibold',
                  tier.featured ? 'text-white' : 'text-petrol-900',
                ]}>
                {tier.name}
              </h3>
            </div>
            {tier.featured && (
              <div class='mt-2 flex flex-wrap gap-2'>
                <span class='inline-block rounded-full bg-white px-3 py-0.5 text-xs font-semibold text-sky-600'>
                  Recomendado
                </span>
                {tier.savings && (
                  <span class='inline-block rounded-full bg-emerald-400 px-3 py-0.5 text-xs font-semibold text-white'>
                    {tier.savings}
                  </span>
                )}
              </div>
            )}
            <p
              class:list={[
                'mt-4 text-sm/6',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
              {tier.description}
            </p>
            <p class='mt-6 flex items-baseline gap-x-1'>
              <span
                class:list={[
                  'font-semibold tracking-tight',
                  tier.featured ? 'text-5xl text-white' : 'text-4xl text-petrol-900',
                ]}>
                {tier.price}
              </span>
              <span
                class:list={[
                  'text-sm/6 font-semibold',
                  tier.featured ? 'text-white/70' : 'text-petrol-600',
                ]}>
                {tier.unit}
              </span>
            </p>
            <ul
              role='list'
              class:list={[
                'mt-8 space-y-3 text-sm/6',
                tier.featured ? 'text-sky-100' : 'text-petrol-600',
              ]}>
              {tier.features.map((feature) => (
                <li class='flex gap-x-3'>
                  <Check
                    class:list={[
                      'h-6 w-5 flex-none',
                      tier.featured ? 'text-white' : 'text-sky-600',
                    ]}
                    aria-hidden='true'
                  />
                  <Fragment set:html={feature} />
                </li>
              ))}
            </ul>
          </div>
          <div class='mt-8'>
            <hr class:list={[
              'mb-6 border-0 h-px',
              tier.featured ? 'bg-white/20' : 'bg-petrol-100',
            ]} />
            <a
              href={tier.ctaHref}
              target='_blank'
              rel='noopener noreferrer nofollow'
              class:list={[
                'block rounded-md px-3 py-2 text-center text-sm/6 font-semibold shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2',
                tier.featured
                  ? 'bg-white text-sky-600 hover:bg-sky-50 focus-visible:outline-white'
                  : 'bg-sky-50 text-sky-600 ring-1 ring-sky-200 ring-inset hover:ring-sky-300 focus-visible:outline-sky-600',
              ]}>
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class='mx-auto mt-10 max-w-2xl text-center text-sm text-petrol-500'>
      Todos los precios + IVA. Sin permanencia contractual. El presupuesto final se define tras el diagnóstico inicial gratuito.
    </p>
  </div>
</div>
