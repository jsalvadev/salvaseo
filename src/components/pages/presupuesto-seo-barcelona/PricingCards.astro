---
import { Check } from '@lucide/astro'

interface PricingTier {
  name: string
  price: string
  unit: string
  description: string
  features: string[]
  cta: string
  ctaHref: string
  featured?: boolean
  commitment: string
  commitmentMonths: number
  savings?: string
  hidden?: boolean
}

const tiers: PricingTier[] = [
  {
    name: 'Visibilidad Local',
    price: '350 €',
    unit: '/mes IVA incl.',
    description: 'Deja de ser invisible en tu zona y empieza a recibir llamadas de clientes que tienes a la vuelta de la esquina.',
    commitment: 'Compromiso recomendado: 3 meses',
    commitmentMonths: 3,
    features: [
      'Auditoría de competencia y visibilidad local',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Alta en directorios locales y coherencia de nombre, dirección y teléfono',
      'Publicaciones mensuales en GBP',
      'Monitorización y respuesta a reseñas',
      'Mapa de visibilidad real por barrios y zonas de Barcelona',
      'Informe mensual con seguimiento de posiciones en Maps',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20Plan%20Visibilidad%20Local%20de%20350%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
  },
  {
    name: 'Visibilidad Total',
    price: '550 €',
    unit: '/mes IVA incl.',
    description: 'Sal de la sombra en toda la ciudad. Una estrategia de asalto para dominar las búsquedas más rentables de Barcelona.',
    commitment: 'Compromiso recomendado: 4 meses',
    commitmentMonths: 4,
    featured: true,
    features: [
      'Auditoría SEO on-page de la web',
      'Estudio de palabras clave transaccionales',
      'Optimización de encabezados, titles y descriptions',
      'Creación de páginas de servicio optimizadas',
      'Optimización técnica de velocidad y experiencia de carga',
      'Datos estructurados para destacar en resultados de Google',
      'Creación u optimización de Google Business Profile',
      'Categorías, servicios, fotos y atributos optimizados',
      'Publicaciones mensuales en GBP enlazadas a páginas de servicio',
      'Informe mensual unificado con seguimiento en Maps + orgánico',
      'Llamada mensual de seguimiento',
      'Soporte por WhatsApp',
    ],
    cta: 'Solicita tu diagnóstico',
    ctaHref: 'https://wa.me/34692051399?text=Hola%20Salva%2C%20me%20interesa%20el%20Plan%20Visibilidad%20Total%20de%20550%E2%82%AC%2Fmes.%20%C2%BFPodemos%20hacer%20el%20diagn%C3%B3stico%20inicial%3F',
    hidden: false,
  },
  {
    name: 'Ficha + Web',
    price: '800 €',
    unit: '/mes + IVA',
    description: 'Google Maps + posicionamiento orgánico. El proyecto SEO más completo para dominar las búsquedas locales en Barcelona.',
    commitment: 'Compromiso recomendado: 6 meses',
    commitmentMonths: 6,
    featured: false,
    hidden: true,
    features: [],
    cta: 'Solicita tu diagnóstico',
    ctaHref: '',
  },
]

const TOTAL_SEGMENTS = 6
---

<div
  id='paquetes'
  class='relative overflow-hidden bg-warm-white py-24 sm:py-32'
  style='scroll-margin-top: var(--navbar-height)'>

  <!-- Architectural grid (Eixample-inspired) -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: linear-gradient(rgba(26,60,74,0.038) 1px, transparent 1px), linear-gradient(90deg, rgba(26,60,74,0.038) 1px, transparent 1px); background-size: 48px 48px;'>
  </div>

  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>

    <!-- Headline block: editorial split on desktop -->
    <div class='mb-12 lg:flex lg:items-end lg:justify-between lg:gap-16'>

      <!-- Left: section heading -->
      <div class='flex-1' data-animate>
        <div class='flex items-center gap-3 mb-6'>
          <span class='block h-px w-10 bg-orange-500' aria-hidden='true'></span>
          <p class='text-[0.7rem] font-bold uppercase tracking-[0.22em] text-orange-500'>
            Precio SEO mensual: tarifas y paquetes
          </p>
        </div>

        <h2
          style='font-family: "Titan One", cursive;'
          class='leading-[0.88] tracking-tight'>
          <span class='block text-[clamp(1.6rem,3.5vw,2.75rem)] text-petrol-600 mb-1'>
            Invierte solo en
          </span>
          <span class='block text-[clamp(3.5rem,8.5vw,7.5rem)] text-petrol-900'>
            lo que necesitas<span class='text-orange-400'>.</span>
          </span>
        </h2>
      </div>

      <!-- Right: philosophy note (desktop only) -->
      <div
        class='hidden lg:block lg:max-w-[240px] xl:max-w-[260px] pb-3 pl-10 border-l-2 border-petrol-100'
        data-animate>
        <p class='text-base leading-relaxed text-petrol-600 text-pretty'>
          Dos paquetes. Precio fijo mensual. Sin permanencia ni letra pequeña.
        </p>
        <p class='mt-3 text-sm text-petrol-600/60'>
          El presupuesto se concreta tras el diagnóstico inicial gratuito.
        </p>
      </div>

    </div>

    <!-- Accent rule -->
    <div class='mb-14 flex items-center' data-animate>
      <div class='h-[3px] w-16 bg-orange-500 rounded-full'></div>
      <div class='h-px flex-1 bg-gradient-to-r from-orange-500/30 via-petrol-100 to-transparent'></div>
    </div>

    <!-- Pricing cards grid -->
    <div class='grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8 max-w-5xl'>
      {tiers.filter(t => !t.hidden).map((tier, index) => (
        <div
          data-animate
          style={tier.featured
            ? `transition-delay: ${index * 100}ms; box-shadow: 0 30px 60px -15px rgba(26,60,74,0.4);`
            : `transition-delay: ${index * 100}ms;`}
          class:list={[
            'relative flex flex-col rounded-2xl overflow-hidden',
            tier.featured
              ? 'bg-petrol-900'
              : 'bg-white border border-default shadow-sm hover:shadow-lg transition-shadow duration-300',
          ]}>

          <!-- Ghost "€" watermark on featured card -->
          {tier.featured && (
            <div
              class='pointer-events-none absolute -right-4 -bottom-2 select-none leading-none'
              aria-hidden='true'
              style='font-family: "Titan One", cursive; font-size: 13rem; color: rgba(249,115,22,0.06); line-height: 1;'>
              €
            </div>
          )}

          <div class='relative flex-1 p-8 xl:p-10'>

            <!-- Commitment bar -->
            <div class='mb-7'>
              <div class='flex gap-1.5 mb-2'>
                {Array.from({ length: TOTAL_SEGMENTS }).map((_, i) => (
                  <div
                    class:list={[
                      'h-1.5 flex-1 rounded-full',
                      i < tier.commitmentMonths
                        ? 'bg-orange-500'
                        : tier.featured ? 'bg-white/10' : 'bg-petrol-100',
                    ]}
                  />
                ))}
              </div>
              <p class:list={[
                'text-xs font-semibold uppercase tracking-wide',
                tier.featured ? 'text-white/35' : 'text-petrol-600/50',
              ]}>
                {tier.commitmentMonths} de {TOTAL_SEGMENTS} meses recomendados
              </p>
            </div>

            <!-- Tier name + badge -->
            <div class='flex items-start justify-between gap-3 mb-2'>
              <div>
                <p class:list={[
                  'text-[0.55rem] font-bold uppercase tracking-[0.22em] mb-0.5',
                  tier.featured ? 'text-orange-400/50' : 'text-petrol-600/40',
                ]}>
                  Plan
                </p>
                <h3
                  class:list={[
                    'text-sm font-bold uppercase tracking-[0.12em]',
                    tier.featured ? 'text-white/70' : 'text-petrol-800',
                  ]}>
                  {tier.name}
                </h3>
              </div>
              {tier.featured && (
                <span class='mt-0.5 inline-flex items-center rounded-full bg-orange-500 px-3 py-1 text-[0.65rem] font-bold uppercase tracking-wide text-white shadow-lg shadow-orange-500/40'>
                  ★ Recomendado
                </span>
              )}
            </div>

            <!-- Price -->
            <div class='mb-5 flex items-baseline gap-2'>
              <span
                class:list={[
                  'font-bold leading-none text-[clamp(2.75rem,5.5vw,4rem)]',
                  tier.featured ? 'text-orange-400' : 'text-petrol-900',
                ]}
                style='font-family: "Titan One", cursive;'>
                {tier.price}
              </span>
              <span class:list={[
                'text-sm font-semibold',
                tier.featured ? 'text-white/35' : 'text-petrol-600/55',
              ]}>
                {tier.unit}
              </span>
            </div>

            <!-- Description -->
            <p
              class:list={[
                'text-sm leading-relaxed pb-5 mb-5',
                tier.featured
                  ? 'text-white/55 border-b border-white/10'
                  : 'text-petrol-600 border-b border-petrol-100',
              ]}>
              <Fragment set:html={tier.description} />
            </p>

            <!-- Features list -->
            <ul class='space-y-2.5'>
              {tier.features.map((feature) => (
                <li class='flex items-start gap-3'>
                  <span
                    class:list={[
                      'mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full',
                      tier.featured
                        ? 'bg-orange-500/15 text-orange-400'
                        : 'bg-sky-50 text-sky-600',
                    ]}>
                    <Check class='h-3 w-3' aria-hidden='true' />
                  </span>
                  <span class:list={[
                    'text-sm leading-relaxed',
                    tier.featured ? 'text-white/65' : 'text-petrol-700',
                  ]}>
                    <Fragment set:html={feature} />
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA button -->
          <div class='relative p-8 xl:p-10 pt-0'>
            <a
              href={tier.ctaHref}
              target='_blank'
              rel='noopener noreferrer nofollow'
              class:list={[
                'block w-full rounded-xl px-6 py-3.5 text-center text-sm font-bold uppercase tracking-wide transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2',
                tier.featured
                  ? 'bg-orange-500 text-white shadow-lg shadow-orange-500/30 hover:bg-orange-400 hover:-translate-y-0.5 focus-visible:outline-orange-500'
                  : 'bg-petrol-900 text-white hover:bg-petrol-800 hover:-translate-y-0.5 focus-visible:outline-petrol-900',
              ]}>
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <p
      class='mt-8 max-w-5xl text-sm text-petrol-600/60'
      data-animate>
      Precios con IVA incluido. Sin permanencia ni letra pequeña.
    </p>

  </div>
</div>
