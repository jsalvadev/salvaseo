---
import { Euro, ShieldCheck, Clock } from '@lucide/astro'
import WhatsAppButton from '../../WhatsAppButton.astro'
---

<div class='bg-petrol-900'>
  <div class='relative isolate overflow-hidden px-6 lg:px-8'>
    <svg
      class='absolute inset-0 -z-10 h-full w-full'
      aria-hidden='true'>
      <defs>
        <pattern
          id='hero-dot-pattern'
          width='20'
          height='20'
          patternUnits='userSpaceOnUse'>
          <circle
            cx='1'
            cy='1'
            r='1'
            fill='rgb(255 255 255 / 0.12)'
          ></circle>
        </pattern>
      </defs>
      <rect
        width='100%'
        height='100%'
        fill='url(#hero-dot-pattern)'
      ></rect>
    </svg>

    <div class='mx-auto max-w-3xl py-24 sm:py-32 lg:py-40'>
      <div class='mb-6 flex justify-center'>
        <span
          class='rounded-full bg-sky-500/10 border border-sky-400/20 px-3 py-1 text-sm/6 text-sky-300'>
          Presupuesto SEO en Barcelona
        </span>
      </div>
      <div class='mb-8 flex flex-wrap items-center justify-center gap-3'>
        <span
          class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-petrol-100'>
          <Euro
            class='size-4'
            aria-hidden='true'
          />
          Desde 350 €/mes
        </span>
        <span
          class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-petrol-100'>
          <ShieldCheck
            class='size-4'
            aria-hidden='true'
          />
          Contratación mensual
        </span>
        <span
          class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-petrol-100'>
          <Clock
            class='size-4'
            aria-hidden='true'
          />
          Diagnóstico gratuito
        </span>
      </div>
      <div class='text-center'>
        <h1
          class='text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl'>
          Presupuesto SEO en Barcelona — Precio y Paquetes Mensuales
        </h1>

        <p
          class='mt-8 text-lg font-medium text-pretty text-petrol-100 sm:text-xl/8'>
          Tres paquetes de servicios SEO con precio mensual cerrado desde el diagnóstico. Posicionamiento orgánico en Google para clientes que buscan resultados medibles — el compromiso se renueva con tracción real.
        </p>
        <div
          class='mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-x-6'>
          <WhatsAppButton text='Solicita tu diagnóstico gratuito' />
          <a
            href='#paquetes'
            class='text-sm/6 font-semibold text-white hover:text-sky-300 transition-colors'>
            Ver paquetes y precios <span aria-hidden='true'>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
