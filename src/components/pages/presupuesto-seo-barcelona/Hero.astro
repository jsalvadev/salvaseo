---
import WhatsAppButton from '../../WhatsAppButton.astro'
import { buildWhatsAppHref } from '../../../data/site'
import { ChevronRight } from '@lucide/astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  upheading?: string
  heading?: string
  description?: string
  primaryCtaText?: string
  secondaryCtaText?: string
  secondaryCtaHref?: string
  breadcrumbItems?: BreadcrumbItem[]
}

const {
  upheading = 'Presupuesto SEO en Barcelona',
  description = 'Estar en la sombra en una ciudad como Barcelona tiene un precio demasiado alto en ventas perdidas. Ser invisible te está saliendo caro hoy mismo. Elige tu estrategia y deja de regalarle mercado a tu competencia.',
  primaryCtaText = 'Analiza mi web',
  secondaryCtaText = 'Ver paquetes y precios',
  secondaryCtaHref = '#paquetes',
  breadcrumbItems,
} = Astro.props

const waHref = buildWhatsAppHref()
const currentYear = new Date().getFullYear()
---

<section class='relative bg-teal overflow-hidden'>
  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'>
  </div>

  <!-- Large faded watermark -->
  <div class="font-heading pointer-events-none absolute -top-8 right-0 select-none leading-none"
    aria-hidden='true'>
    €
  </div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line
      x1='72%' y1='0%' x2='100%' y2='100%'
      stroke='rgba(250,234,177,0.07)' stroke-width='1'></line>
    <line
      x1='78%' y1='0%' x2='108%' y2='100%'
      stroke='rgba(250,234,177,0.04)' stroke-width='1'></line>
    <line
      x1='65%' y1='0%' x2='93%' y2='100%'
      stroke='rgba(250,234,177,0.04)' stroke-width='1'></line>
  </svg>

  <!-- Bottom hairline accent -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent'
    aria-hidden='true'>
  </div>

  <!-- Radial glow bottom-left -->
  <div
    class='pointer-events-none absolute -bottom-32 -left-32 w-96 h-96 rounded-full'
    aria-hidden='true'>
  </div>

  <!-- Breadcrumb (inside dark section, below fixed navbar) -->
  {breadcrumbItems && (
    <nav
      aria-label='Breadcrumb'
      class='relative container-site pt-[calc(var(--navbar-height)+1.25rem)]'>
      <ol class='flex items-center gap-1.5 text-sm'>
        {breadcrumbItems.map((item, idx) => (
          <li class='flex items-center gap-1.5'>
            {idx > 0 && (
              <ChevronRight class='size-3.5 text-white/30 shrink-0' aria-hidden='true' />
            )}
            {item.href ? (
              <a
                href={item.href}
                class='text-white/60 hover:text-white transition-colors'>
                {item.label}
              </a>
            ) : (
              <span class='text-white/90 font-medium' aria-current='page'>
                {item.label}
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )}

  <!-- Main grid -->
  <div class={`relative container-site pb-12 sm:pb-16 lg:pb-20 ${breadcrumbItems ? 'pt-6' : 'pt-20 sm:pt-24 lg:pt-28'}`}>
    <div class='grid lg:grid-cols-[1fr_360px] xl:grid-cols-[1fr_400px] gap-10 lg:gap-16 items-center'>

      <!-- LEFT: Content -->
      <div>
        <!-- Eyebrow -->
        <div class='animate-fade-in-up [animation-delay:0ms] flex items-center gap-3 mb-5'>
          <span class='block h-px w-10 bg-sand'></span>
          <h1 class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sand'>
            {upheading}
          </h1>
        </div>

        <!-- Headline -->
        <p
          class='animate-fade-in-up [animation-delay:80ms]'
>
          <span class='block text-[1.9rem] sm:text-[2.2rem] lg:text-[2.5rem] xl:text-[2.94rem] leading-[0.93] tracking-tight text-white'>
            Tu plan para
          </span>
          <span class='block text-[1.9rem] sm:text-[2.2rem] lg:text-[2.5rem] xl:text-[2.94rem] leading-[0.93] tracking-tight mt-1'>
            <span class='text-white'>ser&nbsp;</span><span class='text-sand'>visible.</span>
          </span>
        </p>

        <!-- Accent rule -->
        <div class='animate-fade-in-up [animation-delay:160ms] mt-5 flex items-center gap-0'>
          <div class='h-px w-16 bg-sand'></div>
          <div class='h-px w-24 bg-gradient-to-r from-sand/50 to-transparent'></div>
        </div>

        <!-- Body copy -->
        <p class='animate-fade-in-up [animation-delay:230ms] mt-5 max-w-[52ch] text-lg leading-relaxed text-white/75 text-pretty'>
          Estar en la sombra en una ciudad como Barcelona tiene un <strong class='text-white font-semibold'>precio demasiado alto en ventas perdidas.</strong> Ser invisible <strong class='text-white font-semibold'>te está saliendo caro hoy mismo.</strong> Elige tu estrategia y deja de regalarle mercado a tu competencia.
        </p>


        <!-- CTA -->
        <div class='animate-fade-in-up [animation-delay:440ms] mt-8'>
          <WhatsAppButton
            text={primaryCtaText}
            href={waHref}
            class='px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-sand/20 hover:shadow-sand/30 transition-shadow'
          />
        </div>

      </div>

      <!-- RIGHT: Price widget -->
      <aside
        class='animate-fade-in [animation-delay:480ms] hidden lg:flex flex-col gap-3'
        aria-hidden='true'>

        <!-- Label -->
        <p class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-white/30 px-1'>
          Tarifas SEO · Barcelona {currentYear}
        </p>

        <!-- Tier 1: Solo Ficha -->
        <div
          class='rounded-2xl border p-5 relative overflow-hidden'>
          <div class='flex items-start justify-between mb-3'>
            <div>
              <span class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-white/75 block mb-1'>
                Que te encuentren en Google Maps
              </span>
              <div class='flex items-baseline gap-2'>
                <span
                  class='text-[clamp(1.85rem,3.5vw,2.5rem)] font-bold text-white leading-none'
>
                  350 €
                </span>
                <span class='text-sm text-white/35'>/mes · sin IVA</span>
              </div>
            </div>
            <span class='text-xs font-semibold text-white/30 mt-1'>3 meses rec.</span>
          </div>
          <div class='flex gap-1 mb-3'>
            {[...Array(6)].map((_, i) => (
              <div class={`h-1 flex-1 rounded-full ${i < 3 ? 'bg-sand/60' : 'bg-white/8'}`} />
            ))}
          </div>
          <ul class='space-y-1.5'>
            {['Convierte búsquedas en visitas reales.', 'Multiplica tus reseñas de 5 estrellas.', 'Ficha de Maps profesional y actualizada.'].map(f => (
              <li class='flex items-center gap-2 text-sm text-white/75'>
                <span class='h-1 w-1 rounded-full bg-sand/60 shrink-0'></span>
                {f}
              </li>
            ))}
          </ul>
        </div>

        <!-- Tier 2: Web + Ficha (featured) -->
        <div
          class='rounded-2xl border p-5 relative overflow-hidden'>

          <div class='flex items-start justify-between gap-2 mb-1'>
            <span class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sand/70 block text-pretty'>
              Que te encuentren en Maps y en Google
            </span>
            <div
              class='shrink-0 rounded-full px-3 py-1'>
              <span class='text-xs font-bold uppercase tracking-wider text-cream whitespace-nowrap'>
                ★ Más elegido
              </span>
            </div>
          </div>

          <div class='mb-3'>
            <div class='flex items-baseline gap-2'>
              <span
                class='text-[clamp(1.85rem,3.5vw,2.5rem)] font-bold text-white leading-none'
>
                550 €
              </span>
              <span class='text-sm text-sand/40'>/mes · sin IVA</span>
            </div>
          </div>

          <div class='flex gap-1 mb-3'>
            {[...Array(6)].map((_, i) => (
              <div class={`h-1 flex-1 rounded-full ${i < 4 ? 'bg-sand/80' : 'bg-white/10'}`} />
            ))}
          </div>

          <ul class='space-y-1.5 mb-3'>
            {['Dominio total en Maps y buscadores.', 'Escala posiciones sobre tu competencia.', 'Lidera los resultados de tu sector.'].map(f => (
              <li class='flex items-center gap-2 text-sm text-white/75'>
                <span class='h-1 w-1 rounded-full bg-sand/70 shrink-0'></span>
                {f}
              </li>
            ))}
          </ul>
        </div>

        <!-- Footer -->
        <div class='flex items-center justify-center gap-3 px-1'>
          <div class='h-px flex-1 bg-gradient-to-r from-transparent to-white/15'></div>
          <p class='text-xs font-semibold text-white/35 whitespace-nowrap'>
            Sin permanencia
          </p>
          <div class='h-px flex-1 bg-gradient-to-l from-transparent to-white/15'></div>
        </div>
      </aside>
    </div>
  </div>
</section>
