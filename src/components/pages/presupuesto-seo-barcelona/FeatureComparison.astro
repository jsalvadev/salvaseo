---
interface ComparisonFeature {
  name: string
  ficha: string
  bundle: string
}

interface ComparisonCategory {
  name: string
  features: ComparisonFeature[]
}

const categories: ComparisonCategory[] = [
  {
    name: 'Ficha de Google Maps',
    features: [
      { name: 'Análisis de por qué no apareces y quién aparece antes que tú', ficha: '✓', bundle: '✓' },
      { name: 'Creación u optimización de tu ficha de Google Maps',            ficha: '✓', bundle: '✓' },
      { name: 'Categorías, servicios, fotos y atributos',                      ficha: '✓', bundle: '✓' },
      { name: 'Monitorización y respuesta a reseñas',                          ficha: '✓', bundle: '✓' },
      { name: 'En qué zonas de Barcelona apareces y en cuáles no',             ficha: '✓', bundle: '✓' },
    ]
  },
  {
    name: 'Citaciones y directorios',
    features: [
      { name: 'Alta en directorios locales',                        ficha: '✓', bundle: '✓' },
      { name: 'Tu nombre, dirección y teléfono iguales en todos los sitios donde apareces online', ficha: '✓', bundle: '✓' },
    ]
  },
  {
    name: 'Web y contenido',
    features: [
      { name: 'Revisión y corrección de tu web',                                    ficha: '—', bundle: '✓' },
      { name: 'Búsquedas que usa tu cliente cuando quiere contratar',              ficha: '—', bundle: '✓' },
      { name: 'Textos de tu web optimizados para que Google los entienda',         ficha: '—', bundle: '✓' },
      { name: 'Páginas de servicio optimizadas',                                   ficha: '—', bundle: '✓' },
      { name: 'Reorganización de tu web para que Google la entienda mejor',        ficha: '—', bundle: '✓' },
      { name: 'Tu web más rápida para que nadie se vaya antes de llamarte',        ficha: '—', bundle: '✓' },
      { name: 'Configuración técnica para destacar en Google',                     ficha: '—', bundle: '✓' },
      { name: 'Textos mejorados para superar a tu competencia en Google',          ficha: '—', bundle: '✓' },
    ]
  },
  {
    name: 'Estrategia combinada',
    features: [
      { name: 'Análisis de competencia local + orgánica cruzado',                   ficha: '—', bundle: '✓' },
      { name: 'Investigación de keywords locales + transaccionales',                ficha: '—', bundle: '✓' },
      { name: 'Estrategia de enlaces internos entre páginas y ficha',               ficha: '—', bundle: '✓' },
      { name: 'Publicaciones en GBP enlazadas a páginas de servicio',              ficha: '—', bundle: '✓' },
      { name: 'Alineación de categorías GBP con páginas web',                      ficha: '—', bundle: '✓' },
      { name: 'Datos estructurados cruzados ficha ↔ web',                          ficha: '—', bundle: '✓' },
    ]
  },
  {
    name: 'Seguimiento',
    features: [
      { name: 'Cómo subes en Google Maps cada mes',  ficha: '✓', bundle: '✓' },
      { name: 'Cómo sube tu web en Google cada mes', ficha: '—', bundle: '✓' },
      { name: 'Informe mensual de resultados',        ficha: '✓', bundle: '✓' },
      { name: 'Llamada mensual de seguimiento',       ficha: '✓', bundle: '✓' },
      { name: 'Soporte por WhatsApp',                 ficha: '✓', bundle: '✓' },
      { name: 'Tiempo recomendado',                   ficha: '3 meses', bundle: '4 meses' },
    ]
  }
]

const checkFicha  = `<svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-label="Incluido" style="display:inline-block;vertical-align:middle;"><path d="M4 10.5l4 4L16 6" stroke="var(--color-sage)" stroke-opacity="0.7" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
const checkBundle = `<svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-label="Incluido" style="display:inline-block;vertical-align:middle;"><path d="M4 10.5l4 4L16 6" stroke="var(--color-base)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
const dashSvg     = `<span aria-label="No incluido" style="display:inline-block;width:10px;height:1.5px;background:color-mix(in srgb,var(--color-base) 18%,transparent);border-radius:2px;vertical-align:middle;"></span>`

function renderFicha(value: string): string {
  if (value === '✓') return checkFicha
  if (value === '—') return dashSvg
  return `<span style="font-size:var(--text-xs);font-weight:700;color:color-mix(in srgb,var(--color-base) 55%,transparent);letter-spacing:0.04em;">${value}</span>`
}

function renderBundle(value: string): string {
  if (value === '✓') return checkBundle
  if (value === '—') return dashSvg
  return `<span style="font-size:var(--text-xs);font-weight:700;color:var(--color-base);letter-spacing:0.04em;">${value}</span>`
}
---

<div
  class='relative overflow-hidden py-24 sm:py-32'
  style='background: linear-gradient(160deg, color-mix(in srgb, var(--color-cream) 97%, white) 0%, var(--color-cream) 45%, color-mix(in srgb, var(--color-cream) 90%, var(--color-base)) 100%);'>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line x1='70%' y1='0%' x2='100%' y2='100%' stroke='var(--color-base)' stroke-opacity='0.04' stroke-width='1'></line>
    <line x1='76%' y1='0%' x2='108%' y2='100%' stroke='var(--color-base)' stroke-opacity='0.025' stroke-width='1'></line>
    <line x1='63%' y1='0%' x2='92%'  y2='100%' stroke='var(--color-base)' stroke-opacity='0.025' stroke-width='1'></line>
  </svg>

  <!-- Ghost watermark -->
  <div
    class='font-heading pointer-events-none absolute -right-6 bottom-4 select-none leading-none text-wm-xl font-bold'
    style='color: color-mix(in srgb, var(--color-base) 5%, transparent);'
    aria-hidden='true'>
    Plan
  </div>

  <!-- Top hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 top-0 h-px'
    style='background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-base) 20%, transparent), transparent);'
    aria-hidden='true'>
  </div>

  <!-- Bottom hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px'
    style='background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-base) 10%, transparent), transparent);'
    aria-hidden='true'>
  </div>

  <div class='relative container-site'>

    <!-- ── Section header ──────────────────────────────── -->
    <header class='mb-14 max-w-2xl' data-animate>

      <h2 class='text-xs font-bold tracking-[0.2em] uppercase text-sage mb-6'>
        Posicionamiento web: precios por servicio
      </h2>

      <p
        class='font-heading text-h2 font-normal leading-[1.05] tracking-tight text-pretty mb-5'
        style='color: var(--color-base);'>
        Detalle completo de <span class='text-sage'>cada plan</span><span class='text-sage'>.</span>
      </p>

      <div class='flex items-center'>
        <div class='h-px w-32 bg-gradient-to-r from-sage/5 to-sage/35'></div>
        <div class='h-px w-10 bg-sage/60'></div>
      </div>

    </header>

    <!-- ── DESKTOP TABLE ────────────────────────────────── -->
    <div class='mx-auto max-w-3xl hidden lg:block' data-animate>
      <table class='w-full text-left border-collapse'>
        <caption class='sr-only'>Tarifas de posicionamiento SEO: comparativa de paquetes</caption>

        <thead>
          <tr>
            <th scope='col' class='pt-7 pb-5 pr-8 text-left align-top'>
              <span
                class='text-xs font-semibold tracking-[0.14em] uppercase'
                style='color: color-mix(in srgb, var(--color-base) 30%, transparent);'>
                Características
              </span>
            </th>

            <th scope='col' class='pt-4 pb-4 px-6 text-left align-top w-48'>
              <span
                class='block text-xs font-semibold leading-snug mb-2'
                style='color: color-mix(in srgb, var(--color-base) 55%, transparent);'>
                Más llamadas desde Google Maps
              </span>
              <span
                class='font-heading block font-bold text-h5 leading-none whitespace-nowrap'
                style='color: color-mix(in srgb, var(--color-base) 70%, transparent);'>
                350 €/mes
              </span>
            </th>

            <th scope='col' class='pt-4 pb-4 px-6 text-left align-top w-48 relative'>
              <!-- Featured column bg only, no top line -->
              <div
                class='absolute inset-x-0 inset-y-0 rounded-t-xl'
                style='background: color-mix(in srgb, var(--color-sage) 8%, transparent);'
                aria-hidden='true'>
              </div>
              <div class='relative'>
                <span
                  class='block text-xs font-semibold leading-snug mb-2'
                  style='color: color-mix(in srgb, var(--color-base) 75%, transparent);'>
                  Más llamadas desde Google Maps y tu web
                </span>
                <span
                  class='font-heading block font-bold text-h5 leading-none whitespace-nowrap'
                  style='color: var(--color-base);'>
                  550 €/mes
                </span>
              </div>
            </th>
          </tr>
        </thead>

        <tbody>
          {categories.map((category, catIdx) => (
            <>
              <tr>
                <th scope='colgroup' colspan={3} class='pt-8 pb-2'>
                  <div class='flex items-center gap-3'>
                    <span
                      class='text-xs font-bold tabular-nums font-heading'
                      style='color: color-mix(in srgb, var(--color-base) 25%, transparent);'
                      aria-hidden='true'>
                      {String(catIdx + 1).padStart(2, '0')}
                    </span>
                    <div
                      class='h-px flex-1'
                      style='background: color-mix(in srgb, var(--color-base) 10%, transparent);'>
                    </div>
                    <span
                      class='text-xs font-bold tracking-[0.16em] uppercase'
                      style='color: color-mix(in srgb, var(--color-base) 65%, transparent);'>
                      {category.name}
                    </span>
                    <div
                      class='h-px w-4'
                      style='background: color-mix(in srgb, var(--color-base) 10%, transparent);'>
                    </div>
                  </div>
                </th>
              </tr>

              {category.features.map((feature) => (
                <tr class='group/row transition-colors duration-100 feature-row'>
                  <th
                    scope='row'
                    class='py-3 pr-8 text-sm font-normal text-left transition-colors duration-100 feature-label'>
                    {feature.name}
                  </th>
                  <td class='py-3 px-6 text-center w-40'>
                    <Fragment set:html={renderFicha(feature.ficha)} />
                  </td>
                  <td class='py-3 px-6 text-center w-40 bundle-cell transition-colors duration-100'>
                    <Fragment set:html={renderBundle(feature.bundle)} />
                  </td>
                </tr>
              ))}
            </>
          ))}

          <tr aria-hidden='true'>
            <td colspan='3' class='pb-2'></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ── MOBILE: Tabbed stacked cards ──────────────────── -->
    <div class='lg:hidden' data-animate>

      <input type='radio' id='fc-tab-ficha' name='fc-tabs' class='fc-tab-input sr-only' checked />
      <input type='radio' id='fc-tab-bundle' name='fc-tabs' class='fc-tab-input sr-only' />

      <div class='fc-tabs flex gap-1.5 p-1 rounded-xl mb-7 fc-tabs-bg'>
        <label for='fc-tab-ficha' class='fc-tab-label fc-label-ficha flex-1 text-center cursor-pointer rounded-lg py-2.5 px-3 text-xs font-bold uppercase tracking-wide transition-all duration-200'>
          Local · 350 €
        </label>
        <label for='fc-tab-bundle' class='fc-tab-label fc-label-bundle flex-1 text-center cursor-pointer rounded-lg py-2.5 px-3 text-xs font-bold uppercase tracking-wide transition-all duration-200'>
          Total · 550 €
        </label>
      </div>

      <div class='fc-panels'>

        <div class='fc-panel-ficha space-y-3'>
          {categories.map((category, catIdx) => (
            <div class='rounded-xl overflow-hidden fc-card-local'>
              <div class='flex items-center gap-2 px-5 py-3 fc-card-header-local'>
                <span
                  class='text-xs font-bold font-heading tabular-nums'
                  style='color: color-mix(in srgb, var(--color-base) 25%, transparent);'
                  aria-hidden='true'>
                  {String(catIdx + 1).padStart(2, '0')}
                </span>
                <span
                  class='text-xs font-bold tracking-[0.14em] uppercase'
                  style='color: color-mix(in srgb, var(--color-base) 60%, transparent);'>
                  {category.name}
                </span>
              </div>
              <ul class='fc-card-list-local'>
                {category.features.map(feature => (
                  <li class='flex items-center justify-between py-3 px-5 gap-4'>
                    <span
                      class='text-sm'
                      style='color: color-mix(in srgb, var(--color-base) 55%, transparent);'>
                      {feature.name}
                    </span>
                    <span class='shrink-0'>
                      <Fragment set:html={renderFicha(feature.ficha)} />
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class='fc-panel-bundle space-y-3'>
          {categories.map((category, catIdx) => (
            <div class='rounded-xl overflow-hidden fc-card-bundle'>
              <div class='flex items-center gap-2 px-5 py-3 fc-card-header-bundle'>
                <span
                  class='text-xs font-bold font-heading tabular-nums text-sage'
                  style='opacity: 0.5;'
                  aria-hidden='true'>
                  {String(catIdx + 1).padStart(2, '0')}
                </span>
                <span
                  class='text-xs font-bold tracking-[0.14em] uppercase'
                  style='color: color-mix(in srgb, var(--color-base) 75%, transparent);'>
                  {category.name}
                </span>
              </div>
              <ul class='fc-card-list-bundle'>
                {category.features.map(feature => (
                  <li class='flex items-center justify-between py-3 px-5 gap-4'>
                    <span
                      class='text-sm'
                      style='color: color-mix(in srgb, var(--color-base) 65%, transparent);'>
                      {feature.name}
                    </span>
                    <span class='shrink-0'>
                      <Fragment set:html={renderBundle(feature.bundle)} />
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

      </div>
    </div>

  </div>
</div>

<style>
  .fc-tab-input { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

  .fc-tabs-bg {
    background: color-mix(in srgb, var(--color-base) 8%, transparent);
  }

  .fc-tab-label {
    color: color-mix(in srgb, var(--color-base) 45%, transparent);
  }

  #fc-tab-ficha:checked  ~ .fc-tabs .fc-label-ficha,
  #fc-tab-bundle:checked ~ .fc-tabs .fc-label-bundle {
    background: color-mix(in srgb, var(--color-sage) 15%, transparent);
    color: var(--color-base);
  }

  .fc-panel-ficha,
  .fc-panel-bundle { display: none; }

  #fc-tab-ficha:checked  ~ .fc-panels .fc-panel-ficha  { display: block; }
  #fc-tab-bundle:checked ~ .fc-panels .fc-panel-bundle { display: block; }

  /* Table row borders and hover */
  .feature-row {
    border-bottom: 1px solid color-mix(in srgb, var(--color-base) 8%, transparent);
  }
  .feature-row:hover {
    background: color-mix(in srgb, var(--color-base) 3%, transparent);
  }
  .feature-label {
    color: color-mix(in srgb, var(--color-base) 55%, transparent);
  }
  .feature-row:hover .feature-label {
    color: color-mix(in srgb, var(--color-base) 75%, transparent);
  }
  .bundle-cell {
    background: color-mix(in srgb, var(--color-sage) 5%, transparent);
  }
  .feature-row:hover .bundle-cell {
    background: color-mix(in srgb, var(--color-sage) 9%, transparent);
  }

  /* Mobile cards */
  .fc-card-local {
    background: color-mix(in srgb, var(--color-base) 6%, transparent);
  }
  .fc-card-header-local {
    border-bottom: 1px solid color-mix(in srgb, var(--color-base) 8%, transparent);
  }
  .fc-card-list-local > li + li {
    border-top: 1px solid color-mix(in srgb, var(--color-base) 6%, transparent);
  }

  .fc-card-bundle {
    background: color-mix(in srgb, var(--color-sage) 8%, transparent);
    outline: 1px solid color-mix(in srgb, var(--color-sage) 15%, transparent);
  }
  .fc-card-header-bundle {
    border-bottom: 1px solid color-mix(in srgb, var(--color-sage) 15%, transparent);
  }
  .fc-card-list-bundle > li + li {
    border-top: 1px solid color-mix(in srgb, var(--color-sage) 10%, transparent);
  }
</style>
