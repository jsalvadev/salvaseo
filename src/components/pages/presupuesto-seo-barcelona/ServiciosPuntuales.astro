---
import Upheading from '../../Upheading.astro'
import WhatsAppButton from '../../WhatsAppButton.astro'

interface PuntualService {
  name: string
  price: string
  description: string
}

const services: PuntualService[] = [
  {
    name: 'Auditoría SEO local',
    price: '250 €',
    description: 'Análisis de ficha GBP, web, citaciones, posiciones en Maps y competencia. Entregable: documento con diagnóstico + plan de acción priorizado.',
  },
  {
    name: 'Optimización de Google Business Profile',
    price: '200 €',
    description: 'Optimización one-shot de la ficha: categorías, descripción, fotos, atributos, horarios, productos/servicios y primeras publicaciones.',
  },
  {
    name: 'Consultoría SEO por hora',
    price: '45 €/hora',
    description: 'Sesiones de asesoramiento sobre cualquier tema SEO. Mínimo 2 horas por sesión.',
  },
  {
    name: 'Diseño web SEO (1 página)',
    price: '650 €',
    description: 'Landing page o web one-page diseñada y optimizada para SEO desde cero. Responsive y con formulario de contacto.',
  },
  {
    name: 'Diseño web SEO (hasta 5 páginas)',
    price: '1.500 €',
    description: 'Web completa con hasta 5 páginas, optimizada para SEO, responsive, con formulario de contacto.',
  },
]

const extras = [
  { name: 'Contenido adicional (1 artículo/página)', price: '100 €' },
  { name: 'Publicaciones extra en GBP (4 más/mes)', price: '60 €/mes' },
  { name: 'Landing page nueva optimizada', price: '400 €' },
  { name: 'Rediseño web completo', price: 'Presupuesto a medida' },
  { name: 'Sesión de consultoría adicional (1h)', price: '45 €' },
  { name: 'Informe de competencia extra', price: '120 €' },
]
---

<div class='py-24 sm:py-32'>
  <div class='container-site'>
    <div class='mx-auto max-w-4xl'>
      <Upheading as='h2' text='Precio auditoría SEO y servicios puntuales' />
      <p class='mt-2 text-4xl font-semibold tracking-tight text-pretty text-cream sm:text-5xl'>
        Acciones puntuales con precio cerrado
      </p>
      <p class='mt-6 text-lg text-cream/70'>
        Desde el precio de una auditoría SEO hasta consultoría por horas. Intervenciones profesionales fuera del plan mensual — en muchos casos, el primer paso antes de iniciar un proyecto de posicionamiento recurrente.
      </p>
    </div>

    <!-- Servicios puntuales -->
    <div class='mx-auto mt-16 max-w-4xl'>
      <div class='overflow-hidden rounded-xl border border-surface/10'>
        <table class='min-w-full divide-y divide-charcoal/10'>
          <thead>
            <tr class='bg-surface/5'>
              <th scope='col' class='py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-cream sm:pl-6'>Servicio</th>
              <th scope='col' class='px-3 py-3.5 text-left text-sm font-semibold text-cream'>Precio</th>
            </tr>
          </thead>
          <tbody class='divide-y divide-charcoal/5'>
            {services.map((service) => (
              <tr class='hover:bg-surface/5 transition-colors'>
                <td class='py-4 pr-3 pl-4 sm:pl-6'>
                  <div class='text-sm font-medium text-cream'>{service.name}</div>
                  <div class='mt-1 text-sm text-cream/60'>{service.description}</div>
                </td>
                <td class='whitespace-nowrap px-3 py-4 text-sm font-semibold text-cream'>{service.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Extras / Add-ons -->
    <div class='mx-auto mt-16 max-w-4xl'>
      <Upheading as='h3' text='Add-ons disponibles' />
      <p class='mt-4 text-sm text-cream/60'>
        Disponibles para clientes de cualquier paquete mensual.
      </p>
      <div class='mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2'>
        {extras.map((extra) => (
          <div class='flex items-center justify-between rounded-lg border border-surface/10 px-4 py-3'>
            <span class='text-sm text-cream/70'>{extra.name}</span>
            <span class='ml-4 shrink-0 text-sm font-semibold text-teal'>{extra.price}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class='mx-auto mt-12 max-w-4xl text-center'>
      <WhatsAppButton text='Analiza mi web' />
    </div>
  </div>
</div>
