---
import { buildWhatsAppHref } from '../../../data/site'

const waHref = buildWhatsAppHref("Hola Salva, me gustaría que analizaras mi página web gratuitamente.")

const fakeTestimonials = [
  { name: "María G.", business: "Tienda online", text: "¡Salva es el mejor! En 3 meses mi web está la primera en Google. ¡Os lo juro!" },
  { name: "Carlos M.", business: "Restaurante", text: "Hace lo que dice y funciona de verdad. Ahora todo el mundo encuentra mi negocio en internet." },
  { name: "Laura B.", business: "Clínica dental", text: "El mejor de Barcelona. Rápido, claro y con resultados. ¡100% recomendado!" },
]


---

<section class='relative overflow-hidden bg-white py-24 md:py-32'>

  <!-- Graph-paper grid watermark -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='
      background-image:
        linear-gradient(rgba(26,60,74,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(26,60,74,0.025) 1px, transparent 1px);
      background-size: 40px 40px;
    '
  ></div>

  <!-- Left accent bar (sky) -->
  <div
    class='absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-40 bg-sky-500 rounded-r-full pointer-events-none'
    aria-hidden='true'
  ></div>

  <!-- Titan One watermark — large ? -->
  <div
    class='pointer-events-none absolute -right-6 bottom-0 select-none leading-none hidden lg:block'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(12rem, 22vw, 20rem); color: rgba(14,165,233,0.04); line-height: 1; transform: rotate(6deg);'>
    ?
  </div>

  <div class='mx-auto max-w-7xl px-6 lg:px-8'>

    <!-- ── Header ──────────────────────────────────────────── -->
    <div class='max-w-3xl' data-animate>

      <!-- Eyebrow -->
      <div class='flex items-center gap-3 mb-6'>
        <span class='h-px w-8 bg-sky-500 flex-shrink-0'></span>
        <span class='text-xs font-semibold tracking-[0.18em] uppercase text-sky-600'>
          ¿Por qué creerme?
        </span>
      </div>

      <!-- Headline: "Aquí no hay [strikethrough] testimonios" -->
      <h2
        class='text-4xl sm:text-5xl lg:text-[3.5rem] tracking-tight text-petrol-900 leading-[1.1]'
        style='font-family: "Titan One", cursive;'>
        Aquí no hay<br />
        <span class='relative inline-block'>
          testimonios
          <!-- Orange strikethrough bar -->
          <span
            class='absolute left-0 right-0'
            aria-hidden='true'
            style='top: 50%; height: 7px; background: linear-gradient(90deg, #f97316, #fb923c); transform: rotate(-1.4deg) translateY(-50%); border-radius: 2px;'>
          </span>
        </span>
      </h2>

      <p class='mt-4 text-base/7 text-petrol-600 font-medium max-w-lg'>
        Y hay un motivo muy claro para eso.
      </p>
    </div>

    <!-- ── Two-column body ──────────────────────────────────── -->
    <div class='mt-16 grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-12 lg:gap-20 items-start'>

      <!-- ── LEFT: Fake testimonials zone ─────────────────── -->
      <div data-animate-direction='left'>

        <!-- Zone label -->
        <p class='text-sm font-semibold text-petrol-700 mb-1'>
          Muchas páginas de SEO tienen esto:
        </p>
        <p class='text-xs text-petrol-400 mb-4 leading-relaxed'>
          Personas que probablemente no conoces, no vas a conocer nunca,
          y cuya página web ni siquiera puedes buscar.
        </p>

        <!-- Fake testimonial cards with stamp overlay -->
        <div class='space-y-3'>
          {fakeTestimonials.map((t, i) => (
            <div
              class='relative rounded-xl p-5 bg-petrol-50 border border-petrol-100 overflow-hidden'
              style={`opacity: ${0.55 - i * 0.08}; filter: grayscale(0.7);`}
              aria-hidden='true'>

              <!-- Stamp — esquina superior derecha -->
              <div
                class='absolute top-3 right-3 pointer-events-none'
                style='z-index: 2; transform: rotate(6deg);'>
                <div style='
                  border: 2px solid rgba(239,68,68,0.6);
                  border-radius: 3px;
                  padding: 2px 8px;
                  color: rgba(239,68,68,0.6);
                  font-family: "Titan One", cursive;
                  font-size: 0.6rem;
                  letter-spacing: 0.18em;
                  text-transform: uppercase;
                  white-space: nowrap;
                  background: rgba(255,255,255,0.7);
                '>
                  DUDOSO
                </div>
              </div>

              <!-- Stars -->
              <div class='flex gap-0.5 mb-3'>
                {[1,2,3,4,5].map(() => (
                  <svg class='h-3.5 w-3.5 text-amber-400' fill='currentColor' viewBox='0 0 20 20'>
                    <path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' />
                  </svg>
                ))}
              </div>

              <!-- Quote text -->
              <p class='text-sm text-petrol-700 italic leading-relaxed'>&ldquo;{t.text}&rdquo;</p>

              <!-- Name + business -->
              <div class='mt-3 flex items-center gap-2'>
                <div class='shrink-0 size-7 rounded-full bg-petrol-200 flex items-center justify-center'>
                  <span class='text-[0.6rem] font-bold text-petrol-500'>{t.name.charAt(0)}</span>
                </div>
                <div>
                  <p class='text-xs font-semibold text-petrol-600'>{t.name}</p>
                  <p class='text-[0.65rem] text-petrol-400'>{t.business}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Disclaimer note -->
        <p class='mt-4 text-[0.68rem] text-petrol-400 text-center italic leading-relaxed'>
          Estos no son reales. No hay forma de comprobar si son verdad.
        </p>
      </div>

      <!-- ── RIGHT: Manifesto + offer ──────────────────────── -->
      <div class='space-y-8' data-animate-direction='right'>

        <!-- Manifesto body -->
        <div class='space-y-5 text-base/7 text-petrol-700 text-pretty'>
          <p>
            Lo que sí puedes hacer es mandarme tu página — gratis. Yo te mando
            un análisis hecho con herramientas SEO reales donde vas a ver,
            <strong class='font-semibold text-petrol-900'>
              con todo lujo de detalles y de forma muy clara,
            </strong>
            por qué Google no te muestra y qué habría que hacer para cambiar eso.
          </p>
          <p>
            Y si después de leerlo no estás
            <strong class='font-semibold text-petrol-900'>
              deseando llamarme o enviarme ese WhatsApp
            </strong>
            — no pasa nada. Solo habrás tardado 30 segundos en escribirme.
          </p>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href={waHref}
          target='_blank'
          rel='noopener noreferrer'
          class='group flex items-center justify-center gap-3 w-full rounded-xl bg-[#25D366] hover:bg-[#20c05c] active:bg-[#1aad52] text-white font-bold text-base px-6 py-4 transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366]'
          style='box-shadow: 0 4px 20px rgba(37,211,102,0.28);'>
          <!-- WhatsApp icon -->
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='h-5 w-5 shrink-0'
            fill='currentColor'
            viewBox='0 0 24 24'
            aria-hidden='true'>
            <path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z'/>
            <path d='M12 0C5.374 0 0 5.373 0 12c0 2.117.549 4.107 1.51 5.84L.057 23.032a.75.75 0 0 0 .921.916l5.242-1.437A11.945 11.945 0 0 0 12 24c6.626 0 12-5.373 12-12S18.626 0 12 0zm0 21.75a9.75 9.75 0 0 1-4.953-1.347l-.355-.21-3.683 1.01.998-3.618-.23-.374A9.75 9.75 0 0 1 12 2.25c5.385 0 9.75 4.365 9.75 9.75s-4.365 9.75-9.75 9.75z'/>
          </svg>
          Analiza mi página — es gratis
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='h-4 w-4 shrink-0 transition-transform duration-200 group-hover:translate-x-1'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2.5'
            aria-hidden='true'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3' />
          </svg>
        </a>

        <!-- No risk note -->
        <p class='text-center text-xs text-petrol-400 leading-relaxed'>
          No pierdas el tiempo con testimonios que no puedes verificar.<br />
          <strong class='text-petrol-500'>Mándame tu página. Es gratis. Y si no te sorprende, no me contratas.</strong>
        </p>

      </div>
    </div>
  </div>
</section>
