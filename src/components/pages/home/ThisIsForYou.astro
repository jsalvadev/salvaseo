---
import WhatsAppButton from '../../WhatsAppButton.astro'
---

<section class='relative overflow-hidden bg-gradient-to-br from-sage to-surface py-24 md:py-32'>

  <!-- Dot-grid texture overlay -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'>
  </div>

  <!-- Large ghosted watermark -->
  <div class="font-heading pointer-events-none absolute -left-10 top-1/2 -translate-y-1/2 select-none leading-none"
    aria-hidden='true'>
    TÚ
  </div>

  <!-- Radial ambient top-right -->
  <div
    class='pointer-events-none absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full'
    aria-hidden='true'>
  </div>

  <!-- Top / bottom hairline accents -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/35 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-[1280px] px-5'>
    <div class='grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-20 items-start'>

      <!-- ── LEFT: card list ───────────────────────────────────────── -->
      <ul class='flex flex-col gap-3 mt-2'>

        {[
          {
            num: '01',
            heading: 'Tu negocio está en Barcelona',
            body: 'Clínicas, talleres, despachos, empresas locales. Tienes una web y quieres aparecer antes que tu competencia en Google.',
          },
          {
            num: '02',
            heading: 'Llevas tiempo pagando anuncios sin resultados duraderos',
            body: 'Cada mes pagas por clics que no se convierten, y en cuanto paras la campaña desapareces.',
          },
          {
            num: '03',
            heading: 'Tu web no aparece ni en la segunda página',
            body: 'Buscas tu propio negocio en Google y tienes que llegar muy abajo para encontrarte.',
          },
          {
            num: '04',
            heading: 'Tu ficha de Google Business Profile no rinde',
            body: 'Apareces en Maps pero casi no recibes llamadas, tus reseñas están estancadas.',
          },
        ].map((item) => (
          <li
            data-animate
            class='esto-card group relative rounded-xl border border-cream/20 bg-cream/5 px-6 py-5 transition-all duration-300 hover:border-cream/35 hover:bg-cream/10 overflow-hidden cursor-default'>

            <!-- Card left accent bar (appears on hover) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-cream scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>

            <!-- Content row -->
            <div class='relative flex items-start gap-4'>

              <!-- Check badge -->
              <div class='shrink-0 mt-0.5 flex h-5 w-5 items-center justify-center rounded-full bg-cream/15 ring-1 ring-cream/30 transition-all duration-300 group-hover:bg-cream/25 group-hover:ring-cream/50'>
                <svg
                  class='h-2.5 w-2.5 text-cream'
                  viewBox='0 0 12 10'
                  fill='none'
                  aria-hidden='true'>
                  <path
                    d='M1 5l3.5 3.5L11 1'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              </div>

              <!-- Text -->
              <div class='min-w-0'>
                <p class='font-heading text-p font-bold text-white mb-1.5 leading-snug'>
                  {item.heading}
                </p>
                <p class='text-p text-cream/80 leading-relaxed text-pretty'>
                  {item.body}
                </p>
              </div>

            </div>
          </li>
        ))}

      </ul>

      <!-- ── RIGHT: sticky headline block ────────────────────────────── -->
      <div class='lg:sticky lg:top-28 text-right'>

        <div data-animate class='mb-8'>
          <h2 class='text-sm italic font-bold text-cream'>Consultor SEO cerca de ti</h2>
        </div>

        <p data-animate class='font-heading text-h2 font-bold leading-tight text-white tracking-tight'>
          Esto es para ti <span class='text-cream'>si.</span>
        </p>

        <div data-animate class='mt-6 flex items-center justify-end'>
          <div class='h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35'></div>
          <div class='h-px w-10 bg-cream/60'></div>
        </div>

        <!-- CTA -->
        <div data-animate class='mt-10 flex justify-end'>
          <a href="#" class="rounded-md bg-cream px-3.5 py-2.5 text-sm font-bold text-base shadow-xs hover:bg-cream/90">Reserva tu llamada</a>
        </div>

        <!-- Decorative vertical rule (desktop) -->
        <div
          class='hidden lg:block mt-12 w-px h-20 bg-gradient-to-b from-sand/30 to-transparent'
          aria-hidden='true'>
        </div>
      </div>

    </div>
  </div>
</section>
