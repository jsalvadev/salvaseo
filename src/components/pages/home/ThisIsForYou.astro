---
import CalButton from '../../CalButton.astro'
---

<section class='relative overflow-hidden py-24 md:py-32' style='background: radial-gradient(ellipse 70% 60% at 0% 100%, rgba(42,55,44,0.85) 0%, transparent 60%), radial-gradient(ellipse 55% 50% at 100% 0%, rgba(124,140,118,0.45) 0%, transparent 55%), linear-gradient(155deg, #4e5d52 0%, #697565 55%, #728070 100%);'>

  <!-- Dot-grid texture overlay -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    class='dot-grid-32'>
  </div>

  <!-- Large ghosted watermark -->
  <div
    class='font-heading pointer-events-none absolute -left-10 top-1/2 -translate-y-1/2 select-none leading-none'
    aria-hidden='true'
    style='font-size: clamp(14rem, 28vw, 24rem); color: rgba(236,223,204,0.08); line-height: 1; white-space: nowrap;'>
    TÚ
  </div>

  <!-- Radial ambient top-right -->
  <div
    class='pointer-events-none absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(52,101,109,0.05) 0%, transparent 65%);'>
  </div>

  <!-- Top / bottom hairline accents -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cream/35 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-cream/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-[1280px] px-5'>
    <div class='grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-20 items-start'>

      <!-- ── LEFT: card list ───────────────────────────────────────── -->
      <ul class='flex flex-col gap-3 mt-2 lg:order-1'>

        {[
          {
            num: '01',
            heading: 'Tu negocio está en Barcelona',
            body: 'Instaladores, fontaneros, pintores, cerrajeros, jardineros. Tienes web y quieres que te llamen desde Google.',
          },
          {
            num: '02',
            heading: 'Dependes del boca a boca y no puedes controlarlo.',
            body: 'Dependes del boca a boca. Cuando para, para el trabajo.',
          },
          {
            num: '03',
            heading: 'Tu web no aparece ni en la segunda página',
            body: 'Buscas tu propio negocio en Google y tienes que llegar muy abajo para encontrarte.',
          },
          {
            num: '04',
            heading: 'Tu ficha de Google Maps no funciona',
            body: 'Apareces, pero casi no te llaman y llevas meses sin reseñas nuevas.',
          },
        ].map((item) => (
          <li
            data-animate
            class='relative rounded-xl border border-cream/20 bg-cream/5 px-6 py-5 transition-all duration-300 hover:border-cream/30 hover:bg-cream/10 overflow-hidden cursor-default'>

            <!-- Card left accent bar (appears on hover) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-cream scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>


            <!-- Content row -->
            <div class='relative flex items-start gap-4'>

              <!-- Check badge -->
              <div class='shrink-0 mt-0.5 flex h-5 w-5 items-center justify-center rounded-full bg-cream/12 ring-1 ring-cream/25 transition-all duration-300 group-hover:bg-cream/22 group-hover:ring-cream/50'>
                <svg
                  class='size-3 text-cream'
                  viewBox='0 0 12 10'
                  fill='none'
                  aria-hidden='true'>
                  <path
                    d='M1.5 5.5l2 2L11 1.5'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              </div>

              <!-- Text -->
              <div class='min-w-0'>
                <p class='text-base font-bold text-cream/90 mb-1.5 leading-snug transition-colors duration-300 group-hover:text-cream'>
                  {item.heading}
                </p>
                <p class='text-base text-cream/75 leading-relaxed text-pretty transition-colors duration-300 group-hover:text-cream/85'>
                  {item.body}
                </p>
              </div>

            </div>
          </li>
        ))}

      </ul>

      <!-- ── RIGHT: sticky headline block ────────────────────────────── -->
      <div class='lg:sticky lg:top-28 lg:order-2 lg:text-right'>

        <h2 class='text-xs font-bold tracking-[0.18em] uppercase text-cream mb-8'>
          Consultor SEO cerca de ti
        </h2>

        <p
          data-animate
          class='font-heading text-h2 font-normal leading-[0.9] tracking-tight'>
          <span class='block text-white mb-1'>
            Ahora mismo,
          </span>
          <span class='block text-cream'>
            ese cliente llama a otro<span class='text-cream'>.</span>
          </span>
        </p>

        <!-- Animated underline rule -->
        <div data-animate class='mt-6 flex items-center lg:justify-end'>
          <div class='h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35'></div>
          <div class='h-px w-10 bg-cream/60'></div>
        </div>

        <!-- CTA -->
        <div data-animate class='mt-10 lg:flex lg:justify-end'>
          <CalButton
            text='Agenda una llamada gratis'
            variant='cream'
            class='px-6 py-3 text-sm font-bold'
          />
        </div>

        <!-- Decorative vertical rule (desktop) -->
        <div
          class='hidden lg:block mt-12 w-px h-20 bg-gradient-to-b from-cream/30 to-transparent ml-auto'
          aria-hidden='true'>
        </div>
      </div>

    </div>
  </div>
</section>