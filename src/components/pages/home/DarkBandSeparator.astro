---
import { Users, BadgeCheck, CalendarClock, TrendingUp } from '@lucide/astro'
---

<div class='bg-petrol-900 py-12'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <dl data-animate class='grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4'>
      <div class='flex flex-col items-center gap-3 text-center'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sky-500/10 ring-1 ring-sky-500/20'>
          <Users class='size-5 text-sky-400' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>10+ negocios</dt>
        <dd class='text-sm text-petrol-100'>ya posicionados</dd>
      </div>
      <div class='flex flex-col items-center gap-3 text-center'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sky-500/10 ring-1 ring-sky-500/20'>
          <BadgeCheck class='size-5 text-sky-400' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Auditoría gratuita</dt>
        <dd class='text-sm text-petrol-100'>valorada en 200 €</dd>
      </div>
      <div class='flex flex-col items-center gap-3 text-center'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sky-500/10 ring-1 ring-sky-500/20'>
          <CalendarClock class='size-5 text-sky-400' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Sin contratos</dt>
        <dd class='text-sm text-petrol-100'>de permanencia</dd>
      </div>
      <div class='flex flex-col items-center gap-3 text-center'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sky-500/10 ring-1 ring-sky-500/20'>
          <TrendingUp class='size-5 text-sky-400' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Resultados en 3-6 meses</dt>
        <dd class='text-sm text-petrol-100'>según tu sector</dd>
      </div>
    </dl>
  </div>
</div>
