---
import { Users, BadgeCheck, CalendarClock, TrendingUp } from '@lucide/astro'
---

<div class='relative py-16 lg:py-20 overflow-hidden bg-surface'>
  <div class='pointer-events-none absolute inset-0 opacity-[0.04]' aria-hidden='true'></div>
  <div class='relative container-site'>
    <dl data-animate class='grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4'>
      <div class='rounded-xl px-6 py-8 flex flex-col items-center gap-3 text-center bg-white-overlay'>
        <div class='flex size-10 items-center justify-center rounded-full bg-cream-10 border-cream-20'>
          <Users class='size-5 text-cream' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Trato directo</dt>
        <dd class='text-sm text-white-75'>sin intermediarios</dd>
      </div>
      <div class='rounded-xl px-6 py-8 flex flex-col items-center gap-3 text-center bg-white-overlay'>
        <div class='flex size-10 items-center justify-center rounded-full bg-cream-10 border-cream-20'>
          <BadgeCheck class='size-5 text-cream' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Auditoría gratuita</dt>
        <dd class='text-sm text-white-75'>valorada en <span class='text-cream font-semibold'>200 €</span></dd>
      </div>
      <div class='rounded-xl px-6 py-8 flex flex-col items-center gap-3 text-center bg-white-overlay'>
        <div class='flex size-10 items-center justify-center rounded-full bg-cream-10 border-cream-20'>
          <CalendarClock class='size-5 text-cream' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Sin contratos</dt>
        <dd class='text-sm text-white-75'>de permanencia</dd>
      </div>
      <div class='rounded-xl px-6 py-8 flex flex-col items-center gap-3 text-center bg-white-overlay'>
        <div class='flex size-10 items-center justify-center rounded-full bg-cream-10 border-cream-20'>
          <TrendingUp class='size-5 text-cream' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Resultados <span class='text-cream'>3-6</span> meses</dt>
        <dd class='text-sm text-white-75'>según tu sector</dd>
      </div>
    </dl>
  </div>
</div>