---
import { Users, BadgeCheck, CalendarClock, TrendingUp } from '@lucide/astro'
---

<div class='relative bg-charcoal py-16 lg:py-20 overflow-hidden'>
  <!-- diagonal texture -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.04]'
    style='background-image: repeating-linear-gradient(135deg, rgba(250,234,177,0.15) 0 1px, transparent 1px 16px);'
    aria-hidden='true'></div>
  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>
    <dl data-animate class='grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4'>
      <div class='rounded-xl bg-white/5 backdrop-blur-sm border border-white/5 px-6 py-8 flex flex-col items-center gap-3 text-center transition-colors hover:bg-white/[0.08]'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sand/10 ring-1 ring-sand/20'>
          <Users class='size-5 text-sand' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Trato directo</dt>
        <dd class='text-sm text-white/75'>sin intermediarios</dd>
      </div>
      <div class='rounded-xl bg-white/5 backdrop-blur-sm border border-white/5 px-6 py-8 flex flex-col items-center gap-3 text-center transition-colors hover:bg-white/[0.08]'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sand/10 ring-1 ring-sand/20'>
          <BadgeCheck class='size-5 text-sand' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Auditoría gratuita</dt>
        <dd class='text-sm text-white/75'>valorada en <span class='text-sand font-semibold'>200 €</span></dd>
      </div>
      <div class='rounded-xl bg-white/5 backdrop-blur-sm border border-white/5 px-6 py-8 flex flex-col items-center gap-3 text-center transition-colors hover:bg-white/[0.08]'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sand/10 ring-1 ring-sand/20'>
          <CalendarClock class='size-5 text-sand' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Sin contratos</dt>
        <dd class='text-sm text-white/75'>de permanencia</dd>
      </div>
      <div class='rounded-xl bg-white/5 backdrop-blur-sm border border-white/5 px-6 py-8 flex flex-col items-center gap-3 text-center transition-colors hover:bg-white/[0.08]'>
        <div class='flex size-10 items-center justify-center rounded-full bg-sand/10 ring-1 ring-sand/20'>
          <TrendingUp class='size-5 text-sand' aria-hidden='true' />
        </div>
        <dt class='text-xl font-semibold text-white'>Resultados <span class='text-sand'>3-6</span> meses</dt>
        <dd class='text-sm text-white/75'>según tu sector</dd>
      </div>
    </dl>
  </div>
</div>
