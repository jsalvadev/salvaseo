---
import Upheading from '../../Upheading.astro'
import { MapPin, Handshake, Building2 } from '@lucide/astro'

const profiles = [
  {
    icon: MapPin,
    watermark: 'LOCAL',
    accent: 'sky',
    heading: 'Negocios que viven de su zona',
    body: `Clínicas, talleres, despachos, empresas locales… Si tus clientes están
      cerca, una <a href='/seo-local-barcelona/' class='text-sky-a11y font-medium hover:text-sky-600 underline decoration-sky-200 underline-offset-2 transition-colors'>estrategia de SEO local en Barcelona</a> transforma tu ficha de Google en un canal constante de llamadas y solicitudes de presupuesto.`,
  },
  {
    icon: Handshake,
    watermark: 'DIRECTO',
    accent: 'orange',
    heading: 'Personas que se implican',
    body: `Los mejores resultados llegan cuando el dueño del negocio <strong class='font-semibold text-petrol-900'>conoce su mercado, participa en las decisiones estratégicas y valora la transparencia en el proceso</strong>.`,
  },
  {
    icon: Building2,
    watermark: 'BCN',
    accent: 'gradient',
    heading: 'Barcelona y alrededores',
    body: `El <a href='/posicionamiento-web-barcelona/' class='text-sky-a11y font-medium hover:text-sky-600 underline decoration-sky-200 underline-offset-2 transition-colors'>servicio de posicionamiento web en Barcelona</a> se complementa con trabajo de proximidad: visitar tu local y analizar la competencia de tu barrio <strong class='font-semibold text-petrol-900'>sobre el terreno</strong>.`,
  },
]
---

<section class='relative overflow-hidden bg-warm-white py-24 sm:py-32'>

  <!-- Subtle dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0 opacity-60'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(26,60,74,0.055) 1px, transparent 1px); background-size: 32px 32px;'>
  </div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <!-- Section header -->
    <div
      data-animate-direction='left'
      class='mb-16 md:mb-20 max-w-2xl'>
      <Upheading
        as='h2'
        text='Especialista SEO en Barcelona para negocios locales'
        color='var(--color-sky-500)'
      />
      <p
        class='mt-2 tracking-tight text-petrol-900 text-pretty'
        style='font-family: "Titan One", cursive; font-size: clamp(1.55rem, 3.1vw, 2.49rem); line-height: 1.05; font-weight: 400;'>
        Esto es para ti si.
      </p>
      <p class='mt-5 text-lg/7 text-petrol-700 max-w-lg text-pretty'>
        Cada proyecto entra con un objetivo claro de facturación. Sin ese foco,
        el SEO no convierte.
      </p>
    </div>

    <!-- Profile rows -->
    <div class='flex flex-col divide-y divide-petrol-100 border-t border-petrol-100'>
      {
        profiles.map(({ icon: Icon, watermark, accent, heading, body }) => (
          <div
            data-animate
            class='group relative flex items-start gap-6 py-10 md:py-12 overflow-hidden transition-colors duration-300 hover:bg-petrol-50/60 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 rounded-xl'>

            <!-- Watermark word -->
            <div
              class='pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 select-none leading-none transition-all duration-500 opacity-[0.028] group-hover:opacity-[0.06]'
              aria-hidden='true'
              style={`font-family: "Titan One", cursive; font-size: clamp(5rem, 13vw, 11rem); line-height: 1; color: rgba(52,101,109,0.06);`}>
              {watermark}
            </div>

            <!-- Left accent bar -->
            <div
              class='flex-shrink-0 mt-1 w-1 self-stretch rounded-full min-h-[3rem] bg-teal'
              aria-hidden='true'
            />

            <!-- Icon -->
            <div
              class='flex-shrink-0 mt-0.5 flex h-10 w-10 items-center justify-center rounded-xl bg-teal/10 text-teal'>
              <Icon class='size-5' aria-hidden='true' />
            </div>

            <!-- Text -->
            <div class='relative flex-1 min-w-0'>
              <h3 class='text-xl font-semibold tracking-tight text-petrol-900 mb-3 text-pretty'>
                {heading}
              </h3>
              <p class='text-base/7 text-petrol-700 text-pretty max-w-2xl' set:html={body} />
            </div>

          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div
      data-animate
      class='mt-12 flex flex-col sm:flex-row items-center gap-4'>
      <a
        href='#contacto'
        class='rounded-md bg-teal px-5 py-3 text-sm font-bold text-white shadow-sm hover:bg-[#3d7880] active:bg-[#2b565d] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal transition-all'>
        Quiero mi análisis gratuito
      </a>
      <p class='text-sm text-petrol-700'>Auditoría gratuita · Sin contratos de permanencia</p>
    </div>

  </div>
</section>
