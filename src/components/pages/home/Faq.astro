---
interface FaqItem {
  question: string
  answer: string
}

interface Props {
  upheading?: string
  heading?: string
  idPrefix?: string
  items?: FaqItem[]
}

const {
  upheading = 'CONSULTOR SEO: PREGUNTAS FRECUENTES',
  heading = 'Aún tienes',
  idPrefix = 'faq',
  items = [],
} = Astro.props
---

<div class="relative overflow-hidden bg-cream">
  <!-- Large ghosted watermark -->
  <div class="font-heading pointer-events-none absolute -left-6 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-base/[0.04]"
    aria-hidden='true'>
    ?
  </div>
  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 lg:py-40">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-xs font-bold tracking-[0.2em] uppercase text-base">{upheading}</h2>
      <p class="mt-5 font-heading text-h2 font-semibold tracking-tight text-gray-900">{heading} <span class="text-sage">dudas.</span></p>
      <div class="mt-6 flex items-center">
        <div class="h-px w-32 bg-gradient-to-r from-base/5 to-base/25"></div>
        <div class="h-px w-10 bg-base/50"></div>
      </div>
      <dl class="mt-16 divide-y divide-gray-900/10">
        {items.map((item, idx) => (
          <div class="py-6 first:pt-0 last:pb-0">
            <dt>
              <h3 class="font-heading text-h6 font-semibold">
                <button type="button" command="--toggle" commandfor={`${idPrefix}-${idx}`} class="flex w-full items-start justify-between text-left text-gray-900">
                  {item.question}
                  <span class="ml-6 flex h-7 items-center">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 in-aria-expanded:hidden">
                      <path d="M12 6v12m6-6H6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 not-in-aria-expanded:hidden">
                      <path d="M18 12H6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </button>
              </h3>
            </dt>
            <el-disclosure id={`${idPrefix}-${idx}`} hidden class="contents">
              <dd class="mt-2 pr-12">
                <div class="text-base/7 text-gray-600" set:html={item.answer} />
              </dd>
            </el-disclosure>
          </div>
        ))}
      </dl>
    </div>
  </div>
</div>