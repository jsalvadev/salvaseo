---
import Upheading from '../../Upheading.astro'
import type { FaqItem } from '../../../data/faq-home'

interface Props {
  upheading?: string
  upheadingColor?: string
  heading: string
  idPrefix?: string
  items: FaqItem[]
  class?: string
}

const { upheading, upheadingColor, heading, idPrefix = 'faq', items, class: className } = Astro.props
---

<div class:list={['bg-sandstone-soft', className]}>
  <div class='mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 lg:py-40'>
    <div class='mx-auto max-w-4xl'>
      {upheading && <Upheading as='h2' text={upheading} color={upheadingColor} />}
      <p
        class='text-4xl font-semibold tracking-tight text-petrol-900 sm:text-5xl'>
        {heading}
      </p>
      <div class='mt-16 space-y-4'>
        {items.map((item, i) => (
          <div class='bg-white rounded-lg border border-petrol-100 border-l-[3px] border-l-transparent p-5 transition-all duration-200 hover:border-petrol-200 hover:shadow-sm hover:border-l-orange-500'>
            <dt>
              <button
                type='button'
                command='--toggle'
                commandfor={`${idPrefix}-${i}`}
                class='flex w-full items-start justify-between text-left text-petrol-900'>
                <h3 class='text-base/7 font-semibold'>
                  <span class='text-orange-500 font-semibold font-mono text-sm mr-2'>{i + 1}.</span>
                  {item.question}
                </h3>
                <span class='ml-6 flex h-7 items-center'>
                  <svg
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.5'
                    aria-hidden='true'
                    class='size-5 transition-transform duration-200 in-aria-expanded:rotate-180'>
                    <path
                      d='M19.5 8.25l-7.5 7.5-7.5-7.5'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                    />
                  </svg>
                </span>
              </button>
            </dt>
            <el-disclosure
              id={`${idPrefix}-${i}`}
              hidden
              class='contents'>
              <dd class='mt-2 pr-12'>
                <Fragment set:html={item.answer} />
              </dd>
            </el-disclosure>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
