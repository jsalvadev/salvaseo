---
import type { FaqItem } from '../../../data/faq-home'

interface Props {
  upheading?: string
  upheadingColor?: string
  heading: string
  intro?: string
  idPrefix?: string
  items: FaqItem[]
  class?: string
}

const { upheading, heading, intro, idPrefix = 'faq', items, class: className } = Astro.props

function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim()
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(item.answer),
    },
  })),
}
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class:list={['relative overflow-hidden py-24 sm:py-32', className]}>

  <!-- Watermark -->
  <div
    class='font-display pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none text-[20rem] leading-none text-cream/[0.03]'
    aria-hidden='true'>?</div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <!-- Header -->
    <div class='mb-14' data-animate>
      {upheading && (
        <div class='flex items-center gap-3 mb-6'>
          <span class='block h-px w-10 bg-teal' aria-hidden='true'></span>
          <h2 class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-teal'>{upheading}</h2>
        </div>
      )}
      <p class='font-display text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] tracking-tight text-cream text-pretty'>
        {heading}<span class='text-teal'>.</span>
      </p>
      <div class='mt-5 flex items-center'>
        <div class='h-[3px] w-16 bg-teal rounded-full'></div>
        <div class='h-px flex-1 bg-gradient-to-r from-teal/30 to-transparent'></div>
      </div>
      {intro && (
        <p class='mt-5 max-w-2xl text-base/7 text-cream/70 text-pretty' set:html={intro} />
      )}
    </div>

    <!-- FAQ items -->
    <div class='divide-y divide-surface/40 max-w-3xl'>
      {items.map((item, i) => (
        <div class='py-6' data-animate>
          <div class='flex items-start gap-5'>
            <!-- Number -->
            <span class='shrink-0 pt-0.5 text-[0.6rem] font-bold tracking-[0.14em] uppercase text-teal/50 w-6 text-right'>
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class='flex-1 min-w-0'>
              <h3 class='text-base font-semibold text-cream leading-snug'>
                <button
                  type='button'
                  command='--toggle'
                  commandfor={`${idPrefix}-${i}`}
                  class='text-left w-full hover:text-cream/80 transition-colors cursor-pointer flex items-start justify-between gap-4 group'>
                  <span>{item.question}</span>
                  <svg
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.5'
                    aria-hidden='true'
                    class='shrink-0 mt-0.5 w-4 h-4 text-teal/50 transition-transform duration-200 group-[[open]]:rotate-180'>
                    <path d='M19.5 8.25l-7.5 7.5-7.5-7.5' stroke-linecap='round' stroke-linejoin='round' />
                  </svg>
                </button>
              </h3>
              <el-disclosure id={`${idPrefix}-${i}`} hidden class='contents'>
                <div class='mt-4 pl-0 text-base/7 text-cream/70 text-pretty'>
                  <Fragment set:html={item.answer} />
                </div>
              </el-disclosure>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
