---
import WhatsAppButton from '../../WhatsAppButton.astro'

const plans = [
  {
    id: 'ficha',
    label: 'Solo ficha de Google',
    price: 350,
    includes: 'Gestión completa de tu perfil en Google Maps',
  },
  {
    id: 'ficha-web',
    label: 'Ficha + Página web',
    price: 550,
    includes: 'Perfil de Google Maps y tu web optimizada',
  },
]
---

<section id='calculadora' class='relative overflow-hidden bg-charcoal py-24 md:py-32'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(255,255,255,0.028) 1px, transparent 1px); background-size: 32px 32px;'>
  </div>

  <!-- Top/bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/20 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/20 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <div class='lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-20 lg:items-start'>

      <!-- ══ LEFT COL — copy ══════════════════════════════════════════ -->
      <div data-animate class='relative mb-12 lg:mb-0 lg:sticky lg:top-[calc(var(--navbar-height,80px)+2rem)]'>

        <!-- Ghost watermark inside left col -->
        <div
          id='wm-ghost'
          class='pointer-events-none absolute -bottom-8 -left-6 select-none leading-none transition-all duration-500'
          aria-hidden='true'
          style='font-family: "Titan One", cursive; font-size: clamp(8rem, 18vw, 14rem); color: rgba(255,255,255,0.05); line-height: 1; white-space: nowrap;'>
          2×
        </div>

        <div class='flex items-center gap-3 mb-8'>
          <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
          <h2 class='label-section text-sand'>
            Precio del consultor SEO profesional
          </h2>
        </div>

        <p
          style='font-family: "Titan One", cursive;'
          class='leading-[0.92] tracking-tight'>
          <span class='block text-[clamp(1.55rem,3.1vw,2.49rem)] text-white/50 mb-1'>
            ¿Cuántos clientes necesitas
          </span>
          <span class='block text-[clamp(1.55rem,3.1vw,2.49rem)] text-white'>
            para que salga a cuenta<span class='text-sand'>?</span>
          </span>
        </p>

        <p class='mt-7 text-base md:text-lg text-white/70 leading-relaxed text-pretty max-w-[42ch]'>
          Lo primero que hacemos juntos es calcular
          <strong class='font-semibold text-white'>cuánto tiene que rentarte esto</strong>.
          Si lo que me pagas no trae más de lo que cuesta, no tiene ningún sentido seguir.
        </p>

        <!-- Bottom statement -->
        <div class='relative mt-8 rounded-xl bg-white/[0.06] border border-white/10 px-6 py-5 max-w-[42ch]'>
          <div
            class='pointer-events-none absolute left-0 top-4 bottom-4 w-[6px] bg-sand rounded-r-full'
            aria-hidden='true'>
          </div>
          <p class='text-base md:text-lg text-white leading-relaxed font-medium text-pretty'>
            Mi trabajo es traerte esos clientes y más.<br />
            Si no lo consigo, me lo dices y paramos.
          </p>
        </div>

      </div>

      <!-- ══ RIGHT COL — calculator ═══════════════════════════════════ -->
      <div>

        <!-- ── Plan selector ────────────────────────────────────────── -->
        <div data-animate class='mb-6 flex flex-col sm:flex-row gap-3'>
          {plans.map((plan, i) => (
            <button
              class='plan-btn relative flex-1 rounded-xl border px-5 py-4 text-left transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal/50'
              data-price={plan.price}
              data-active={i === 0 ? 'true' : 'false'}
              aria-pressed={i === 0 ? 'true' : 'false'}
              type='button'>
              <span class='plan-name block text-sm font-bold mb-1 leading-snug'>
                {plan.label}
              </span>
              <span class='plan-price block leading-none mb-2' style='font-family: "Titan One", cursive; font-size: 1.6rem;'>
                {plan.price}€<span class='text-sm font-normal'>/mes</span>
              </span>
              <span class='plan-desc block text-[0.7rem] leading-snug mb-2.5'>
                {plan.includes}
              </span>
              <!-- IVA badge -->
              <span class='plan-iva inline-flex items-center rounded-full border px-2 py-0.5 text-[0.6rem] font-semibold tracking-wide'>
                IVA incluido
              </span>
            </button>
          ))}
        </div>

        <!-- ── Calculator card ──────────────────────────────────────── -->
        <div data-animate class='relative rounded-2xl overflow-hidden border border-white/10 bg-white/[0.06]'>

          <!-- Card top accent -->
          <div class='absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-sand/30 via-sand to-sand/30'></div>

          <div class='relative p-8 md:p-10'>

            <!-- Slider row -->
            <div class='mb-10'>
              <label for='ticket-slider' class='block mb-3'>
                <span class='text-sm font-semibold text-white/45 uppercase tracking-[0.14em]'>
                  ¿Cuánto te paga de media un cliente tuyo?
                </span>
              </label>

              <div class='flex items-center gap-5 mb-4'>
                <input
                  id='ticket-slider'
                  type='range'
                  min='50'
                  max='2000'
                  step='50'
                  value='250'
                  class='ticket-slider flex-1 h-2 rounded-full appearance-none cursor-pointer'
                  aria-label='Cuánto te paga un cliente tuyo de media, en euros'
                />
                <div class='shrink-0 flex items-baseline gap-0.5 min-w-[5.5rem] justify-end'>
                  <span
                    id='ticket-display'
                    class='tabular-nums text-sand leading-none'
                    style='font-family: "Titan One", cursive; font-size: clamp(2rem, 3.5vw, 2.6rem);'>
                    250
                  </span>
                  <span class='text-lg font-bold text-sand/60 ml-0.5'>€</span>
                </div>
              </div>

              <!-- Slider scale hints -->
              <div class='flex justify-between text-[0.65rem] font-medium text-white/25 tabular-nums px-0.5'>
                <span>50€</span>
                <span>2.000€</span>
              </div>
            </div>

            <!-- Equation divider -->
            <div class='h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-10'></div>

            <!-- The equation -->
            <div class='grid grid-cols-[1fr_auto_1fr_auto_1fr] items-center gap-2 md:gap-4 mb-10'>

              <!-- Mi coste -->
              <div class='text-center'>
                <div class='label-ui text-white/35 mb-2'>Lo que me pagas</div>
                <div
                  id='fee-display'
                  class='tabular-nums text-white/80 leading-none transition-all duration-200'
                  style='font-family: "Titan One", cursive; font-size: clamp(1.6rem, 3vw, 2.4rem);'>
                  350
                </div>
                <div class='text-xs text-white/30 mt-1'>€/mes</div>
              </div>

              <!-- ÷ -->
              <div
                class='text-white/20 leading-none'
                style='font-family: "Titan One", cursive; font-size: clamp(1.4rem, 2.5vw, 2rem);'
                aria-hidden='true'>
                ÷
              </div>

              <!-- Ticket medio -->
              <div class='text-center'>
                <div class='label-ui text-white/35 mb-2'>Tu cliente medio</div>
                <div
                  id='ticket-eq'
                  class='tabular-nums text-sand leading-none'
                  style='font-family: "Titan One", cursive; font-size: clamp(1.6rem, 3vw, 2.4rem);'>
                  250
                </div>
                <div class='text-xs text-white/30 mt-1'>€/cliente</div>
              </div>

              <!-- = -->
              <div
                class='text-white/20 leading-none'
                style='font-family: "Titan One", cursive; font-size: clamp(1.4rem, 2.5vw, 2rem);'
                aria-hidden='true'>
                =
              </div>

              <!-- Result -->
              <div class='text-center'>
                <div class='label-ui text-sand/70 mb-2'>Clientes para cubrirme</div>
                <div
                  id='clients-result'
                  class='tabular-nums text-sand leading-none'
                  style='font-family: "Titan One", cursive; font-size: clamp(2.4rem, 5vw, 4rem);'>
                  2
                </div>
                <div class='text-xs text-sand/50 mt-1'>clientes</div>
              </div>

            </div>

            <!-- Punchline -->
            <div class='relative rounded-xl bg-white/[0.05] border border-white/10 px-6 py-5'>
              <div
                class='pointer-events-none absolute left-0 top-4 bottom-4 w-[3px] bg-sand rounded-r-full'
                aria-hidden='true'>
              </div>
              <p id='punchline' class='text-base text-white leading-relaxed font-medium text-pretty'>
                Con solo <strong id='punchline-n' class='text-sand'>2 clientes nuevos</strong> que lleguen por Google,
                ya has cubierto lo que me pagas ese mes.
                <span class='block mt-1 text-white/40 text-sm'>Todo lo que venga después es beneficio puro.</span>
              </p>
            </div>

            <!-- CTA -->
            <div class='mt-6'>
              <WhatsAppButton
                text='Reserva tu llamada'
                class='w-full justify-center px-6 py-3.5 text-[0.9375rem] font-bold shadow-lg shadow-sand/20 hover:shadow-sand/30 transition-shadow'
              />
            </div>

          </div>
        </div>

      </div>
      <!-- end right col -->

    </div>
  </div>
</section>

<style>
  /* ── Plan buttons — dark background context ── */
  .plan-btn[data-active='true'] {
    background-color: rgba(250, 234, 177, 0.10);
    border-color: rgba(250, 234, 177, 0.45);
  }
  .plan-btn[data-active='true'] .plan-name  { color: #FAEAB1; }
  .plan-btn[data-active='true'] .plan-price { color: var(--color-sand); }
  .plan-btn[data-active='true'] .plan-desc  { color: rgba(250,234,177,0.65); }
  .plan-btn[data-active='true'] .plan-iva   {
    color: rgba(250,234,177,0.7);
    border-color: rgba(250,234,177,0.25);
    background-color: rgba(250,234,177,0.08);
  }

  .plan-btn[data-active='false'] {
    background-color: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.10);
  }
  .plan-btn[data-active='false'] .plan-name  { color: rgba(255,255,255,0.4); }
  .plan-btn[data-active='false'] .plan-price { color: rgba(255,255,255,0.25); }
  .plan-btn[data-active='false'] .plan-desc  { color: rgba(255,255,255,0.3); }
  .plan-btn[data-active='false'] .plan-iva   {
    color: rgba(255,255,255,0.3);
    border-color: rgba(255,255,255,0.10);
  }

  .plan-btn:hover[data-active='false'] {
    background-color: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.18);
  }
  .plan-btn:hover[data-active='false'] .plan-name { color: rgba(255,255,255,0.65); }

  /* ── Slider ── */
  .ticket-slider::-webkit-slider-runnable-track {
    background: linear-gradient(to right, #FAEAB1 var(--pct, 10%), rgba(255,255,255,0.12) var(--pct, 10%));
    border-radius: 9999px;
    height: 8px;
  }
  .ticket-slider::-moz-range-track {
    background: rgba(255,255,255,0.12);
    border-radius: 9999px;
    height: 8px;
  }
  .ticket-slider::-moz-range-progress {
    background: #FAEAB1;
    border-radius: 9999px;
    height: 8px;
  }
  .ticket-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #FAEAB1;
    border: 3px solid #334443;
    box-shadow: 0 0 0 2px rgba(250,234,177,0.35);
    cursor: pointer;
    margin-top: -7px;
    transition: box-shadow 0.15s;
  }
  .ticket-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #FAEAB1;
    border: 3px solid #334443;
    box-shadow: 0 0 0 2px rgba(250,234,177,0.35);
    cursor: pointer;
  }
  .ticket-slider:hover::-webkit-slider-thumb,
  .ticket-slider:focus::-webkit-slider-thumb {
    box-shadow: 0 0 0 5px rgba(250,234,177,0.20);
  }

  /* ── Number pop ── */
  @keyframes numPop {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.18); }
    100% { transform: scale(1); }
  }
  .num-pop { animation: numPop 0.22s ease-out; }
</style>

<script>
  const slider      = document.getElementById('ticket-slider') as HTMLInputElement
  const ticketDisp  = document.getElementById('ticket-display') as HTMLElement
  const ticketEq    = document.getElementById('ticket-eq') as HTMLElement
  const feeDisp     = document.getElementById('fee-display') as HTMLElement
  const clientsRes  = document.getElementById('clients-result') as HTMLElement
  const punchlineN  = document.getElementById('punchline-n') as HTMLElement
  const wmGhost     = document.getElementById('wm-ghost') as HTMLElement
  const planBtns    = document.querySelectorAll<HTMLButtonElement>('.plan-btn')

  const MIN = 50
  const MAX = 2000
  let currentFee = 350

  function updateTrack(val: number) {
    const pct = ((val - MIN) / (MAX - MIN)) * 100
    slider.style.setProperty('--pct', `${pct}%`)
  }

  function pop(el: HTMLElement) {
    el.classList.remove('num-pop')
    void el.offsetWidth
    el.classList.add('num-pop')
  }

  function recalc() {
    const ticket  = parseInt(slider.value, 10)
    const clients = Math.ceil(currentFee / ticket)
    const word    = clients === 1 ? 'cliente nuevo' : 'clientes nuevos'

    ticketDisp.textContent  = ticket.toLocaleString('es-ES')
    ticketEq.textContent    = ticket.toLocaleString('es-ES')
    feeDisp.textContent     = currentFee.toLocaleString('es-ES')
    clientsRes.textContent  = String(clients)
    punchlineN.textContent  = `${clients} ${word}`
    wmGhost.textContent     = `${clients}×`

    updateTrack(ticket)
    pop(clientsRes)
    pop(feeDisp)
  }

  planBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      planBtns.forEach((b) => {
        b.dataset.active = 'false'
        b.setAttribute('aria-pressed', 'false')
      })
      btn.dataset.active = 'true'
      btn.setAttribute('aria-pressed', 'true')
      currentFee = parseInt(btn.dataset.price ?? '350', 10)
      recalc()
    })
  })

  slider.addEventListener('input', recalc)
  updateTrack(parseInt(slider.value, 10))
</script>
