---
import CalButton from '../../CalButton.astro'
import Watermark from '../../Watermark.astro'

const plans = [
  {
    id: 'ficha',
    label: 'Más llamadas desde Google Maps',
    price: 350,
    includes: 'Gestión completa de tu perfil en Google Maps',
  },
  {
    id: 'ficha-web',
    label: 'Más llamadas desde Google Maps y tu web',
    price: 550,
    includes: 'Perfil de Google Maps y tu web optimizada',
  },
]
---

<section id='calculadora' class='relative overflow-hidden bg-gradient-to-br from-base to-surface/70 py-24 md:py-32'>
  <Watermark text="ROI" position="bottom-left" opacity={4} size="4xl" />

  <!-- Ambient light gradients -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-20 -left-10 h-[380px] w-[480px] rounded-full bg-sage/20 blur-3xl"></div>
    <div class="absolute -bottom-10 right-0 h-[320px] w-[420px] rounded-full bg-cream/12 blur-3xl"></div>
  </div>

  <div class='relative container-site'>

    <div class='lg:grid lg:grid-cols-[1fr_1.15fr] lg:gap-20 lg:items-start'>

      <!-- ══ LEFT COL — copy ══════════════════════════════════════════ -->
      <div data-animate class='relative mb-12 lg:mb-0 lg:sticky lg:top-[calc(var(--navbar-height,80px)+2rem)]'>

        <!-- Preheader -->
        <div class='mb-8'>
          <h2 class='text-xs font-bold text-cream'>PRECIO DEL CONSULTOR SEO PROFESIONAL</h2>
        </div>

        <!-- h2 -->
        <p class='font-heading text-h2 font-normal leading-tight tracking-tight text-white'>
          Cuántos clientes necesitas para que <span class='text-cream'>salga a cuenta.</span>
        </p>

        <!-- Accent rule -->
        <div class='mt-6 flex items-center'>
          <div class='h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35'></div>
          <div class='h-px w-10 bg-cream/60'></div>
        </div>

        <p class='mt-5 text-base text-white/70 leading-relaxed text-pretty max-w-[42ch]'>
          Lo primero que hacemos juntos es calcular
          <strong class='font-semibold text-white'>cuánto tiene que rentarte esto</strong>.
          Si lo que me pagas no trae más de lo que cuesta, no tiene ningún sentido seguir.
        </p>


      </div>

      <!-- ══ RIGHT COL — calculator ═══════════════════════════════════ -->
      <div>

        <!-- ── Plan selector ────────────────────────────────────────── -->
        <div data-animate class='mb-6 flex flex-col sm:flex-row gap-3'>
          {plans.map((plan, i) => (
            <button
              class='plan-btn relative flex-1 rounded-xl border border-cream/30 bg-cream/5 px-5 py-4 text-left transition-all duration-200 cursor-pointer hover:border-cream/60 hover:bg-cream/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cream/50 data-[active=true]:border-cream/70 data-[active=true]:bg-cream/12 data-[active=true]:shadow-[0_0_0_1px_rgba(236,223,204,0.2)]'
              data-price={plan.price}
              data-active={i === 0 ? 'true' : 'false'}
              aria-pressed={i === 0 ? 'true' : 'false'}
              type='button'>
              <span class='plan-name block font-heading text-base font-bold mb-3 leading-snug text-white'>
                {plan.label}
              </span>
              <div class='flex items-baseline gap-2 mb-4'>
                <span class='plan-price leading-none font-heading text-cream'>
                  {plan.price}€<span class='text-xs font-normal text-white/45'>/mes</span>
                </span>
                <span class='plan-iva inline-flex items-center rounded-full border border-cream/30 text-cream px-2 py-0.5 text-xs font-semibold tracking-wide'>
                  sin IVA
                </span>
              </div>
              <span class='plan-desc block text-base leading-snug text-white/60'>
                {plan.includes}
              </span>
            </button>
          ))}
        </div>

        <!-- ── Calculator card ──────────────────────────────────────── -->
        <div data-animate class='relative rounded-2xl overflow-hidden bg-white-06 border-white-10'>

          <div class='absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-cream/20 via-cream/60 to-cream/20'></div>

          <div class='relative p-8 md:p-10'>

            <!-- Slider row -->
            <div class='mb-10'>
              <label for='ticket-slider' class='block mb-3'>
                <span class='text-xs font-semibold text-white/45 uppercase tracking-[0.14em]'>
                  ¿Cuánto te paga de media un cliente?
                </span>
              </label>

              <div class='flex items-center gap-5 mb-4'>
                <input
                  id='ticket-slider'
                  type='range'
                  min='50'
                  max='2000'
                  step='50'
                  value='250'
                  class='flex-1 h-2 rounded-full appearance-none cursor-pointer bg-gradient-to-r from-cream to-white/10'
                  aria-label='Cuánto te paga un cliente tuyo de media, en euros'
                />
                <div class='shrink-0 flex items-baseline gap-0.5 min-w-[5.5rem] justify-end'>
                  <span class="font-heading text-h3 tabular-nums text-cream leading-none" id='ticket-display'>250</span>
                  <span class='text-h5 font-bold text-cream/60 ml-0.5'>€</span>
                </div>
              </div>

              <div class='flex justify-between text-base font-medium text-white/25 tabular-nums px-0.5'>
                <span>50€</span>
                <span>2.000€</span>
              </div>
            </div>

            <!-- Equation divider -->
            <div class='h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-10'></div>

            <!-- The equation -->
            <div class='grid grid-cols-[1fr_auto_1fr_auto_1fr] items-center gap-2 md:gap-4 mb-10'>

              <div class='text-center'>
                <div class='text-xs font-semibold tracking-[0.12em] uppercase text-white/35 mb-2'>Lo que me pagas</div>
                <div class="font-heading text-h3 tabular-nums text-cream leading-none transition-all duration-200" id='fee-display'>350</div>
                <div class='text-xs text-white/55 mt-3'>€/mes</div>
              </div>

              <div class="font-heading text-white/20 leading-none" aria-hidden='true'>÷</div>

              <div class='text-center'>
                <div class='text-xs font-semibold tracking-[0.12em] uppercase text-white/35 mb-2'>Tu cliente medio</div>
                <div class="font-heading text-h3 tabular-nums text-cream leading-none" id='ticket-eq'>250</div>
                <div class='text-xs text-white/55 mt-3'>€/cliente</div>
              </div>

              <div class="font-heading text-white/20 leading-none" aria-hidden='true'>=</div>

              <div class='text-center'>
                <div class='text-xs font-semibold tracking-[0.12em] uppercase text-cream/70 mb-2'>Para cubrirme</div>
                <div class="font-heading text-h3 tabular-nums text-cream leading-none" id='clients-result'>2</div>
                <div class='text-xs text-cream/70 mt-3'>clientes</div>
              </div>

            </div>

            <!-- Punchline -->
            <div class='relative rounded-xl px-6 py-5 bg-white-05 border-white-10'>
              <div class='pointer-events-none absolute left-0 top-4 bottom-4 w-[3px] bg-cream/50 rounded-r-full' aria-hidden='true'></div>
              <p id='punchline' class='text-base text-white leading-relaxed text-pretty'>
                Con solo <span id='punchline-n' class='text-cream'>2 clientes nuevos</span> que lleguen por Google,
                ya has cubierto lo que me pagas ese mes.
                <span class='block mt-1 text-white/40 text-base'>Todo lo que venga después es beneficio tuyo.</span>
              </p>
            </div>

            <!-- CTA -->
            <div class='mt-6'>
              <CalButton text='Agenda una llamada gratis' class='block w-full text-center' />
            </div>

          </div>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  #ticket-slider::-webkit-slider-thumb {
    appearance: none;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 9999px;
    background: var(--color-cream);
    cursor: pointer;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-cream) 25%, transparent);
  }
  #ticket-slider::-moz-range-thumb {
    width: 1.125rem;
    height: 1.125rem;
    border: none;
    border-radius: 9999px;
    background: var(--color-cream);
    cursor: pointer;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-cream) 25%, transparent);
  }
</style>

<script>
  const slider      = document.getElementById('ticket-slider') as HTMLInputElement
  const ticketDisp  = document.getElementById('ticket-display') as HTMLElement
  const ticketEq    = document.getElementById('ticket-eq') as HTMLElement
  const feeDisp     = document.getElementById('fee-display') as HTMLElement
  const clientsRes  = document.getElementById('clients-result') as HTMLElement
  const punchlineN  = document.getElementById('punchline-n') as HTMLElement
const planBtns    = document.querySelectorAll<HTMLButtonElement>('.plan-btn')

  const MIN = 50
  const MAX = 2000
  let currentFee = 350

  function updateTrack(val: number) {
    const pct = ((val - MIN) / (MAX - MIN)) * 100
    slider.style.setProperty('--pct', `${pct}%`)
  }

  function pop(el: HTMLElement) {
    el.classList.remove('num-pop')
    void el.offsetWidth
    el.classList.add('num-pop')
  }

  function recalc() {
    const ticket  = parseInt(slider.value, 10)
    const clients = Math.ceil(currentFee / ticket)
    const word    = clients === 1 ? 'cliente nuevo' : 'clientes nuevos'

    ticketDisp.textContent  = ticket.toLocaleString('es-ES')
    ticketEq.textContent    = ticket.toLocaleString('es-ES')
    feeDisp.textContent     = currentFee.toLocaleString('es-ES')
    clientsRes.textContent  = String(clients)
    punchlineN.textContent  = `${clients} ${word}`
    updateTrack(ticket)
    pop(clientsRes)
    pop(feeDisp)
  }

  planBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      planBtns.forEach((b) => {
        b.dataset.active = 'false'
        b.setAttribute('aria-pressed', 'false')
      })
      btn.dataset.active = 'true'
      btn.setAttribute('aria-pressed', 'true')
      currentFee = parseInt(btn.dataset.price ?? '350', 10)
      recalc()
    })
  })

  slider.addEventListener('input', recalc)
  updateTrack(parseInt(slider.value, 10))
</script>
