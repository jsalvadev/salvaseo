---
import WhatsAppButton from '../../WhatsAppButton.astro'
import { buildWhatsAppHref } from '../../../data/site'

const waHref = buildWhatsAppHref()
---

<section class='relative bg-petrol-900 overflow-hidden'>
  <!-- Watermark #1 -->
  <div
    class='pointer-events-none absolute -top-8 right-0 select-none leading-none'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(14rem, 28vw, 24rem); color: rgba(255,255,255,0.025); line-height: 1;'>
    #1
  </div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line
      x1='72%'
      y1='0%'
      x2='100%'
      y2='100%'
      stroke='rgba(249,115,22,0.07)'
      stroke-width='1'
    ></line>
    <line
      x1='78%'
      y1='0%'
      x2='108%'
      y2='100%'
      stroke='rgba(249,115,22,0.04)'
      stroke-width='1'
    ></line>
    <line
      x1='65%'
      y1='0%'
      x2='93%'
      y2='100%'
      stroke='rgba(14,165,233,0.04)'
      stroke-width='1'
    ></line>
  </svg>

  <!-- Radial glow bottom-left -->
  <div
    class='pointer-events-none absolute -bottom-32 -left-32 w-96 h-96 rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.08) 0%, transparent 70%);'>
  </div>

  <!-- ── Main grid ───────────────────────────────────────────────── -->
  <div
    class='relative mx-auto max-w-7xl px-6 pt-20 pb-12 sm:pt-24 sm:pb-16 lg:px-8 lg:pt-28 lg:pb-20'>
    <div
      class='grid lg:grid-cols-[1fr_300px] xl:grid-cols-[1fr_320px] gap-12 lg:gap-20 items-start'>
      <!-- ── LEFT: Content ───────────────────────────────────────── -->
      <div>
        <!-- Eyebrow -->
        <div
          class='animate-fade-in-up [animation-delay:0ms] flex items-center gap-3 mb-5'>
          <span class='block h-px w-10 bg-orange-500' aria-hidden='true'></span>
          <h1
            class='label-section text-orange-400'>
            Consultor SEO en Barcelona
          </h1>
        </div>

        <!-- Headline (visual only) -->
        <p
          class='animate-fade-in-up [animation-delay:80ms]'
          style='font-family: "Titan One", cursive;'>
          <span
            class='block text-4xl sm:text-5xl lg:text-6xl xl:text-[4rem] leading-[0.93] tracking-tight text-white'>
            Si no apareces
          </span>
          <span
            class='block text-4xl sm:text-5xl lg:text-6xl xl:text-[4rem] leading-[0.93] tracking-tight mt-1'>
            <span class='text-white'>en Google,&nbsp;</span><span
              class='text-orange-400'>no existes.</span
            >
          </span>
        </p>

        <!-- Accent rule -->
        <div
          class='animate-fade-in-up [animation-delay:160ms] mt-5 flex items-center gap-0'>
          <div class='h-px w-16 bg-orange-500'></div>
          <div
            class='h-px w-24 bg-gradient-to-r from-orange-500/50 to-transparent'>
          </div>
        </div>

        <!-- Body -->
        <p
          class='animate-fade-in-up [animation-delay:230ms] mt-5 max-w-[52ch] text-lg leading-relaxed text-petrol-100 text-pretty'>
          Cada día, cientos de personas en Barcelona buscan en Google lo que tú
          ofreces. Si no apareces en los primeros resultados,
          <strong class='text-white font-semibold'>no saben que existes.</strong>
        </p>

        <p
          class='animate-fade-in-up [animation-delay:300ms] mt-4 max-w-[52ch] text-lg leading-relaxed text-petrol-100 text-pretty'>
          Mi trabajo es que dejes de ser invisible y
          <strong class='text-white font-semibold'>seas lo primero que vean.</strong>
        </p>

        <p
          class='animate-fade-in-up [animation-delay:360ms] mt-4 max-w-[52ch] text-lg leading-relaxed text-petrol-100 text-pretty'>
          Escríbeme ahora mismo por WhatsApp y dime: <strong
            class='text-white font-semibold'
            >"Salva, mi página web es invisible en Barcelona."</strong>
        </p>

        <!-- CTAs -->
        <div
          class='animate-fade-in-up [animation-delay:440ms] mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-x-7'>
          <WhatsAppButton
            text='Analiza mi web'
            href={waHref}
            class='px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-sky-500/20 hover:shadow-sky-500/30 transition-shadow'
          />
        </div>
      </div>

      <!-- ── RIGHT: SERP visualization ──────────────────────────── -->
      <aside
        class='animate-fade-in [animation-delay:480ms] hidden lg:flex flex-col gap-0 pt-2'
        aria-hidden='true'>

        <!-- Label -->
        <p class='label-ui text-petrol-600 mb-3 px-0.5'>
          Resultados Google · Barcelona
        </p>

        <!-- Mock search bar -->
        <div class='flex items-center gap-2.5 rounded-full bg-white/[0.05] border border-white/[0.08] px-3.5 py-2 mb-3'>
          <svg class='shrink-0 w-3 h-3 text-petrol-600' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2.5'>
            <circle cx='11' cy='11' r='8'/><path d='m21 21-4.35-4.35'/>
          </svg>
          <div class='h-1.5 w-36 rounded-full bg-white/20'></div>
          <div class='ml-auto shrink-0 h-3 w-px bg-white/20'></div>
          <svg class='shrink-0 w-3.5 h-3.5' viewBox='0 0 40 40' fill='none'>
            <circle cx='20' cy='20' r='20' fill='#4285F4'/>
            <path d='M28.5 20.2c0-.7-.1-1.4-.2-2H20v3.8h4.8c-.2 1-.8 1.8-1.7 2.4v2h2.7c1.6-1.5 2.7-3.7 2.7-6.2z' fill='#fff'/>
            <path d='M20 29c2.4 0 4.5-.8 6-2.2l-2.7-2c-.8.5-1.9.9-3.3.9-2.5 0-4.6-1.7-5.4-4h-2.8v2c1.5 3 4.5 5.3 8.2 5.3z' fill='#fff'/>
            <path d='M14.6 21.7c-.2-.5-.3-1.1-.3-1.7s.1-1.2.3-1.7v-2h-2.8C11.3 17.5 11 18.7 11 20s.3 2.5.8 3.7l2.8-2z' fill='#fff'/>
            <path d='M20 14.3c1.4 0 2.6.5 3.6 1.4l2.5-2.5C24.5 11.8 22.4 11 20 11c-3.7 0-6.7 2.3-8.2 5.3l2.8 2c.8-2.3 2.9-4 5.4-4z' fill='#fff'/>
          </svg>
        </div>

        <!-- SERP card wrapper -->
        <div class='relative flex flex-col gap-2'>

          <!-- Animated cursor -->
          <div id='serp-cursor' class='pointer-events-none absolute z-20' style='top: 80px; right: 12px;'>
            <svg width='18' height='22' viewBox='0 0 18 22' fill='none' xmlns='http://www.w3.org/2000/svg'>
              <path d='M1 1L1 17L5.5 13.5L8 20L10.5 19L8 12.5L13.5 12.5L1 1Z' fill='white' stroke='rgba(0,0,0,0.4)' stroke-width='1.2' stroke-linejoin='round'/>
            </svg>
          </div>

          <!-- Click ripple -->
          <div id='serp-ripple' class='pointer-events-none absolute z-10 w-6 h-6 rounded-full' style='top: 68px; right: 4px; opacity: 0; border: 1.5px solid rgba(56,189,248,0.8);'></div>

          <!-- Posición #1 — TU EMPRESA -->
          <div
            id='serp-result-1'
            class='rounded-xl border p-3.5 relative overflow-hidden'
            style='background: linear-gradient(135deg, rgba(14,165,233,0.12) 0%, rgba(14,165,233,0.06) 100%); border-color: rgba(56,189,248,0.4); box-shadow: 0 0 20px rgba(14,165,233,0.15), inset 0 1px 0 rgba(255,255,255,0.08);'>

            <!-- Corner badge -->
            <div class='absolute top-2.5 right-2.5 flex items-center gap-1 bg-orange-500/20 border border-orange-400/30 rounded-full px-1.5 py-0.5'>
              <span class='text-[0.5rem] font-bold uppercase tracking-wider text-orange-400'>#1</span>
            </div>

            <!-- Favicon row + URL -->
            <div class='flex items-center gap-2 mb-2'>
              <div class='size-4 rounded-sm flex items-center justify-center shrink-0' style='background: linear-gradient(135deg, #0ea5e9, #0284c7);'>
                <div class='size-2 rounded-sm bg-white/80'></div>
              </div>
              <div class='flex flex-col gap-0.5'>
                <div class='h-1.5 w-18 rounded-full bg-white/30'></div>
                <div class='h-1 w-24 rounded-full' style='background: rgba(134,239,172,0.5);'></div>
              </div>
            </div>

            <!-- Title (blue like Google) -->
            <div class='h-2 w-full rounded-full mb-1' style='background: rgba(96,165,250,0.6);'></div>
            <div class='h-2 w-3/4 rounded-full mb-2.5' style='background: rgba(96,165,250,0.4);'></div>

            <!-- Stars -->
            <div class='flex items-center gap-1 mb-2'>
              {[1,2,3,4,5].map(() => (
                <svg class='w-2.5 h-2.5 text-orange-400' viewBox='0 0 20 20' fill='currentColor'>
                  <path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z'/>
                </svg>
              ))}
              <span class='text-[0.5rem] text-orange-300/80 ml-0.5'>4.9 (32 reseñas)</span>
            </div>

            <!-- Description lines -->
            <div class='h-1.5 w-full rounded-full bg-white/15 mb-1'></div>
            <div class='h-1.5 w-4/5 rounded-full bg-white/10 mb-3'></div>

            <!-- Visit counter (C) -->
            <div class='flex items-center justify-between'>
              <p class='text-[0.58rem] font-bold uppercase tracking-widest text-sky-400 flex items-center gap-1.5'>
                <span class='block h-px w-3 bg-sky-400/60'></span>
                Tu empresa aquí
                <span class='block h-px w-3 bg-sky-400/60'></span>
              </p>
              <div class='flex items-center gap-1 bg-sky-500/10 border border-sky-400/20 rounded-full px-2 py-0.5'>
                <span class='block w-1 h-1 rounded-full bg-sky-400' style='animation: pulse-glow 1.5s ease-in-out infinite;'></span>
                <span id='serp-visit-count' class='text-[0.5rem] font-bold text-sky-300 tabular-nums'>843</span>
                <span class='text-[0.45rem] text-sky-400/60'>visitas hoy</span>
              </div>
            </div>
          </div>

          <!-- Posiciones 2, 3, 4 — borrosas -->
          {
            [2, 3, 4].map(pos => (
              <div
                class='rounded-xl border p-3.5 blur-[1.5px]'
                style='background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.05);'>
                <div class='flex items-center gap-2 mb-2'>
                  <div class='size-4 rounded-sm bg-white/10 shrink-0'></div>
                  <div class='flex flex-col gap-0.5'>
                    <div class='h-1.5 w-14 rounded-full bg-white/10'></div>
                    <div class='h-1 w-20 rounded-full bg-white/[0.06]'></div>
                  </div>
                  <span class='ml-auto text-[0.55rem] font-bold text-white/15 shrink-0'>{pos}</span>
                </div>
                <div class='h-1.5 w-full rounded-full bg-white/[0.08] mb-1'></div>
                <div class='h-1.5 w-3/4 rounded-full bg-white/[0.06] mb-2'></div>
                <div class='h-1 w-full rounded-full bg-white/[0.05] mb-0.5'></div>
                <div class='h-1 w-4/5 rounded-full bg-white/[0.04]'></div>
              </div>
            ))
          }
        </div>

        <!-- Stat footer -->
        <div class='mt-3 flex items-center justify-center gap-2'>
          <div class='h-px flex-1 bg-gradient-to-r from-transparent to-white/20'></div>
          <p class='text-[0.65rem] font-semibold text-petrol-100/70 whitespace-nowrap'>
            91% de los clics van a la primera posición
          </p>
          <div class='h-px flex-1 bg-gradient-to-l from-transparent to-white/20'></div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  // ── Cursor animation ────────────────────────────────────────────────────
  const cursor = document.getElementById('serp-cursor')
  const ripple = document.getElementById('serp-ripple')
  const card   = document.getElementById('serp-result-1')

  if (cursor && ripple && card) {
    // Target: title area of the #1 card (approx center-top of the card)
    // We animate via CSS custom properties
    const runCursor = () => {
      // Reset to start position (bottom-right, outside cards)
      cursor.style.transition = 'none'
      cursor.style.transform  = 'translate(0px, 120px) scale(1)'
      cursor.style.opacity    = '0'
      ripple.style.opacity    = '0'
      ripple.style.transform  = 'scale(0)'

      setTimeout(() => {
        // Appear and move toward the title bars on the card
        cursor.style.transition = 'transform 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.2s ease'
        cursor.style.opacity    = '1'
        cursor.style.transform  = 'translate(-80px, 20px) scale(1)'
      }, 300)

      setTimeout(() => {
        // Click: scale down
        cursor.style.transition = 'transform 0.1s ease'
        cursor.style.transform  = 'translate(-80px, 20px) scale(0.75)'

        // Ripple burst
        ripple.style.transition = 'none'
        ripple.style.top        = '72px'
        ripple.style.right      = '88px'
        ripple.style.opacity    = '1'
        ripple.style.transform  = 'scale(0.5)'
        setTimeout(() => {
          ripple.style.transition = 'transform 0.5s ease-out, opacity 0.5s ease-out'
          ripple.style.transform  = 'scale(3)'
          ripple.style.opacity    = '0'
        }, 20)

        // Card flash
        card.style.transition = 'box-shadow 0.1s ease'
        card.style.boxShadow  = '0 0 32px rgba(56,189,248,0.45), inset 0 1px 0 rgba(255,255,255,0.08)'
        setTimeout(() => {
          card.style.boxShadow = '0 0 20px rgba(14,165,233,0.15), inset 0 1px 0 rgba(255,255,255,0.08)'
        }, 300)
      }, 1500)

      setTimeout(() => {
        // Release click
        cursor.style.transition = 'transform 0.12s ease'
        cursor.style.transform  = 'translate(-80px, 20px) scale(1)'
      }, 1650)

      setTimeout(() => {
        // Fade out
        cursor.style.transition = 'opacity 0.4s ease'
        cursor.style.opacity    = '0'
      }, 2200)
    }

    // Run twice, spaced out
    setTimeout(runCursor, 1800)
    setTimeout(runCursor, 9000)
  }

  // ── Visit counter ───────────────────────────────────────────────────────
  const countEl = document.getElementById('serp-visit-count')
  if (countEl) {
    let count = 843
    setInterval(() => {
      count += Math.floor(Math.random() * 3) + 1
      countEl.textContent = count.toLocaleString('es-ES')
    }, 2200)
  }
</script>
