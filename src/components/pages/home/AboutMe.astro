---
import aboutMeImage from '../../../assets/about-me.webp'
import { Mail, Phone } from '@lucide/astro'
---

<section
  id='sobre-mi'
  class='relative overflow-hidden py-24 md:py-32 bg-gradient-to-tl from-base to-surface'>

  <!-- Ambient light gradients -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-24 left-1/2 h-[420px] w-[600px] -translate-x-1/2 rounded-full bg-cream/15 blur-3xl"></div>
    <div class="absolute bottom-0 -right-10 h-[280px] w-[360px] rounded-full bg-sage/20 blur-3xl"></div>
  </div>

  <!-- Large ghosted watermark -->
  <div class="font-heading pointer-events-none absolute -right-6 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-white/[0.04]"
    aria-hidden='true'>
    SEO
  </div>

  <div class='absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-40 bg-sage rounded-r-full pointer-events-none'
    aria-hidden='true'></div>

  <div class='container-site'>
    <div
      data-animate-direction='left'
      class='grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-12 lg:gap-20 items-center'>

      <!-- Photo column -->
      <div class='relative flex justify-center lg:justify-start flex-shrink-0'>
        <div class='absolute -bottom-4 -right-4 w-full h-full rounded-2xl bg-sage/25 border border-sage/30' aria-hidden='true'></div>
        <div class='absolute -bottom-2 -right-2 w-full h-full rounded-2xl bg-sage/15 border border-sage/25' aria-hidden='true'></div>

        <img
          src={aboutMeImage.src}
          width={aboutMeImage.width}
          height={aboutMeImage.height}
          loading='lazy'
          alt='Salvador Jesús, consultor SEO freelance en Barcelona'
          class='relative aspect-4/5 w-56 sm:w-64 rounded-2xl object-cover shadow-2xl ring-1 ring-surface/5'
        />

        <div class='absolute -top-3 -left-3 w-6 h-6 rounded-full bg-sage shadow-sm' aria-hidden='true'></div>
      </div>

      <!-- Content column -->
      <div class='space-y-7 max-w-xl'>

        <!-- Preheader -->
        <div>
          <h2 class='text-xs font-bold text-cream'>CONSULTOR SEO FREELANCE EN BARCELONA</h2>
        </div>

        <!-- Headline -->
        <div class='space-y-1.5'>
          <p class='font-heading text-h2 font-bold leading-tight tracking-tight text-white'>
            Quién demonios <span class='text-cream'>soy.</span>
          </p>
        </div>

        <!-- Accent rule -->
        <div class='flex items-center'>
          <div class='h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35'></div>
          <div class='h-px w-10 bg-cream/60'></div>
        </div>

        <!-- Bio -->
        <p class='text-base text-white/70 leading-relaxed text-pretty'>
          Me llamo Salva y hago que los negocios locales dejen de ser invisibles en Google. Soy muy de números, así que todo lo que hago se mide: más llamadas, más mensajes, más presupuestos. Si se puede medir, se puede mejorar.
        </p>
        <hr class='border-cream/10' />

        <!-- Contact links -->
        <div class='flex flex-wrap gap-4'>
          <a
            href='mailto:salvadorjesus.seo@gmail.com'
            class='group inline-flex items-center gap-2.5 text-sm text-cream/80 hover:text-cream transition-colors duration-200'>
            <span class='flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-sage ring-1 ring-cream/20 group-hover:ring-cream/40 transition-all duration-200'>
              <Mail class='h-4 w-4' />
            </span>
            salvadorjesus.seo@gmail.com
          </a>

          <a
            href='tel:+34692051399'
            class='group inline-flex items-center gap-2.5 text-sm text-cream/80 hover:text-cream transition-colors duration-200'>
            <span class='flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-sage ring-1 ring-cream/20 group-hover:ring-cream/40 transition-all duration-200'>
              <Phone class='h-4 w-4' />
            </span>
            +34 692 051 399
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
