---
import WhatsAppButton from '../../WhatsAppButton.astro'
---

<section class='relative overflow-hidden bg-teal py-24 md:py-32'>

  <!-- Dot-grid texture overlay -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(255,255,255,0.028) 1px, transparent 1px); background-size: 32px 32px;'>
  </div>

  <!-- Large ghosted watermark -->
  <div
    class='pointer-events-none absolute -left-10 top-1/2 -translate-y-1/2 select-none leading-none'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(14rem, 28vw, 24rem); color: rgba(250,234,177,0.08); line-height: 1; white-space: nowrap;'>
    TÚ
  </div>

  <!-- Radial ambient top-right -->
  <div
    class='pointer-events-none absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.05) 0%, transparent 65%);'>
  </div>

  <!-- Top / bottom hairline accents -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/35 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-[1280px] px-5'>
    <div class='grid lg:grid-cols-[1fr_1.15fr] gap-12 lg:gap-20 items-start'>

      <!-- ── LEFT: sticky headline block ────────────────────────────── -->
      <div class='lg:sticky lg:top-28'>

        <div data-animate class='flex items-center gap-3 mb-8'>
          <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
          <h2 class='label-section text-sand'>
            Consultor SEO cerca de ti
          </h2>
        </div>

        <p
          data-animate
          style='font-family: "Titan One", cursive;'
          class='leading-[0.9] tracking-tight'>
          <span class='block text-[clamp(1.55rem,3.1vw,2.49rem)] text-white/55 mb-1'>
            Esto es
          </span>
          <span class='block text-[clamp(1.55rem,3.1vw,2.49rem)] text-white'>
            para ti si<span class='text-sand'>.</span>
          </span>
        </p>

        <!-- Animated underline rule -->
        <div data-animate class='mt-6 flex items-center'>
          <div class='h-[3px] w-16 bg-sand rounded-full'></div>
          <div class='h-px w-24 bg-gradient-to-r from-sand/40 to-transparent'></div>
        </div>

        <p
          data-animate
          class='mt-6 max-w-[38ch] text-base md:text-lg text-white/55 leading-relaxed text-pretty'>
          Te identificas con alguna de estas situaciones
        </p>

        <!-- CTA -->
        <div data-animate class='mt-10'>
          <WhatsAppButton
            text='Reserva tu llamada'
            class='px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-sand/20 hover:shadow-sand/30 transition-shadow'
          />
        </div>

        <!-- Decorative vertical rule (desktop) -->
        <div
          class='hidden lg:block mt-12 w-px h-20 bg-gradient-to-b from-sand/30 to-transparent'
          aria-hidden='true'>
        </div>
      </div>

      <!-- ── RIGHT: card list ───────────────────────────────────────── -->
      <ul class='flex flex-col gap-3 mt-2'>

        {[
          {
            num: '01',
            heading: 'Tu negocio está en Barcelona',
            body: 'Clínicas, talleres, despachos, empresas locales. Tienes una web y quieres aparecer antes que tu competencia en Google.',
          },
          {
            num: '02',
            heading: 'Llevas tiempo pagando anuncios sin resultados duraderos',
            body: 'Cada mes pagas por clics que no se convierten, y en cuanto paras la campaña desapareces.',
          },
          {
            num: '03',
            heading: 'Tu web no aparece ni en la segunda página',
            body: 'Buscas tu propio negocio en Google y tienes que llegar muy abajo para encontrarte.',
          },
          {
            num: '04',
            heading: 'Quieres clientes que lleguen solos',
            body: 'Sin depender de redes sociales ni de anuncios de pago.',
          },
          {
            num: '05',
            heading: 'Tu ficha de Google Business Profile no rinde',
            body: 'Apareces en Maps pero casi no recibes llamadas, tus reseñas están estancadas.',
          },
        ].map((item) => (
          <li
            data-animate
            class='esto-card group relative rounded-xl border border-white/[0.07] bg-white/[0.03] px-6 py-5 transition-all duration-300 hover:border-sand/30 hover:bg-white/[0.055] overflow-hidden cursor-default'>

            <!-- Card left accent bar (appears on hover) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sand scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>

            <!-- Ghost ordinal number background -->
            <div
              class='pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 select-none leading-none transition-opacity duration-300 opacity-60 group-hover:opacity-100'
              aria-hidden='true'
              style={`font-family: "Titan One", cursive; font-size: 5rem; color: rgba(250,234,177,0.10); line-height: 1;`}>
              {item.num}
            </div>

            <!-- Content row -->
            <div class='relative flex items-start gap-4'>

              <!-- Check badge -->
              <div class='shrink-0 mt-0.5 flex h-7 w-7 items-center justify-center rounded-full bg-sand/12 ring-1 ring-sand/25 transition-all duration-300 group-hover:bg-sand/22 group-hover:ring-sand/50'>
                <svg
                  class='h-3.5 w-3.5 text-sand'
                  viewBox='0 0 12 10'
                  fill='none'
                  aria-hidden='true'>
                  <path
                    d='M1 5l3.5 3.5L11 1'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              </div>

              <!-- Text -->
              <div class='min-w-0'>
                <p class='text-[0.9375rem] font-bold text-white/90 mb-1.5 leading-snug transition-colors duration-300 group-hover:text-white'>
                  {item.heading}
                </p>
                <p class='text-sm text-white/75 leading-relaxed text-pretty transition-colors duration-300 group-hover:text-white/85'>
                  {item.body}
                </p>
              </div>

            </div>
          </li>
        ))}

      </ul>
    </div>
  </div>
</section>
