---
// Reserva una llamada — Cal.com element-click
import WhatsAppButton from '../../WhatsAppButton.astro'
---

<section id='contacto' class='relative overflow-hidden bg-cream'>

  <!-- Subtle radial gradient top-center -->
  <div
    class='pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full blur-3xl'
    aria-hidden='true'
    style='background: radial-gradient(ellipse, rgba(52,101,109,0.07) 0%, transparent 70%);'>
  </div>

  <!-- Top hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-teal/20 to-transparent'
    aria-hidden='true'>
  </div>

  <div class='relative mx-auto max-w-[1280px] px-5 py-24 md:py-32'>

    <!-- Header centrado -->
    <div class='text-center mb-16' data-animate-direction='left'>

      <!-- Eyebrow -->
      <div class='flex items-center justify-center gap-3 mb-4'>
        <span class='block h-px w-8 bg-teal/40' aria-hidden='true'></span>
        <p class='label-section text-teal'>Consultor SEO · Barcelona</p>
        <span class='block h-px w-8 bg-teal/40' aria-hidden='true'></span>
      </div>

      <!-- Headline -->
      <h2
        class='text-[clamp(1.55rem,3.1vw,2.49rem)] leading-[0.95] tracking-tight text-charcoal text-pretty'
        style='font-family: "Titan One", cursive; font-weight: 400;'>
        30 minutos.<br>
        <span class='text-teal'>Un plan real para tu negocio.</span>
      </h2>

      <!-- Accent rule -->
      <div class='mt-5 flex items-center justify-center'>
        <div class='h-px w-12 bg-teal'></div>
        <div class='h-px w-20 bg-gradient-to-r from-teal/40 to-transparent'></div>
      </div>

      <!-- Body -->
      <p class='mt-6 text-base leading-relaxed text-charcoal/70 text-pretty max-w-[46ch] mx-auto'>
        Una llamada gratuita donde analizamos tu situación real en Google y te digo qué está fallando.
        <strong class='text-charcoal font-semibold'>Sin rodeos. Sin venderte nada.</strong>
      </p>
    </div>

    <!-- Stats + CTA -->
    <div class='flex flex-col items-center gap-12' data-animate>

      <!-- Stats row -->
      <div class='grid grid-cols-3 divide-x divide-teal/15 w-full max-w-xl'>

        <div class='text-center px-6 py-2'>
          <p
            class='text-teal leading-none mb-1'
            style='font-family: "Titan One", cursive; font-size: clamp(2.2rem, 5vw, 3rem);'>
            30'
          </p>
          <p class='text-sm text-charcoal/55 font-medium'>de duración</p>
        </div>

        <div class='text-center px-6 py-2'>
          <p
            class='text-teal leading-none mb-1'
            style='font-family: "Titan One", cursive; font-size: clamp(2.2rem, 5vw, 3rem);'>
            0€
          </p>
          <p class='text-sm text-charcoal/55 font-medium'>sin coste</p>
        </div>

        <div class='text-center px-6 py-2'>
          <p
            class='text-teal leading-none mb-1'
            style='font-family: "Titan One", cursive; font-size: clamp(2.2rem, 5vw, 3rem);'>
            1:1
          </p>
          <p class='text-sm text-charcoal/55 font-medium'>solo yo, tú</p>
        </div>

      </div>

      <!-- CTA -->
      <div class='flex flex-col items-center gap-3'>
        <WhatsAppButton
          text='Reserva tu llamada gratuita'
          class='px-7 py-3.5 text-base shadow-lg shadow-sand/30 hover:shadow-sand/50 transition-shadow'
        />
        <p class='text-xs text-charcoal/40'>
          Sin spam. Elige el día y la hora que te vaya mejor.
        </p>
      </div>

    </div>

  </div>

  <!-- Bottom hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal/20 to-transparent'
    aria-hidden='true'>
  </div>

</section>
