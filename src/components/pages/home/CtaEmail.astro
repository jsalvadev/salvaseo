---
import CalButton from '../../CalButton.astro'
import HeadingRule from '../../HeadingRule.astro'
---

<section id='contacto' class='relative overflow-hidden bg-white'>

  <!-- Subtle radial gradient top-center -->
  <div
    class='pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full blur-3xl'
    aria-hidden='true'>
  </div>

  <!-- Top hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-teal/20 to-transparent'
    aria-hidden='true'>
  </div>

  <div class='relative container-site py-24 md:py-32'>

    <!-- Header centrado -->
    <div class='text-center mb-16' data-animate-direction='left'>

      <!-- Eyebrow -->
      <div class='flex items-center justify-center gap-3 mb-4'>
        <span class='block h-px w-8 bg-sage/40' aria-hidden='true'></span>
        <p class='text-xs font-bold tracking-[0.18em] uppercase text-sage'>CONSULTOR SEO · BARCELONA</p>
        <span class='block h-px w-8 bg-sage/40' aria-hidden='true'></span>
      </div>

      <!-- Headline -->
      <h2 class="font-heading font-heading text-h2 font-bold leading-[1.05] leading-[0.95] tracking-tight text-cream text-pretty">
        30 minutos.<br>
        <span class='text-sage'>Un plan real para tu negocio.</span>
      </h2>

      <!-- Accent rule -->
      <HeadingRule color='var(--color-sage)' fadeColor='var(--color-teal)' size='sm' class='mt-5 justify-center' />

      <!-- Body -->
      <p class='mt-6 text-base leading-relaxed text-cream/70 text-pretty max-w-[46ch] mx-auto'>
        Una llamada gratuita donde analizamos tu situación real en Google y te digo qué está fallando.
        <strong class='text-cream font-semibold'>Sin rodeos. Sin venderte nada.</strong>
      </p>
    </div>

    <!-- Stats + CTA -->
    <div class='flex flex-col items-center gap-12' data-animate>

      <!-- Stats row -->
      <div class='grid grid-cols-3 divide-x divide-teal/15 w-full max-w-xl'>

        <div class='text-center px-6 py-2'>
          <p class="font-heading text-sage leading-none mb-1">
            30'
          </p>
          <p class='text-sm text-cream/55 font-medium'>de duración</p>
        </div>

        <div class='text-center px-6 py-2'>
          <p class="font-heading text-sage leading-none mb-1">
            0€
          </p>
          <p class='text-sm text-cream/55 font-medium'>sin coste</p>
        </div>

        <div class='text-center px-6 py-2'>
          <p class="font-heading text-sage leading-none mb-1">
            1:1
          </p>
          <p class='text-sm text-cream/55 font-medium'>solo yo, tú</p>
        </div>

      </div>

      <!-- CTA -->
      <div class='flex flex-col items-center gap-3'>
        <CalButton variant="sand" class="px-7 py-3.5 text-base shadow-lg shadow-sand/30 hover:shadow-sand/50" />
        <p class='text-xs text-cream/40'>
          Sin spam. Elige el día y la hora que te vaya mejor.
        </p>
      </div>

    </div>

  </div>

  <!-- Bottom hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal/20 to-transparent'
    aria-hidden='true'>
  </div>

</section>
