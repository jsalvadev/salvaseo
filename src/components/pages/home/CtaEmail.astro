---
// "Empecemos por tu caso" — split-panel CTA
// Left: dark petrol with form / Right: cream with trust signals
---

<section id='contacto-cta' class='relative overflow-hidden'>
  <div class='grid grid-cols-1 lg:grid-cols-2'>

    <!-- ── LEFT: Dark form panel ─────────────────────────────────── -->
    <div class='relative bg-petrol-900 overflow-hidden px-8 py-16 sm:px-12 sm:py-20 lg:py-24 flex flex-col justify-center'>

      <!-- Eixample dot grid watermark -->
      <div
        class='pointer-events-none absolute inset-0'
        aria-hidden='true'
        style='background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1.5px, transparent 1.5px); background-size: 28px 28px;'>
      </div>

      <!-- Diagonal tension lines (inherited from Hero language) -->
      <svg
        class='pointer-events-none absolute inset-0 w-full h-full'
        aria-hidden='true'
        preserveAspectRatio='none'
        xmlns='http://www.w3.org/2000/svg'>
        <line x1='80%' y1='0%' x2='110%' y2='100%' stroke='rgba(249,115,22,0.06)' stroke-width='1'></line>
        <line x1='70%' y1='0%' x2='95%' y2='100%' stroke='rgba(14,165,233,0.04)' stroke-width='1'></line>
      </svg>

      <!-- Orange left accent bar -->
      <div class='absolute top-0 left-0 w-[3px] h-full bg-gradient-to-b from-orange-500 via-orange-400/60 to-transparent'></div>

      <!-- Large faded "@" watermark -->
      <div
        class='pointer-events-none select-none absolute -bottom-8 -right-4 leading-none hidden lg:block'
        aria-hidden='true'
        style='font-family: "Titan One", cursive; font-size: 18rem; color: rgba(255,255,255,0.018); line-height: 1;'>
        @
      </div>

      <!-- Content -->
      <div class='relative max-w-md' data-animate>

        <!-- Eyebrow -->
        <div class='flex items-center gap-3 mb-5'>
          <span class='block h-px w-8 bg-orange-500'></span>
          <span class='text-[0.68rem] font-bold uppercase tracking-[0.22em] text-orange-400'>
            Primer contacto
          </span>
        </div>

        <!-- Headline -->
        <h2
          class='text-4xl sm:text-5xl text-white leading-[0.95] tracking-tight'
          style='font-family: "Titan One", cursive;'>
          Empecemos<br />
          <span class='text-orange-400'>por tu caso</span>
        </h2>

        <!-- Accent rule -->
        <div class='mt-4 flex items-center gap-0'>
          <div class='h-px w-12 bg-orange-500'></div>
          <div class='h-px w-20 bg-gradient-to-r from-orange-500/50 to-transparent'></div>
        </div>

        <!-- Description -->
        <p class='mt-5 text-base leading-relaxed text-petrol-100 text-pretty'>
          Cuéntame tu caso. Recibirás respuesta
          <strong class='text-white font-semibold'>en menos de 24h</strong>
          con el análisis inicial de tu negocio.
          <span class='text-white/60'>Sin compromiso.</span>
        </p>

        <!-- Form -->
        <form id='cta-email-form' class='mt-7 space-y-3.5'>
          <div>
            <label for='cta-name' class='sr-only'>Nombre</label>
            <input
              id='cta-name'
              type='text'
              name='name'
              autocomplete='name'
              placeholder='Tu nombre (opcional)'
              class='w-full rounded-lg px-4 py-3.5 text-sm text-white placeholder:text-white/35 border border-white/15 focus:outline-none focus:border-orange-400 focus:ring-4 focus:ring-orange-400/15 transition-all'
              style='background: rgba(255,255,255,0.06);'
            />
          </div>

          <div>
            <label for='email-address' class='sr-only'>Email</label>
            <input
              id='email-address'
              type='email'
              name='email'
              required
              placeholder='tu@email.com'
              autocomplete='email'
              class='w-full rounded-lg px-4 py-3.5 text-sm text-white placeholder:text-white/35 border border-white/15 focus:outline-none focus:border-orange-400 focus:ring-4 focus:ring-orange-400/15 transition-all'
              style='background: rgba(255,255,255,0.06);'
            />
          </div>

          <div>
            <label for='cta-message' class='sr-only'>Mensaje</label>
            <textarea
              id='cta-message'
              name='message'
              rows='3'
              required
              placeholder='Tu negocio, tu zona, qué te preocupa…'
              class='w-full rounded-lg px-4 py-3.5 text-sm text-white placeholder:text-white/35 border border-white/15 focus:outline-none focus:border-orange-400 focus:ring-4 focus:ring-orange-400/15 transition-all resize-none'
              style='background: rgba(255,255,255,0.06);'
            ></textarea>
          </div>

          <div class='flex items-start gap-2.5'>
            <input
              type='checkbox'
              id='cta-privacy-consent'
              name='privacyConsent'
              required
              class='mt-0.5 accent-orange-500 shrink-0'
            />
            <label for='cta-privacy-consent' class='text-sm text-white/55 leading-relaxed'>
              He leído y acepto la
              <a href='/politica-privacidad' class='text-orange-400 underline underline-offset-2 hover:text-orange-300 transition-colors'>
                política de privacidad
              </a>
            </label>
          </div>

          <button
            type='submit'
            id='cta-submit-btn'
            class='w-full rounded-lg bg-orange-500 hover:bg-orange-400 active:bg-orange-600 text-white font-bold text-sm px-6 py-3.5 transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500 disabled:opacity-50 disabled:cursor-not-allowed'
            style='box-shadow: 0 4px 24px rgba(249,115,22,0.32);'>
            Analiza mi web
          </button>
        </form>

        <div id='cta-form-message' class='mt-4 hidden'>
          <p class='text-sm'></p>
        </div>

      </div>
    </div>

    <!-- ── RIGHT: Trust signals panel ────────────────────────────── -->
    <div class='relative overflow-hidden px-8 py-16 sm:px-12 sm:py-20 lg:py-24 flex flex-col justify-center bg-sandstone-soft'>

      <!-- Large faded "BCN" watermark -->
      <div
        class='pointer-events-none select-none absolute -bottom-6 -right-8 leading-none hidden lg:block'
        aria-hidden='true'
        style='font-family: "Titan One", cursive; font-size: 13rem; color: rgba(26,60,74,0.04); line-height: 1;'>
        BCN
      </div>

      <div class='relative space-y-0 max-w-sm'>

        <!-- Signal 1 -->
        <div data-animate class='flex gap-5 items-start py-8'>
          <div
            class='shrink-0 size-11 rounded-full bg-petrol-900 flex items-center justify-center'
            style='box-shadow: 0 4px 16px rgba(26,60,74,0.2);'>
            <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' class='size-5 text-orange-400'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z' />
            </svg>
          </div>
          <div>
            <p class='text-sm font-bold text-petrol-900 uppercase tracking-wide'>Respuesta en menos de 24h</p>
            <p class='mt-1.5 text-sm text-petrol-700 leading-relaxed'>
              Tu email lo lee y responde directamente quien trabajará tu proyecto.
            </p>
          </div>
        </div>

        <!-- Divider -->
        <div class='h-px bg-petrol-100'></div>

        <!-- Signal 2 -->
        <div data-animate class='flex gap-5 items-start py-8'>
          <div
            class='shrink-0 size-11 rounded-full bg-petrol-900 flex items-center justify-center'
            style='box-shadow: 0 4px 16px rgba(26,60,74,0.2);'>
            <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' class='size-5 text-orange-400'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z' />
            </svg>
          </div>
          <div>
            <p class='text-sm font-bold text-petrol-900 uppercase tracking-wide'>Análisis inicial incluido</p>
            <p class='mt-1.5 text-sm text-petrol-700 leading-relaxed'>
              Recibirás una evaluación de tu situación actual y las oportunidades reales de tu negocio.
            </p>
          </div>
        </div>

        <!-- Divider -->
        <div class='h-px bg-petrol-100'></div>

        <!-- Signal 3 -->
        <div data-animate class='flex gap-5 items-start py-8'>
          <div
            class='shrink-0 size-11 rounded-full bg-petrol-900 flex items-center justify-center'
            style='box-shadow: 0 4px 16px rgba(26,60,74,0.2);'>
            <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' class='size-5 text-orange-400'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z' />
            </svg>
          </div>
          <div>
            <p class='text-sm font-bold text-petrol-900 uppercase tracking-wide'>¿Prefieres llamar o WhatsApp?</p>
            <p class='mt-1.5 text-sm text-petrol-700'>
              <a href='tel:+34692051399' class='font-bold text-orange-500 hover:text-orange-600 transition-colors'>
                +34 692 051 399
              </a>
            </p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const ctaForm = document.getElementById('cta-email-form') as HTMLFormElement;
  const ctaSubmitBtn = document.getElementById('cta-submit-btn') as HTMLButtonElement;
  const ctaMessageDiv = document.getElementById('cta-form-message') as HTMLDivElement;
  const ctaMessageP = ctaMessageDiv.querySelector('p') as HTMLParagraphElement;

  const parseApiResponse = async (response: Response) => {
    const rawBody = await response.text();
    const contentType = response.headers.get('content-type') || '';
    const isJsonResponse = contentType.includes('application/json');

    if (!isJsonResponse) {
      return { data: null, rawBody, isJsonResponse };
    }

    try {
      return { data: JSON.parse(rawBody), rawBody, isJsonResponse: true };
    } catch {
      return { data: null, rawBody, isJsonResponse: false };
    }
  };

  ctaForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    ctaSubmitBtn.disabled = true;
    ctaSubmitBtn.textContent = 'Enviando...';
    ctaMessageDiv.classList.add('hidden');

    try {
      const formData = new FormData(ctaForm);
      const response = await fetch('/api/send-cta-email', {
        method: 'POST',
        body: formData
      });

      const { data, rawBody, isJsonResponse } = await parseApiResponse(response);

      if (!response.ok) {
        const errorMessage =
          data && typeof data === 'object' && 'error' in data
            ? String(data.error)
            : null;
        const looksLikeHtml = rawBody.trim().startsWith('<');
        throw new Error(
          errorMessage ||
            (looksLikeHtml
              ? 'El servicio de envío no está disponible ahora mismo.'
              : 'Error al enviar el email')
        );
      }

      if (!isJsonResponse) {
        throw new Error('Respuesta inesperada del servidor. Inténtalo de nuevo.');
      }

      ctaMessageP.textContent = '¡Email enviado! Te contactaré pronto.';
      ctaMessageP.className = 'text-sm text-green-400';
      ctaForm.reset();
    } catch (error) {
      ctaMessageP.textContent = error instanceof Error ? error.message : 'Error al enviar el email. Inténtalo de nuevo.';
      ctaMessageP.className = 'text-sm text-red-400';
    }

    ctaSubmitBtn.disabled = false;
    ctaSubmitBtn.textContent = 'Analiza mi web';
    ctaMessageDiv.classList.remove('hidden');
  });
</script>
