---
import { Check, Search, FileText, Link } from '@lucide/astro'
import AccentRule from '../../AccentRule.astro'

interface Props {
  upheading?: string
  heading: string
  subtitle: string
}

const { upheading, heading, subtitle } = Astro.props

const services = [
  {
    num: '01',
    icon: Search,
    label: 'Descubrimiento y diagnóstico',
    title: 'Análisis inicial',
    intro:
      'Antes de invertir un solo euro, un diagnóstico real de tu situación revela por qué tu web no está captando clientes y cuál es el plan de ataque directo.',
    bullets: [
      { label: 'Auditoría y viabilidad', body: 'Diagnóstico de los errores que frenan tu web y validación de si el posicionamiento orgánico es el motor que tu negocio necesita ahora mismo.' },
      { label: 'Estudio de demanda', body: 'Mapa de las búsquedas reales de tus clientes en Google, filtradas por volumen e intención de compra para priorizar las que generan facturación.' },
      { label: 'Arquitectura web', body: 'Estructura de servicios optimizada para que Google te muestre correctamente y tus clientes encuentren lo que buscan sin fricción.' },
      { label: 'Auditoría técnica', body: 'Corrección de los fallos de carga y rastreo que frenan tu visibilidad. Si Google no puede recorrer tu web, tu negocio no aparece.' },
      { label: 'Estrategia de impacto', body: 'Hoja de ruta con las acciones ordenadas por retorno esperado. Cada paso apunta directamente a generar resultados medibles.' },
      { label: 'Consultoría directa', body: 'Criterio técnico disponible en cada paso para resolver dudas y validar decisiones con seguridad.' },
      { label: 'Análisis de competencia', body: 'Mapa detallado de quién ocupa tus posiciones en Google, qué estrategias aplican y cuáles son los flancos por donde adelantarles.' },
    ],
  },
  {
    num: '02',
    icon: FileText,
    label: 'Optimización dentro de tu web',
    title: 'SEO On Page',
    intro:
      'Cada página de tu web necesita un objetivo claro y una respuesta precisa a lo que tu cliente busca. Si el contenido no conecta con esa intención, tu web no factura.',
    bullets: [
      { label: 'Optimización de intención', body: 'Títulos, metadatos y encabezados alineados para que cada URL responda exactamente a lo que tu cliente quiere encontrar.' },
      { label: 'Contenidos de negocio', body: 'Textos diseñados para atraer visitantes cualificados y transformar la lectura en oportunidades de venta reales.' },
      { label: 'Contenidos que resuelven', body: 'Páginas que responden las preguntas reales de tu audiencia. Resolver la duda del visitante es el primer paso para convertirlo en cliente.' },
      { label: 'Enlazado interno estratégico', body: 'Red de conexiones entre tus páginas que guía a Google por tu estructura y concentra la autoridad en tus servicios más rentables.' },
      { label: 'Control de visibilidad', body: 'Google solo dedica recursos a las páginas que generan negocio. Las páginas irrelevantes que diluyen tu relevancia se eliminan del índice.' },
      { label: 'Velocidad y estabilidad de carga', body: 'Una web rápida retiene al visitante y mejora su posición en Google. En Barcelona nadie espera: la lentitud cuesta clientes.' },
    ],
  },
  {
    num: '03',
    icon: Link,
    label: 'Autoridad fuera de tu web',
    title: 'SEO Off Page',
    intro:
      'No basta con ser el mejor en Barcelona; los demás tienen que decirlo. Lo que ocurre fuera de tu web confirma a Google que eres una apuesta segura.',
    bullets: [
      { label: 'Enlaces de autoridad', body: 'Red de enlaces en sitios relevantes que transfieren fuerza real a tu dominio.' },
      { label: 'Auditoría de enlaces entrantes', body: 'Control total de quién enlaza a tu web. Los enlaces tóxicos que pueden estar hundiendo tu posicionamiento se identifican y eliminan.' },
      { label: 'Contenidos que atraen enlaces', body: 'Activos de contenido tan relevantes que otras webs enlazan de forma natural. Autoridad orgánica y sostenible a medio plazo.' },
      { label: 'Reputación y confianza', body: 'Menciones y reseñas que refuerzan tu marca ante Google y dan seguridad a tu cliente antes de comprar.' },
      { label: 'Estrategia de autoridad', body: 'Plan de crecimiento a medio plazo con un ritmo natural. Una ventaja competitiva resistente a actualizaciones del algoritmo.' },
    ],
  },
]
---

<section id='servicios' class='relative overflow-hidden py-24 sm:py-32 bg-(--color-cream)' style='color: var(--color-base)'>

  <!-- ── Dot-grid texture ──────────────────────────────────────────── -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
  ></div>

  <!-- ── Faded Brawler watermark ─────────────────────────────────── -->
  <div class="font-heading pointer-events-none absolute -right-6 top-0 select-none leading-none text-wm font-bold text-base/[0.07]"
    aria-hidden='true'
  >
    SEO
  </div>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sage/20 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sage/20 to-transparent' aria-hidden='true'></div>

  <div class='relative container-site'>

    <!-- ── Section header ─────────────────────────────────────────── -->
    <div class='mb-16 md:mb-20 max-w-3xl'>

      <!-- Eyebrow -->
      {upheading && (
        <div data-animate class='mb-8'>
          <h2 class='text-xs font-bold uppercase tracking-widest'>{upheading}</h2>
        </div>
      )}

      <!-- Section heading -->
      <p
        data-animate
        class='font-heading text-h2 font-bold leading-[1.05] tracking-tight text-pretty mb-4'
        set:html={heading + '<span class="text-sage">.</span>'}
      />

      <!-- Accent rule -->
      <AccentRule color='base' data-animate />


      <!-- Subtitle -->
      <p data-animate class='mt-6 text-base opacity-70 leading-relaxed text-pretty max-w-[52ch]'>
        <Fragment set:html={subtitle} />
      </p>
    </div>

    <!-- ── Service cards ──────────────────────────────────────────── -->
    <ul
      role='list'
      class='grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3'
    >
      {services.map((service, idx) => {
        const Icon = service.icon
        return (
          <li
            data-animate
            data-animate-delay={idx * 130}
            class='group relative flex flex-col rounded-2xl border border-surface/20 bg-white overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-surface/10 hover:border-sage/40'
          >
            <!-- Left accent bar (hover reveal) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sage scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'
            ></div>

            <!-- ── Dark banner header ──────────────────────────── -->
            <div class='relative overflow-hidden bg-surface px-6 py-7 flex flex-col gap-4'>

              <!-- Diagonal tension line -->
              <svg class='pointer-events-none absolute inset-0 w-full h-full' aria-hidden='true' preserveAspectRatio='none'>
                <line x1='60%' y1='0%' x2='100%' y2='100%' stroke='rgba(236,223,204,0.08)' stroke-width='1' />
              </svg>

              <!-- Ghost ordinal watermark -->
              <div class="font-heading pointer-events-none absolute -right-1 -bottom-3 select-none leading-none transition-opacity duration-300 text-cream/10"
                aria-hidden='true'
              >
                {service.num}
              </div>

              <!-- Icon badge + service label -->
              <div class='relative flex items-center gap-3'>
                <div class='flex size-7 shrink-0 items-center justify-center rounded-lg bg-cream/15 ring-1 ring-cream/20'>
                  <Icon aria-hidden='true' class='size-3.5 text-cream' />
                </div>
                <span class='text-xs font-semibold tracking-[0.12em] uppercase text-white/40'>
                  {service.label}
                </span>
              </div>

              <!-- Service number + title -->
              <div class='relative'>
                <div class='flex items-baseline gap-2.5'>
                  <span class='font-heading text-h4 leading-none font-bold text-cream/50 tabular-nums shrink-0'>
                    {service.num}
                  </span>
                  <h3 class='font-heading text-h6 font-bold text-white tracking-tight leading-snug'>
                    {service.title}
                  </h3>
                </div>
              </div>
            </div>

            <!-- ── Card body ──────────────────────────────────── -->
            <div class='flex flex-col gap-5 p-6 flex-1'>

              <!-- Bullets -->
              <ul role='list' class='space-y-3'>
                {service.bullets.map((bullet) => (
                  <li class='flex gap-3'>
                    <Check class='mt-0.5 size-4 shrink-0 text-sage' aria-hidden='true' />
                    <span>
                      <h4 class='inline text-sm font-semibold'>{bullet.label}</h4>
                      <span class='text-sm text-sage'> — {bullet.body}</span>
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        )
      })}
    </ul>

  </div>
</section>
