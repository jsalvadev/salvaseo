---
import { Check, Search, FileText, Link } from '@lucide/astro'

interface Props {
  upheading?: string
  heading: string
  subtitle: string
}

const { upheading, heading, subtitle } = Astro.props

const services = [
  {
    num: '01',
    icon: Search,
    label: 'Descubrimiento y diagnóstico',
    title: 'Análisis inicial',
    intro:
      'Antes de invertir un solo euro, un diagnóstico real de tu situación revela por qué tu web no está captando clientes y cuál es el plan de ataque directo.',
    bullets: [
      { label: 'Auditoría y viabilidad', body: 'Miro qué está fallando en tu web y si tiene sentido invertir en SEO antes de que gastes un euro.' },
      { label: 'Estudio de demanda', body: 'Averiguo cuánta gente busca tu oficio en tu zona y qué palabras exactas escribe en Google para encontrarte.' },
      { label: 'Arquitectura web', body: 'Organizo tu web para que Google sepa exactamente qué ofreces y dónde trabajas.' },
      { label: 'Auditoría técnica', body: 'Si tu web carga lenta o tiene errores que Google no puede leer, no apareces. Lo detecto y lo arreglo.' },
      { label: 'Estrategia de impacto', body: 'Te explico qué voy a hacer, en qué orden y por qué. Sin sorpresas.' },
      { label: 'Consultoría directa', body: 'Si tienes una duda o quieres saber cómo va, me llamas y te lo explico.' },
      { label: 'Análisis de competencia', body: 'Miro quién aparece antes que tú en Google y por qué. Luego trabajo para adelantarles.' },
    ],
  },
  {
    num: '02',
    icon: FileText,
    label: 'Optimización dentro de tu web',
    title: 'SEO On Page',
    intro:
      'Cada página de tu web necesita un objetivo claro y una respuesta precisa a lo que tu cliente busca. Si el contenido no conecta con esa intención, tu web no factura.',
    bullets: [
      { label: 'Optimización de intención', body: 'Preparo cada página de tu web para que aparezca cuando alguien busca exactamente lo que tú ofreces.' },
      { label: 'Contenidos de negocio', body: 'Escribo los textos de tu web para que quien entra, llame o pida presupuesto.' },
      { label: 'Contenidos que resuelven', body: 'Creo páginas que responden las dudas que tiene tu cliente antes de contratarte. Así llega convencido.' },
      { label: 'Enlazado interno estratégico', body: 'Conecto las páginas de tu web entre sí para que Google entienda cuáles son las más importantes.' },
      { label: 'Control de visibilidad', body: 'Elimino las páginas que no sirven para nada. Cuantas menos páginas malas, mejor posiciona tu web.' },
      { label: 'Velocidad y estabilidad de carga', body: 'Si tu web tarda en cargar, el cliente se va. La hago rápida para que no pierdas a nadie por eso.' },
    ],
  },
  {
    num: '03',
    icon: Link,
    label: 'Autoridad fuera de tu web',
    title: 'SEO Off Page',
    intro:
      'No basta con ser el mejor en Barcelona; los demás tienen que decirlo. Lo que ocurre fuera de tu web confirma a Google que eres una apuesta segura.',
    bullets: [
      { label: 'Enlaces de autoridad', body: 'Consigo que otras webs mencionen la tuya. Para Google, eso es una señal de que eres de confianza.' },
      { label: 'Auditoría de enlaces entrantes', body: 'Reviso si hay webs malas apuntando a la tuya sin que lo sepas. Eso puede estar hundiendo tu posición en Google y lo elimino.' },
      { label: 'Contenidos que atraen enlaces', body: 'Creo contenido que otras webs quieren compartir. Cada mención es un voto para que Google te suba.' },
      { label: 'Reputación y confianza', body: 'Gestiono tus reseñas y menciones online para que Google y tus clientes vean que eres un negocio serio.' },
      { label: 'Estrategia de autoridad', body: 'Trabajo mes a mes para que tu posición en Google suba y se mantenga, aunque Google cambie sus reglas.' },
    ],
  },
]
---

<section id='servicios' class='relative overflow-hidden py-24 sm:py-32 bg-gradient-to-br from-cream via-cream to-sand/25' style='color: var(--color-base)'>

  <!-- ── Dot-grid texture ──────────────────────────────────────────── -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
  ></div>

  <!-- ── Faded Brawler watermark ─────────────────────────────────── -->
  <div class="font-heading pointer-events-none absolute -right-6 top-0 select-none leading-none text-wm font-bold text-base/[0.07]"
    aria-hidden='true'
  >
    SEO
  </div>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sage/20 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sage/20 to-transparent' aria-hidden='true'></div>

  <div class='relative container-site'>

    <!-- ── Section header ─────────────────────────────────────────── -->
    <div class='mb-16 md:mb-20 max-w-3xl'>

      <!-- Eyebrow -->
      {upheading && (
        <div data-animate>
          <h2 class='text-xs font-bold uppercase tracking-widest'>{upheading}</h2>
        </div>
      )}

      <!-- Section heading -->
      <p
        data-animate
        class='mt-5 font-heading text-h2 font-normal leading-[1.05] tracking-tight text-pretty mb-4'
        set:html={heading + '<span class="text-sage">.</span>'}
      />

      <!-- Accent rule -->
      <div data-animate class='mt-6 flex items-center'>
        <div class='h-px w-32 bg-gradient-to-r from-base/5 to-base/35'></div>
        <div class='h-px w-10 bg-base/60'></div>
      </div>


      <!-- Subtitle -->
      <p data-animate class='mt-6 text-base opacity-70 leading-relaxed text-pretty max-w-[52ch]'>
        <Fragment set:html={subtitle} />
      </p>
    </div>

    <!-- ── Service cards ──────────────────────────────────────────── -->
    <ul
      role='list'
      class='grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3'
    >
      {services.map((service, idx) => {
        const Icon = service.icon
        return (
          <li
            data-animate
            data-animate-delay={idx * 130}
            class='group relative flex flex-col rounded-2xl bg-white overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-surface/10'
          >
            <!-- Left accent bar (hover reveal) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-surface scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'
            ></div>

            <!-- ── Dark banner header ──────────────────────────── -->
            <div class='relative overflow-hidden bg-surface px-6 py-7 flex flex-col gap-4'>

              <!-- Diagonal tension line -->
              <svg class='pointer-events-none absolute inset-0 w-full h-full' aria-hidden='true' preserveAspectRatio='none'>
                <line x1='60%' y1='0%' x2='100%' y2='100%' stroke='rgba(236,223,204,0.08)' stroke-width='1' />
              </svg>

              <!-- Ghost ordinal watermark -->
              <div class="font-heading pointer-events-none absolute -right-1 -bottom-3 select-none leading-none transition-opacity duration-300 text-cream/10 hidden lg:block"
                aria-hidden='true'
              >
                {service.num}
              </div>

              <!-- Icon badge + service label -->
              <div class='relative flex items-center gap-3'>
                <div class='flex size-7 shrink-0 items-center justify-center rounded-lg bg-cream/15 ring-1 ring-cream/20'>
                  <Icon aria-hidden='true' class='size-3.5 text-cream' />
                </div>
                <span class='text-xs font-semibold tracking-[0.12em] uppercase text-white/40'>
                  {service.label}
                </span>
              </div>

              <!-- Service number + title -->
              <div class='relative'>
                <div class='flex items-baseline gap-2.5'>
                  <span class='font-heading text-h4 leading-none font-bold text-cream/50 tabular-nums shrink-0'>
                    {service.num}
                  </span>
                  <h3 class='font-heading text-h6 font-bold text-white tracking-tight leading-snug'>
                    {service.title}
                  </h3>
                </div>
              </div>
            </div>

            <!-- ── Card body ──────────────────────────────────── -->
            <div class='flex flex-col gap-5 p-6 flex-1'>

              <!-- Bullets -->
              <ul role='list' class='space-y-3'>
                {service.bullets.map((bullet) => (
                  <li class='flex gap-3'>
                    <Check class='mt-0.5 size-4 shrink-0 text-sage' aria-hidden='true' />
                    <span>
                      <h4 class='inline text-base font-semibold'>{bullet.label}</h4>
                      <span class='text-base text-sage'> — {bullet.body}</span>
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        )
      })}
    </ul>

  </div>
</section>
