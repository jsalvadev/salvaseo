---
import { Users, BadgeCheck, CalendarClock, TrendingUp } from '@lucide/astro'

type IconKey = 'users' | 'badgeCheck' | 'calendarClock' | 'trendingUp'

interface BannerItem {
  icon: IconKey
  value: string
  label: string
}

interface Props {
  items?: BannerItem[]
}

const iconByKey = {
  users: Users,
  badgeCheck: BadgeCheck,
  calendarClock: CalendarClock,
  trendingUp: TrendingUp,
} as const

const ringColors = ['teal', 'teal', 'teal', 'teal'] as const

const defaultItems: BannerItem[] = [
  { icon: 'users', value: 'Trato directo', label: 'sin intermediarios' },
  { icon: 'badgeCheck', value: 'Auditoría gratuita', label: 'valorada en 200 €' },
  { icon: 'calendarClock', value: 'Sin contratos', label: 'de permanencia' },
  { icon: 'trendingUp', value: 'Resultados en 3-6 meses', label: 'según tu sector' },
]

const { items = defaultItems } = Astro.props
---

<div class='relative bg-charcoal py-16 lg:py-20 overflow-hidden'>
  <!-- diagonal texture -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.04]'
    style='background-image: repeating-linear-gradient(135deg, rgba(52,101,109,0.5) 0 1px, transparent 1px 16px);'
    aria-hidden='true'></div>
  <div class='relative mx-auto max-w-[1280px] px-5'>
    <dl data-animate class='grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4'>
      {items.map((item, idx) => {
        const Icon = iconByKey[item.icon]
        return (
          <div class='rounded-xl bg-white/5 backdrop-blur-sm border border-white/5 px-6 py-8 flex flex-col items-center gap-3 text-center transition-colors hover:bg-white/[0.08]'>
            <div class='flex size-10 items-center justify-center rounded-full ring-1 bg-sand/10 ring-sand/20'>
              <Icon class='size-5 text-sand' aria-hidden='true' />
            </div>
            <dt class='text-xl font-semibold text-white'>{item.value}</dt>
            <dd class='text-sm text-white/75'>{item.label}</dd>
          </div>
        )
      })}
    </dl>
  </div>
</div>
