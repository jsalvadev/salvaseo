---
import WhatsAppButton from '../../WhatsAppButton.astro'
import Breadcrumb from '../../Breadcrumb.astro'
import { buildWhatsAppHref } from '../../../data/site'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  upheading?: string
  primaryCtaText?: string
  breadcrumbItems?: BreadcrumbItem[]
}

const {
  upheading = 'Posicionamiento web en Barcelona',
  primaryCtaText = 'Analiza mi web',
  breadcrumbItems,
} = Astro.props

const waHref = buildWhatsAppHref()
---

<section class='hero-section relative bg-petrol-900 overflow-hidden min-h-svh flex flex-col justify-center'>

  <!-- Eixample grid texture (Barcelona's characteristic city block pattern) -->
  <div class='pointer-events-none absolute inset-0' aria-hidden='true'>
    <svg class='absolute inset-0 w-full h-full opacity-[0.035]' xmlns='http://www.w3.org/2000/svg'>
      <defs>
        <pattern id='eixample' x='0' y='0' width='64' height='64' patternUnits='userSpaceOnUse'>
          <rect x='4' y='4' width='56' height='56' fill='none' stroke='white' stroke-width='0.75'/>
          <line x1='4' y1='14' x2='14' y2='4' stroke='white' stroke-width='0.75'/>
          <line x1='50' y1='4' x2='60' y2='14' stroke='white' stroke-width='0.75'/>
          <line x1='60' y1='50' x2='50' y2='60' stroke='white' stroke-width='0.75'/>
          <line x1='14' y1='60' x2='4' y2='50' stroke='white' stroke-width='0.75'/>
        </pattern>
      </defs>
      <rect width='100%' height='100%' fill='url(#eixample)'/>
    </svg>
  </div>

  <!-- Radial ambient — top left (sky) -->
  <div
    class='pointer-events-none absolute -top-40 -left-40 w-[640px] h-[640px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 60%);'>
  </div>

  <!-- Radial ambient — bottom right (orange) -->
  <div
    class='pointer-events-none absolute -bottom-32 -right-32 w-[480px] h-[480px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(249,115,22,0.08) 0%, transparent 65%);'>
  </div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line x1='60%' y1='0%' x2='85%' y2='100%' stroke='rgba(249,115,22,0.06)' stroke-width='1'/>
    <line x1='66%' y1='0%' x2='92%' y2='100%' stroke='rgba(14,165,233,0.04)' stroke-width='1'/>
  </svg>

  <!-- Bottom hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-orange-500/20 to-transparent'
    aria-hidden='true'>
  </div>

  <!-- Breadcrumb — absolute so it doesn't affect vertical centering -->
  {breadcrumbItems && (
    <div class='absolute top-0 left-0 right-0 z-10'>
      <Breadcrumb items={breadcrumbItems} dark={true} />
    </div>
  )}

  <!-- Main content -->
  <div class='relative mx-auto max-w-7xl px-6 lg:px-8 py-16 sm:py-20 lg:py-24'>

    <!-- Upheading pill -->
    <div class='hero-upheading animate-fade-in-up [animation-delay:0ms]'>
      <span class='upheading-dot' aria-hidden='true'></span>
      <h1 class='upheading-text'>{upheading}</h1>
    </div>

    <!-- Main heading -->
    <div class='hero-heading animate-fade-in-up [animation-delay:70ms]' style='font-family: "Titan One", cursive;'>
      <span class='hero-h-line1'>Deja de perder clientes</span>
      <span class='hero-h-line3'>
        <span class='hero-h-muted'>frente a tu&nbsp;</span><span class='hero-h-orange'>competencia.</span>
      </span>
    </div>

    <!-- Accent rule -->
    <div class='hero-rule animate-fade-in-up [animation-delay:150ms]' aria-hidden='true'>
      <div class='hero-rule-solid'></div>
      <div class='hero-rule-fade'></div>
    </div>

    <!-- Body copy -->
    <p class='animate-fade-in-up [animation-delay:220ms] mt-5 max-w-[52ch] text-[1.0625rem] leading-relaxed text-pretty' style='color: rgba(255,255,255,0.62);'>
      En Barcelona, <strong style='color: rgba(255,255,255,0.9); font-weight: 600;'>o eres el primero o eres el secreto de tu competencia.</strong> Aparece primero en Google y pon tu web a generar contactos de verdad.
    </p>

    <p class='animate-fade-in-up [animation-delay:280ms] mt-3 max-w-[46ch] text-[1.0625rem] leading-relaxed text-pretty' style='color: rgba(255,255,255,0.62);'>
      Si te buscan, <strong style='color: rgba(255,255,255,0.9); font-weight: 600;'>que te encuentren a ti primero.</strong>
    </p>

    <!-- CTA -->
    <div class='animate-fade-in-up [animation-delay:380ms] mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4'>
      <WhatsAppButton
        text={primaryCtaText}
        href={waHref}
        class='px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-sky-500/20 hover:shadow-sky-500/30 transition-shadow'
      />
    </div>

  </div>
</section>

<style>
  /* ── Upheading pill ── */
  .hero-upheading {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(249, 115, 22, 0.1);
    border: 1px solid rgba(249, 115, 22, 0.25);
    border-radius: 100px;
    padding: 0.3rem 0.85rem 0.3rem 0.6rem;
    margin-bottom: 1.5rem;
  }

  .upheading-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-orange-500);
    flex-shrink: 0;
    animation: dot-pulse 2.2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.4); }
    50%       { box-shadow: 0 0 0 5px rgba(249,115,22,0); }
  }

  .upheading-text {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(249, 115, 22, 0.85);
    line-height: 1;
  }

  /* ── Heading ── */
  .hero-heading {
    display: flex;
    flex-direction: column;
    letter-spacing: -0.02em;
    line-height: 0.9;
  }

  .hero-h-line1 {
    display: block;
    font-size: clamp(2.25rem, 5vw, 4rem);
    color: white;
    line-height: 0.92;
  }

  .hero-h-line3 {
    display: block;
    font-size: clamp(1.1rem, 2.3vw, 1.9rem);
    line-height: 1.1;
    margin-top: 0.22em;
  }

  .hero-h-muted  { color: rgba(255, 255, 255, 0.32); }
  .hero-h-orange { color: var(--color-orange-400); }

  /* ── Accent rule ── */
  .hero-rule {
    display: flex;
    align-items: center;
    margin-top: 1.25rem;
  }

  .hero-rule-solid {
    width: 3.5rem;
    height: 3px;
    background: var(--color-orange-500);
    border-radius: 100px;
  }

  .hero-rule-fade {
    width: 5rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(249,115,22,0.5), transparent);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .upheading-dot { animation: none; }
  }
</style>
