---
import { Search, TrendingUp, Users } from '@lucide/astro'
import WhatsAppButton from '../../WhatsAppButton.astro'
import barcelonaImage from '../../../assets/barcelona.webp'

interface Props {
  upheading: string
  heading: string
  description: string
  primaryCtaText: string
  secondaryCtaText: string
  secondaryCtaHref: string
}

const { upheading, heading, description, primaryCtaText, secondaryCtaText, secondaryCtaHref } = Astro.props
---

<div class='bg-petrol-900'>
  <div class='relative isolate overflow-hidden px-6 lg:px-8'>
    <img
      src={barcelonaImage.src}
      alt=''
      class='absolute inset-0 -z-10 size-full object-cover opacity-20 [mask-image:linear-gradient(to_right,transparent_30%,black_70%)]'
      loading='eager'
      decoding='async'
    />

    <div class='mx-auto max-w-3xl py-24 sm:py-32 lg:py-40'>
      <div class='hidden sm:mb-8 sm:flex sm:justify-center'>
        <h1 class='relative rounded-full bg-sky-500/10 border border-sky-400/20 px-3 py-1 text-sm/6 text-sky-300'>
          {upheading}
        </h1>
      </div>
      <div class='text-center'>
        <p class='text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl'>
          {heading}
        </p>
        <p class='mt-8 text-lg font-medium text-pretty text-petrol-100 sm:text-xl/8'>
          <Fragment set:html={description} />
        </p>
        <div class='mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-x-6'>
          <WhatsAppButton text={primaryCtaText} />
          <a
            href={secondaryCtaHref}
            class='text-sm/6 font-semibold text-white hover:text-sky-300 transition-colors'>
            {secondaryCtaText} <span aria-hidden='true'>→</span>
          </a>
        </div>
        <div class='mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3'>
          <span class='inline-flex items-center gap-2 text-sm text-petrol-100'>
            <Search class='size-4' aria-hidden='true' />
            Google #1
          </span>
          <span class='inline-flex items-center gap-2 text-sm text-petrol-100'>
            <TrendingUp class='size-4' aria-hidden='true' />
            Más contactos
          </span>
          <span class='inline-flex items-center gap-2 text-sm text-petrol-100'>
            <Users class='size-4' aria-hidden='true' />
            Más clientes
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
