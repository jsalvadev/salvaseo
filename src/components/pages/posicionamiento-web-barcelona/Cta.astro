---
import { Search, TrendingUp, Users } from '@lucide/astro'
import Upheading from '../../Upheading.astro'
import WhatsAppButton from '../../WhatsAppButton.astro'

interface Props {
  upheading?: string
  heading: string
  text: string
  layout?: 'side-by-side' | 'centered'
  primaryCtaText: string
  secondaryCtaText?: string
  secondaryCtaHref?: string
}

const {
  upheading,
  heading,
  text,
  layout = 'side-by-side',
  primaryCtaText,
  secondaryCtaText,
  secondaryCtaHref,
} = Astro.props
---

<div class:list={['relative bg-teal overflow-hidden', layout === 'centered' && 'px-6 lg:px-8']}>
  <!-- gradient mesh -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'></div>
  <!-- dot grid -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.10]'
    aria-hidden='true'></div>
  <!-- floating decorative rings -->
  <div
    class='pointer-events-none absolute -top-20 -left-20 size-80 rounded-full border border-sand/10'
    aria-hidden='true'></div>
  <div
    class='pointer-events-none absolute -bottom-24 -right-24 size-96 rounded-full border border-sand/[0.08]'
    aria-hidden='true'></div>

  {layout === 'side-by-side' ? (
    <div
      data-animate
      class='relative mx-auto max-w-[1280px] px-5 py-24 sm:py-32 lg:flex lg:items-center lg:justify-between'>
      <div>
        {upheading && <Upheading as='h2' text={upheading} color='var(--color-sand)' />}
        <p
          class='max-w-2xl text-4xl font-semibold tracking-tight text-white sm:text-5xl text-pretty'>
          {heading}
        </p>
        <!-- accent bar -->
        <div class='mt-4 h-1 w-20 rounded-full bg-gradient-to-r from-sand to-sand/60'></div>
        <p class='mt-6 max-w-xl text-lg text-white/75'>
          <Fragment set:html={text} />
        </p>
      </div>
      <div
        class='mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-x-6 lg:mt-0 lg:shrink-0'>
        <WhatsAppButton text={primaryCtaText} />
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class='text-sm/6 font-semibold text-white hover:text-sand transition-colors'>
            {secondaryCtaText}
            <span aria-hidden='true'>→</span>
          </a>
        )}
      </div>
    </div>
  ) : (
    <div data-animate class='relative mx-auto max-w-2xl py-24 sm:py-32 text-center'>
      {upheading && <Upheading as='h2' text={upheading} />}
      <p
        class='mt-2 text-4xl font-semibold tracking-tight text-white sm:text-5xl'>
        {heading}
      </p>
      <!-- accent bar -->
      <div class='mx-auto mt-4 h-1 w-20 rounded-full bg-gradient-to-r from-sand to-sand/60'></div>
      <p class='mt-6 text-lg/8 text-white/75'>
        <Fragment set:html={text} />
      </p>
      <div
        class='mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-x-6'>
        <WhatsAppButton text={primaryCtaText} />
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class='text-sm/6 font-semibold text-white hover:text-sand transition-colors'>
            {secondaryCtaText} →
          </a>
        )}
      </div>
    </div>
  )}
</div>
