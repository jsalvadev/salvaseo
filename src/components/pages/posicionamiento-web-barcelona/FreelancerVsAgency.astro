---
import { MapPinned, MessageCircle, PiggyBank } from '@lucide/astro'
import HeadingRule from '../../HeadingRule.astro'

const benefits = [
  {
    num: '01',
    icon: MessageCircle,
    accentClass: 'bg-sage/10 ring-sage/25',
    iconClass: 'text-sage',
    barClass: 'bg-sage',
    heading: 'Acceso directo al especialista',
    body: 'Resuelve dudas y valida cambios técnicos <strong>al instante</strong> por WhatsApp, videollamada o email. Al eliminar las capas intermedias, tu proyecto gana en precisión y el tiempo de respuesta se reduce al mínimo.',
  },
  {
    num: '02',
    icon: MapPinned,
    accentClass: 'bg-sage/10 ring-sage/25',
    iconClass: 'text-sage',
    barClass: 'bg-sage',
    heading: 'Estrategia adaptada a tu zona',
    body: 'Aprovecha un conocimiento profundo del mercado de Barcelona. Tu web se posiciona respondiendo a la realidad de tu barrio y sector, captando el tráfico que genera <strong>facturación real en tu zona</strong>.',
  },
  {
    num: '03',
    icon: PiggyBank,
    accentClass: 'bg-sage/10 ring-sage/25',
    iconClass: 'text-sage',
    barClass: 'bg-sage',
    heading: 'Tu presupuesto rinde al máximo',
    body: 'Maximiza tu presupuesto destinándolo exclusivamente a optimizar tu web. Un modelo eficiente pensado para pymes y negocios locales.',
  },
]
---

<div class='relative overflow-hidden py-24 sm:py-32'>

  <!-- ── Subtle linear grid texture ───────────────────────────────── -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
  ></div>

  <!-- ── Faded Titan One watermark ─────────────────────────────────── -->
  <div class="font-heading pointer-events-none absolute -left-6 top-1/2 -translate-y-1/2 select-none leading-none hidden lg:block"
    aria-hidden='true'
  >
    DIRECTO
  </div>

  <!-- ── Orange corner accent (right edge) ─────────────────────────── -->
  <div
    class='pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-40 bg-sage rounded-l-full'
    aria-hidden='true'
  ></div>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-teal/15 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal/15 to-transparent' aria-hidden='true'></div>

  <div class='relative container-site'>
    <div class='grid lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-20 items-start'>

      <!-- ── LEFT: sticky heading block ──────────────────────────────── -->
      <div class='lg:sticky lg:top-28'>

        <!-- Eyebrow -->
        <div data-animate class='flex items-center gap-3 mb-8'>
          <span class='block h-px w-10 bg-sage' aria-hidden='true'></span>
          <p class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sage'>
            Consultor freelance vs agencia de posicionamiento web en Barcelona
          </p>
        </div>

        <!-- Titan One heading -->
        <h2
          data-animate

          class='leading-[0.92] tracking-tight mb-6'
        >
          <span class='block font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] text-cream/60'>
            Alguien que
          </span>
          <span class='block font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] text-cream'>
            responde cuando llamas<span class='text-sage'>.</span>
          </span>
        </h2>

        <!-- Accent rule -->
        <HeadingRule thick color='var(--color-sage)' fadeColor='var(--color-teal)' data-animate />

        <!-- Subtitle -->
        <p data-animate class='mt-6 max-w-[40ch] text-base md:text-lg text-cream/70 leading-relaxed text-pretty'>
          Como negocio local o pyme, tu mayor ventaja es la velocidad de respuesta. Un servicio donde la estrategia y la ejecución técnica ocurren en el mismo lugar, sin esperas ni filtros.
        </p>

        <!-- Decorative vertical rule -->
        <div class='hidden lg:block mt-12 w-px h-20 bg-gradient-to-b from-teal/30 to-transparent' aria-hidden='true'></div>
      </div>

      <!-- ── RIGHT: benefit card list ─────────────────────────────── -->
      <ul class='flex flex-col gap-4 mt-2'>

        {benefits.map((benefit, idx) => {
          const Icon = benefit.icon
          return (
            <li
              data-animate
              data-animate-delay={idx * 120}
              class='group relative rounded-2xl border border-surface/10 bg-white px-6 py-6 transition-all duration-300 hover:border-teal/30 hover:shadow-xl hover:shadow-charcoal/5 overflow-hidden cursor-default'
            >

              <!-- Left accent bar (hover reveal) -->
              <div
                class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sage scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
                aria-hidden='true'
              ></div>

              <!-- Ghost ordinal watermark -->
              <div class="font-heading pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 select-none leading-none transition-opacity duration-300 opacity-60 group-hover:opacity-100 hidden lg:block"
                aria-hidden='true'
              >
                {benefit.num}
              </div>

              <!-- Card content -->
              <div class='relative flex items-start gap-4'>

                <!-- Icon badge -->
                <div class:list={[
                  'shrink-0 mt-0.5 flex size-10 items-center justify-center rounded-xl ring-1 transition-all duration-300',
                  benefit.accentClass,
                ]}>
                  <Icon aria-hidden='true' class:list={['size-5', benefit.iconClass]} />
                </div>

                <div class='min-w-0'>
                  <!-- Expanding accent line -->
                  <div
                    class:list={[
                      'h-0.5 w-8 rounded-full mb-3 transition-all duration-300 group-hover:w-16',
                      benefit.barClass,
                    ]}
                    aria-hidden='true'
                  ></div>

                  <h3 class='text-lg font-semibold tracking-tight text-cream mb-2 leading-snug transition-colors duration-300'>
                    {benefit.heading}
                  </h3>
                  <p
                    class='text-base/6 text-cream/70 text-pretty transition-colors duration-300 group-hover:text-sage'
                    set:html={benefit.body}
                  />
                </div>

              </div>
            </li>
          )
        })}

      </ul>
    </div>
  </div>
</div>
