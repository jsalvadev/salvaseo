---
import { MapPin } from '@lucide/astro'
import Upheading from '../../Upheading.astro'

interface AreaItem {
  title: string
  description: string
  stat?: string
}

interface Props {
  upheading: string
  heading: string
  intro: string
  areas: AreaItem[]
}

const { upheading, heading, intro, areas } = Astro.props
---

<div class='bg-white py-24 sm:py-32'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='mx-auto max-w-2xl text-center'>
      <Upheading as='h2' text={upheading} class='text-center' />
      <p class='mt-2 text-4xl font-semibold tracking-tight text-pretty text-petrol-900 sm:text-5xl'>
        {heading}
      </p>
      <div class='mt-6 text-lg/8 text-petrol-700'>
        <Fragment set:html={intro} />
      </div>
    </div>
    <div class='mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-4'>
      {areas.map((area) => (
        <div class='flex flex-col bg-petrol-50 rounded-lg p-5 border border-petrol-100'>
          <div class='flex items-center gap-3 mb-3'>
            <div class='flex size-8 shrink-0 items-center justify-center rounded-full bg-sky-50 text-sky-600'>
              <MapPin class='size-4' aria-hidden='true' />
            </div>
            {area.stat && (
              <span class='inline-block text-xs font-semibold text-sky-600 bg-sky-50 border border-sky-100 rounded-full px-2.5 py-0.5'>
                {area.stat}
              </span>
            )}
          </div>
          <h3 class='font-semibold text-petrol-900'>
            {area.title}
          </h3>
          <p class='mt-1 text-sm/6 text-petrol-700'>
            <Fragment set:html={area.description} />
          </p>
        </div>
      ))}
    </div>
  </div>
</div>
