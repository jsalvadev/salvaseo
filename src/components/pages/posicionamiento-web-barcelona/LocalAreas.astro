---
import { MapPin } from '@lucide/astro'
import Upheading from '../../Upheading.astro'

interface AreaItem {
  title: string
  description: string
}

interface Props {
  upheading: string
  heading: string
  intro: string
  areas: AreaItem[]
}

const { upheading, heading, intro, areas } = Astro.props
---

<div class='bg-white py-24 sm:py-32'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='mx-auto max-w-2xl text-center'>
      <Upheading as='h2' text={upheading} class='text-center' />
      <p class='mt-2 text-4xl font-semibold tracking-tight text-pretty text-petrol-900 sm:text-5xl'>
        {heading}
      </p>
      <div class='mt-6 text-lg/8 text-petrol-700'>
        <Fragment set:html={intro} />
      </div>
    </div>
    <div class='mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2 lg:mx-0 lg:max-w-none'>
      {areas.map((area) => (
        <div class='flex items-start gap-4 bg-petrol-50 rounded-lg p-5 border border-petrol-100'>
          <div class='flex size-10 shrink-0 items-center justify-center rounded-full bg-sky-50 text-sky-600'>
            <MapPin class='size-5' aria-hidden='true' />
          </div>
          <div>
            <h3 class='font-semibold text-petrol-900'>
              {area.title}
            </h3>
            <p class='mt-1 text-sm/6 text-petrol-700'>
              <Fragment set:html={area.description} />
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
