---
import { MapPin } from '@lucide/astro'

interface AreaItem {
  title: string
  description: string
  stat?: string
}

interface Props {
  upheading: string
  heading: string
  intro: string
  areas: AreaItem[]
}

const { upheading, heading, intro, areas } = Astro.props
---

<section class='relative overflow-hidden bg-white py-24 sm:py-32'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(26,60,74,0.05) 1px, transparent 1px); background-size: 32px 32px;'
  ></div>

  <!-- Ghost watermark -->
  <div
    class='pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none leading-none'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(10rem, 22vw, 18rem); color: rgba(249,115,22,0.04); line-height: 1; white-space: nowrap;'
  >
    CAT
  </div>

  <!-- Radial ambient glow -->
  <div
    class='pointer-events-none absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.04) 0%, transparent 65%);'
  ></div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'
  >
    <line x1='0%' y1='100%' x2='30%' y2='0%' stroke='rgba(26,60,74,0.04)' stroke-width='1' />
    <line x1='70%' y1='100%' x2='100%' y2='0%' stroke='rgba(249,115,22,0.03)' stroke-width='1' />
  </svg>

  <!-- Top/bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-petrol-100 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-petrol-100 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>

    <!-- ── Section header ─────────────────────────────────────────── -->
    <div class='mb-14 lg:mb-16 max-w-2xl'>

      <!-- Eyebrow -->
      <div data-animate class='flex items-center gap-3 mb-8'>
        <span class='block h-px w-10 bg-orange-500' aria-hidden='true'></span>
        <p class='text-[0.7rem] font-bold uppercase tracking-[0.22em] text-orange-500'>
          {upheading}
        </p>
      </div>

      <!-- Titan One heading — 2-line treatment -->
      <h2
        data-animate
        style='font-family: "Titan One", cursive;'
        class='leading-[0.92] tracking-tight text-pretty'
      >
        <span class='block text-[clamp(1.8rem,4vw,3rem)] text-petrol-700'>
          {heading.split(' ').slice(0, 2).join(' ')}
        </span>
        <span class='block text-[clamp(3rem,6vw,4.5rem)] text-petrol-900'>
          {heading.split(' ').slice(2).join(' ')}<span class='text-orange-400'>.</span>
        </span>
      </h2>

      <!-- Orange accent rule -->
      <div data-animate class='mt-6 flex items-center' aria-hidden='true'>
        <div class='h-[3px] w-16 bg-orange-500 rounded-full'></div>
        <div class='h-px w-24 bg-gradient-to-r from-orange-500/40 to-transparent'></div>
      </div>

      <!-- Intro HTML -->
      <div
        data-animate
        class='mt-6 [&_p]:text-base [&_p]:leading-relaxed [&_p]:text-petrol-700 [&_p]:text-pretty [&_p:not(:first-child)]:mt-4 [&_a]:text-sky-600 [&_a]:underline [&_a]:decoration-sky-300/50 [&_a:hover]:text-sky-700 [&_a:hover]:decoration-sky-400/70 [&_strong]:text-petrol-900 [&_strong]:font-semibold'
      >
        <Fragment set:html={intro} />
      </div>
    </div>

    <!-- ── Area ranking rows ──────────────────────────────────────── -->
    <div class='flex flex-col divide-y divide-petrol-100'>

      {areas.map((area, idx) => {
        const padNum = String(idx + 1).padStart(2, '0')
        const statParts = area.stat?.split(' ') ?? []
        const statNum = statParts[0] ?? ''
        const statUnit = statParts.slice(1).join(' ')

        return (
          <div
            data-animate
            data-animate-delay={idx * 120}
            class='group relative flex flex-col sm:flex-row gap-6 sm:gap-10 py-10 overflow-hidden cursor-default'
          >

            <!-- Ghost ordinal watermark -->
            <div
              class='pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 select-none leading-none transition-opacity duration-300 opacity-100 group-hover:opacity-[1.5]'
              aria-hidden='true'
              style='font-family: "Titan One", cursive; font-size: 7rem; color: rgba(26,60,74,0.06); line-height: 1;'
            >
              {padNum}
            </div>

            <!-- Left accent bar (hover reveal) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-orange-500 scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'
            ></div>

            <!-- ── Stat column ──────────────────────────────────── -->
            {area.stat && (
              <div class='shrink-0 flex flex-col justify-center sm:w-36'>
                <span
                  class='block text-[2.6rem] leading-none font-bold text-orange-500 tabular-nums transition-colors duration-300 group-hover:text-orange-600'
                  style='font-family: "Titan One", cursive;'
                >
                  {statNum}
                </span>
                <span class='mt-1 text-[0.55rem] font-bold uppercase tracking-[0.18em] text-orange-400 transition-colors duration-300 group-hover:text-orange-500'>
                  {statUnit}
                </span>
              </div>
            )}

            <!-- ── Content column ───────────────────────────────── -->
            <div class='relative min-w-0 flex-1'>

              <!-- City row meta -->
              <div class='flex items-center gap-2.5 mb-2'>
                <span class='text-[0.5rem] font-bold uppercase tracking-[0.2em] text-petrol-600/40'>
                  {padNum}
                </span>
                <MapPin aria-hidden='true' class='size-3 text-petrol-600/40' />
                <span class='text-[0.5rem] font-bold uppercase tracking-[0.2em] text-petrol-600/40'>
                  Cataluña
                </span>
              </div>

              <h3 class='text-lg font-semibold text-petrol-900 leading-snug transition-colors duration-300 group-hover:text-orange-600 mb-2.5'>
                {area.title}
              </h3>

              <p class='text-sm/6 text-petrol-600 text-pretty transition-colors duration-300 group-hover:text-petrol-700 max-w-[60ch]'>
                {area.description}
              </p>
            </div>

          </div>
        )
      })}

    </div>

  </div>
</section>
