---
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";
import Upheading from "../../Upheading.astro";
import WhatsAppButton from "../../WhatsAppButton.astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  subtitle?: string;
  sectionId?: string;
  phases?: TimelinePhase[];
  ctaHeading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const iconByKey = {
  scale: Scale,
  barChart3: BarChart3,
  badgeCheck: BadgeCheck,
  target: Target,
  trendingUp: TrendingUp,
  calendarClock: CalendarClock,
  chartNoAxesColumn: ChartNoAxesColumn,
  lineChart: LineChart,
  layers3: Layers3,
} as const;

const defaultPhases: TimelinePhase[] = [
  {
    title: "Diagnóstico técnico y análisis de mercado",
    intro:
      "Un mapa de los errores que frenan tu visibilidad y de las oportunidades de mercado que ahora pierdes. Problemas técnicos de tu web documentados junto a un estudio de las búsquedas de tus clientes.",
    bullets: [
      {
        icon: "scale",
        emphasis: "Diagnóstico competitivo.",
        text: "Comparativa de tu situación real frente a tus competidores directos.",
      },
      {
        icon: "barChart3",
        emphasis: "Demanda local real.",
        text: "Volumen de búsqueda verificado en tu zona y sector.",
      },
      {
        icon: "badgeCheck",
        emphasis: "Viabilidad confirmada.",
        text: "Verificación de la rentabilidad del proyecto antes de invertir.",
      },
    ],
    outro: "Auditoría gratuita con tus próximas acciones priorizadas por impacto.",
  },
  {
    title: "Estrategia de posicionamiento web SEO",
    intro:
      "La incertidumbre se sustituye por una hoja de ruta técnica. Con el diagnóstico en la mano, la estrategia desglosa las acciones necesarias para captar clientes en tu zona y sector.",
    bullets: [
      {
        icon: "target",
        emphasis: "Jerarquía de objetivos.",
        text: "Las búsquedas con mayor retorno potencial se atacan primero.",
      },
      {
        icon: "trendingUp",
        emphasis: "Estimación de visitas.",
        text: "Proyección realista del volumen de visitantes según tu mercado.",
      },
      {
        icon: "calendarClock",
        emphasis: "Cronograma de ejecución.",
        text: "Cambios técnicos planificados mes a mes con plazos estimados de consolidación.",
      },
    ],
    outro:
      "Cada paso del plan se valida antes de ejecutarlo. Si una acción no se alinea con tus objetivos de negocio, se descarta.",
  },
  {
    title: "Ejecución y resultados medibles",
    intro:
      "Mientras gestionas tu negocio, tu web escala posiciones y consolida su autoridad en Google. Métricas de negocio, no solo de visitas.",
    bullets: [
      {
        icon: "chartNoAxesColumn",
        emphasis: "Seguimiento de conversiones.",
        text: "Visitas que se transforman en llamadas reales o formularios completados, medidas mes a mes.",
      },
      {
        icon: "lineChart",
        emphasis: "Evolución de posiciones.",
        text: "Términos conquistados y próximos objetivos visibles en cada informe.",
      },
      {
        icon: "layers3",
        emphasis: "Crecimiento acumulativo.",
        text: "Un activo que mantiene su valor. A diferencia de la publicidad, tu posicionamiento persiste y se refuerza mes a mes.",
      },
    ],
    outro:
      "Captación del volumen de búsquedas de tu sector en Barcelona con conversión directa a clientes.",
  },
];

const {
  upheading,
  heading,
  subtitle = "Tres fases para ejecutar, medir y escalar. Visualiza el retorno de tu inversión en Barcelona mediante informes claros y objetivos cumplidos.",
  sectionId = "proceso",
  phases = defaultPhases,
  ctaHeading = "Identifica el potencial de tu negocio en Barcelona.",
  ctaText = "Recibe gratis un análisis de tu situación actual valorado en 200 € y descubre cómo captar a los clientes que hoy pierdes.",
  ctaHref = "https://wa.me/34692051399?text=Hola%20Salva%2C%20he%20visto%20tu%20web.%20Tengo%20un%20negocio%20en%20Barcelona%20y%20me%20gustar%C3%ADa%20saber%20si%20el%20SEO%20puede%20ayudarme%20a%20conseguir%20m%C3%A1s%20clientes.",
  ctaLabel = "Analiza mi web",
} = Astro.props;
---

<section id={sectionId} class="relative overflow-hidden bg-petrol-900 py-24 sm:py-32">

  <!-- ── Dot-grid texture ──────────────────────────────────────────── -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.028) 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <!-- ── Faded Titan One watermark ─────────────────────────────────── -->
  <div
    class="pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none leading-none"
    aria-hidden="true"
    style='font-family: "Titan One", cursive; font-size: clamp(12rem, 24vw, 20rem); color: rgba(249,115,22,0.04); line-height: 1; white-space: nowrap;'
  >
    PLAN
  </div>

  <!-- ── Radial ambient glow ───────────────────────────────────────── -->
  <div
    class="pointer-events-none absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full"
    aria-hidden="true"
    style="background: radial-gradient(circle, rgba(14,165,233,0.05) 0%, transparent 65%);"
  ></div>

  <!-- ── Diagonal tension lines ───────────────────────────────────── -->
  <svg
    class="pointer-events-none absolute inset-0 w-full h-full"
    aria-hidden="true"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <line x1="0%" y1="0%" x2="30%" y2="100%" stroke="rgba(249,115,22,0.05)" stroke-width="1" />
    <line x1="70%" y1="0%" x2="100%" y2="100%" stroke="rgba(14,165,233,0.04)" stroke-width="1" />
  </svg>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-orange-500/35 to-transparent" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-orange-500/15 to-transparent" aria-hidden="true"></div>

  <!-- ── Content ───────────────────────────────────────────────────── -->
  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1fr_1.35fr] gap-12 lg:gap-20 items-start">

      <!-- ── LEFT: sticky heading block ──────────────────────────────── -->
      <div class="lg:sticky lg:top-28">

        <!-- Eyebrow -->
        <div data-animate class="flex items-center gap-3 mb-8">
          <span class="block h-px w-10 bg-orange-500" aria-hidden="true"></span>
          {upheading && (
            <p class="text-[0.7rem] font-bold uppercase tracking-[0.22em] text-orange-400">
              {upheading}
            </p>
          )}
        </div>

        <!-- Titan One heading -->
        <h2
          data-animate
          style='font-family: "Titan One", cursive;'
          class="leading-[0.92] tracking-tight text-[clamp(2rem,4.5vw,3.25rem)] text-white text-pretty"
        >
          {heading}<span class="text-orange-400">.</span>
        </h2>

        <!-- Orange accent rule -->
        <div data-animate class="mt-6 flex items-center">
          <div class="h-[3px] w-16 bg-orange-500 rounded-full"></div>
          <div class="h-px w-24 bg-gradient-to-r from-orange-500/40 to-transparent"></div>
        </div>

        <!-- Subtitle -->
        <p data-animate class="mt-6 max-w-[38ch] text-base md:text-lg text-white/55 leading-relaxed text-pretty">
          {subtitle}
        </p>

        <!-- Decorative vertical rule -->
        <div class="hidden lg:block mt-12 w-px h-20 bg-gradient-to-b from-orange-500/30 to-transparent" aria-hidden="true"></div>
      </div>

      <!-- ── RIGHT: phase rows ─────────────────────────────────────── -->
      <div class="flex flex-col">

        {phases.map((phase, idx) => {
          const isLast = idx === phases.length - 1;
          const padNum = String(idx + 1).padStart(2, "0");

          return (
            <div
              data-animate
              data-animate-delay={idx * 130}
              class:list={[
                "relative flex gap-5 py-10 overflow-hidden",
                !isLast && "border-b border-white/[0.07]",
              ]}
            >
              <!-- Ghost ordinal number -->
              <div
                class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 select-none leading-none"
                aria-hidden="true"
                style='font-family: "Titan One", cursive; font-size: 5.5rem; color: rgba(249,115,22,0.06); line-height: 1;'
              >
                {padNum}
              </div>

              <!-- Step column: "Fase" label + Titan One number -->
              <div class="shrink-0 flex flex-col items-center pt-0.5 w-11">
                <span class="text-[0.5rem] font-bold uppercase tracking-[0.18em] text-orange-400 leading-none mb-0.5">
                  Fase
                </span>
                <span
                  class="text-[2.2rem] leading-none font-bold text-orange-400/40 tabular-nums"
                  style='font-family: "Titan One", cursive;'
                >
                  {padNum}
                </span>
              </div>

              <!-- Phase content -->
              <div class="relative min-w-0 flex-1">

                <h3 class="text-[0.9375rem] font-bold text-white/90 mb-3 leading-snug text-pretty">
                  {phase.title}
                </h3>

                <p class="text-sm/6 text-white/50 mb-5 text-pretty">
                  {phase.intro}
                </p>

                <!-- Bullets -->
                <ul class="space-y-2.5 mb-5">
                  {phase.bullets.map((bullet) => {
                    const Icon = iconByKey[bullet.icon];
                    return (
                      <li class="flex items-start gap-3">
                        <span class="shrink-0 mt-0.5 flex size-6 items-center justify-center rounded-md bg-orange-500/10 ring-1 ring-orange-500/20">
                          <Icon aria-hidden="true" class="size-3 text-orange-400" />
                        </span>
                        <span class="text-sm/6 text-white/50">
                          <strong class="font-semibold text-white/80">{bullet.emphasis}</strong>{" "}
                          {bullet.text}
                        </span>
                      </li>
                    );
                  })}
                </ul>

                <!-- Outro pill — sky accent -->
                <div class="inline-flex items-start gap-2 rounded-lg border border-sky-500/20 bg-sky-500/[0.07] px-3.5 py-2.5">
                  <svg
                    aria-hidden="true"
                    class="mt-0.5 size-4 shrink-0 text-sky-400/80"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-sm/6 text-sky-300/75">{phase.outro}</span>
                </div>

              </div>
            </div>
          );
        })}

      </div>
    </div>


  </div>
</section>
