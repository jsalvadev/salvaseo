---
import CalButton from '../../CalButton.astro'
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  headingAccent?: string;
  subtitle?: string;
  sectionId?: string;
  phases?: TimelinePhase[];
}

const iconByKey = {
  scale: Scale,
  barChart3: BarChart3,
  badgeCheck: BadgeCheck,
  target: Target,
  trendingUp: TrendingUp,
  calendarClock: CalendarClock,
  chartNoAxesColumn: ChartNoAxesColumn,
  lineChart: LineChart,
  layers3: Layers3,
} as const;

const defaultPhases: TimelinePhase[] = [
  {
    title: "Miro por qué tu web no aparece",
    intro:
      "Te digo qué está fallando y cuánta gente busca tu oficio en tu zona.",
    bullets: [
      {
        icon: "scale",
        emphasis: "Diagnóstico competitivo.",
        text: "Comparativa de tu situación real frente a tus competidores directos.",
      },
      {
        icon: "barChart3",
        emphasis: "Demanda local real.",
        text: "Cuánta gente busca tu oficio en tu zona cada mes.",
      },
      {
        icon: "badgeCheck",
        emphasis: "Viabilidad confirmada.",
        text: "Te digo antes de empezar si tiene sentido invertir.",
      },
    ],
    outro: "Auditoría gratuita con tus próximas acciones priorizadas por impacto.",
  },
  {
    title: "Preparo tu web para que Google la muestre",
    intro:
      "La estrategia desglosa las acciones necesarias para captar clientes en tu zona y sector.",
    bullets: [
      {
        icon: "target",
        emphasis: "Jerarquía de objetivos.",
        text: "Empiezo por lo que antes te trae llamadas.",
      },
      {
        icon: "trendingUp",
        emphasis: "Estimación de visitas.",
        text: "Te digo cuántas visitas puedes esperar y cuándo.",
      },
    ],
    outro:
      "Cada paso del plan se valida antes de ejecutarlo. Si una acción no se alinea con tus objetivos de negocio, se descarta.",
  },
  {
    title: "Mientras tú trabajas, tu web sube en Google",
    intro:
      "Mientras gestionas tu negocio, tu web escala posiciones y consolida su autoridad en Google.",
    bullets: [
      {
        icon: "chartNoAxesColumn",
        emphasis: "Seguimiento de conversiones.",
        text: "Cuento las llamadas y contactos que llegan desde Google.",
      },
      {
        icon: "lineChart",
        emphasis: "Evolución de posiciones.",
        text: "Cada mes ves exactamente en qué has subido.",
      },
    ],
    outro:
      "Tu web compite por el volumen de búsquedas de tu sector en Barcelona y lo convierte en contactos reales.",
  },
];

const {
  upheading,
  heading,
  headingAccent,
  subtitle = "Tres fases. Cada una con un entregable claro y un resultado medible.",
  sectionId = "proceso",
  phases = defaultPhases,
} = Astro.props;
---

<section id={sectionId} class="relative overflow-hidden bg-gradient-to-tr from-surface to-base/80 py-24 sm:py-32">

  <!-- ── Dot-grid texture ──────────────────────────────────────────── -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
  ></div>

  <!-- ── Faded Titan One watermark ─────────────────────────────────── -->
  <div class="font-heading pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-white/[0.04]"
    aria-hidden="true"
  >
    PLAN
  </div>

  <!-- ── Radial ambient glow ───────────────────────────────────────── -->
  <div
    class="pointer-events-none absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full"
    aria-hidden="true"
  ></div>

  <!-- ── Diagonal tension lines ───────────────────────────────────── -->
  <svg
    class="pointer-events-none absolute inset-0 w-full h-full"
    aria-hidden="true"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <line x1="0%" y1="0%" x2="30%" y2="100%" stroke="rgba(250,234,177,0.06)" stroke-width="1" />
    <line x1="70%" y1="0%" x2="100%" y2="100%" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
  </svg>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/35 to-transparent" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent" aria-hidden="true"></div>

  <!-- ── Content ───────────────────────────────────────────────────── -->
  <div class="relative container-site">
    <div class="grid lg:grid-cols-[1fr_1.35fr] gap-12 lg:gap-20 items-start">

      <!-- ── LEFT: sticky heading block ──────────────────────────────── -->
      <div class="lg:sticky lg:top-28">

        <!-- Eyebrow -->
        {upheading && (
          <h2 data-animate class="text-xs font-bold text-cream">{upheading}</h2>
        )}

        <!-- Titan One display — visual only, not semantic heading -->
        <p
          data-animate
          class="mt-5 font-heading text-h2 font-normal leading-[1.05] tracking-tight text-white text-pretty"
        >
          <Fragment set:html={heading} />{headingAccent && <><br /><span class="text-cream">{headingAccent}</span></>}<span class="text-cream">{!headingAccent && '.'}</span>
        </p>

        <!-- Accent rule -->
        <div data-animate class="mt-6 flex items-center">
          <div class="h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35"></div>
          <div class="h-px w-10 bg-cream/60"></div>
        </div>

        <div data-animate class='mt-8'>
          <CalButton variant='cream' />
        </div>

        <!-- Decorative vertical rule -->
        <div class="hidden lg:block mt-12 w-px h-20 bg-gradient-to-b from-sand/30 to-transparent" aria-hidden="true"></div>
      </div>

      <!-- ── RIGHT: phase rows ─────────────────────────────────────── -->
      <div class="flex flex-col">

        {phases.map((phase, idx) => {
          const isLast = idx === phases.length - 1;
          const padNum = String(idx + 1).padStart(2, "0");

          return (
            <div
              data-animate
              data-animate-delay={idx * 130}
              class:list={[
                "relative flex gap-5 py-10 overflow-hidden",
                !isLast && "border-b border-white/[0.07]",
              ]}
            >
              <!-- Ghost ordinal number -->
              <div class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 select-none leading-none font-heading"
                aria-hidden="true"
              >
                {padNum}
              </div>

              <!-- Step column: "Fase" label + Titan One number -->
              <div class="shrink-0 flex flex-col items-center pt-0.5 w-11">
                <span class="text-xs font-bold tracking-[0.14em] uppercase text-cream leading-none mb-0.5">
                  Fase
                </span>
                <span
                  class="text-h3 leading-none font-heading font-bold text-cream/40 tabular-nums"

                >
                  {padNum}
                </span>
              </div>

              <!-- Phase content -->
              <div class="relative min-w-0 flex-1">

                <p class="text-base font-bold text-white/90 mb-3 leading-snug text-pretty">
                  {phase.title}
                </p>

                <p class="text-base text-white/75 mb-5 text-pretty">
                  {phase.intro}
                </p>

                <!-- Bullets -->
                <ul class="space-y-2.5 mb-5">
                  {phase.bullets.map((bullet) => {
                    const Icon = iconByKey[bullet.icon];
                    return (
                      <li class="flex items-start gap-3">
                        <span class="shrink-0 mt-0.5 flex size-6 items-center justify-center rounded-md bg-cream/10 ring-1 ring-sand/20">
                          <Icon aria-hidden="true" class="size-3 text-cream" />
                        </span>
                        <span class="text-sm text-white/75">
                          <strong class="font-semibold text-white/80">{bullet.emphasis}</strong>{" "}
                          {bullet.text}
                        </span>
                      </li>
                    );
                  })}
                </ul>


              </div>
            </div>
          );
        })}

      </div>
    </div>

  </div>
</section>
