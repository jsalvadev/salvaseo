---
import type { FaqItem } from '../../../data/faq-home'

interface Props {
  upheading?: string
  heading: string
  idPrefix?: string
  items: FaqItem[]
  class?: string
}

const { upheading, heading, idPrefix = 'faq', items, class: className } = Astro.props
---

<section class:list={['bcnfaq-root', className]}>

  <!-- ── "?" watermark ───────────────────────────────────────────── -->
  <div class="bcnfaq-wm" aria-hidden="true">?</div>

  <!-- ── Dot-grid texture ──────────────────────────────────────────── -->
  <div class="bcnfaq-grid" aria-hidden="true"></div>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class="bcnfaq-hairline-top" aria-hidden="true"></div>
  <div class="bcnfaq-hairline-bottom" aria-hidden="true"></div>

  <div class="bcnfaq-inner">

    <!-- ── Header ──────────────────────────────────────────────────── -->
    <header class="bcnfaq-header">

      <!-- Eyebrow: h-px line + orange uppercase label -->
      {upheading && (
        <div class="bcnfaq-eyebrow" data-animate>
          <span class="bcnfaq-eyebrow-line" aria-hidden="true"></span>
          <h2 class="bcnfaq-eyebrow-text">{upheading}</h2>
        </div>
      )}

      <!-- Titan One heading -->
      <p class="bcnfaq-heading" data-animate>
        {heading}<span class="bcnfaq-dot">.</span>
      </p>

      <!-- Orange accent rule -->
      <div class="bcnfaq-rule" data-animate aria-hidden="true">
        <span class="bcnfaq-rule-solid"></span>
        <span class="bcnfaq-rule-fade"></span>
      </div>

    </header>

    <!-- ── FAQ list ────────────────────────────────────────────────── -->
    <div class="bcnfaq-list">
      {items.map((item, i) => (
        <div class="bcnfaq-item" data-animate data-animate-delay={i * 70}>

          <div class="bcnfaq-dt">
            <!-- Titan One number -->
            <span class="bcnfaq-num" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>

            <!-- Question -->
            <h3 class="bcnfaq-question">
              <button
                type="button"
                command="--toggle"
                commandfor={`${idPrefix}-${i}`}
                class="bcnfaq-btn"
              >
                {item.question}
              </button>
            </h3>

            <!-- Chevron -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
              class="bcnfaq-chevron"
            >
              <path d="M19.5 8.25l-7.5 7.5-7.5-7.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>

          <el-disclosure id={`${idPrefix}-${i}`} hidden class="contents">
            <div class="bcnfaq-dd">
              <span aria-hidden="true"></span>
              <div class="bcnfaq-answer-body">
                <Fragment set:html={item.answer} />
              </div>
            </div>
          </el-disclosure>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Root ──────────────────────────────────────────────────── */
  .bcnfaq-root {
    position: relative;
    overflow: hidden;
    background-color: var(--color-petrol-100);
  }

  /* ── "?" watermark ─────────────────────────────────────────── */
  .bcnfaq-wm {
    pointer-events: none;
    position: absolute;
    top: -2rem;
    right: -1rem;
    overflow: hidden;
    user-select: none;
    font-family: 'Titan One', cursive;
    font-size: clamp(10rem, 28vw, 26rem);
    line-height: 1;
    color: rgba(26, 60, 74, 0.065);
  }

  /* ── Dot-grid texture ─────────────────────────────────────── */
  .bcnfaq-grid {
    pointer-events: none;
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(26, 60, 74, 0.055) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  /* ── Hairlines ────────────────────────────────────────────── */
  .bcnfaq-hairline-top,
  .bcnfaq-hairline-bottom {
    pointer-events: none;
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(26, 60, 74, 0.15), transparent);
  }
  .bcnfaq-hairline-top    { top: 0; }
  .bcnfaq-hairline-bottom { bottom: 0; }

  /* ── Inner container ────────────────────────────────────────── */
  .bcnfaq-inner {
    position: relative;
    margin: 0 auto;
    max-width: 80rem;
    padding: 6rem 1.5rem;
  }

  @media (min-width: 640px) {
    .bcnfaq-inner { padding: 8rem 1.5rem; }
  }

  @media (min-width: 1024px) {
    .bcnfaq-inner {
      padding: 10rem 2rem;
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 0 5rem;
      align-items: start;
    }
  }

  /* ── Header ─────────────────────────────────────────────────── */
  .bcnfaq-header {
    max-width: 42rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 1024px) {
    .bcnfaq-header {
      margin-bottom: 0;
      position: sticky;
      top: calc(var(--navbar-height, 56px) + 2rem);
    }
  }

  /* Eyebrow row */
  .bcnfaq-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .bcnfaq-eyebrow-line {
    display: block;
    height: 1px;
    width: 2.5rem;
    flex-shrink: 0;
    background-color: var(--color-teal);
  }

  .bcnfaq-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin: 0;
  }

  /* Heading */
  .bcnfaq-heading {
    font-family: 'Titan One', cursive;
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.05;
    color: var(--color-petrol-900);
    margin: 0 0 1.5rem;
    text-wrap: pretty;
  }

  .bcnfaq-dot {
    color: var(--color-teal);
  }

  /* Orange accent rule */
  .bcnfaq-rule {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .bcnfaq-rule-solid {
    display: block;
    height: 3px;
    width: 4rem;
    background-color: var(--color-teal);
    border-radius: 9999px;
  }

  .bcnfaq-rule-fade {
    display: block;
    height: 1px;
    width: 6rem;
    background: linear-gradient(to right, rgba(52, 101, 109, 0.4), transparent);
  }

  /* ── FAQ list ──────────────────────────────────────────────── */
  .bcnfaq-list {
    margin: 0;
    padding: 0;
    max-width: 48rem;
  }

  @media (min-width: 1024px) {
    .bcnfaq-list { max-width: none; }
  }

  /* ── FAQ item ──────────────────────────────────────────────── */
  .bcnfaq-item {
    border-top: 1px solid rgba(26, 60, 74, 0.12);
    padding: 1.75rem 0;
  }

  .bcnfaq-item:last-child {
    border-bottom: 1px solid rgba(26, 60, 74, 0.12);
  }

  /* ── dt grid: [number | question | chevron] ────────────────── */
  .bcnfaq-dt {
    display: grid;
    grid-template-columns: 3rem 1fr 1.5rem;
    align-items: start;
    gap: 0.75rem 1rem;
  }

  @media (min-width: 640px) {
    .bcnfaq-dt {
      grid-template-columns: 4rem 1fr 1.5rem;
      gap: 0.75rem 1.5rem;
    }
  }

  /* ── Number ─────────────────────────────────────────────────── */
  .bcnfaq-num {
    font-family: 'Titan One', cursive;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1;
    padding-top: 0.1rem;
    color: rgba(26, 60, 74, 0.18);
    transition: color 0.3s ease;
  }

  .bcnfaq-item:has(button[aria-expanded="true"]) .bcnfaq-num {
    color: var(--color-teal);
  }

  /* ── Question h3 ─────────────────────────────────────────────── */
  .bcnfaq-question {
    margin: 0;
    padding: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }

  /* ── Button ──────────────────────────────────────────────────── */
  .bcnfaq-btn {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-family-sans, 'DM Sans Variable', sans-serif);
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    font-weight: 600;
    line-height: 1.45;
    color: var(--color-petrol-900);
    transition: color 0.2s ease;
  }

  .bcnfaq-btn:hover {
    color: var(--color-teal);
  }

  .bcnfaq-item:has(button[aria-expanded="true"]) .bcnfaq-btn {
    color: var(--color-teal);
  }

  /* ── Chevron ─────────────────────────────────────────────────── */
  .bcnfaq-chevron {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
    color: var(--color-petrol-600);
    transition: transform 0.38s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
  }

  .bcnfaq-item:has(button[aria-expanded="true"]) .bcnfaq-chevron {
    transform: rotate(180deg);
    color: var(--color-teal);
  }

  /* ── Answer reveal ───────────────────────────────────────────── */
  el-disclosure:not([hidden]) {
    animation: bcnfaq-reveal 0.42s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .bcnfaq-dd {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0 1rem;
    margin: 0.875rem 0 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .bcnfaq-dd {
      grid-template-columns: 4rem 1fr;
      gap: 0 1.5rem;
    }
  }

  .bcnfaq-answer-body {
    padding-right: 1.5rem;
  }

  /* Answer content color overrides */
  .bcnfaq-answer-body :global(p),
  .bcnfaq-answer-body :global(li) {
    color: #2A5566 !important;
    line-height: 1.75;
    font-size: 0.9375rem;
  }

  .bcnfaq-answer-body :global(strong) {
    color: #1A3C4A !important;
    font-weight: 600;
  }

  .bcnfaq-answer-body :global(ul) {
    color: #2A5566 !important;
    margin-top: 0.5rem;
  }

  .bcnfaq-answer-body :global(a) {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .bcnfaq-answer-body :global(a:hover) {
    color: var(--color-teal);
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    el-disclosure:not([hidden]) { animation: none; }
    .bcnfaq-chevron,
    .bcnfaq-num,
    .bcnfaq-btn { transition: none; }
  }
</style>
