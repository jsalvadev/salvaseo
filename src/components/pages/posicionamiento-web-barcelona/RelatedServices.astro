---
import { MapPin, Receipt } from '@lucide/astro'

const related = [
  {
    icon: MapPin,
    label: 'Visibilidad en Google Maps',
    title: 'SEO Local en Barcelona',
    description:
      'Si tu negocio tiene presencia física, el Local Pack de Google Maps es tu canal de captación más inmediato. Optimiza tu ficha y aparece antes que tu competencia en las búsquedas de zona.',
    href: '/seo-local-barcelona/',
    cta: 'Ver SEO local',
    ordinal: '01',
  },
  {
    icon: Receipt,
    label: 'Tarifas y paquetes',
    title: 'Presupuesto Posicionamiento Web Barcelona',
    description:
      'Dos paquetes con precio fijo mensual, sin permanencia. Consulta qué incluye cada plan y elige la inversión que se ajusta al tamaño y objetivos de tu negocio.',
    href: '/presupuesto-seo-barcelona/',
    cta: 'Ver precios',
    ordinal: '02',
  },
]
---

<section class='relative overflow-hidden py-20 md:py-28' style='background: linear-gradient(135deg, #3a4236 0%, #697565 50%, #8a9e88 100%)'>

  <!-- Diagonal rule top -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cream/40 to-transparent' aria-hidden='true'></div>

  <!-- Watermark -->
  <div class='font-heading pointer-events-none absolute -right-6 top-0 select-none leading-none text-wm font-bold text-white/[0.04]' aria-hidden='true'>
    SERVICIOS
  </div>

  <!-- Background noise texture -->
  <svg class='pointer-events-none absolute inset-0 h-full w-full opacity-[0.025]' aria-hidden='true'>
    <filter id='rs-noise'>
      <feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/>
      <feColorMatrix type='saturate' values='0'/>
    </filter>
    <rect width='100%' height='100%' filter='url(#rs-noise)'/>
  </svg>

  <div class='relative container-site'>

    <!-- Section header -->
    <div class='mb-14'>
      <div data-animate>
        <h2 class='text-xs font-bold uppercase tracking-widest text-cream/60'>POSICIONAMIENTO WEB PARA PYMES Y EMPRESAS EN BARCELONA</h2>
      </div>
      <p data-animate class='mt-5 font-heading text-h2 font-semibold tracking-tight text-cream'>
        Más formas de aparecer en Google<span class='text-sage'>.</span>
      </p>
      <div data-animate class='mt-6 flex items-center'>
        <div class='h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35'></div>
        <div class='h-px w-10 bg-cream/60'></div>
      </div>
    </div>

    <!-- Cards -->
    <div class='grid grid-cols-1 sm:grid-cols-2 gap-5 lg:gap-6'>
      {related.map((item, idx) => {
        const Icon = item.icon
        return (
          <a
            href={item.href}
            data-animate
            data-animate-delay={idx * 120}
            class='group relative flex flex-col justify-between rounded-xl border border-cream/20 bg-white/5 p-8 transition-all duration-300 hover:border-cream/40 hover:bg-white/10 hover:-translate-y-1 hover:shadow-xl'
          >
            <!-- Ghost ordinal -->
            <span class='font-heading pointer-events-none absolute -right-4 top-1/2 -translate-y-1/2 text-[clamp(5rem,12vw,8rem)] font-black leading-none text-white/[0.03] select-none' aria-hidden='true'>
              {item.ordinal}
            </span>

            <!-- Inner content -->
            <div class='relative z-10 flex flex-col gap-5'>

              <!-- Icon + label -->
              <div class='flex items-center gap-3'>
                <div class='flex size-9 items-center justify-center rounded-lg bg-cream/10 ring-1 ring-cream/25 transition-all duration-300 group-hover:bg-cream/20 group-hover:ring-cream/45'>
                  <Icon class='size-[15px] text-cream/80' aria-hidden='true' />
                </div>
                <span class='text-xs font-bold uppercase tracking-[0.2em] text-cream/65 group-hover:text-cream/85 transition-colors duration-300'>
                  {item.label}
                </span>
              </div>

              <!-- Title -->
              <p class='font-heading text-h6 font-bold leading-[1.15] tracking-tight text-cream transition-colors duration-300 group-hover:text-white'>
                {item.title}
              </p>

              <!-- Description -->
              <p class='text-sm text-cream/70 leading-relaxed text-pretty transition-colors duration-300 group-hover:text-cream/90'>
                {item.description}
              </p>

              <!-- CTA -->
              <div class='mt-4 flex items-center gap-1 text-xs font-bold uppercase tracking-[0.04em] text-cream/75 group-hover:text-cream group-hover:gap-2 transition-all duration-200'>
                <span>{item.cta}</span>
                <svg width='14' height='14' viewBox='0 0 14 14' fill='none' aria-hidden='true' class='transition-transform duration-200 group-hover:translate-x-0.5'>
                  <path d='M2 7h10M8 3l4 4-4 4' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/>
                </svg>
              </div>

            </div>
          </a>
        )
      })}
    </div>

  </div>
</section>