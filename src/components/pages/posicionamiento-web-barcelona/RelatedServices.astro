---
import { MapPin, Receipt, ArrowRight } from '@lucide/astro'

const related = [
  {
    icon: MapPin,
    label: 'Visibilidad en Google Maps',
    title: 'SEO Local en Barcelona',
    description:
      'Si tu negocio tiene presencia física, el Local Pack de Google Maps es tu canal de captación más inmediato. Optimiza tu ficha y aparece antes que tu competencia en las búsquedas de zona.',
    href: '/seo-local-barcelona/',
    cta: 'Ver SEO local',
  },
  {
    icon: Receipt,
    label: 'Tarifas y paquetes',
    title: 'Presupuesto SEO Barcelona',
    description:
      'Dos paquetes con precio fijo mensual, sin permanencia. Consulta qué incluye cada plan y elige la inversión que se ajusta al tamaño y objetivos de tu negocio.',
    href: '/presupuesto-seo-barcelona/',
    cta: 'Ver precios',
  },
]
---

<section class='relative overflow-hidden bg-teal py-16 md:py-20'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(255,255,255,0.028) 1px, transparent 1px); background-size: 32px 32px;'>
  </div>

  <!-- Top hairline -->
  <div
    class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent'
    aria-hidden='true'>
  </div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <div data-animate class='flex items-center gap-3 mb-8'>
      <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
      <p class='text-[0.7rem] font-bold uppercase tracking-[0.22em] text-sand/60'>
        Quizás te puede interesar
      </p>
    </div>

    <div class='grid grid-cols-1 sm:grid-cols-2 gap-4'>
      {related.map((item, idx) => {
        const Icon = item.icon
        return (
          <a
            href={item.href}
            data-animate
            data-animate-delay={idx * 100}
            class='group relative rounded-xl border border-white/[0.07] bg-white/[0.03] px-6 py-5 transition-all duration-300 hover:border-sand/30 hover:bg-white/[0.055] overflow-hidden flex flex-col gap-4 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sand'>

            <!-- Left accent bar -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sand scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>

            <!-- Icon + label -->
            <div class='flex items-center gap-3'>
              <div class='flex size-9 shrink-0 items-center justify-center rounded-xl bg-sand/[0.08] ring-1 ring-sand/20 transition-all duration-300 group-hover:bg-sand/[0.15] group-hover:ring-sand/35'>
                <Icon class='size-4 text-sand/60 group-hover:text-sand transition-colors duration-300' aria-hidden='true' />
              </div>
              <span class='text-[0.65rem] font-bold uppercase tracking-[0.18em] text-white/30'>
                {item.label}
              </span>
            </div>

            <!-- Title + description -->
            <div class='min-w-0'>
              <p class='text-base font-semibold text-white/85 mb-1.5 leading-snug transition-colors duration-300 group-hover:text-white'>
                {item.title}
              </p>
              <p class='text-sm text-white/50 leading-relaxed text-pretty transition-colors duration-300 group-hover:text-white/65'>
                {item.description}
              </p>
            </div>

            <!-- CTA -->
            <div class='flex items-center gap-1.5 text-xs font-semibold text-sand/60 group-hover:text-sand group-hover:gap-2.5 transition-all duration-200 mt-auto'>
              {item.cta}
              <ArrowRight class='size-3.5' aria-hidden='true' />
            </div>

          </a>
        )
      })}
    </div>

  </div>
</section>
