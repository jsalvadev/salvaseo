---
import { MapPin, Receipt } from '@lucide/astro'

const related = [
  {
    icon: MapPin,
    label: 'Visibilidad en Google Maps',
    title: 'SEO Local en Barcelona',
    description:
      'Si tu negocio tiene presencia física, el Local Pack de Google Maps es tu canal de captación más inmediato. Optimiza tu ficha y aparece antes que tu competencia en las búsquedas de zona.',
    href: '/seo-local-barcelona/',
    cta: 'Ver SEO local',
    ordinal: '01',
  },
  {
    icon: Receipt,
    label: 'Tarifas y paquetes',
    title: 'Presupuesto Posicionamiento Web Barcelona',
    description:
      'Dos paquetes con precio fijo mensual, sin permanencia. Consulta qué incluye cada plan y elige la inversión que se ajusta al tamaño y objetivos de tu negocio.',
    href: '/presupuesto-seo-barcelona/',
    cta: 'Ver precios',
    ordinal: '02',
  },
]
---

<section class='related-root relative overflow-hidden py-20 md:py-28' style='background: linear-gradient(135deg, #3a4236 0%, #697565 50%, #8a9e88 100%)'>

  <!-- Diagonal rule top -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cream/40 to-transparent' aria-hidden='true'></div>

  <!-- Watermark -->
  <div class='font-heading pointer-events-none absolute -right-6 top-0 select-none leading-none text-wm font-bold text-white/[0.04]' aria-hidden='true'>
    SERVICIOS
  </div>

  <!-- Background noise texture -->
  <svg class='pointer-events-none absolute inset-0 h-full w-full opacity-[0.025]' aria-hidden='true'>
    <filter id='rs-noise'>
      <feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/>
      <feColorMatrix type='saturate' values='0'/>
    </filter>
    <rect width='100%' height='100%' filter='url(#rs-noise)'/>
  </svg>

  <div class='relative container-site'>

    <!-- Section header -->
    <div class='mb-14'>
      <div data-animate>
        <h2 class='text-xs font-bold uppercase tracking-widest text-cream/60'>POSICIONAMIENTO WEB PARA PYMES Y EMPRESAS EN BARCELONA</h2>
      </div>
      <p data-animate class='mt-5 font-heading text-h2 font-semibold tracking-tight text-cream'>
        Más formas de aparecer en Google<span class='text-sage'>.</span>
      </p>
      <div data-animate class='mt-6 flex items-center'>
        <div class='h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35'></div>
        <div class='h-px w-10 bg-cream/60'></div>
      </div>
    </div>

    <!-- Cards -->
    <div class='grid grid-cols-1 sm:grid-cols-2 gap-5 lg:gap-6'>
      {related.map((item, idx) => {
        const Icon = item.icon
        return (
          <a
            href={item.href}
            data-animate
            data-animate-delay={idx * 120}
            class='related-card group'
          >
            <!-- Ghost ordinal -->
            <span class='related-ordinal' aria-hidden='true'>{item.ordinal}</span>

            <!-- Inner content -->
            <div class='relative z-10 flex flex-col gap-5 h-full'>

              <!-- Icon + label -->
              <div class='flex items-center gap-3'>
                <div class='related-icon-wrap'>
                  <Icon class='size-[15px] text-cream/80 transition-colors duration-300 group-hover:text-cream' aria-hidden='true' />
                </div>
                <span class='text-xs font-bold uppercase tracking-[0.2em] text-cream/65 group-hover:text-cream/85 transition-colors duration-300'>
                  {item.label}
                </span>
              </div>

              <!-- Title -->
              <p class='related-title'>
                {item.title}
              </p>

              <!-- Description -->
              <p class='text-sm text-cream/70 leading-relaxed text-pretty transition-colors duration-300 group-hover:text-cream/90 flex-1'>
                {item.description}
              </p>

              <!-- CTA -->
              <div class='related-cta'>
                <span>{item.cta}</span>
                <svg width='14' height='14' viewBox='0 0 14 14' fill='none' class='related-cta-arrow' aria-hidden='true'>
                  <path d='M2 7h10M8 3l4 4-4 4' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/>
                </svg>
              </div>

            </div>
          </a>
        )
      })}
    </div>

  </div>
</section>

<style>
  /* Card base */
  .related-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 2rem 2rem 1.75rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-cream) 18%, transparent);
    background: color-mix(in srgb, black 12%, transparent);
    overflow: hidden;
    transition: border-color 0.35s ease, background 0.35s ease, transform 0.3s ease, box-shadow 0.35s ease;
    text-decoration: none;
    outline-offset: 3px;
  }
  .related-card:hover {
    border-color: color-mix(in srgb, var(--color-cream) 40%, transparent);
    background: color-mix(in srgb, black 20%, transparent);
    transform: translateY(-3px);
    box-shadow: 0 20px 60px -12px rgba(0,0,0,0.4);
  }
  .related-card:focus-visible {
    outline: 2px solid var(--color-sand);
  }


  /* Ghost ordinal */
  .related-ordinal {
    position: absolute;
    right: -0.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-heading, 'Titan One', sans-serif);
    font-size: clamp(5rem, 12vw, 8rem);
    font-weight: 900;
    line-height: 1;
    color: white;
    opacity: 0.03;
    user-select: none;
    pointer-events: none;
    transition: opacity 0.35s ease;
    letter-spacing: -0.04em;
  }
  .related-card:hover .related-ordinal {
    opacity: 0.055;
  }

  /* Icon wrap */
  .related-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.125rem;
    height: 2.125rem;
    flex-shrink: 0;
    border-radius: 0.625rem;
    background: color-mix(in srgb, var(--color-cream) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cream) 25%, transparent);
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .related-card:hover .related-icon-wrap {
    background: color-mix(in srgb, var(--color-cream) 22%, transparent);
    border-color: color-mix(in srgb, var(--color-cream) 45%, transparent);
  }

  /* Title */
  .related-title {
    font-family: var(--font-heading, 'Titan One', sans-serif);
    font-size: var(--text-h6);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-cream);
    transition: color 0.3s ease;
  }
  .related-card:hover .related-title {
    color: white;
  }

  /* CTA row */
  .related-cta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-cream) 75%, transparent);
    transition: color 0.25s ease, gap 0.25s ease;
    margin-top: 0.5rem;
  }
  .related-card:hover .related-cta {
    color: var(--color-cream);
    gap: 0.625rem;
  }
  .related-cta-arrow {
    transition: transform 0.25s ease;
  }
  .related-card:hover .related-cta-arrow {
    transform: translateX(3px);
  }
</style>
