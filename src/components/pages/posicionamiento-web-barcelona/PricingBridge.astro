---
import WhatsAppButton from '../../WhatsAppButton.astro'

interface Guarantee {
  title: string
  description: string
}

interface Props {
  upheading: string
  heading: string
  priceHighlight?: string
  intro: string
  guarantees: Guarantee[]
  quote: string
  quoteAuthor: string
}

const {
  upheading,
  heading,
  priceHighlight,
  intro,
  guarantees,
  quote,
  quoteAuthor,
} = Astro.props

/* Parse "Desde 350 €/mes" → prefix="Desde", num="350", unit="€/mes" */
const priceParts = priceHighlight?.split(' ') ?? []
const pricePrefix = priceParts[0] ?? ''
const priceNum    = priceParts[1] ?? ''
const priceUnit   = priceParts.slice(2).join(' ')
---

<section class='relative overflow-hidden bg-petrol-900 py-24 sm:py-32'>

  <!-- ── Dot-grid texture ──────────────────────────────────────────── -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(255,255,255,0.028) 1px, transparent 1px); background-size: 32px 32px;'
  ></div>

  <!-- ── Price number as background watermark ───────────────────────── -->
  {priceNum && (
    <div
      class='pointer-events-none absolute -right-4 top-1/2 -translate-y-1/2 select-none leading-none'
      aria-hidden='true'
      style={`font-family: "Titan One", cursive; font-size: clamp(14rem, 30vw, 26rem); color: rgba(249,115,22,0.04); line-height: 1;`}
    >
      {priceNum}
    </div>
  )}

  <!-- ── Radial ambient glow — left ───────────────────────────────── -->
  <div
    class='pointer-events-none absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.05) 0%, transparent 65%);'
  ></div>

  <!-- ── Radial ambient glow — right center ───────────────────────── -->
  <div
    class='pointer-events-none absolute top-1/3 right-0 w-[500px] h-[500px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(249,115,22,0.055) 0%, transparent 65%);'
  ></div>

  <!-- ── Radial ambient glow — bottom ─────────────────────────────── -->
  <div
    class='pointer-events-none absolute -bottom-20 right-1/3 w-96 h-96 rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(249,115,22,0.04) 0%, transparent 65%);'
  ></div>

  <!-- ── Diagonal tension lines ───────────────────────────────────── -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'
  >
    <line x1='0%' y1='0%' x2='30%' y2='100%' stroke='rgba(249,115,22,0.05)' stroke-width='1' />
    <line x1='70%' y1='0%' x2='100%' y2='100%' stroke='rgba(14,165,233,0.04)' stroke-width='1' />
  </svg>

  <!-- ── Top / bottom hairlines ────────────────────────────────────── -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-orange-500/35 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-orange-500/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='grid lg:grid-cols-[1fr_1.25fr] gap-12 lg:gap-16 items-start'>

      <!-- ── LEFT: sticky heading block ──────────────────────────────── -->
      <div class='lg:sticky lg:top-28'>

        <!-- Eyebrow -->
        <div data-animate class='flex items-center gap-3 mb-8'>
          <span class='block h-px w-10 bg-orange-500' aria-hidden='true'></span>
          <h2 class='label-section text-orange-400'>
            {upheading}
          </h2>
        </div>

        <!-- Titan One display — visual only, not semantic heading -->
        <p
          data-animate
          style='font-family: "Titan One", cursive;'
          class='leading-[0.92] tracking-tight mb-6'
        >
          <span class='block text-[clamp(1.8rem,4vw,3rem)] text-white/55'>
            Solo inviertes en
          </span>
          <span class='relative block text-[clamp(3rem,7vw,5rem)] text-white'>
            lo que funciona<span class='text-orange-400'>.</span>
            <!-- Underline accent -->
            <span
              class='pointer-events-none absolute -bottom-1 left-0 h-[3px] rounded-full'
              aria-hidden='true'
              style='width: 72%; background: linear-gradient(to right, rgba(249,115,22,0.55), rgba(249,115,22,0));'
            ></span>
          </span>
        </p>

        <!-- Orange accent rule -->
        <div data-animate class='flex items-center mt-8'>
          <div class='h-[3px] w-16 bg-orange-500 rounded-full'></div>
          <div class='h-px w-24 bg-gradient-to-r from-orange-500/40 to-transparent'></div>
        </div>

        <!-- Intro HTML (dark bg overrides) -->
        <div
          data-animate
          class='mt-6 max-w-[40ch] text-base md:text-lg leading-relaxed text-pretty'
        >
          <p class='text-white/55 leading-relaxed text-pretty [&_strong]:text-white/85 [&_strong]:font-semibold'>
            <Fragment set:html={intro} />
          </p>
        </div>

        <!-- Decorative vertical rule -->
        <div class='hidden lg:block mt-10 w-px h-20 bg-gradient-to-b from-orange-500/30 to-transparent' aria-hidden='true'></div>

        <!-- CTAs -->
        <div data-animate class='mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4'>
          <a
            href='/presupuesto-seo-barcelona/#paquetes'
            class='rounded-md bg-sky-500 px-5 py-3 text-sm font-bold text-white shadow-sm hover:bg-sky-400 active:bg-sky-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-400 transition-colors'
          >
            Ver paquetes y precios
          </a>
          <WhatsAppButton text='Analiza mi web' />
        </div>
      </div>

      <!-- ── RIGHT: pricing content ────────────────────────────────── -->
      <div class='flex flex-col gap-6'>

        <!-- Price card -->
        {priceHighlight && (
          <div
            data-animate
            class='relative overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.03] px-8 py-8'
          >
            <!-- Gradient top accent border -->
            <div
              class='pointer-events-none absolute inset-x-0 top-0 h-[2px] rounded-t-2xl'
              aria-hidden='true'
              style='background: linear-gradient(to right, transparent, rgba(249,115,22,0.65) 40%, rgba(249,115,22,0.65) 60%, transparent);'
            ></div>

            <!-- Inner diagonal accent -->
            <svg class='pointer-events-none absolute inset-0 w-full h-full' aria-hidden='true' preserveAspectRatio='none'>
              <line x1='80%' y1='0%' x2='100%' y2='100%' stroke='rgba(249,115,22,0.08)' stroke-width='1' />
            </svg>

            <!-- Corner ambient glow -->
            <div
              class='pointer-events-none absolute -top-8 -right-8 w-32 h-32 rounded-full'
              aria-hidden='true'
              style='background: radial-gradient(circle, rgba(249,115,22,0.12) 0%, transparent 70%);'
            ></div>

            <p class='label-micro text-orange-400/60 mb-1'>
              {pricePrefix}
            </p>

            <div class='flex items-end gap-3 leading-none'>
              <span
                class='font-bold text-orange-400 tabular-nums'
                style='font-family: "Titan One", cursive; font-size: clamp(3.5rem, 10vw, 5.5rem); line-height: 1;'
              >
                {priceNum}
              </span>
              <div class='mb-2 flex flex-col gap-0.5'>
                <span class='text-2xl font-semibold text-white/50'>
                  {priceUnit}
                </span>
                <span class='label-ui text-orange-400/50'>
                  IVA incluido
                </span>
              </div>
            </div>

            <!-- Meta pills -->
            <div class='mt-5 flex flex-wrap gap-2'>
              <span class='inline-flex items-center gap-1.5 rounded-full border border-sky-500/20 bg-sky-500/[0.08] px-3 py-1 text-xs font-semibold text-sky-300/80'>
                <span class='block w-1.5 h-1.5 rounded-full bg-sky-400'></span>
                Diagnóstico gratuito
              </span>
              <span class='inline-flex items-center gap-1.5 rounded-full border border-orange-500/20 bg-orange-500/[0.08] px-3 py-1 text-xs font-semibold text-orange-300/80'>
                <span class='block w-1.5 h-1.5 rounded-full bg-orange-400'></span>
                Sin contratos de permanencia
              </span>
            </div>
          </div>
        )}

        <!-- Guarantees list — card style with hover accent bars -->
        <ul
          role='list'
          class='flex flex-col gap-2'
        >
          {guarantees.map((item, i) => (
            <li
              data-animate
              class='group relative overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.03] px-6 py-5
                     transition-all duration-300 hover:border-orange-500/30 hover:bg-white/[0.055] cursor-default'
            >
              <!-- Left accent bar -->
              <div
                class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-orange-500
                        scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
                aria-hidden='true'
              ></div>

              <!-- Ghost ordinal -->
              <div
                class='pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 select-none leading-none
                        opacity-0 group-hover:opacity-100 transition-opacity duration-300'
                aria-hidden='true'
                style={`font-family: "Titan One", cursive; font-size: 4.5rem; color: rgba(249,115,22,0.07); line-height: 1;`}
              >
                {String(i + 1).padStart(2, '0')}
              </div>

              <!-- Content -->
              <div class='relative flex items-start gap-4'>
                <!-- Check badge -->
                <div class='shrink-0 mt-0.5 flex size-6 items-center justify-center rounded-full bg-orange-500/12 ring-1 ring-orange-500/25 transition-all duration-200 group-hover:bg-orange-500/22 group-hover:ring-orange-500/50'>
                  <svg class='size-3 text-orange-400' viewBox='0 0 12 10' fill='none' aria-hidden='true'>
                    <path d='M1 5l3.5 3.5L11 1' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' />
                  </svg>
                </div>

                <p class='text-sm/6 text-white/50 text-pretty transition-colors duration-200 group-hover:text-white/65'>
                  <strong class='font-semibold text-white/85'>{item.title}</strong>{' '}
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ul>

        <!-- Quote -->
        {quote && (
          <div
            data-animate
            class='flex items-start gap-5 rounded-2xl border border-white/[0.08] bg-white/[0.03] px-8 py-7'
          >
            <span
              class='flex-shrink-0 mt-0.5 text-5xl text-sky-500/30 font-serif leading-none select-none'
              aria-hidden='true'
            >"</span>
            <figure>
              <blockquote class='text-base/7 italic text-petrol-100 text-pretty'>
                <p>{quote}</p>
              </blockquote>
              {quoteAuthor && (
                <figcaption class='mt-3 text-sm text-white/40'>
                  {quoteAuthor}
                </figcaption>
              )}
            </figure>
          </div>
        )}

      </div>
    </div>
  </div>
</section>
