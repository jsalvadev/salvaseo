---
import AccentRule from '../../AccentRule.astro'

interface Guarantee {
  title: string
  description: string
}

interface Props {
  upheading: string
  heading: string
  priceHighlight?: string
  intro: string
  guarantees: Guarantee[]
  quote: string
  quoteAuthor: string
}

const {
  upheading,
  heading,
  priceHighlight,
  intro,
  guarantees,
  quote,
  quoteAuthor,
} = Astro.props

const priceParts  = priceHighlight?.split(' ') ?? []
const pricePrefix = priceParts[0] ?? ''
const priceNum    = priceParts[1] ?? ''
const priceUnit   = priceParts.slice(2).join(' ')

---

<section class='relative overflow-hidden bg-gradient-to-tl from-base via-surface to-base/60 py-24 sm:py-32'>

  <!-- Diagonal tension lines -->
  <svg class='pointer-events-none absolute inset-0 w-full h-full' aria-hidden='true' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'>
    <line x1='0%'  y1='0%' x2='30%'  y2='100%' stroke='rgba(236,223,204,0.05)' stroke-width='1'/>
    <line x1='70%' y1='0%' x2='100%' y2='100%' stroke='rgba(255,255,255,0.03)' stroke-width='1'/>
  </svg>

  <!-- Large ghosted watermark -->
  <div class="font-heading pointer-events-none absolute -right-6 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-white/[0.04]"
    aria-hidden='true'>
    350
  </div>

  <!-- Top / bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cream/35 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-cream/15 to-transparent' aria-hidden='true'></div>

  <div class='relative container-site max-w-2xl'>

    <!-- ── Section header ─────────────────────────────────────────── -->
    <header class='mb-16 sm:mb-20'>

      <h2 data-animate class='text-xs font-bold uppercase tracking-widest text-cream'>{upheading}</h2>

      <p
        data-animate
        class='mt-5 font-heading text-h2 font-bold leading-[1.05] tracking-tight text-white text-pretty mb-6 [&_span]:text-cream'
        set:html={heading + '<span>.</span>'}
      />

      <AccentRule data-animate />

      <div data-animate class='mt-6'>
        <p class='text-base text-white/65 leading-relaxed text-pretty'>
          {intro}
        </p>
      </div>
    </header>

    <!-- ── Price feature strip ────────────────────────────────────── -->
    {priceHighlight && (
      <div
        data-animate
        class='relative overflow-hidden rounded-2xl border border-cream/10 bg-white/[0.03] mb-14'
      >
        <!-- Top accent gradient border -->
        <div class='absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-cream/60 via-cream/40 to-transparent rounded-t-2xl' aria-hidden='true'></div>

        <!-- Inner diagonal -->
        <svg class='pointer-events-none absolute inset-0 w-full h-full' aria-hidden='true' preserveAspectRatio='none'>
          <line x1='75%' y1='0%' x2='100%' y2='100%' stroke='rgba(236,223,204,0.07)' stroke-width='1'/>
        </svg>

        <div class='px-8 py-10 sm:px-10 sm:py-11 flex flex-col gap-5'>

          <!-- Label -->
          <p class='text-xs font-bold tracking-[0.14em] uppercase text-cream/50'>{pricePrefix}</p>

          <!-- Price + CTA row -->
          <div class='flex flex-wrap items-end justify-between gap-x-6 gap-y-4'>

            <!-- Price number -->
            <div class='flex items-end gap-3 leading-none'>
              <span class='font-heading text-h1 font-bold text-cream tabular-nums leading-none'>
                {priceNum}
              </span>
              <div class='mb-1 flex flex-col gap-0.5'>
                <span class='text-h6 font-semibold text-white/45'>{priceUnit}</span>
                <span class='text-xs font-semibold tracking-[0.12em] uppercase text-cream/40'>sin IVA</span>
              </div>
            </div>

            <!-- CTA -->
            <div class='flex items-center gap-3 mb-1'>
              <span class='text-cream/60 text-2xl rotate-[-10deg]' aria-hidden='true'>→</span>
              <a
                href='/presupuesto-seo-barcelona/#paquetes'
                class='rounded-md bg-cream px-5 py-2.5 text-sm font-bold text-surface shadow-sm hover:bg-[#f5e09a] active:bg-[#e8d280] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cream transition-colors'
              >
                Ver paquetes y precios
              </a>
            </div>

          </div>

        </div>
      </div>
    )}

    <!-- ── Guarantees: vertical stack ────────────────────────────── -->
    <ul role='list' class='flex flex-col gap-0'>
      {guarantees.map((item, i) => (
        <li
          data-animate
          class='group relative border-b border-white/[0.07] py-8 sm:py-10 pl-6'
        >
          <!-- Left accent line -->
          <span
            class='absolute left-0 top-8 sm:top-10 h-[calc(100%-4rem)] sm:h-[calc(100%-5rem)] w-px bg-gradient-to-b from-cream/30 to-transparent group-hover:from-cream/60 transition-colors duration-300'
            aria-hidden='true'
          ></span>

          <!-- Ordinal label -->
          <p class='font-heading text-xs font-bold tracking-[0.16em] uppercase text-cream/35 mb-3 group-hover:text-cream/60 transition-colors duration-300'>
            {String(i + 1).padStart(2, '0')}
          </p>

          <!-- Title -->
          <p class='font-semibold text-white/90 mb-2 leading-snug'>{item.title}</p>

          <!-- Description -->
          <p class='text-sm text-white/50 text-pretty leading-relaxed'>{item.description}</p>
        </li>
      ))}
    </ul>

    <!-- ── Quote ─────────────────────────────────────────────────── -->
    {quote && (
      <div
        data-animate
        class='mt-12 flex items-start gap-5 rounded-2xl border border-white/[0.08] bg-white/[0.03] px-8 py-7'
      >
        <span class='flex-shrink-0 mt-0.5 text-5xl text-cream/30 font-serif leading-none select-none' aria-hidden='true'>"</span>
        <figure>
          <blockquote class='text-base italic text-white/75 text-pretty leading-relaxed'>
            <p>{quote}</p>
          </blockquote>
          {quoteAuthor && (
            <figcaption class='mt-3 text-sm text-white/40'>{quoteAuthor}</figcaption>
          )}
        </figure>
      </div>
    )}

  </div>
</section>
