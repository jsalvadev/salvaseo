---
import { Map, MapPin, Phone } from '@lucide/astro'
import Upheading from '../../Upheading.astro'
import WhatsAppButton from '../../WhatsAppButton.astro'

interface Props {
  upheading?: string
  heading: string
  primaryCtaText: string
  secondaryCtaText?: string
  secondaryCtaHref?: string
}

const { upheading, heading, primaryCtaText, secondaryCtaText, secondaryCtaHref } = Astro.props
---

<div class='bg-petrol-900'>
  <div class='mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8'>
    <div class='mx-auto max-w-2xl text-center'>
      <!-- Benefit pills -->
      <div class='mb-8 flex flex-wrap items-center justify-center gap-3'>
        <span class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-petrol-100'>
          <Map class='size-4' aria-hidden='true' />
          Google Maps
        </span>
        <span class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-petrol-100'>
          <MapPin class='size-4' aria-hidden='true' />
          Local Pack
        </span>
        <span class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-petrol-100'>
          <Phone class='size-4' aria-hidden='true' />
          Más llamadas
        </span>
      </div>

      {upheading && <Upheading as='h2' text={upheading} />}
      <p class='text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl'>
        {heading}
      </p>
      <div class='mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-x-6'>
        <WhatsAppButton text={primaryCtaText} />
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class='text-sm/6 font-semibold text-white hover:text-sky-300 transition-colors'>
            {secondaryCtaText} <span aria-hidden='true'>→</span>
          </a>
        )}
      </div>
    </div>
  </div>
</div>
