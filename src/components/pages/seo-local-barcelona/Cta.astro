---
import { Map, MapPin, Phone } from '@lucide/astro'
import WhatsAppButton from '../../WhatsAppButton.astro'

interface Props {
  upheading?: string
  heading: string
  primaryCtaText: string
  secondaryCtaText?: string
  secondaryCtaHref?: string
}

const { upheading, heading, primaryCtaText, secondaryCtaText, secondaryCtaHref } = Astro.props
---

<div class='relative bg-sage overflow-hidden'>
  <!-- gradient mesh -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'></div>
  <!-- dot grid -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.10]'
    aria-hidden='true'></div>
  <!-- floating decorative rings -->
  <div
    class='pointer-events-none absolute -top-20 -left-20 size-80 rounded-full border border-sand/10'
    aria-hidden='true'></div>
  <div
    class='pointer-events-none absolute -bottom-24 -right-24 size-96 rounded-full border border-sand/[0.08]'
    aria-hidden='true'></div>

  <div data-animate class='relative container-site py-24 sm:py-32'>
    <div class='mx-auto max-w-2xl text-center'>
      <!-- Benefit pills -->
      <div class='mb-8 flex flex-wrap items-center justify-center gap-3'>
        <span class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-white/75'>
          <Map class='size-4' aria-hidden='true' />
          Google Maps
        </span>
        <span class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-white/75'>
          <MapPin class='size-4' aria-hidden='true' />
          Local Pack
        </span>
        <span class='inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-sm text-white/75'>
          <Phone class='size-4' aria-hidden='true' />
          Más llamadas
        </span>
      </div>

      {upheading && (
        <div class='flex items-center justify-center gap-3 mb-4'>
          <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
          <p class='text-xs font-bold tracking-[0.18em] uppercase text-cream'>{upheading}</p>
          <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
        </div>
      )}
      <p class='text-h2 font-semibold tracking-tight text-balance text-white sm:text-h1'>
        {heading}
      </p>
      <!-- accent bar -->
      <div class='mx-auto mt-4 h-1 w-20 rounded-full bg-gradient-to-r from-sand to-sand/40'></div>
      <div class='mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-x-6'>
        <WhatsAppButton text={primaryCtaText} />
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class='text-sm/6 font-semibold text-white hover:text-cream transition-colors'>
            {secondaryCtaText} <span aria-hidden='true'>→</span>
          </a>
        )}
      </div>
    </div>
  </div>
</div>
