---
import { UtensilsCrossed, Stethoscope, Scale, ShoppingBag, Wrench, Hotel } from '@lucide/astro'

type IconKey = 'utensilsCrossed' | 'stethoscope' | 'scale' | 'shoppingBag' | 'wrench' | 'hotel'

interface BusinessType {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  businessTypes?: BusinessType[]
}

const iconByKey = {
  utensilsCrossed: UtensilsCrossed,
  stethoscope: Stethoscope,
  scale: Scale,
  shoppingBag: ShoppingBag,
  wrench: Wrench,
  hotel: Hotel,
} as const

// Sample searches shown per business type
const searchByIcon: Record<IconKey, string[]> = {
  utensilsCrossed: ['"restaurante italiano eixample"', '"brunch barcelona"'],
  stethoscope:     ['"dentista barcelona"', '"fisioterapeuta cerca de mí"'],
  scale:           ['"abogado laboralista barcelona"', '"gestoría autónomos bcn"'],
  shoppingBag:     ['"floristería barcelona cerca"', '"tienda ropa gràcia"'],
  wrench:          ['"cerrajero urgente barcelona"', '"electricista barcelona"'],
  hotel:           ['"hotel boutique barcelona"', '"apartamento turístico eixample"'],
}

const defaultBusinessTypes: BusinessType[] = [
  {
    icon: 'utensilsCrossed',
    title: 'Restaurantes y hostelería',
    description:
      '"Restaurante italiano Eixample", "bar de tapas Gràcia", "brunch Barcelona"… Las búsquedas de hostelería son <strong>100 % locales</strong> y con intención inmediata.',
  },
  {
    icon: 'stethoscope',
    title: 'Clínicas y salud',
    description:
      'Dentistas, fisioterapeutas, psicólogos, veterinarios. El paciente busca <strong>cercanía y confianza</strong>: reseñas, reputación online y ficha completa marcan la diferencia.',
  },
  {
    icon: 'scale',
    title: 'Abogados y asesorías',
    description:
      '"Abogado laboralista Barcelona", "gestoría autónomos Barcelona". Son búsquedas con <strong>alta intención de contratación</strong> y ticket medio elevado.',
  },
  {
    icon: 'shoppingBag',
    title: 'Tiendas y comercio',
    description:
      'Floristería, tienda de ropa, ferretería, óptica. El cliente que busca <strong>"cerca de mí"</strong> quiere comprar hoy, no comparar durante semanas.',
  },
  {
    icon: 'wrench',
    title: 'Talleres y servicios técnicos',
    description:
      'Cerrajeros, electricistas, fontaneros, talleres mecánicos. Búsquedas de <strong>urgencia</strong> donde el primero en aparecer se lleva al cliente. Sin excepción.',
  },
  {
    icon: 'hotel',
    title: 'Hoteles y turismo',
    description:
      'Hoteles, apartamentos turísticos, tours y experiencias. Barcelona recibe millones de turistas que <strong>buscan en Google Maps</strong> antes de reservar.',
  },
]

const {
  upheading = 'SEO local para negocios físicos en Barcelona',
  heading = 'Para qué tipo de negocios funciona el SEO local',
  intro = 'Si alguien puede buscarte en Google escribiendo <strong>"[tu servicio] + Barcelona"</strong>, el SEO local es tu canal de captación más rentable.',
  businessTypes = defaultBusinessTypes,
} = Astro.props

const ordinals = ['01', '02', '03', '04', '05', '06']
---

<section class='relative overflow-hidden py-24 md:py-32'>

  <!-- Subtle dot-grid -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'>
  </div>

  <!-- Titan One watermark -->
  <div class="font-heading pointer-events-none absolute -left-6 top-1/2 -translate-y-1/2 select-none leading-none"
    aria-hidden='true'>
    BCN
  </div>

  <!-- Orange right accent bar -->
  <div
    class='pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-32 bg-sage rounded-l-full'
    aria-hidden='true'>
  </div>

  <!-- Top / bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-charcoal/10 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-charcoal/10 to-transparent' aria-hidden='true'></div>

  <div class='relative container-site'>

    <!-- ── Section header ─────────────────────────────────────────────── -->
    <div class='mb-14 md:mb-18 max-w-3xl'>
      <div data-animate class='flex items-center gap-3 mb-8'>
        <span class='block h-px w-10 bg-sage' aria-hidden='true'></span>
        <h2 class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sage'>
          {upheading}
        </h2>
      </div>

      <p
        data-animate

        class='font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] leading-[1.05] tracking-tight text-cream text-pretty'>
        Puede que tu negocio ya tenga clientes buscándolo<span class='text-sage'>.</span>
      </p>

      <div data-animate class='mt-6 flex items-center'>
        <div class='h-[3px] w-16 bg-sage rounded-full'></div>
        <div class='h-px w-24 bg-gradient-to-r from-teal/40 to-transparent'></div>
      </div>

      <p data-animate class='mt-6 max-w-[52ch] text-base md:text-lg text-cream/70 leading-relaxed text-pretty'>
        <Fragment set:html={intro} />
      </p>
    </div>

    <!-- ── Cards grid ─────────────────────────────────────────────────── -->
    <dl class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4'>
      {businessTypes.map((item, idx) => {
        const Icon = iconByKey[item.icon]
        const searches = searchByIcon[item.icon]
        const num = ordinals[idx] ?? String(idx + 1).padStart(2, '0')
        return (
          <div
            data-animate
            data-animate-delay={idx * 80}
            class='btype-card group relative overflow-hidden rounded-2xl border border-surface/10 bg-white px-6 py-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-charcoal/8 hover:border-teal/30 cursor-default'>

            <!-- Ghost ordinal watermark -->
            <div class="font-heading pointer-events-none absolute -bottom-3 -right-2 select-none leading-none transition-opacity duration-300 opacity-100 group-hover:opacity-100"
              aria-hidden='true'>
              {num}
            </div>

            <!-- Left accent bar (appears on hover) -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sage scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>

            <!-- ── Search mockup ── -->
            <div class='mb-5 space-y-1.5'>
              {searches.map((q) => (
                <div class='flex items-center gap-2 rounded-lg px-2.5 py-1.5 border transition-colors duration-300'>
                  <!-- Google G -->
                  <svg class='shrink-0 w-3 h-3' viewBox='0 0 40 40' fill='none' aria-hidden='true'>
                    <circle cx='20' cy='20' r='20' fill='#4285F4'/>
                    <path d='M28.5 20.2c0-.7-.1-1.4-.2-2H20v3.8h4.8c-.2 1-.8 1.8-1.7 2.4v2h2.7c1.6-1.5 2.7-3.7 2.7-6.2z' fill='#fff'/>
                    <path d='M20 29c2.4 0 4.5-.8 6-2.2l-2.7-2c-.8.5-1.9.9-3.3.9-2.5 0-4.6-1.7-5.4-4h-2.8v2c1.5 3 4.5 5.3 8.2 5.3z' fill='#fff'/>
                    <path d='M14.6 21.7c-.2-.5-.3-1.1-.3-1.7s.1-1.2.3-1.7v-2h-2.8C11.3 17.5 11 18.7 11 20s.3 2.5.8 3.7l2.8-2z' fill='#fff'/>
                    <path d='M20 14.3c1.4 0 2.6.5 3.6 1.4l2.5-2.5C24.5 11.8 22.4 11 20 11c-3.7 0-6.7 2.3-8.2 5.3l2.8 2c.8-2.3 2.9-4 5.4-4z' fill='#fff'/>
                  </svg>
                  <span class='text-[0.68rem] text-cream/60 font-medium leading-none tracking-tight truncate'>
                    {q}
                  </span>
                  <div class='ml-auto shrink-0 flex gap-0.5'>
                    <div class='h-1 w-1 rounded-full bg-surface/20'></div>
                    <div class='h-1 w-1 rounded-full bg-surface/20'></div>
                    <div class='h-1 w-1 rounded-full bg-surface/20'></div>
                  </div>
                </div>
              ))}
            </div>

            <!-- ── Icon + Title ── -->
            <div class='relative flex items-start gap-3.5'>

              <div class='shrink-0 mt-0.5 flex h-9 w-9 items-center justify-center rounded-xl bg-sage/5 ring-1 ring-teal/15 transition-all duration-300 group-hover:bg-sage/10 group-hover:ring-teal/25'>
                <Icon class='size-4.5 text-sage' aria-hidden='true' />
              </div>

              <div class='min-w-0'>
                <!-- Expanding accent line -->
                <div class='h-0.5 w-6 bg-sage rounded-full transition-all duration-300 group-hover:w-12 mb-2.5'></div>
                <dt class='text-[0.9375rem] font-bold text-cream leading-snug mb-2 transition-colors duration-300 group-hover:text-cream'>
                  {item.title}
                </dt>
                <dd class='text-sm text-cream/70 leading-relaxed text-pretty'>
                  <Fragment set:html={item.description} />
                </dd>
              </div>

            </div>
          </div>
        )
      })}
    </dl>


  </div>
</section>
