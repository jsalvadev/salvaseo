---
import WhatsAppButton from '../../WhatsAppButton.astro'
import Breadcrumb from '../../Breadcrumb.astro'
import { buildWhatsAppHref } from '../../../data/site'
import { Image } from 'astro:assets'
import localPackImg from '../../../assets/local-pack-fontanero-barcelona.png'

interface Props {
  heading: string
  description: string
  primaryCtaText: string
  secondaryCtaText: string
  secondaryCtaHref: string
}

const { heading, description, primaryCtaText, secondaryCtaText, secondaryCtaHref } = Astro.props

const waHref = buildWhatsAppHref()

// Split heading at " en " for two-tone Titan One treatment
const splitIdx = heading.toLowerCase().indexOf(' en ')
const headingFirst  = splitIdx !== -1 ? heading.slice(0, splitIdx + 4) : heading   // "…cercanas en"
const headingSecond = splitIdx !== -1 ? heading.slice(splitIdx + 4)    : ''         // "clientes que pagan"
---

<section class='relative bg-teal overflow-hidden'>

  <!-- Ambient radial blobs -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'>
  </div>

  <!-- Dot grid -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'>
  </div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line x1='68%' y1='0%' x2='95%'  y2='100%' stroke='rgba(250,234,177,0.06)' stroke-width='1'/>
    <line x1='74%' y1='0%' x2='104%' y2='100%' stroke='rgba(250,234,177,0.035)' stroke-width='1'/>
    <line x1='61%' y1='0%' x2='88%'  y2='100%' stroke='rgba(250,234,177,0.04)' stroke-width='1'/>
  </svg>

  <!-- Titan One watermark -->
  <div class="font-heading pointer-events-none absolute -top-6 right-0 select-none leading-none hidden lg:block"
    aria-hidden='true'>
    LOCAL
  </div>

  <!-- Radial glow bottom-left -->
  <div
    class='pointer-events-none absolute -bottom-32 -left-32 w-96 h-96 rounded-full'
    aria-hidden='true'>
  </div>

  <Breadcrumb
    items={[{ label: 'Inicio', href: '/' }, { label: 'Consultor SEO Local Barcelona' }]}
    dark
  />

  <div class='relative z-10 mx-auto max-w-[1280px] px-5'>
    <div class='min-h-[80vh] flex items-center pt-10 pb-24 lg:pt-12 lg:pb-28'>
      <div class='w-full grid lg:grid-cols-12 gap-10 lg:gap-14 items-center'>

        <!-- ── LEFT: text content (7 cols) ─────────────────────────── -->
        <div class='lg:col-span-7 hero-left'>

          <!-- Eyebrow -->
          <div class='flex items-center gap-3 mb-7'>
            <span class='block h-px w-10 bg-sand shrink-0' aria-hidden='true'></span>
            <h1 class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sand'>Consultor SEO Local en Barcelona</h1>
          </div>

          <!-- Visual display heading (not semantic) -->
          <p class='hero-heading font-heading'>
            {headingSecond ? (
              <>
                <span class='block text-[clamp(1rem,2.2vw,1.8rem)] text-white/40 leading-[1.05] tracking-tight mb-1'>
                  {headingFirst}
                </span>
                <span class='block font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] text-white leading-[0.93] tracking-tight'>
                  {headingSecond}<span class='text-sand'>.</span>
                </span>
              </>
            ) : (
              <span class='block font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] text-white leading-[1.05] tracking-tight'>
                {heading}
              </span>
            )}
          </p>

          <!-- Accent rule -->
          <div class='mt-5 mb-7 flex items-center gap-0 hero-rule' aria-hidden='true'>
            <div class='h-[3px] w-16 bg-sand rounded-full'></div>
            <div class='h-px w-24 bg-gradient-to-r from-sand/50 to-transparent'></div>
          </div>

          <!-- Description -->
          <p class='text-[1.0625rem] text-white/75 leading-[1.75] max-w-2xl mb-8 hero-description'>
            <Fragment set:html={description} />
          </p>

          <!-- CTAs -->
          <div class='flex flex-col sm:flex-row gap-4 items-start mb-8 hero-ctas'>
            <WhatsAppButton text={primaryCtaText} href={waHref} class='px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-teal/20 hover:shadow-teal/30 transition-shadow' />
          </div>


        </div>

        <!-- ── RIGHT: Local Pack screenshot (5 cols) ─────────────── -->
        <div class='hidden lg:block lg:col-span-5 hero-right'>
          <Image
            src={localPackImg}
            alt='Resultados del Local Pack de Google para "fontanero urgente barcelona"'
            width={762}
            height={719}
            class='w-full h-auto block rounded-2xl'
            loading='eager'
          />
          <p class='mt-3 text-center text-xs text-white/40 leading-relaxed'>
            Captura real de Google · Local Pack para "fontanero urgente barcelona"
          </p>
        </div>

      </div>
    </div>
  </div>


</section>
