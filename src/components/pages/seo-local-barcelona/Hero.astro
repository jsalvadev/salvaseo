---
import { Image } from 'astro:assets'
import WhatsAppButton from '../../WhatsAppButton.astro'
import seoLocalHeroImage from '../../../assets/seo-local-hero.jpg'

interface Props {
  heading: string
  description: string
  primaryCtaText: string
  secondaryCtaText: string
  secondaryCtaHref: string
}

const { heading, description, primaryCtaText, secondaryCtaText, secondaryCtaHref } = Astro.props
---

<section class='relative bg-petrol-900 overflow-hidden'>
  <!-- Ambient background blobs -->
  <div
    class='pointer-events-none absolute inset-0'
    style='background: radial-gradient(ellipse at 10% 60%, rgba(14,165,233,0.13) 0%, transparent 55%), radial-gradient(ellipse at 85% 20%, rgba(249,115,22,0.08) 0%, transparent 50%), radial-gradient(ellipse at 50% 100%, rgba(14,165,233,0.06) 0%, transparent 60%);'
    aria-hidden='true'></div>

  <!-- Dot grid -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.07]'
    style='background-image: radial-gradient(circle, #7dd3fc 1px, transparent 1px); background-size: 28px 28px;'
    aria-hidden='true'></div>

  <!-- Hero photo: bleeds to right on large screens -->
  <Image
    src={seoLocalHeroImage}
    alt=''
    width={900}
    height={1100}
    class='pointer-events-none absolute right-0 top-0 h-full w-[45%] object-cover object-center opacity-[0.08] [mask-image:linear-gradient(to_left,black_0%,transparent_100%)] hidden xl:block'
    loading='eager'
    fetchpriority='high'
    aria-hidden='true'
  />

  <div class='relative z-10 mx-auto max-w-7xl px-6 lg:px-8'>
    <div class='min-h-[88vh] flex items-center py-24 lg:py-16'>
      <div class='w-full grid lg:grid-cols-12 gap-10 lg:gap-14 items-center'>

        <!-- ── LEFT: Text content (7 cols) ── -->
        <div class='lg:col-span-7 hero-left'>

          <!-- Badge -->
          <div class='mb-7 hero-badge'>
            <span
              class='inline-flex items-center gap-2 rounded-full bg-sky-500/10 border border-sky-400/20 px-4 py-1.5 text-sm font-medium text-sky-300'>
              <svg
                class='size-3.5 shrink-0'
                viewBox='0 0 16 16'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
                aria-hidden='true'>
                <path
                  d='M8 1.5C5.51 1.5 3.5 3.51 3.5 6c0 3.5 4.5 8.5 4.5 8.5S12.5 9.5 12.5 6c0-2.49-2.01-4.5-4.5-4.5zm0 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z'
                  fill='currentColor'></path>
              </svg>
              SEO Local en Barcelona
            </span>
          </div>

          <!-- H1 -->
          <h1
            class='text-white leading-[1.08] mb-7 hero-heading'
            style='font-family: "Titan One", cursive; font-size: clamp(2.6rem, 5.5vw, 4.25rem); letter-spacing: -0.015em;'>
            {heading}
          </h1>

          <!-- Accent rule -->
          <div class='flex items-center gap-2 mb-8 hero-rule' aria-hidden='true'>
            <div class='h-[3px] w-14 bg-orange-500 rounded-full'></div>
            <div class='h-[3px] w-5 bg-sky-400/35 rounded-full'></div>
            <div class='h-[3px] w-2 bg-sky-400/15 rounded-full'></div>
          </div>

          <!-- Description -->
          <p class='text-[1.0625rem] text-petrol-100 leading-[1.75] max-w-2xl mb-8 hero-description'>
            <Fragment set:html={description} />
          </p>

          <!-- 46% stat callout -->
          <div
            class='inline-flex items-center gap-4 mb-10 px-5 py-4 rounded-xl bg-white/[0.05] border border-white/[0.09] backdrop-blur-sm hero-stat'>
            <span
              class='text-[3.25rem] leading-none text-orange-500 shrink-0'
              style='font-family: "Titan One", cursive;'
              aria-hidden='true'>46%</span>
            <p class='text-sm text-petrol-100 leading-snug max-w-[16rem]'>
              de las búsquedas en Google tienen intención local — tu cliente ya está buscando ahora mismo.
            </p>
          </div>

          <!-- CTAs -->
          <div class='flex flex-col sm:flex-row gap-4 items-start mb-8 hero-ctas'>
            <WhatsAppButton text={primaryCtaText} />
            <a
              href={secondaryCtaHref}
              class='group inline-flex items-center gap-2 text-sm font-semibold text-white/75 hover:text-white transition-colors py-3 px-1'>
              {secondaryCtaText}
              <span
                class='group-hover:translate-x-1 transition-transform duration-200'
                aria-hidden='true'>→</span>
            </a>
          </div>

          <!-- Trust signals -->
          <div
            class='flex flex-wrap gap-x-7 gap-y-2.5 pt-5 border-t border-white/[0.09] hero-trust'>
            <span class='inline-flex items-center gap-2 text-sm text-petrol-100'>
              <span class='size-2 rounded-full bg-maps-green shadow-[0_0_6px_rgba(52,168,83,0.7)]'
                aria-hidden='true'></span>
              Diagnóstico gratuito
            </span>
            <span class='inline-flex items-center gap-2 text-sm text-petrol-100'>
              <span class='size-2 rounded-full bg-maps-green shadow-[0_0_6px_rgba(52,168,83,0.7)]'
                aria-hidden='true'></span>
              Sin permanencia
            </span>
            <span class='inline-flex items-center gap-2 text-sm text-petrol-100'>
              <span class='size-2 rounded-full bg-maps-green shadow-[0_0_6px_rgba(52,168,83,0.7)]'
                aria-hidden='true'></span>
              Resultados en 4–8 semanas
            </span>
          </div>
        </div>

        <!-- ── RIGHT: Google Local Pack mockup (5 cols) ── -->
        <div class='hidden lg:flex lg:col-span-5 justify-center items-center hero-right'>
          <div class='mockup-scene' aria-hidden='true'>

            <!-- Floating badge -->
            <div
              class='absolute -top-3 -right-5 z-20 bg-orange-500 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg'
              style='transform: rotate(4deg);'>
              Tu negocio aquí ↓
            </div>

            <!-- Local Pack card -->
            <div
              class='mockup-card bg-white rounded-2xl overflow-hidden w-[330px] shadow-[0_32px_80px_-8px_rgba(0,0,0,0.55),0_0_0_1px_rgba(255,255,255,0.06)]'>

              <!-- Browser chrome -->
              <div
                class='bg-[#f1f3f4] px-4 py-2.5 flex items-center gap-3 border-b border-black/[0.07]'>
                <div class='flex gap-1.5 shrink-0' aria-hidden='true'>
                  <div class='size-2.5 rounded-full bg-[#ff5f56]'></div>
                  <div class='size-2.5 rounded-full bg-[#ffbd2e]'></div>
                  <div class='size-2.5 rounded-full bg-[#27c93f]'></div>
                </div>
                <div
                  class='flex-1 bg-white rounded-full px-3 py-1.5 text-[11px] text-gray-500 flex items-center gap-1.5 border border-black/[0.08]'>
                  <svg class='size-3 text-gray-400 shrink-0' viewBox='0 0 16 16' fill='none'>
                    <circle cx='7' cy='7' r='4.5' stroke='currentColor' stroke-width='1.5'></circle>
                    <path
                      d='M10.5 10.5l2.5 2.5'
                      stroke='currentColor'
                      stroke-width='1.5'
                      stroke-linecap='round'></path>
                  </svg>
                  <span>dentista barcelona</span>
                </div>
              </div>

              <!-- Map area -->
              <div class='relative h-40 overflow-hidden bg-[#e8edd4]'>
                <!-- Street grid SVG -->
                <svg
                  class='absolute inset-0 w-full h-full'
                  xmlns='http://www.w3.org/2000/svg'
                  aria-hidden='true'>
                  <!-- Main roads -->
                  <line x1='0' y1='60' x2='330' y2='60' stroke='#fff' stroke-width='5'></line>
                  <line x1='0' y1='115' x2='330' y2='115' stroke='#fff' stroke-width='4'></line>
                  <line x1='75' y1='0' x2='75' y2='160' stroke='#fff' stroke-width='5'></line>
                  <line x1='165' y1='0' x2='165' y2='160' stroke='#fff' stroke-width='5'></line>
                  <line x1='255' y1='0' x2='255' y2='160' stroke='#fff' stroke-width='4'></line>
                  <!-- Secondary streets -->
                  <line x1='0' y1='30' x2='330' y2='30' stroke='#fff' stroke-width='2.5'></line>
                  <line x1='0' y1='88' x2='330' y2='88' stroke='#fff' stroke-width='2.5'></line>
                  <line x1='120' y1='0' x2='120' y2='160' stroke='#fff' stroke-width='2.5'></line>
                  <line x1='210' y1='0' x2='210' y2='160' stroke='#fff' stroke-width='2.5'></line>
                  <!-- Building blocks -->
                  <rect x='80' y='35' width='36' height='20' rx='2' fill='#d4dfc0'></rect>
                  <rect x='125' y='10' width='38' height='18' rx='2' fill='#cdd9b8'></rect>
                  <rect x='170' y='35' width='36' height='20' rx='2' fill='#d4dfc0'></rect>
                  <rect x='216' y='10' width='35' height='18' rx='2' fill='#cdd9b8'></rect>
                  <rect x='80' y='93' width='36' height='18' rx='2' fill='#cdd9b8'></rect>
                  <rect x='170' y='93' width='36' height='18' rx='2' fill='#d4dfc0'></rect>
                  <rect x='260' y='65' width='30' height='15' rx='2' fill='#cdd9b8'></rect>
                </svg>

                <!-- Blue highlight area -->
                <div
                  class='absolute inset-0'
                  style='background: radial-gradient(ellipse at 32% 48%, rgba(66,133,244,0.12) 0%, transparent 60%);'>
                </div>

                <!-- Pin 1: highlighted (your business) -->
                <div class='absolute' style='top: 36%; left: 26%;'>
                  <div class='relative'>
                    <div
                      class='size-8 bg-[#4285F4] rounded-full border-[2.5px] border-white shadow-[0_4px_12px_rgba(66,133,244,0.5)] flex items-center justify-center z-10 relative'>
                      <span class='text-white text-[11px] font-black leading-none'>1</span>
                    </div>
                    <div
                      class='absolute inset-0 rounded-full bg-[#4285F4]/25 pin-pulse'
                      style='animation: pin-ring 2s ease-out infinite;'>
                    </div>
                  </div>
                </div>

                <!-- Pin 2 -->
                <div class='absolute' style='top: 50%; left: 58%;'>
                  <div
                    class='size-6 bg-gray-400 rounded-full border-2 border-white shadow-md flex items-center justify-center'>
                    <span class='text-white text-[10px] font-bold leading-none'>2</span>
                  </div>
                </div>

                <!-- Pin 3 -->
                <div class='absolute' style='top: 22%; left: 70%;'>
                  <div
                    class='size-6 bg-gray-400 rounded-full border-2 border-white shadow-md flex items-center justify-center'>
                    <span class='text-white text-[10px] font-bold leading-none'>3</span>
                  </div>
                </div>
              </div>

              <!-- Business listings -->
              <div class='divide-y divide-gray-100'>

                <!-- #1 — highlighted -->
                <div class='px-4 py-3.5 bg-[#f8fbff] border-l-[3px] border-[#4285F4]'>
                  <div class='flex justify-between items-center gap-3'>
                    <div class='min-w-0'>
                      <p class='text-[13px] font-semibold text-gray-900 truncate'>
                        Clínica Dental López
                      </p>
                      <div class='flex items-center gap-1 mt-0.5'>
                        <span class='text-yellow-400 text-[11px] leading-none tracking-tight'>
                          ★★★★★
                        </span>
                        <span class='text-[11px] text-gray-500'>4.9 · 127 reseñas</span>
                      </div>
                      <div class='flex items-center gap-2 mt-0.5'>
                        <span class='text-[11px] text-[#137333] font-medium'>Abierto</span>
                        <span class='text-[11px] text-gray-400'>· 0.3 km · Dentista</span>
                      </div>
                    </div>
                    <span
                      class='shrink-0 bg-[#1a73e8] text-white text-[11px] px-3 py-1.5 rounded-full font-semibold'>
                      Llamar
                    </span>
                  </div>
                </div>

                <!-- #2 — dimmed -->
                <div class='px-4 py-3 opacity-40'>
                  <p class='text-[12px] font-semibold text-gray-700'>Dental Center BCN</p>
                  <div class='flex items-center gap-1 mt-0.5'>
                    <span class='text-yellow-400 text-[11px] leading-none'>★★★★</span>
                    <span class='text-[11px] text-gray-400'>4.2 · 43 reseñas · 0.8 km</span>
                  </div>
                </div>

                <!-- #3 — dimmed -->
                <div class='px-4 py-3 opacity-25'>
                  <p class='text-[12px] font-semibold text-gray-700'>Odontología Gràcia</p>
                  <div class='flex items-center gap-1 mt-0.5'>
                    <span class='text-yellow-400 text-[11px] leading-none'>★★★</span>
                    <span class='text-[11px] text-gray-400'>3.8 · 18 reseñas · 1.2 km</span>
                  </div>
                </div>

              </div>
            </div>

            <!-- Caption -->
            <p class='text-center text-[11px] text-petrol-100/50 mt-3 tracking-wide uppercase'>
              Local Pack · <strong class='text-petrol-100/70 font-semibold'>44 % de los clics</strong>
            </p>

            <!-- Decorative glow behind card -->
            <div
              class='absolute -bottom-12 left-1/2 -translate-x-1/2 w-56 h-24 bg-sky-500/15 blur-3xl rounded-full pointer-events-none'
              aria-hidden='true'></div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom wave transition to warm-white -->
  <div class='absolute bottom-0 left-0 right-0 pointer-events-none' aria-hidden='true'>
    <svg
      viewBox='0 0 1440 56'
      fill='none'
      xmlns='http://www.w3.org/2000/svg'
      class='w-full h-14'
      preserveAspectRatio='none'>
      <path d='M0 56L360 28L720 44L1080 16L1440 36V56H0Z' fill='#FAFAF8'></path>
    </svg>
  </div>
</section>

<style>
  /* ── Mockup 3D tilt ── */
  .mockup-scene {
    position: relative;
    width: 330px;
  }

  .mockup-card {
    transform: perspective(1100px) rotateY(-5deg) rotateX(3deg) translateZ(0);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .mockup-scene:hover .mockup-card {
    transform: perspective(1100px) rotateY(-1.5deg) rotateX(1deg) translateZ(10px);
  }

  /* ── Map pin ring animation ── */
  @keyframes pin-ring {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    100% {
      transform: scale(2.8);
      opacity: 0;
    }
  }

  /* ── Entrance animations ── */
  .hero-badge,
  .hero-heading,
  .hero-rule,
  .hero-description,
  .hero-stat,
  .hero-ctas,
  .hero-trust {
    opacity: 0;
    transform: translateY(22px);
    animation: hero-enter 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-badge      { animation-delay: 0.05s; }
  .hero-heading    { animation-delay: 0.15s; }
  .hero-rule       { animation-delay: 0.25s; }
  .hero-description { animation-delay: 0.30s; }
  .hero-stat       { animation-delay: 0.38s; }
  .hero-ctas       { animation-delay: 0.46s; }
  .hero-trust      { animation-delay: 0.54s; }

  .hero-right {
    opacity: 0;
    transform: translateY(30px) scale(0.97);
    animation: hero-enter 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  @keyframes hero-enter {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-badge, .hero-heading, .hero-rule, .hero-description,
    .hero-stat, .hero-ctas, .hero-trust, .hero-right {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .pin-pulse {
      animation: none;
    }
    .mockup-card {
      transform: none;
    }
  }
</style>
