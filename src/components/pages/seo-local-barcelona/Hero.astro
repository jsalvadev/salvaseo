---
import type { ImageMetadata } from 'astro'

interface Props {
  preheader: string
  h1: string
  description: string
  image: ImageMetadata
  imageAlt: string
  imageCaption?: string
  watermark?: string
}

const { preheader, h1, description, image, imageAlt, imageCaption, watermark } = Astro.props
---

<div class="relative isolate bg-gradient-to-b from-base to-surface/80 overflow-hidden">
  <svg aria-hidden="true" class="absolute inset-0 -z-10 size-full mask-[radial-gradient(100%_100%_at_top_right,white,transparent)] stroke-cream/5">
    <defs>
      <pattern id="grid-seo-local" width="200" height="200" x="50%" y="-1" patternUnits="userSpaceOnUse">
        <path d="M100 200V.5M.5 .5H200" fill="none" />
      </pattern>
    </defs>
    <svg x="50%" y="-1" class="overflow-visible fill-cream/[0.02]">
      <path d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z" stroke-width="0" />
    </svg>
    <rect width="100%" height="100%" fill="url(#grid-seo-local)" stroke-width="0" />
  </svg>

  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-20 -right-10 h-[400px] w-[500px] rounded-full bg-cream/10 blur-3xl"></div>
    <div class="absolute bottom-0 -left-20 h-[300px] w-[380px] rounded-full bg-sage/15 blur-3xl"></div>
  </div>

  {watermark && (
    <div class="font-heading pointer-events-none absolute -right-6 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-white/[0.04]"
      aria-hidden="true" style="text-transform: capitalize;">
      {watermark}
    </div>
  )}

  <div class="container-site py-24 sm:py-32 lg:flex lg:items-center lg:gap-x-10 lg:py-24">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:flex-auto">

      <h1 class="text-xs font-bold text-cream" data-animate>{preheader}</h1>

      <p
        data-animate
        class="mt-5 font-heading text-h1 font-normal leading-[1.05] tracking-tight text-white text-pretty"
        set:html={h1}
      />

      <div class="mt-6 flex items-center">
        <div class="h-px w-32 bg-gradient-to-r from-cream/5 to-cream/35"></div>
        <div class="h-px w-10 bg-cream/60"></div>
      </div>

      <p data-animate class="mt-8 text-base/8 text-cream/70 text-pretty max-w-[60ch]" set:html={description} />

      <div data-animate class="mt-10 flex items-center gap-x-6">
        <slot name="cta" />
      </div>

    </div>

    <div data-animate class="mt-16 sm:mt-24 lg:mt-0 lg:shrink-0 lg:grow">
      <svg role="img" viewBox="0 0 366 729" class="mx-auto w-[22.875rem] max-w-full drop-shadow-xl">
        <title>{imageAlt}</title>
        <defs>
          <clipPath id="phone-clip-seo-local">
            <rect width="316" height="684" rx="36" />
          </clipPath>
        </defs>
        <path d="M363.315 64.213C363.315 22.99 341.312 1 300.092 1H66.751C25.53 1 3.528 22.99 3.528 64.213v44.68l-.857.143A2 2 0 0 0 1 111.009v24.611a2 2 0 0 0 1.671 1.973l.95.158a2.26 2.26 0 0 1-.093.236v26.173c.212.1.398.296.541.643l-1.398.233A2 2 0 0 0 1 167.009v47.611a2 2 0 0 0 1.671 1.973l1.368.228c-.139.319-.314.533-.511.653v16.637c.221.104.414.313.56.689l-1.417.236A2 2 0 0 0 1 237.009v47.611a2 2 0 0 0 1.671 1.973l1.347.225c-.135.294-.302.493-.49.607v377.681c0 41.213 22 63.208 63.223 63.208h95.074c.947-.504 2.717-.843 4.745-.843l.141.001h.194l.086-.001 33.704.005c1.849.043 3.442.37 4.323.838h95.074c41.222 0 63.223-21.999 63.223-63.212v-394.63c-.259-.275-.48-.796-.63-1.47l-.011-.133 1.655-.276A2 2 0 0 0 366 266.62v-77.611a2 2 0 0 0-1.671-1.973l-1.712-.285c.148-.839.396-1.491.698-1.811V64.213Z" fill="#4B5563" />
        <path d="M16 59c0-23.748 19.252-43 43-43h246c23.748 0 43 19.252 43 43v615c0 23.196-18.804 42-42 42H58c-23.196 0-42-18.804-42-42V59Z" fill="#343E4E" />
        <foreignObject width="316" height="684" clip-path="url(#phone-clip-seo-local)" transform="translate(24 24)">
          <img
            src={image.src}
            alt={imageAlt}
            width="316"
            height="684"
            style="width:100%;height:100%;object-fit:cover;object-position:top;"
            fetchpriority="high"
          />
        </foreignObject>
      </svg>
      {imageCaption && (
        <p class="mt-3 text-center text-xs text-cream/50">{imageCaption}</p>
      )}
    </div>
  </div>
</div>
