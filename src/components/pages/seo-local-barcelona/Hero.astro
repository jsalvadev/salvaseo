---
import { MapPin, Map, Phone } from '@lucide/astro'
import WhatsAppButton from '../../WhatsAppButton.astro'

interface Props {
  heading: string
  description: string
  primaryCtaText: string
  secondaryCtaText: string
  secondaryCtaHref: string
}

const { heading, description, primaryCtaText, secondaryCtaText, secondaryCtaHref } = Astro.props
---

<div class='relative bg-petrol-900 overflow-hidden'>
  <!-- gradient mesh -->
  <div
    class='pointer-events-none absolute inset-0'
    style='background: radial-gradient(ellipse at 20% 50%, rgba(14,165,233,0.12) 0%, transparent 60%), radial-gradient(ellipse at 80% 30%, rgba(249,115,22,0.07) 0%, transparent 50%);'
    aria-hidden='true'></div>
  <!-- dot grid -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.10]'
    style='background-image: radial-gradient(circle, #7dd3fc 1px, transparent 1px); background-size: 32px 32px;'
    aria-hidden='true'></div>
  <!-- floating decorative rings -->
  <div
    class='pointer-events-none absolute -top-20 -left-20 size-80 rounded-full border border-sky-400/10'
    style='animation: subtle-float 6s ease-in-out infinite;'
    aria-hidden='true'></div>
  <div
    class='pointer-events-none absolute -bottom-24 -right-24 size-96 rounded-full border border-orange-500/[0.08]'
    style='animation: subtle-float 6s ease-in-out infinite 3s;'
    aria-hidden='true'></div>

  <div class='relative isolate px-6 lg:px-8'>
    <img
      src='https://images.pexels.com/photos/543606/pexels-photo-543606.jpeg'
      alt=''
      class='absolute inset-0 -z-10 size-full object-cover opacity-20 [mask-image:linear-gradient(to_right,transparent_30%,black_70%)]'
      loading='eager'
      decoding='async'
    />

    <div class='mx-auto max-w-3xl py-32 sm:py-48 lg:py-56'>
      <div class='hidden sm:mb-8 sm:flex sm:justify-center'>
        <h1 class='animate-fade-in-up [animation-delay:0ms] relative rounded-full bg-sky-500/10 border border-sky-400/20 px-3 py-1 text-sm/6 text-sky-300'>
          SEO Local en Barcelona
        </h1>
      </div>
      <div class='text-center'>
        <p class='animate-fade-in-up [animation-delay:100ms] text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl'>
          {heading}
        </p>
        <!-- accent bar -->
        <div class='animate-fade-in-up [animation-delay:150ms] mx-auto mt-6 h-1 w-20 rounded-full bg-gradient-to-r from-orange-500 to-sky-500'></div>
        <p class='animate-fade-in-up [animation-delay:200ms] mt-8 text-lg font-medium text-pretty text-petrol-100 sm:text-xl/8'>
          <Fragment set:html={description} />
        </p>
        <div class='animate-fade-in-up [animation-delay:300ms] mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-x-6'>
          <WhatsAppButton text={primaryCtaText} />
          <a
            href={secondaryCtaHref}
            class='text-sm/6 font-semibold text-white hover:text-sky-300 transition-colors'>
            {secondaryCtaText} <span aria-hidden='true'>→</span>
          </a>
        </div>
        <div class='animate-fade-in-up [animation-delay:400ms] mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3'>
          <span class='inline-flex items-center gap-1.5 text-sm text-petrol-100'>
            <span class='size-1.5 rounded-full bg-orange-500' aria-hidden='true'></span>
            <Map class='size-4' aria-hidden='true' />
            Google Maps
          </span>
          <span class='inline-flex items-center gap-1.5 text-sm text-petrol-100'>
            <span class='size-1.5 rounded-full bg-orange-500' aria-hidden='true'></span>
            <MapPin class='size-4' aria-hidden='true' />
            Local Pack
          </span>
          <span class='inline-flex items-center gap-1.5 text-sm text-petrol-100'>
            <span class='size-1.5 rounded-full bg-orange-500' aria-hidden='true'></span>
            <Phone class='size-4' aria-hidden='true' />
            Llamadas
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
