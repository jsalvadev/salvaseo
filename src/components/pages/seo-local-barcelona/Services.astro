---
import { SearchCheck, MapPin, Key, Globe, FileText, Link, Star } from '@lucide/astro'
import Upheading from '../../Upheading.astro'

type IconKey = 'searchCheck' | 'mapPin' | 'key' | 'globe' | 'fileText' | 'link' | 'star'

interface ServiceItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  services?: ServiceItem[]
  ctaText?: string
  ctaHref?: string
}

const iconByKey = {
  searchCheck: SearchCheck,
  mapPin: MapPin,
  key: Key,
  globe: Globe,
  fileText: FileText,
  link: Link,
  star: Star,
} as const

const defaultServices: ServiceItem[] = [
  {
    icon: 'searchCheck',
    title: 'Auditoría SEO local',
    description:
      'Auditas tu visibilidad actual en ficha de Google, web, citaciones NAP y Maps para <strong>identificar fugas de captación y oportunidades de facturación local</strong>.',
  },
  {
    icon: 'mapPin',
    title: 'Optimización de Google Business Profile',
    description:
      'Ejecutas optimización de categorías, descripción, fotos, horarios, atributos, publicaciones y productos. Un perfil completo puede generar <strong>hasta un 70 % más de visitas</strong> y más contactos comerciales.',
  },
  {
    icon: 'key',
    title: 'Palabras clave geolocalizadas',
    description:
      'Identificas keywords con intención local real para atraer búsquedas de alta conversión: <strong>clientes que necesitan tu servicio cerca y ahora</strong>.',
  },
  {
    icon: 'globe',
    title: 'SEO On Page con enfoque local',
    description:
      'Validas URLs geográficas, encabezados locales, schema LocalBusiness y <strong>NAP consistente</strong> para escalar relevancia local y reducir coste de adquisición.',
  },
  {
    icon: 'fileText',
    title: 'Contenido geolocalizado',
    description:
      'Ejecutas páginas de servicio por zona o barrio y contenidos locales que responden dudas reales de compra para <strong>acelerar captación de clientes en Barcelona</strong>.',
  },
  {
    icon: 'link',
    title: 'Link building local y citaciones NAP',
    description:
      'Refuerzas autoridad local con directorios de referencia, medios de zona y colaboraciones estratégicas, manteniendo <strong>consistencia NAP</strong> en todo internet.',
  },
  {
    icon: 'star',
    title: 'Gestión de reseñas y reputación online',
    description:
      'Escalas volumen y calidad de reseñas, ejecutas respuestas estratégicas y elevas tu <strong>ranking en Google Maps</strong> para convertir más visitas en clientes.',
  },
]

const {
  upheading = 'Servicios de SEO local para negocios en Barcelona',
  heading = 'SEO local en Barcelona para escalar captación y facturación',
  intro = 'Cada acción se ejecuta para que <strong>domines Google Maps y el Local Pack</strong>, aumentes contactos cualificados y conviertas búsquedas cercanas en ventas recurrentes.',
  services = defaultServices,
  ctaText,
  ctaHref,
} = Astro.props

const primaryServices = services.slice(0, 3)
const secondaryServices = services.slice(3)
---

<div id='servicios-local' class='bg-white py-24 sm:py-32'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <div data-animate class='mx-auto max-w-2xl lg:mx-0'>
      <Upheading as='h2' text={upheading} />
      <p class='mt-2 text-4xl font-semibold tracking-tight text-petrol-900 sm:text-5xl text-pretty'>
        {heading}
      </p>
      <p class='mt-4 text-base/7 text-petrol-700 w-full max-w-[60ch]'>
        <Fragment set:html={intro} />
      </p>
    </div>

    <!-- Local Pack card: top 3 services -->
    <div data-animate class='mx-auto mt-16 max-w-2xl bg-white border border-petrol-100 rounded-xl overflow-hidden border-t-2 border-t-sky-200'>
      <div class='flex items-center gap-2 px-6 py-3 border-b border-petrol-100 bg-petrol-50/50'>
        <MapPin class='size-4 text-maps-green' aria-hidden='true' />
        <span class='text-sm font-semibold text-petrol-900'>Servicios principales</span>
      </div>
      {primaryServices.map((service, idx) => {
        const Icon = iconByKey[service.icon]
        return (
          <div class:list={['flex gap-4 px-6 py-5', idx < primaryServices.length - 1 && 'border-b border-petrol-100']}>
            <Icon class='size-6 shrink-0 mt-0.5 text-sky-600' aria-hidden='true' />
            <div>
              <h3 class='text-base font-semibold text-petrol-900'>{service.title}</h3>
              <p class='mt-1 text-sm/6 text-petrol-700'>
                <Fragment set:html={service.description} />
              </p>
            </div>
          </div>
        )
      })}
    </div>

    <!-- Secondary services grid -->
    <div class='mt-12 bg-petrol-50 rounded-2xl p-8'>
      <div class='grid grid-cols-1 gap-8 sm:grid-cols-2'>
        {secondaryServices.map((service, idx) => {
          const Icon = iconByKey[service.icon]
          return (
            <div
              data-animate
              data-animate-delay={idx * 100}
              class='group bg-white rounded-lg p-6 border border-petrol-100 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-petrol-200'>
              <Icon class='size-10 mb-3 text-sky-600' aria-hidden='true' />
              <h3 class='text-base font-semibold text-petrol-900'>{service.title}</h3>
              <div class='h-0.5 w-8 bg-sky-500 rounded-full transition-all duration-300 group-hover:w-14 mt-2 mb-2'></div>
              <p class='mt-2 text-sm/6 text-petrol-700'>
                <Fragment set:html={service.description} />
              </p>
            </div>
          )
        })}
      </div>
    </div>

    {ctaText && ctaHref && (
      <div class='mt-12 text-center'>
        <a
          href={ctaHref}
          class='inline-flex items-center gap-1 text-sm font-semibold text-sky-a11y hover:text-sky-600 transition-colors'>
          {ctaText} <span aria-hidden='true'>→</span>
        </a>
      </div>
    )}
  </div>
</div>
