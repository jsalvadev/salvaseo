---
import { SearchCheck, MapPin, Key, Globe, FileText, Link, Star } from '@lucide/astro'

type IconKey = 'searchCheck' | 'mapPin' | 'key' | 'globe' | 'fileText' | 'link' | 'star'

interface ServiceItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  services?: ServiceItem[]
  ctaText?: string
  ctaHref?: string
}

const iconByKey = {
  searchCheck: SearchCheck,
  mapPin: MapPin,
  key: Key,
  globe: Globe,
  fileText: FileText,
  link: Link,
  star: Star,
} as const

const defaultServices: ServiceItem[] = [
  {
    icon: 'searchCheck',
    title: 'Auditoría SEO local',
    description:
      'Auditas tu visibilidad actual en ficha de Google, web, citaciones NAP y Maps para <strong>identificar fugas de captación y oportunidades de facturación local</strong>.',
  },
  {
    icon: 'mapPin',
    title: 'Optimización de Google Business Profile',
    description:
      'Ejecutas optimización de categorías, descripción, fotos, horarios, atributos, publicaciones y productos. Un perfil completo puede generar <strong>hasta un 70 % más de visitas</strong> y más contactos comerciales.',
  },
  {
    icon: 'key',
    title: 'Palabras clave geolocalizadas',
    description:
      'Identificas keywords con intención local real para atraer búsquedas de alta conversión: <strong>clientes que necesitan tu servicio cerca y ahora</strong>.',
  },
  {
    icon: 'globe',
    title: 'SEO On Page con enfoque local',
    description:
      'Validas URLs geográficas, encabezados locales, schema LocalBusiness y <strong>NAP consistente</strong> para escalar relevancia local y reducir coste de adquisición.',
  },
  {
    icon: 'fileText',
    title: 'Contenido geolocalizado',
    description:
      'Ejecutas páginas de servicio por zona o barrio y contenidos locales que responden dudas reales de compra para <strong>acelerar captación de clientes en Barcelona</strong>.',
  },
  {
    icon: 'link',
    title: 'Link building local y citaciones NAP',
    description:
      'Refuerzas autoridad local con directorios de referencia, medios de zona y colaboraciones estratégicas, manteniendo <strong>consistencia NAP</strong> en todo internet.',
  },
  {
    icon: 'star',
    title: 'Gestión de reseñas y reputación online',
    description:
      'Escalas volumen y calidad de reseñas, ejecutas respuestas estratégicas y elevas tu <strong>ranking en Google Maps</strong> para convertir más visitas en clientes.',
  },
]

const {
  upheading = 'Servicios de SEO local para negocios en Barcelona',
  heading = 'Las palancas que determinan tu visibilidad en Google Maps',
  intro = 'Cada acción se ejecuta para que <strong>domines Google Maps y el Local Pack</strong>, aumentes contactos cualificados y conviertas búsquedas cercanas en ventas recurrentes.',
  services = defaultServices,
  ctaText,
  ctaHref,
} = Astro.props

// Visual metadata: signal bars (1–4) + optional callout stat
const meta = [
  { bars: 3, accent: 'sky',    stat: 'Punto de partida',         wide: false },
  { bars: 4, accent: 'orange', stat: 'Hasta +70 % de contactos', wide: true  },
  { bars: 3, accent: 'sky',    stat: null,                        wide: false },
  { bars: 3, accent: 'sky',    stat: null,                        wide: false },
  { bars: 3, accent: 'sky',    stat: null,                        wide: false },
  { bars: 4, accent: 'sky',    stat: 'Señal de confianza clave',  wide: false },
  { bars: 4, accent: 'orange', stat: '+30 % más llamadas',        wide: true  },
]
---

<section id='servicios-local' class='relative bg-surface py-24 sm:py-32 overflow-hidden'>

  <!-- Background texture: fine dot grid -->
  <div
    class='pointer-events-none absolute inset-0 opacity-[0.06]'
    aria-hidden='true'></div>

  <!-- Ambient glow blobs -->
  <div
    class='pointer-events-none absolute top-0 left-1/3 w-[500px] h-[500px] rounded-full opacity-20'
    aria-hidden='true'></div>
  <div
    class='pointer-events-none absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full opacity-15'
    aria-hidden='true'></div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <!-- ── Header ── -->
    <div class='flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-16' data-animate>
      <div class='max-w-2xl'>
        <div class='flex items-center gap-3 mb-4'>
          <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
          <h2 class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sand'>{upheading}</h2>
        </div>
        <p class="font-display mt-3 text-white leading-[1.1]">
          {heading}
        </p>
      </div>
    </div>

    <!-- ── Services grid ── -->
    <div class='services-grid'>
      {services.map((service, idx) => {
        const Icon = iconByKey[service.icon]
        const m = meta[idx] ?? { bars: 3, accent: 'sky', stat: null, wide: false }
        const isOrange = m.accent === 'orange'
        const accentColor = isOrange ? 'var(--color-sand)' : 'var(--color-teal)'
        const barClass = isOrange ? 'svc-bar-orange' : 'svc-bar-sky'
        const iconBgClass = isOrange ? 'svc-icon-orange' : 'svc-icon-sky'

        return (
          <article
            class:list={[
              'svc-card group relative flex flex-col gap-5 rounded-2xl p-6 border transition-all duration-300',
              m.wide && 'svc-card--wide',
            ]}
            data-animate
            data-animate-delay={idx * 80}>

            <!-- Card number watermark -->
            <span
              class='svc-num pointer-events-none select-none absolute top-4 right-5'
              aria-hidden='true'>
              {String(idx + 1).padStart(2, '0')}
            </span>

            <!-- Top row: icon + signal bars -->
            <div class='flex items-start justify-between'>
              <!-- Icon -->
              <div class:list={['svc-icon-wrap', iconBgClass]}>
                <Icon aria-hidden='true' class='size-5' />
              </div>

              <!-- Signal bars -->
              <div class='signal-bars' aria-hidden='true' title={`Impacto: ${m.bars}/4`}>
                {[1, 2, 3, 4].map(n => (
                  <div
                    class:list={['signal-bar', barClass, n <= m.bars ? 'signal-bar--filled' : 'signal-bar--empty']}>
                  </div>
                ))}
              </div>
            </div>

            <!-- Title -->
            <h3 class='svc-title text-white font-semibold leading-snug text-pretty pr-8'>
              {service.title}
            </h3>

            <!-- Description -->
            <p class='text-[0.875rem] leading-[1.7] text-white/75 flex-1'>
              <Fragment set:html={service.description} />
            </p>

            <!-- Stat badge (if any) -->
            {m.stat && (
              <div class='svc-stat'>
                <span
                  class='size-1.5 rounded-full shrink-0'
                  aria-hidden='true'></span>
                {m.stat}
              </div>
            )}

            <!-- Hover accent line -->
            <div
              class='svc-accent-line'
              aria-hidden='true'></div>
          </article>
        )
      })}
    </div>

    <!-- ── CTA ── -->
    {ctaText && ctaHref && (
      <div class='mt-14 text-center' data-animate>
        <a
          href={ctaHref}
          class='group inline-flex items-center gap-2 text-sm font-semibold text-sand hover:text-sand/80 transition-colors'>
          {ctaText}
          <span class='group-hover:translate-x-1 transition-transform duration-200' aria-hidden='true'>→</span>
        </a>
      </div>
    )}

  </div>
</section>
