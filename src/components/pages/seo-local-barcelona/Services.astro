---
import { SearchCheck, MapPin, Key, Globe, FileText, Link, Star } from '@lucide/astro'

type IconKey = 'searchCheck' | 'mapPin' | 'key' | 'globe' | 'fileText' | 'link' | 'star'

interface ServiceItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  services?: ServiceItem[]
  ctaText?: string
  ctaHref?: string
}

const iconByKey = {
  searchCheck: SearchCheck,
  mapPin: MapPin,
  key: Key,
  globe: Globe,
  fileText: FileText,
  link: Link,
  star: Star,
} as const

const defaultServices: ServiceItem[] = [
  {
    icon: 'searchCheck',
    title: 'Auditoría SEO local',
    description:
      'Auditas tu visibilidad actual en ficha de Google, web, citaciones NAP y Maps para <strong>identificar fugas de captación y oportunidades de facturación local</strong>.',
  },
  {
    icon: 'mapPin',
    title: 'Optimización de Google Business Profile',
    description:
      'Ejecutas optimización de categorías, descripción, fotos, horarios, atributos, publicaciones y productos. Un perfil completo puede generar <strong>hasta un 70 % más de visitas</strong> y más contactos comerciales.',
  },
  {
    icon: 'key',
    title: 'Palabras clave geolocalizadas',
    description:
      'Identificas keywords con intención local real para atraer búsquedas de alta conversión: <strong>clientes que necesitan tu servicio cerca y ahora</strong>.',
  },
  {
    icon: 'globe',
    title: 'SEO On Page con enfoque local',
    description:
      'Validas URLs geográficas, encabezados locales, schema LocalBusiness y <strong>NAP consistente</strong> para escalar relevancia local y reducir coste de adquisición.',
  },
  {
    icon: 'fileText',
    title: 'Contenido geolocalizado',
    description:
      'Ejecutas páginas de servicio por zona o barrio y contenidos locales que responden dudas reales de compra para <strong>acelerar captación de clientes en Barcelona</strong>.',
  },
  {
    icon: 'link',
    title: 'Link building local y citaciones NAP',
    description:
      'Refuerzas autoridad local con directorios de referencia, medios de zona y colaboraciones estratégicas, manteniendo <strong>consistencia NAP</strong> en todo internet.',
  },
  {
    icon: 'star',
    title: 'Gestión de reseñas y reputación online',
    description:
      'Escalas volumen y calidad de reseñas, ejecutas respuestas estratégicas y elevas tu <strong>ranking en Google Maps</strong> para convertir más visitas en clientes.',
  },
]

const stats: (string | null)[] = [
  'Punto de partida',
  'Hasta +70 % de contactos',
  null,
  null,
  null,
  'Señal de confianza clave',
  '+30 % más llamadas',
]

const {
  upheading = 'Servicios de SEO local para negocios en Barcelona',
  heading = 'Las palancas que determinan tu visibilidad en Google Maps',
  intro,
  services = defaultServices,
  ctaText,
  ctaHref,
} = Astro.props

const mainServices = services.slice(0, 6)
const featuredService = services[6]
const featuredStat = stats[6]
---

<section id='servicios-local' class='relative bg-base py-24 sm:py-32 overflow-hidden'>

  <!-- Dot grid texture -->
  <div class='pointer-events-none absolute inset-0 dot-grid-32' aria-hidden='true'></div>

  <!-- Radial glow behind grid -->
  <div class='pointer-events-none absolute inset-0 flex items-center justify-center' aria-hidden='true'>
    <div class='w-3/4 h-1/2 rounded-full bg-sage/[0.04] blur-3xl'></div>
  </div>

  <!-- Watermark -->
  <div
    class='font-heading pointer-events-none absolute -left-4 -bottom-8 select-none leading-none text-wm font-bold text-white/[0.05]'
    aria-hidden='true'>
    MAPS
  </div>

  <div class='relative container-site'>

    <!-- ── Header ── -->
    <div class='mb-16' data-animate>
      <p class='text-xs font-bold tracking-[0.18em] uppercase text-sage'>{upheading}</p>
      <h2 class='font-heading mt-4 text-h2 text-cream leading-[1.1] max-w-2xl'>{heading}</h2>
      {intro && (
        <p class='mt-5 text-base text-cream-70 max-w-xl leading-relaxed'>
          <Fragment set:html={intro} />
        </p>
      )}
    </div>

    <!-- ── Main 2×3 grid with 1px sage separators ── -->
    <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-sage/10 rounded-2xl overflow-hidden border border-sage-20'>
      {mainServices.map((service, idx) => {
        const Icon = iconByKey[service.icon as IconKey]
        const stat = stats[idx]
        const num = String(idx + 1).padStart(2, '0')
        return (
          <article
            class='group relative flex flex-col gap-4 p-7 bg-base transition-colors duration-300 hover:bg-sage-10 cursor-default overflow-hidden'
            data-animate
            data-animate-delay={idx * 60}>

            <!-- Left accent bar -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sage scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>

            <!-- Ghost ordinal -->
            <span
              class='font-heading pointer-events-none select-none absolute bottom-4 right-5 leading-none text-[5rem] text-white/[0.07] transition-opacity duration-300 group-hover:text-white/[0.13]'
              aria-hidden='true'>
              {num}
            </span>

            <!-- Icon -->
            <div class='shrink-0 size-10 flex items-center justify-center rounded-xl bg-sage-10 ring-1 ring-sage/20 transition-all duration-300 group-hover:bg-sage-15 group-hover:ring-sage/40 group-hover:shadow-[0_0_16px_rgba(105,117,101,0.28)]'>
              <Icon aria-hidden='true' class='size-[1.1rem] text-sage' />
            </div>

            <!-- Content -->
            <div class='flex flex-col gap-2 flex-1'>
              <h3 class='font-heading text-h6 text-cream leading-snug pr-10'>{service.title}</h3>
              <p class='text-sm text-cream-70 leading-relaxed text-pretty flex-1'>
                <Fragment set:html={service.description} />
              </p>
            </div>

            <!-- Stat pill -->
            {stat && (
              <div class='inline-flex items-center gap-1.5 self-start px-2.5 py-1 rounded-full bg-sage-10 border border-sage/25 text-sage text-xs font-semibold tracking-wide'>
                <span class='size-1.5 rounded-full bg-sage shrink-0' aria-hidden='true'></span>
                {stat}
              </div>
            )}

            <!-- Bottom accent bar -->
            <div
              class='absolute bottom-0 left-0 h-[1px] w-0 bg-sage/60 transition-all duration-500 group-hover:w-full'
              aria-hidden='true'>
            </div>
          </article>
        )
      })}
    </div>

    <!-- ── Featured 7th card (full width) ── -->
    {featuredService && (() => {
      const Icon = iconByKey[featuredService.icon as IconKey]
      return (
        <article
          class='group relative mt-px flex flex-col sm:flex-row gap-6 sm:gap-10 p-7 sm:p-10 bg-sage-10 rounded-2xl border border-sage-20 border-l-2 border-l-sage/50 transition-all duration-300 hover:border-sage-30 hover:bg-sage-15 cursor-default overflow-hidden'
          data-animate
          data-animate-delay={360}>

          <!-- Ghost ordinal -->
          <span
            class='font-heading pointer-events-none select-none absolute bottom-4 right-8 leading-none text-[7rem] text-white/[0.05] group-hover:text-white/[0.09] transition-opacity duration-300'
            aria-hidden='true'>
            07
          </span>

          <!-- Left: icon + label -->
          <div class='shrink-0 flex flex-row sm:flex-col gap-4 sm:gap-3 items-center sm:items-start sm:w-36'>
            <div class='size-12 flex items-center justify-center rounded-xl bg-sage-15 ring-1 ring-sage/30 transition-all duration-300 group-hover:bg-sage/25 group-hover:ring-sage/40 group-hover:shadow-[0_0_20px_rgba(105,117,101,0.32)]'>
              <Icon aria-hidden='true' class='size-5 text-sage' />
            </div>
            {featuredStat && (
              <div class='inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-sage-10 border border-sage/25 text-sage text-xs font-semibold tracking-wide'>
                <span class='size-1.5 rounded-full bg-sage shrink-0' aria-hidden='true'></span>
                {featuredStat}
              </div>
            )}
          </div>

          <!-- Right: content -->
          <div class='flex flex-col gap-3 flex-1'>
            <h3 class='font-heading text-h4 text-cream leading-snug'>{featuredService.title}</h3>
            <p class='text-base text-cream-70 leading-relaxed text-pretty max-w-2xl'>
              <Fragment set:html={featuredService.description} />
            </p>
          </div>

          <!-- Bottom accent bar -->
          <div
            class='absolute bottom-0 left-0 h-[1px] w-0 bg-sage/60 transition-all duration-500 group-hover:w-full'
            aria-hidden='true'>
          </div>
        </article>
      )
    })()}

    <!-- ── CTA ── -->
    {ctaText && ctaHref && (
      <div class='mt-12 text-center' data-animate>
        <a
          href={ctaHref}
          class='group inline-flex items-center gap-2 text-sm font-semibold text-sage hover:text-cream transition-colors duration-200'>
          {ctaText}
          <span class='group-hover:translate-x-1 transition-transform duration-200' aria-hidden='true'>→</span>
        </a>
      </div>
    )}

  </div>
</section>
