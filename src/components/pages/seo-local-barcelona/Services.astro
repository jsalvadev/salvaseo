---
import { SearchCheck, MapPin, Key, Globe, FileText, Link, Star } from '@lucide/astro'

type IconKey = 'searchCheck' | 'mapPin' | 'key' | 'globe' | 'fileText' | 'link' | 'star'

interface ServiceItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  services?: ServiceItem[]
  ctaText?: string
  ctaHref?: string
}

const iconByKey = {
  searchCheck: SearchCheck,
  mapPin: MapPin,
  key: Key,
  globe: Globe,
  fileText: FileText,
  link: Link,
  star: Star,
} as const

const defaultServices: ServiceItem[] = [
  {
    icon: 'searchCheck',
    title: 'Auditoría SEO local',
    description:
      'Auditas tu visibilidad actual en ficha de Google, web, citaciones NAP y Maps para <strong>identificar fugas de captación y oportunidades de facturación local</strong>.',
  },
  {
    icon: 'mapPin',
    title: 'Optimización de Google Business Profile',
    description:
      'Ejecutas optimización de categorías, descripción, fotos, horarios, atributos, publicaciones y productos. Un perfil completo puede generar <strong>hasta un 70 % más de visitas</strong> y más contactos comerciales.',
  },
  {
    icon: 'key',
    title: 'Palabras clave geolocalizadas',
    description:
      'Identificas keywords con intención local real para atraer búsquedas de alta conversión: <strong>clientes que necesitan tu servicio cerca y ahora</strong>.',
  },
  {
    icon: 'globe',
    title: 'SEO On Page con enfoque local',
    description:
      'Validas URLs geográficas, encabezados locales, schema LocalBusiness y <strong>NAP consistente</strong> para escalar relevancia local y reducir coste de adquisición.',
  },
  {
    icon: 'fileText',
    title: 'Contenido geolocalizado',
    description:
      'Ejecutas páginas de servicio por zona o barrio y contenidos locales que responden dudas reales de compra para <strong>acelerar captación de clientes en Barcelona</strong>.',
  },
  {
    icon: 'link',
    title: 'Link building local y citaciones NAP',
    description:
      'Refuerzas autoridad local con directorios de referencia, medios de zona y colaboraciones estratégicas, manteniendo <strong>consistencia NAP</strong> en todo internet.',
  },
  {
    icon: 'star',
    title: 'Gestión de reseñas y reputación online',
    description:
      'Escalas volumen y calidad de reseñas, ejecutas respuestas estratégicas y elevas tu <strong>ranking en Google Maps</strong> para convertir más visitas en clientes.',
  },
]

const {
  upheading = 'Servicios de SEO local para negocios en Barcelona',
  heading = 'Las palancas que determinan tu visibilidad en Google Maps',
  intro,
  services = defaultServices,
  ctaText,
  ctaHref,
} = Astro.props

const mainServices = services.slice(0, 7)
---

<section id='servicios-local' class='relative py-24 sm:py-32 overflow-hidden' style="background: linear-gradient(160deg, color-mix(in srgb, var(--color-cream) 85%, white) 0%, var(--color-cream) 50%, color-mix(in srgb, var(--color-cream) 85%, var(--color-surface)) 100%);">

  <!-- Dot grid texture -->
  <div class='pointer-events-none absolute inset-0 dot-grid-28' aria-hidden='true'></div>

  <!-- Watermark -->
  <div
    class='font-heading pointer-events-none absolute -left-4 -bottom-8 select-none leading-none text-wm font-bold text-base/[0.05]'
    aria-hidden='true'>
    MAPS
  </div>

  <div class='relative container-site'>

    <!-- ── Header ── -->
    <div class='mb-16' data-animate>
      <h2 class='text-xs font-bold tracking-[0.18em] uppercase text-sage'>{upheading}</h2>
      <p class='font-heading mt-4 text-h2 text-base leading-[1.1] max-w-2xl'>{heading}</p>
      {intro && (
        <p class='mt-5 text-base text-surface max-w-xl leading-relaxed'>
          <Fragment set:html={intro} />
        </p>
      )}
    </div>

    <!-- ── Grid ── -->
    <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6'>
      {mainServices.map((service, idx) => {
        const Icon = iconByKey[service.icon as IconKey]
        return (
          <article
            class:list={['group relative flex flex-col gap-4 p-7 bg-white/60 rounded-2xl transition-colors duration-300 hover:bg-white/90 cursor-default overflow-hidden', idx === 6 && 'sm:col-span-2 lg:col-span-3']}
            data-animate
            data-animate-delay={idx * 60}>

            <!-- Left accent bar -->
            <div
              class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sage scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100'
              aria-hidden='true'>
            </div>

            <!-- Icon -->
            <div class='shrink-0 size-7 flex items-center justify-center rounded-lg bg-sage/10 ring-1 ring-sage/20 transition-all duration-300 group-hover:bg-sage/20 group-hover:ring-sage/40'>
              <Icon aria-hidden='true' class='size-3.5 text-sage' />
            </div>

            <!-- Content -->
            <div class='flex flex-col gap-2 flex-1'>
              <h3 class='font-heading text-h6 text-base leading-snug pr-10'>{service.title}</h3>
              <p class='text-base text-surface leading-relaxed text-pretty flex-1'>
                <Fragment set:html={service.description} />
              </p>
            </div>

            <!-- Bottom accent bar -->
            <div
              class='absolute bottom-0 left-0 h-[1px] w-0 bg-sage/40 transition-all duration-500 group-hover:w-full'
              aria-hidden='true'>
            </div>
          </article>
        )
      })}
    </div>

    <!-- ── CTA ── -->
    {ctaText && ctaHref && (
      <div class='mt-12 text-center' data-animate>
        <a
          href={ctaHref}
          class='group inline-flex items-center gap-2 text-sm font-semibold text-base hover:text-sage transition-colors duration-200'>
          {ctaText}
          <span class='group-hover:translate-x-1 transition-transform duration-200' aria-hidden='true'>→</span>
        </a>
      </div>
    )}

  </div>
</section>
