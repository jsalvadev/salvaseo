---
import CalButton from '../../CalButton.astro'
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  subtitle?: string;
  sectionId?: string;
  phases: TimelinePhase[];
  ctaHeading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  upheading,
  heading,
  subtitle,
  sectionId = "proceso",
  phases,
  ctaHeading = "Tus clientes ya te buscan, descubre si te encuentran.",
  ctaText = "Recibe un diagnóstico inicial de tu ficha de Google Business y tu visibilidad local para decidir con datos el retorno potencial de tu inversión en SEO local.",
  ctaHref = "https://wa.me/34692051399?text=Hola%20Salva%2C%20he%20visto%20tu%20web.%20Tengo%20un%20negocio%20en%20Barcelona%20y%20me%20gustar%C3%ADa%20saber%20si%20el%20SEO%20puede%20ayudarme%20a%20conseguir%20m%C3%A1s%20clientes.",
  ctaLabel = "Analiza mi web",
} = Astro.props;
---

<section id={sectionId} class="relative py-24 sm:py-32 overflow-hidden" style="background: linear-gradient(160deg, var(--color-base) 0%, var(--color-surface) 50%, var(--color-base) 100%);">

  <div class="pointer-events-none absolute inset-0 dot-grid-32" aria-hidden="true"></div>

  <div class="relative container-site">

    <!-- ── Header ── -->
    <div class="max-w-2xl mb-16 lg:mb-20" data-animate>
      {upheading && (
        <h2 class="text-xs font-bold tracking-[0.18em] uppercase text-cream-70 mb-4">{upheading}</h2>
      )}
      <p class="font-heading text-h2 text-white leading-[1.1]">{heading}</p>
      {subtitle && (
        <p class="mt-5 text-base text-white-55 leading-relaxed max-w-[52ch]">{subtitle}</p>
      )}
    </div>

    <!-- ── Timeline ── -->
    <div class="relative">

      <!-- Vertical rule -->
      <div
        class="pointer-events-none absolute left-5 top-0 bottom-0 w-px bg-white/[0.08] hidden sm:block"
        aria-hidden="true">
      </div>

      <ol class="flex flex-col" role="list">
        {phases.map((phase, idx) => {
          const num = String(idx + 1).padStart(2, '0')
          const isLast = idx === phases.length - 1

          return (
            <li
              class:list={[
                'relative grid sm:grid-cols-[3.5rem_1fr] gap-6 sm:gap-12 py-10',
                !isLast && 'border-b border-white/[0.06]',
              ]}
              data-animate
              data-animate-delay={idx * 80}>

              <!-- Step number -->
              <div class="hidden sm:flex justify-center pt-1">
                <span class="font-heading text-h4 leading-none text-white/20 tabular-nums select-none">
                  {num}
                </span>
              </div>

              <!-- Content -->
              <div class="flex flex-col gap-4">

                <!-- Mobile number -->
                <span class="sm:hidden font-heading text-xs font-bold tracking-widest uppercase text-white/30">
                  {isLast ? 'Resultado' : `Fase ${idx + 1}`}
                </span>

                <div>
                  <span class="hidden sm:block text-xs font-bold tracking-widest uppercase text-white/30 mb-2">
                    {isLast ? 'Resultado' : `Fase ${idx + 1}`}
                  </span>
                  <h3 class="font-heading text-h4 text-white-85 leading-snug">{phase.title}</h3>
                </div>

                <p class="text-base text-white-55 leading-relaxed max-w-[54ch]">{phase.intro}</p>

                <ul class="flex flex-col gap-2" role="list">
                  {phase.bullets.map((bullet) => (
                    <li class="flex items-start gap-2.5">
                      <span class="mt-2 shrink-0 size-1.5 rounded-full bg-sage/60" aria-hidden="true"></span>
                      <p class="text-base text-white-55 leading-relaxed">
                        <strong class="text-white-75 font-semibold">{bullet.emphasis}</strong>
                        {' '}{bullet.text}
                      </p>
                    </li>
                  ))}
                </ul>

              </div>
            </li>
          )
        })}
      </ol>
    </div>

    <!-- ── CTA ── -->
    <div class="mt-16 pt-10 border-t border-white/[0.06]" data-animate>
      <div class="flex flex-col lg:flex-row items-start lg:items-center gap-8 lg:gap-16">
        <div class="flex-1">
          <p class="font-heading text-h5 text-white-85 leading-snug mb-3">{ctaHeading}</p>
          <p class="text-base text-white-55 leading-relaxed max-w-[50ch]">{ctaText}</p>
        </div>
        <CalButton color='cream' class='px-6 py-3 shrink-0' />
      </div>
    </div>

  </div>
</section>
