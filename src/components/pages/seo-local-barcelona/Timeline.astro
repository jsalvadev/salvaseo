---
import WhatsAppButton from '../../WhatsAppButton.astro'
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  subtitle?: string;
  sectionId?: string;
  phases?: TimelinePhase[];
  ctaHeading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const iconByKey = {
  scale: Scale,
  barChart3: BarChart3,
  badgeCheck: BadgeCheck,
  target: Target,
  trendingUp: TrendingUp,
  calendarClock: CalendarClock,
  chartNoAxesColumn: ChartNoAxesColumn,
  lineChart: LineChart,
  layers3: Layers3,
} as const;

const defaultPhases: TimelinePhase[] = [
  {
    title: "Diagnóstico técnico y análisis de mercado",
    intro:
      "Identifica los errores que frenan tu visibilidad y conoce las oportunidades de mercado que ahora pierdes. Recibes un mapa de los problemas técnicos de tu web y un estudio de las búsquedas de tus clientes.",
    bullets: [
      { icon: "scale",     emphasis: "Mide tu autoridad.",    text: "Compara tu situación real frente a tus competidores." },
      { icon: "barChart3", emphasis: "Cuantifica tu mercado.", text: "Descubre el volumen de búsqueda real en tu zona." },
      { icon: "badgeCheck",emphasis: "Decide con criterio.",  text: "Verifica la viabilidad del proyecto antes de invertir." },
    ],
    outro: "Accede a tu auditoría gratuita y prioriza tus próximas acciones.",
  },
  {
    title: "Estrategia de posicionamiento web SEO",
    intro:
      "Sustituye la incertidumbre por una hoja de ruta técnica. Con el diagnóstico en la mano, diseccionamos las acciones necesarias para captar clientes en tu zona y sector.",
    bullets: [
      { icon: "target",       emphasis: "Prioriza tus objetivos.",         text: "Identifica qué búsquedas atacar primero para acelerar el retorno." },
      { icon: "trendingUp",   emphasis: "Proyecta tu tráfico.",            text: "Obtén una estimación realista del volumen de visitas según tu mercado." },
      { icon: "calendarClock",emphasis: "Define un cronograma.",           text: "Visualiza qué cambios técnicos se aplican cada mes y el plazo estimado." },
    ],
    outro: "Valida la estrategia. Si una acción no alinea con tus objetivos, se descarta.",
  },
  {
    title: "Ejecución y resultados medibles",
    intro:
      "Mientras gestionas tu negocio, tu web escala posiciones y consolida su autoridad en Google. Obtén métricas de negocio, no solo de tráfico.",
    bullets: [
      { icon: "chartNoAxesColumn", emphasis: "Controla las conversiones.", text: "Mide cuántas visitas se transforman en llamadas reales o formularios." },
      { icon: "lineChart",         emphasis: "Sigue la evolución.",        text: "Visualiza qué términos has conquistado y cuáles son los siguientes objetivos." },
      { icon: "layers3",           emphasis: "Crecimiento acumulado.",     text: "A diferencia de la publicidad, tu posicionamiento persiste y se refuerza mes a mes." },
    ],
    outro: "Capta el volumen de búsquedas de tu sector en Barcelona y convierte usuarios en clientes.",
  },
  {
    title: "Seguimiento y escalado",
    intro:
      "Resultados medibles cada mes: llamadas, contactos y posiciones reales que confirman si la inversión avanza como debe.",
    bullets: [
      { icon: "chartNoAxesColumn", emphasis: "Métricas que importan.",    text: "Impresiones, clics, llamadas y formularios por zona, sin gráficos de vanidad." },
      { icon: "target",            emphasis: "Prioridad por retorno.",    text: "Las acciones con mayor impacto van primero, sin desviar recursos." },
      { icon: "trendingUp",        emphasis: "Crecimiento progresivo.",   text: "Lo que funciona en un servicio o zona se amplía hacia nuevas oportunidades." },
    ],
    outro: "La visibilidad local se convierte en un sistema continuo de captación, no en acciones aisladas.",
  },
];

const {
  upheading,
  heading,
  subtitle = "Cuatro fases para ejecutar, medir y escalar. Visualiza el retorno de tu inversión en Barcelona mediante informes claros y objetivos cumplidos.",
  sectionId = "proceso",
  phases = defaultPhases,
  ctaHeading = "Tus clientes ya te buscan, descubre si te encuentran.",
  ctaText = "Recibe un diagnóstico inicial de tu ficha de Google Business y tu visibilidad local para decidir con datos el retorno potencial de tu inversión en SEO local.",
  ctaHref = "https://wa.me/34692051399?text=Hola%20Salva%2C%20he%20visto%20tu%20web.%20Tengo%20un%20negocio%20en%20Barcelona%20y%20me%20gustar%C3%ADa%20saber%20si%20el%20SEO%20puede%20ayudarme%20a%20conseguir%20m%C3%A1s%20clientes.",
  ctaLabel = "Analiza mi web",
} = Astro.props;

// Heading split: "De no aparecer en el mapa" / "a recibir llamadas cada semana"
const splitIdx = heading.lastIndexOf(' a recibir ');
const headingBefore = splitIdx > -1 ? heading.slice(0, splitIdx) : heading;
const headingAfter  = splitIdx > -1 ? heading.slice(splitIdx + 1) : '';

// Accent the last two words of headingAfter in orange
const afterWords = headingAfter.split(' ');
const headingAfterMain   = afterWords.slice(0, -2).join(' ');
const headingAfterAccent = afterWords.slice(-2).join(' ');

const lastIdx = phases.length - 1;
---

<section
  id={sectionId}
  class="relative bg-teal py-24 sm:py-32 overflow-hidden"
>

  <!-- Subtle dot-grid texture -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
  ></div>

  <!-- Ambient glow — orange top-right -->
  <div
    class="pointer-events-none absolute -right-48 -top-48 w-[40rem] h-[40rem] rounded-full"
    aria-hidden="true"
  ></div>

  <!-- Ambient glow — sky bottom-left -->
  <div
    class="pointer-events-none absolute -left-48 bottom-0 w-[36rem] h-[36rem] rounded-full"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-[1280px] px-5">

    <!-- ── Section header ───────────────────────────────────────────── -->
    <div class="max-w-3xl mb-14 lg:mb-18" data-animate>

      {upheading && (
        <div class="flex items-center gap-3 mb-7">
          <span class="block h-px w-10 bg-sand" aria-hidden="true"></span>
          <h2 class="text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sand">
            {upheading}
          </h2>
        </div>
      )}

      <p class="leading-[0.95] tracking-tight text-pretty font-heading"
      >
        {headingBefore && (
          <span class="block text-[clamp(1.2rem,2.4vw,1.8rem)] text-white/45 mb-1">{headingBefore}</span>
        )}
        <span class="block font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] text-white">{headingAfterMain}</span>
        <span class="block font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05]">{headingAfterAccent}</span>
      </p>

      <div class="mt-5 flex items-center gap-2">
        <div class="h-[3px] w-14 bg-sand rounded-full"></div>
        <div class="h-px flex-1 max-w-[6rem]"></div>
      </div>

      <p
        class="mt-5 text-base lg:text-lg leading-relaxed max-w-[52ch] text-pretty"
      >
        {subtitle}
      </p>
    </div>

    <!-- ── Step indicator — hardcoded 4 steps, no dynamic classes ─── -->
    <div class="step-indicator mb-12" data-animate aria-label="Proceso en 4 pasos">
      <!-- Step 1 -->
      <div class="step-item">
        <div class="step-bubble">1</div>
        <span class="step-name">{phases[0]?.title.split(' ')[0] ?? 'Paso 1'}</span>
      </div>
      <!-- Connector -->
      <div class="step-connector" aria-hidden="true">
        <div class="step-connector-line"></div>
        <svg class="step-connector-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <!-- Step 2 -->
      <div class="step-item">
        <div class="step-bubble">2</div>
        <span class="step-name">{phases[1]?.title.split(' ')[0] ?? 'Paso 2'}</span>
      </div>
      <!-- Connector -->
      <div class="step-connector" aria-hidden="true">
        <div class="step-connector-line"></div>
        <svg class="step-connector-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <!-- Step 3 -->
      <div class="step-item">
        <div class="step-bubble">3</div>
        <span class="step-name">{phases[2]?.title.split(' ')[0] ?? 'Paso 3'}</span>
      </div>
      <!-- Connector -->
      <div class="step-connector" aria-hidden="true">
        <div class="step-connector-line"></div>
        <svg class="step-connector-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <!-- Step 4 — result state -->
      <div class="step-item step-item--arrive">
        <div class="step-bubble step-bubble--arrive">
          <!-- Phone icon -->
          <svg class="size-5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13.5 10.5l-1.5-1.5c-.4-.4-1-.4-1.4 0l-.8.8c-.2.2-.5.2-.7.1C8.4 9.4 7.5 8.5 7.1 7.9c-.1-.2-.1-.5.1-.7l.8-.8c.4-.4.4-1 0-1.4L6.5 3.5c-.4-.4-1-.4-1.4 0L4.3 4.3C3.5 5.1 3.3 6.2 3.7 7.2 4.6 9.5 7 11.4 9.5 12.3c.9.3 2 .1 2.7-.6l.7-.7c.4-.4.4-1 0-1.5z" fill="currentColor"/>
          </svg>
        </div>
        <span class="step-name step-name--arrive">Llamadas</span>
      </div>
    </div>

    <!-- ── Phase cards — 4 columns hardcoded ────────────────────────── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
      {phases.map((phase, idx) => {
        const isLast = idx === lastIdx;
        const num    = String(idx + 1).padStart(2, '0');
        const Icon0  = iconByKey[phase.bullets[0]?.icon];
        const Icon1  = iconByKey[phase.bullets[1]?.icon];
        const Icon2  = iconByKey[phase.bullets[2]?.icon];
        const icons  = [Icon0, Icon1, Icon2];

        return (
          <article
            class:list={['phase-card', isLast && 'phase-card--arrive']}
            data-animate
            data-animate-delay={idx * 90}
          >
            <!-- Card top: step label + big number -->
            <div class="card-header">
              <span class:list={['card-paso-label', isLast && 'card-paso-label--arrive']}>
                {isLast ? 'Resultado' : `Paso ${idx + 1}`}
              </span>
              <div class:list={['card-numeral', isLast && 'card-numeral--arrive']} aria-hidden="true">
                {num}
              </div>
            </div>

            <!-- Divider -->
            <div class:list={['card-divider', isLast && 'card-divider--arrive']}></div>

            <!-- Phase title -->
            <h3 class="card-title">{phase.title}</h3>

            <!-- Intro -->
            <p class="card-intro">{phase.intro}</p>

            <!-- Bullets -->
            <ul class="card-bullets" role="list">
              {phase.bullets.map((bullet, bi) => {
                const BulletIcon = icons[bi];
                return (
                  <li class="card-bullet">
                    {BulletIcon && (
                      <BulletIcon
                        aria-hidden="true"
                        class:list={['card-bullet-icon', isLast && 'card-bullet-icon--arrive']}
                      />
                    )}
                    <span>
                      <strong class="card-bullet-em">{bullet.emphasis}</strong>
                      {' '}{bullet.text}
                    </span>
                  </li>
                );
              })}
            </ul>

            <!-- Outro -->
            <p class="card-outro">{phase.outro}</p>
          </article>
        );
      })}
    </div>

    <!-- ── CTA banner ─────────────────────────────────────────────── -->
    <div class="mt-12" data-animate>
      <div class="cta-panel">

        <!-- Decorative glows -->
        <div
          class="pointer-events-none absolute -right-12 -top-12 size-52 rounded-full"
          aria-hidden="true"
        ></div>
        <div
          class="pointer-events-none absolute -left-8 -bottom-8 size-44 rounded-full"
          aria-hidden="true"
        ></div>

        <div class="relative flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
          <div class="flex-1 text-center lg:text-left">
            <p class="text-xl font-bold text-white leading-snug mb-2">{ctaHeading}</p>
            <p
              class="text-[0.9375rem] leading-relaxed max-w-[50ch]"
            >
              {ctaText}
            </p>
          </div>
          <WhatsAppButton text={ctaLabel} href={ctaHref} class='px-6 py-3 text-[0.9375rem] font-bold shrink-0' />
        </div>
      </div>
    </div>

  </div>
</section>
