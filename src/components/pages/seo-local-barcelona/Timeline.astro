---
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  subtitle?: string;
  sectionId?: string;
  phases?: TimelinePhase[];
  ctaHeading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const iconByKey = {
  scale: Scale,
  barChart3: BarChart3,
  badgeCheck: BadgeCheck,
  target: Target,
  trendingUp: TrendingUp,
  calendarClock: CalendarClock,
  chartNoAxesColumn: ChartNoAxesColumn,
  lineChart: LineChart,
  layers3: Layers3,
} as const;

const defaultPhases: TimelinePhase[] = [
  {
    title: "Diagnóstico técnico y análisis de mercado",
    intro:
      "Identifica los errores que frenan tu visibilidad y conoce las oportunidades de mercado que ahora pierdes. Recibes un mapa de los problemas técnicos de tu web y un estudio de las búsquedas de tus clientes.",
    bullets: [
      { icon: "scale",     emphasis: "Mide tu autoridad.",    text: "Compara tu situación real frente a tus competidores." },
      { icon: "barChart3", emphasis: "Cuantifica tu mercado.", text: "Descubre el volumen de búsqueda real en tu zona." },
      { icon: "badgeCheck",emphasis: "Decide con criterio.",  text: "Verifica la viabilidad del proyecto antes de invertir." },
    ],
    outro: "Accede a tu auditoría gratuita y prioriza tus próximas acciones.",
  },
  {
    title: "Estrategia de posicionamiento web SEO",
    intro:
      "Sustituye la incertidumbre por una hoja de ruta técnica. Con el diagnóstico en la mano, diseccionamos las acciones necesarias para captar clientes en tu zona y sector.",
    bullets: [
      { icon: "target",       emphasis: "Prioriza tus objetivos.",         text: "Identifica qué búsquedas atacar primero para acelerar el retorno." },
      { icon: "trendingUp",   emphasis: "Proyecta tu tráfico.",            text: "Obtén una estimación realista del volumen de visitas según tu mercado." },
      { icon: "calendarClock",emphasis: "Define un cronograma.",           text: "Visualiza qué cambios técnicos se aplican cada mes y el plazo estimado." },
    ],
    outro: "Valida la estrategia. Si una acción no alinea con tus objetivos, se descarta.",
  },
  {
    title: "Ejecución y resultados medibles",
    intro:
      "Mientras gestionas tu negocio, tu web escala posiciones y consolida su autoridad en Google. Obtén métricas de negocio, no solo de tráfico.",
    bullets: [
      { icon: "chartNoAxesColumn", emphasis: "Controla las conversiones.", text: "Mide cuántas visitas se transforman en llamadas reales o formularios." },
      { icon: "lineChart",         emphasis: "Sigue la evolución.",        text: "Visualiza qué términos has conquistado y cuáles son los siguientes objetivos." },
      { icon: "layers3",           emphasis: "Crecimiento acumulado.",     text: "A diferencia de la publicidad, tu posicionamiento persiste y se refuerza mes a mes." },
    ],
    outro: "Capta el volumen de búsquedas de tu sector en Barcelona y convierte usuarios en clientes.",
  },
  {
    title: "Seguimiento y escalado",
    intro:
      "Resultados medibles cada mes: llamadas, contactos y posiciones reales que confirman si la inversión avanza como debe.",
    bullets: [
      { icon: "chartNoAxesColumn", emphasis: "Métricas que importan.",    text: "Impresiones, clics, llamadas y formularios por zona, sin gráficos de vanidad." },
      { icon: "target",            emphasis: "Prioridad por retorno.",    text: "Las acciones con mayor impacto van primero, sin desviar recursos." },
      { icon: "trendingUp",        emphasis: "Crecimiento progresivo.",   text: "Lo que funciona en un servicio o zona se amplía hacia nuevas oportunidades." },
    ],
    outro: "La visibilidad local se convierte en un sistema continuo de captación, no en acciones aisladas.",
  },
];

const {
  upheading,
  heading,
  subtitle = "Cuatro fases para ejecutar, medir y escalar. Visualiza el retorno de tu inversión en Barcelona mediante informes claros y objetivos cumplidos.",
  sectionId = "proceso",
  phases = defaultPhases,
  ctaHeading = "Tus clientes ya te buscan: descubre si te encuentran.",
  ctaText = "Recibe un diagnóstico inicial de tu ficha de Google Business y tu visibilidad local para decidir con datos el retorno potencial de tu inversión en SEO local.",
  ctaHref = "https://wa.me/34692051399?text=Hola%20Salva%2C%20he%20visto%20tu%20web.%20Tengo%20un%20negocio%20en%20Barcelona%20y%20me%20gustar%C3%ADa%20saber%20si%20el%20SEO%20puede%20ayudarme%20a%20conseguir%20m%C3%A1s%20clientes.",
  ctaLabel = "Solicita tu análisis local por WhatsApp",
} = Astro.props;

// Heading split: "De no aparecer en el mapa" / "a recibir llamadas cada semana"
const splitIdx = heading.lastIndexOf(' a recibir ');
const headingBefore = splitIdx > -1 ? heading.slice(0, splitIdx) : heading;
const headingAfter  = splitIdx > -1 ? heading.slice(splitIdx + 1) : '';

// Accent the last two words of headingAfter in orange
const afterWords = headingAfter.split(' ');
const headingAfterMain   = afterWords.slice(0, -2).join(' ');
const headingAfterAccent = afterWords.slice(-2).join(' ');

const lastIdx = phases.length - 1;
---

<section
  id={sectionId}
  class="relative bg-petrol-900 py-24 sm:py-32 overflow-hidden"
>

  <!-- Subtle dot-grid texture -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <!-- Ambient glow — orange top-right -->
  <div
    class="pointer-events-none absolute -right-48 -top-48 w-[40rem] h-[40rem] rounded-full"
    style="background: radial-gradient(circle, rgba(249,115,22,0.11) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <!-- Ambient glow — sky bottom-left -->
  <div
    class="pointer-events-none absolute -left-48 bottom-0 w-[36rem] h-[36rem] rounded-full"
    style="background: radial-gradient(circle, rgba(14,165,233,0.09) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">

    <!-- ── Section header ───────────────────────────────────────────── -->
    <div class="max-w-3xl mb-14 lg:mb-18" data-animate>

      {upheading && (
        <div class="flex items-center gap-3 mb-7">
          <span class="block h-px w-10 bg-orange-500" aria-hidden="true"></span>
          <p class="text-[0.68rem] font-bold uppercase tracking-[0.22em] text-orange-400">
            {upheading}
          </p>
        </div>
      )}

      <h2
        class="leading-[0.92] tracking-tight"
        style="font-family: 'Titan One', cursive;"
      >
        {headingBefore && (
          <span
            class="block mb-2 leading-snug"
            style="font-size: clamp(1.35rem, 2.8vw, 2rem); color: rgba(255,255,255,0.3);"
          >
            {headingBefore}
          </span>
        )}
        <span
          class="block text-white"
          style="font-size: clamp(2.4rem, 5.2vw, 4rem); line-height: 0.92;"
        >
          {headingAfterMain && <>{headingAfterMain} </>}
          <span style="color: var(--color-orange-400);">{headingAfterAccent}</span>
        </span>
      </h2>

      <div class="mt-5 flex items-center gap-2">
        <div class="h-[3px] w-14 bg-orange-500 rounded-full"></div>
        <div class="h-px flex-1 max-w-[6rem]" style="background: linear-gradient(90deg, rgba(249,115,22,0.5), transparent);"></div>
      </div>

      <p
        class="mt-5 text-base lg:text-lg leading-relaxed max-w-[52ch] text-pretty"
        style="color: rgba(255,255,255,0.55);"
      >
        {subtitle}
      </p>
    </div>

    <!-- ── Step indicator — hardcoded 4 steps, no dynamic classes ─── -->
    <div class="step-indicator mb-12" data-animate aria-label="Proceso en 4 pasos">
      <!-- Step 1 -->
      <div class="step-item">
        <div class="step-bubble">1</div>
        <span class="step-name">{phases[0]?.title.split(' ')[0] ?? 'Paso 1'}</span>
      </div>
      <!-- Connector -->
      <div class="step-connector" aria-hidden="true">
        <div class="step-connector-line"></div>
        <svg class="step-connector-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <!-- Step 2 -->
      <div class="step-item">
        <div class="step-bubble">2</div>
        <span class="step-name">{phases[1]?.title.split(' ')[0] ?? 'Paso 2'}</span>
      </div>
      <!-- Connector -->
      <div class="step-connector" aria-hidden="true">
        <div class="step-connector-line"></div>
        <svg class="step-connector-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <!-- Step 3 -->
      <div class="step-item">
        <div class="step-bubble">3</div>
        <span class="step-name">{phases[2]?.title.split(' ')[0] ?? 'Paso 3'}</span>
      </div>
      <!-- Connector -->
      <div class="step-connector" aria-hidden="true">
        <div class="step-connector-line"></div>
        <svg class="step-connector-arrow" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <!-- Step 4 — result state -->
      <div class="step-item step-item--arrive">
        <div class="step-bubble step-bubble--arrive">
          <!-- Phone icon -->
          <svg class="size-5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13.5 10.5l-1.5-1.5c-.4-.4-1-.4-1.4 0l-.8.8c-.2.2-.5.2-.7.1C8.4 9.4 7.5 8.5 7.1 7.9c-.1-.2-.1-.5.1-.7l.8-.8c.4-.4.4-1 0-1.4L6.5 3.5c-.4-.4-1-.4-1.4 0L4.3 4.3C3.5 5.1 3.3 6.2 3.7 7.2 4.6 9.5 7 11.4 9.5 12.3c.9.3 2 .1 2.7-.6l.7-.7c.4-.4.4-1 0-1.5z" fill="currentColor"/>
          </svg>
        </div>
        <span class="step-name step-name--arrive">Llamadas</span>
      </div>
    </div>

    <!-- ── Phase cards — 4 columns hardcoded ────────────────────────── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
      {phases.map((phase, idx) => {
        const isLast = idx === lastIdx;
        const num    = String(idx + 1).padStart(2, '0');
        const Icon0  = iconByKey[phase.bullets[0]?.icon];
        const Icon1  = iconByKey[phase.bullets[1]?.icon];
        const Icon2  = iconByKey[phase.bullets[2]?.icon];
        const icons  = [Icon0, Icon1, Icon2];

        return (
          <article
            class:list={['phase-card', isLast && 'phase-card--arrive']}
            data-animate
            data-animate-delay={idx * 90}
          >
            <!-- Card top: step label + big number -->
            <div class="card-header">
              <span class:list={['card-paso-label', isLast && 'card-paso-label--arrive']}>
                {isLast ? 'Resultado' : `Paso ${idx + 1}`}
              </span>
              <div class:list={['card-numeral', isLast && 'card-numeral--arrive']} aria-hidden="true">
                {num}
              </div>
            </div>

            <!-- Divider -->
            <div class:list={['card-divider', isLast && 'card-divider--arrive']}></div>

            <!-- Phase title -->
            <h3 class="card-title">{phase.title}</h3>

            <!-- Intro -->
            <p class="card-intro">{phase.intro}</p>

            <!-- Bullets -->
            <ul class="card-bullets" role="list">
              {phase.bullets.map((bullet, bi) => {
                const BulletIcon = icons[bi];
                return (
                  <li class="card-bullet">
                    {BulletIcon && (
                      <BulletIcon
                        aria-hidden="true"
                        class:list={['card-bullet-icon', isLast && 'card-bullet-icon--arrive']}
                      />
                    )}
                    <span>
                      <strong class="card-bullet-em">{bullet.emphasis}</strong>
                      {' '}{bullet.text}
                    </span>
                  </li>
                );
              })}
            </ul>

            <!-- Outro -->
            <p class="card-outro">{phase.outro}</p>
          </article>
        );
      })}
    </div>

    <!-- ── CTA banner ─────────────────────────────────────────────── -->
    <div class="mt-12" data-animate>
      <div class="cta-panel">

        <!-- Decorative glows -->
        <div
          class="pointer-events-none absolute -right-12 -top-12 size-52 rounded-full"
          style="background: radial-gradient(circle, rgba(249,115,22,0.18) 0%, transparent 65%);"
          aria-hidden="true"
        ></div>
        <div
          class="pointer-events-none absolute -left-8 -bottom-8 size-44 rounded-full"
          style="background: radial-gradient(circle, rgba(14,165,233,0.15) 0%, transparent 65%);"
          aria-hidden="true"
        ></div>

        <div class="relative flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
          <div class="flex-1 text-center lg:text-left">
            <p class="text-xl font-bold text-white leading-snug mb-2">{ctaHeading}</p>
            <p
              class="text-[0.9375rem] leading-relaxed max-w-[50ch]"
              style="color: rgba(255,255,255,0.6);"
            >
              {ctaText}
            </p>
          </div>
          <a
            href={ctaHref}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="cta-btn shrink-0"
          >
            <!-- WhatsApp icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
              aria-hidden="true" class="size-5 shrink-0">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            {ctaLabel}
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════
     STEP INDICATOR
     Hardcoded 4 steps — no dynamic Tailwind
  ═══════════════════════════════════════ */
  .step-indicator {
    display: flex;
    align-items: center;
    gap: 0;
    max-width: 640px;
  }

  .step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .step-bubble {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(14, 165, 233, 0.18);
    border: 2px solid rgba(14, 165, 233, 0.5);
    color: #38bdf8;
    font-family: 'Titan One', cursive;
    font-size: 1.125rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-bubble--arrive {
    background: rgba(52, 168, 83, 0.18);
    border-color: rgba(52, 168, 83, 0.6);
    color: #34a853;
    animation: bubble-arrive-pulse 2.4s ease-in-out infinite;
  }

  @keyframes bubble-arrive-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(52, 168, 83, 0.3); }
    50%       { box-shadow: 0 0 0 7px rgba(52, 168, 83, 0); }
  }

  .step-name {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.38);
    white-space: nowrap;
  }

  .step-name--arrive {
    color: #34a853;
  }

  .step-connector {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 6px;
    margin-bottom: 22px; /* offset for the label below bubbles */
  }

  .step-connector-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    background-image: repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.18) 0,
      rgba(255,255,255,0.18) 5px,
      transparent 5px,
      transparent 10px
    );
  }

  .step-connector-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 639px) {
    .step-indicator {
      display: none; /* Cards speak for themselves on mobile */
    }
  }

  /* ═══════════════════════════════════════
     PHASE CARDS
  ═══════════════════════════════════════ */
  .phase-card {
    position: relative;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .phase-card:hover {
    transform: translateY(-4px);
    border-color: rgba(14, 165, 233, 0.3);
    box-shadow: 0 20px 48px -12px rgba(0, 0, 0, 0.45);
  }

  .phase-card--arrive {
    border-color: rgba(52, 168, 83, 0.2);
    background: rgba(52, 168, 83, 0.05);
  }

  .phase-card--arrive:hover {
    border-color: rgba(52, 168, 83, 0.4);
  }

  /* ── Card header ── */
  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .card-paso-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(14, 165, 233, 0.9);
    margin-top: 0.2rem;
  }

  .card-paso-label--arrive {
    color: #34a853;
  }

  .card-numeral {
    font-family: 'Titan One', cursive;
    font-size: 3.5rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.12);
    letter-spacing: -0.02em;
    margin-right: -0.25rem;
    transition: color 0.3s ease;
  }

  .phase-card:hover .card-numeral {
    color: rgba(255, 255, 255, 0.2);
  }

  .card-numeral--arrive {
    color: rgba(52, 168, 83, 0.2);
  }

  .phase-card--arrive:hover .card-numeral--arrive {
    color: rgba(52, 168, 83, 0.35);
  }

  /* ── Divider ── */
  .card-divider {
    height: 2px;
    border-radius: 100px;
    background: linear-gradient(90deg, rgba(14,165,233,0.6), rgba(14,165,233,0.1));
    margin-bottom: 1rem;
  }

  .card-divider--arrive {
    background: linear-gradient(90deg, rgba(52,168,83,0.7), rgba(52,168,83,0.1));
  }

  /* ── Title ── */
  .card-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.4;
    margin-bottom: 0.625rem;
  }

  /* ── Intro ── */
  .card-intro {
    font-size: 0.8125rem;
    line-height: 1.72;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 0.875rem;
  }

  /* ── Bullets ── */
  .card-bullets {
    list-style: none;
    margin: 0 0 0.875rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.58);
    padding-left: 0.375rem;
    border-left: 1.5px solid rgba(14, 165, 233, 0.3);
  }

  .phase-card--arrive .card-bullet {
    border-left-color: rgba(52, 168, 83, 0.35);
  }

  .card-bullet-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: rgba(56, 189, 248, 0.85);
  }

  .card-bullet-icon--arrive {
    color: rgba(52, 168, 83, 0.9);
  }

  .card-bullet-em {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ── Outro ── */
  .card-outro {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    font-size: 0.78rem;
    line-height: 1.6;
