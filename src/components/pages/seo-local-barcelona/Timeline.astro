---
import WhatsAppButton from '../../WhatsAppButton.astro'
import {
  BadgeCheck,
  BarChart3,
  CalendarClock,
  ChartNoAxesColumn,
  Layers3,
  LineChart,
  Scale,
  Target,
  TrendingUp,
} from "@lucide/astro";

type IconKey =
  | "scale"
  | "barChart3"
  | "badgeCheck"
  | "target"
  | "trendingUp"
  | "calendarClock"
  | "chartNoAxesColumn"
  | "lineChart"
  | "layers3";

interface TimelineBullet {
  icon: IconKey;
  emphasis: string;
  text: string;
}

interface TimelinePhase {
  title: string;
  intro: string;
  bullets: TimelineBullet[];
  outro: string;
}

interface Props {
  upheading?: string;
  heading: string;
  subtitle?: string;
  sectionId?: string;
  phases?: TimelinePhase[];
  ctaHeading?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const iconByKey = {
  scale: Scale,
  barChart3: BarChart3,
  badgeCheck: BadgeCheck,
  target: Target,
  trendingUp: TrendingUp,
  calendarClock: CalendarClock,
  chartNoAxesColumn: ChartNoAxesColumn,
  lineChart: LineChart,
  layers3: Layers3,
} as const;

const defaultPhases: TimelinePhase[] = [
  {
    title: "Diagnóstico técnico y análisis de mercado",
    intro:
      "Identifica los errores que frenan tu visibilidad y conoce las oportunidades de mercado que ahora pierdes.",
    bullets: [
      { icon: "scale",     emphasis: "Mide tu autoridad.",    text: "Compara tu situación real frente a tus competidores." },
      { icon: "barChart3", emphasis: "Cuantifica tu mercado.", text: "Descubre el volumen de búsqueda real en tu zona." },
      { icon: "badgeCheck",emphasis: "Decide con criterio.",  text: "Verifica la viabilidad del proyecto antes de invertir." },
    ],
    outro: "Accede a tu auditoría gratuita y prioriza tus próximas acciones.",
  },
  {
    title: "Estrategia de posicionamiento web SEO",
    intro:
      "Sustituye la incertidumbre por una hoja de ruta técnica. Diseccionamos las acciones necesarias para captar clientes en tu zona.",
    bullets: [
      { icon: "target",       emphasis: "Prioriza tus objetivos.",  text: "Identifica qué búsquedas atacar primero para acelerar el retorno." },
      { icon: "trendingUp",   emphasis: "Proyecta tu tráfico.",     text: "Estimación realista del volumen de visitas según tu mercado." },
      { icon: "calendarClock",emphasis: "Define un cronograma.",    text: "Visualiza qué cambios técnicos se aplican cada mes y el plazo estimado." },
    ],
    outro: "Valida la estrategia. Si una acción no alinea con tus objetivos, se descarta.",
  },
  {
    title: "Ejecución y resultados medibles",
    intro:
      "Mientras gestionas tu negocio, tu web escala posiciones y consolida su autoridad en Google.",
    bullets: [
      { icon: "chartNoAxesColumn", emphasis: "Controla las conversiones.", text: "Mide cuántas visitas se transforman en llamadas reales o formularios." },
      { icon: "lineChart",         emphasis: "Sigue la evolución.",        text: "Visualiza qué términos has conquistado y cuáles son los siguientes objetivos." },
      { icon: "layers3",           emphasis: "Crecimiento acumulado.",     text: "A diferencia de la publicidad, tu posicionamiento persiste y se refuerza mes a mes." },
    ],
    outro: "Capta el volumen de búsquedas de tu sector en Barcelona y convierte usuarios en clientes.",
  },
  {
    title: "Seguimiento y escalado",
    intro:
      "Resultados medibles cada mes: llamadas, contactos y posiciones reales que confirman si la inversión avanza como debe.",
    bullets: [
      { icon: "chartNoAxesColumn", emphasis: "Métricas que importan.",   text: "Impresiones, clics, llamadas y formularios por zona, sin gráficos de vanidad." },
      { icon: "target",            emphasis: "Prioridad por retorno.",   text: "Las acciones con mayor impacto van primero, sin desviar recursos." },
      { icon: "trendingUp",        emphasis: "Crecimiento progresivo.",  text: "Lo que funciona en un servicio o zona se amplía hacia nuevas oportunidades." },
    ],
    outro: "La visibilidad local se convierte en un sistema continuo de captación, no en acciones aisladas.",
  },
];

const {
  upheading,
  heading,
  subtitle,
  sectionId = "proceso",
  phases = defaultPhases,
  ctaHeading = "Tus clientes ya te buscan, descubre si te encuentran.",
  ctaText = "Recibe un diagnóstico inicial de tu ficha de Google Business y tu visibilidad local para decidir con datos el retorno potencial de tu inversión en SEO local.",
  ctaHref = "https://wa.me/34692051399?text=Hola%20Salva%2C%20he%20visto%20tu%20web.%20Tengo%20un%20negocio%20en%20Barcelona%20y%20me%20gustar%C3%ADa%20saber%20si%20el%20SEO%20puede%20ayudarme%20a%20conseguir%20m%C3%A1s%20clientes.",
  ctaLabel = "Analiza mi web",
} = Astro.props;
---

<section
  id={sectionId}
  class="relative bg-surface py-24 sm:py-32 overflow-hidden"
>

  <!-- Dot texture -->
  <div class="pointer-events-none absolute inset-0 dot-grid-32" aria-hidden="true"></div>

  <!-- Watermark -->
  <div
    class="font-heading pointer-events-none absolute -right-4 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-white/[0.03]"
    aria-hidden="true">
    FASES
  </div>

  <div class="relative container-site">

    <!-- ── Header ── -->
    <div class="max-w-3xl mb-16 lg:mb-20" data-animate>
      {upheading && (
        <p class="text-xs font-bold tracking-[0.18em] uppercase text-sage mb-4">{upheading}</p>
      )}
      <h2 class="font-heading text-h2 text-cream leading-[1.1]">{heading}</h2>
      {subtitle && (
        <p class="mt-5 text-base text-cream-70 leading-relaxed max-w-[52ch]">{subtitle}</p>
      )}
    </div>

    <!-- ── Vertical timeline ── -->
    <div class="relative">

      <!-- Continuous vertical line -->
      <div
        class="pointer-events-none absolute left-[2.75rem] top-0 bottom-0 w-px bg-sage/20 hidden sm:block"
        aria-hidden="true">
      </div>

      <ol class="flex flex-col gap-0" role="list">
        {phases.map((phase, idx) => {
          const isLast = idx === phases.length - 1
          const num = String(idx + 1).padStart(2, '0')
          const Icon0 = iconByKey[phase.bullets[0]?.icon]
          const Icon1 = iconByKey[phase.bullets[1]?.icon]
          const Icon2 = iconByKey[phase.bullets[2]?.icon]
          const icons = [Icon0, Icon1, Icon2]

          return (
            <li
              class:list={[
                'group relative grid sm:grid-cols-[5.5rem_1fr] gap-6 sm:gap-10 py-10 sm:py-12',
                idx < phases.length - 1 && 'border-b border-sage/10',
              ]}
              data-animate
              data-animate-delay={idx * 100}>

              <!-- Left: step node + number -->
              <div class="hidden sm:flex flex-col items-center gap-3 pt-1">
                <!-- Dot node on the line -->
                <div class:list={[
                  'relative z-10 size-5 rounded-full ring-4 ring-surface flex items-center justify-center shrink-0 transition-all duration-300',
                  isLast
                    ? 'bg-sage ring-sage/30'
                    : 'bg-surface border-2 border-sage/50 group-hover:border-sage group-hover:bg-sage/20',
                ]} aria-hidden="true">
                  {isLast && (
                    <span class="size-2 rounded-full bg-cream" aria-hidden="true"></span>
                  )}
                </div>

                <!-- Big ghost ordinal -->
                <span
                  class="font-heading text-[2.5rem] leading-none text-cream-30 select-none tabular-nums transition-colors duration-300 group-hover:text-cream-50"
                  aria-label={`Fase ${idx + 1}`}>
                  {num}
                </span>
              </div>

              <!-- Right: content -->
              <div class="flex flex-col gap-5">

                <!-- Mobile step badge -->
                <div class="flex items-center gap-3 sm:hidden">
                  <span class="inline-flex items-center justify-center size-7 rounded-full bg-sage/20 text-sage text-xs font-bold tabular-nums">
                    {idx + 1}
                  </span>
                  <span class="text-xs font-bold tracking-widest uppercase text-sage">
                    {isLast ? 'Resultado' : `Fase ${idx + 1}`}
                  </span>
                </div>

                <!-- Title -->
                <div class="flex flex-col gap-1">
                  <span class="hidden sm:block text-xs font-bold tracking-widest uppercase text-sage">
                    {isLast ? 'Resultado' : `Fase ${idx + 1}`}
                  </span>
                  <h3 class:list={[
                    'font-heading leading-snug',
                    isLast ? 'text-h3 text-cream' : 'text-h4 text-cream',
                  ]}>
                    {phase.title}
                  </h3>
                </div>

                <!-- Intro -->
                <p class="text-base text-cream-70 leading-relaxed max-w-[56ch]">{phase.intro}</p>

                <!-- Bullets -->
                <ul class="flex flex-col gap-3" role="list">
                  {phase.bullets.map((bullet, bi) => {
                    const BulletIcon = icons[bi]
                    return (
                      <li class="flex items-start gap-3">
                        <div class:list={[
                          'shrink-0 mt-0.5 size-6 flex items-center justify-center rounded-lg transition-colors duration-300',
                          isLast ? 'bg-sage/20 text-sage' : 'bg-white-06 text-sage group-hover:bg-sage/15',
                        ]}>
                          {BulletIcon && <BulletIcon aria-hidden="true" class="size-3.5" />}
                        </div>
                        <p class="text-sm text-cream-70 leading-relaxed">
                          <strong class="text-cream font-semibold">{bullet.emphasis}</strong>
                          {' '}{bullet.text}
                        </p>
                      </li>
                    )
                  })}
                </ul>

                <!-- Outro -->
                <p class:list={[
                  'text-sm leading-relaxed italic border-l-2 pl-4 py-1',
                  isLast
                    ? 'border-sage text-cream-70'
                    : 'border-sage/30 text-cream-50 group-hover:border-sage/60 group-hover:text-cream-70 transition-colors duration-300',
                ]}>
                  {phase.outro}
                </p>

              </div>
            </li>
          )
        })}
      </ol>
    </div>

    <!-- ── CTA banner ── -->
    <div class="mt-16" data-animate>
      <div class="relative rounded-2xl border border-sage-20 bg-white-06 p-8 sm:p-10 overflow-hidden">

        <!-- Subtle sage glow -->
        <div
          class="pointer-events-none absolute -right-16 -top-16 size-64 rounded-full bg-sage/5 blur-3xl"
          aria-hidden="true">
        </div>

        <div class="relative flex flex-col lg:flex-row items-start lg:items-center gap-8 lg:gap-12">
          <div class="flex-1">
            <p class="font-heading text-h5 text-cream leading-snug mb-3">{ctaHeading}</p>
            <p class="text-base text-cream-70 leading-relaxed max-w-[50ch]">{ctaText}</p>
          </div>
          <WhatsAppButton
            text={ctaLabel}
            href={ctaHref}
            class='px-6 py-3 text-sm font-bold shrink-0'
          />
        </div>
      </div>
    </div>

  </div>
</section>
