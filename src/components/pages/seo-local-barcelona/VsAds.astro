---
import { TrendingUp, Zap, Clock, Repeat, PiggyBank, ShieldCheck } from '@lucide/astro'
import WhatsAppButton from '../../WhatsAppButton.astro'
import { buildWhatsAppHref } from '../../../data/site'

const waHref = buildWhatsAppHref()

type IconKey = 'trendingUp' | 'zap' | 'clock' | 'repeat' | 'piggyBank' | 'shieldCheck'

interface ComparisonBullet {
  icon: IconKey
  emphasis: string
  text: string
}

interface ComparisonColumn {
  title: string
  icon: IconKey
  accentClass: string
  ringClass?: string
  noteClass?: string
  note: string
  bullets: ComparisonBullet[]
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  leftColumn?: ComparisonColumn
  rightColumn?: ComparisonColumn
  conclusion?: string
}

const iconByKey = {
  trendingUp: TrendingUp,
  zap: Zap,
  clock: Clock,
  repeat: Repeat,
  piggyBank: PiggyBank,
  shieldCheck: ShieldCheck,
} as const

const defaultLeftColumn: ComparisonColumn = {
  title: 'SEO local',
  icon: 'trendingUp',
  accentClass: 'bg-sky-600',
  note: '<strong>Ideal para:</strong> negocios que buscan estabilidad, rentabilidad a medio plazo y reducir la dependencia de la publicidad de pago.',
  bullets: [
    {
      icon: 'repeat',
      emphasis: 'Activo acumulativo.',
      text: 'Cada mes que trabajas, tu posición se refuerza. El tráfico llega sin pagar por cada clic.',
    },
    {
      icon: 'piggyBank',
      emphasis: 'Coste decreciente por lead.',
      text: 'A medida que subes posiciones, el coste de adquisición baja. La inversión de hoy genera clientes durante meses.',
    },
    {
      icon: 'shieldCheck',
      emphasis: 'Confianza del usuario.',
      text: 'El 70-80 % de los usuarios ignoran los anuncios y hacen clic en resultados orgánicos. Estar en el mapa genera más credibilidad.',
    },
  ],
}

const defaultRightColumn: ComparisonColumn = {
  title: 'Google Ads',
  icon: 'zap',
  accentClass: 'bg-gray-500',
  note: '<strong>Ideal para:</strong> emergencias de visibilidad, promociones temporales o sectores donde necesitas resultados mientras el SEO local consolida posiciones.',
  bullets: [
    {
      icon: 'clock',
      emphasis: 'Resultados inmediatos.',
      text: 'Apareces en la primera posición desde el día uno. Útil para campañas puntuales o lanzamientos.',
    },
    {
      icon: 'piggyBank',
      emphasis: 'Coste constante por clic.',
      text: 'Cada visita tiene un precio fijo. Cuando cortas el presupuesto, desapareces al instante de los resultados.',
    },
    {
      icon: 'shieldCheck',
      emphasis: 'Percepción de anuncio.',
      text: 'Los usuarios saben que es publicidad. La tasa de clic en anuncios es significativamente menor que en resultados orgánicos y Maps.',
    },
  ],
}

const {
  upheading = 'Comparativa SEO local y publicidad en Google',
  heading = 'SEO local vs Google Ads: qué le conviene más a tu negocio',
  intro = 'Ambas estrategias captan clientes, pero <strong>funcionan de forma muy distinta</strong>. Entiende qué te aporta cada una antes de decidir dónde poner tu dinero.',
  leftColumn = defaultLeftColumn,
  rightColumn = defaultRightColumn,
  conclusion = '<strong>La combinación más rentable</strong> para negocios locales en Barcelona: construir SEO local como base y complementar con Ads solo cuando el sector o la urgencia lo requieran. Cada euro invertido en posicionamiento orgánico <strong>sigue generando clientes meses después</strong>.',
} = Astro.props

const headingParts = heading.split(' o ')
const headingFirst = headingParts[0] ?? heading
const headingSecond = headingParts[1] ?? ''
---

<section class='relative overflow-hidden bg-teal py-24 md:py-32'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 30px 30px;'>
  </div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line x1='42%' y1='0%' x2='58%' y2='100%' stroke='rgba(250,234,177,0.05)' stroke-width='1'></line>
    <line x1='48%' y1='0%' x2='66%' y2='100%' stroke='rgba(250,234,177,0.04)' stroke-width='1'></line>
  </svg>

  <!-- Large ghosted watermark -->
  <div
    class='pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none leading-none'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(12rem, 25vw, 20rem); color: rgba(250,234,177,0.04); line-height: 1; white-space: nowrap;'>
    CANAL
  </div>

  <!-- Radial ambient top-left -->
  <div
    class='pointer-events-none absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.05) 0%, transparent 65%);'>
  </div>

  <!-- Top / bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/30 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>

    <!-- ── Section header ──────────────────────────────────────────────── -->
    <div class='mb-14 md:mb-18 max-w-3xl'>
      <div data-animate class='flex items-center gap-3 mb-8'>
        <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
        <h2 class='label-section text-sand'>
          {upheading}
        </h2>
      </div>

      <p
        data-animate
        style='font-family: "Titan One", cursive;'
        class='text-[clamp(1.35rem,3.1vw,2.49rem)] leading-[1.05] tracking-tight text-white text-pretty'>
        {headingSecond ? (
          <>{headingFirst} o <span class='text-sand'>{headingSecond}</span></>
        ) : (
          <>{heading}</>
        )}
      </p>

      <div data-animate class='mt-6 flex items-center'>
        <div class='h-[3px] w-16 bg-sand rounded-full'></div>
        <div class='h-px w-24 bg-gradient-to-r from-sand/40 to-transparent'></div>
      </div>

      <p data-animate class='mt-6 max-w-[52ch] text-base md:text-lg text-white/75 leading-relaxed text-pretty'>
        <Fragment set:html={intro} />
      </p>
    </div>

    <!-- ── Comparison cards ─────────────────────────────────────────── -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-5 mb-14'>

      <!-- LEFT: SEO local — recommended -->
      <div
        data-animate
        class='relative rounded-2xl border overflow-hidden'
        style='background: rgba(250,234,177,0.04); border-color: rgba(250,234,177,0.20);'>

        <!-- Recommended badge -->
        <div class='absolute top-5 right-5 flex items-center gap-1.5 rounded-full px-2.5 py-1' style='background: rgba(250,234,177,0.12); border: 1px solid rgba(250,234,177,0.25);'>
          <span class='block w-1.5 h-1.5 rounded-full bg-sand' style='animation: pulse-glow 1.8s ease-in-out infinite;'></span>
          <span class='text-[0.58rem] font-bold uppercase tracking-wider text-sand/80'>Recomendado</span>
        </div>

        <!-- Top accent bar -->
        <div class='absolute top-0 inset-x-0 h-[3px] bg-gradient-to-r from-sand/60 via-sand/40 to-transparent rounded-t-2xl'></div>

        <!-- Ghost watermark -->
        <div
          class='pointer-events-none absolute -bottom-3 -right-3 select-none leading-none'
          aria-hidden='true'
          style='font-family: "Titan One", cursive; font-size: 7rem; color: rgba(250,234,177,0.06); line-height: 1;'>
          ↗
        </div>

        <div class='p-7 sm:p-8'>
          <!-- Card header -->
          <div class='flex items-center gap-3 mb-7 pr-24'>
            <div class='flex h-9 w-9 items-center justify-center rounded-xl shrink-0' style='background: rgba(250,234,177,0.10); border: 1px solid rgba(250,234,177,0.22);'>
              {(() => { const Icon = iconByKey[leftColumn.icon]; return <Icon class='size-4.5 text-sand' aria-hidden='true' /> })()}
            </div>
            <div>
              <p class='label-ui text-sand/60 leading-none mb-0.5'>Canal propio</p>
              <p class='text-[1.05rem] font-bold text-white leading-tight' style='font-family: "Titan One", cursive;'>{leftColumn.title}</p>
            </div>
          </div>

          <ul class='space-y-4 mb-7'>
            {leftColumn.bullets.map((bullet) => {
              const BulletIcon = iconByKey[bullet.icon]
              return (
                <li class='flex items-start gap-3.5'>
                  <span class='shrink-0 mt-0.5 flex h-6 w-6 items-center justify-center rounded-full' style='background: rgba(250,234,177,0.08); border: 1px solid rgba(250,234,177,0.20);'>
                    <BulletIcon class='size-3 text-sand' aria-hidden='true' />
                  </span>
                  <p class='text-base text-white/75 leading-relaxed pt-0.5'>
                    <strong class='text-white/90 font-semibold'>{bullet.emphasis}</strong>{' '}{bullet.text}
                  </p>
                </li>
              )
            })}
          </ul>

          <!-- Note -->
          <div class='rounded-xl px-4 py-3.5' style='background: rgba(250,234,177,0.05); border: 1px solid rgba(250,234,177,0.12);'>
            <p class='text-base text-white/75 leading-relaxed'>
              <Fragment set:html={leftColumn.note} />
            </p>
          </div>

          <!-- Growth bars -->
          <div class='mt-5 rounded-xl px-4 pt-3.5 pb-4' style='background: rgba(250,234,177,0.04); border: 1px solid rgba(250,234,177,0.10);'>
            <p class='label-ui text-sand/50 mb-2.5'>Efecto acumulativo · 12 meses</p>
            <div class='flex items-end gap-1 h-8'>
              {[1,2,3,4,5,8,11,15,19,24,29,35].map((h) => (
                <div
                  class='flex-1 rounded-sm'
                  style={`height: ${Math.min(h / 35 * 30, 30)}px; background: rgba(250,234,177,${0.15 + (h/35) * 0.4});`}>
                </div>
              ))}
            </div>
            <p class='text-[0.6rem] text-sand/40 mt-1.5'>Cada mes genera más que el anterior</p>
          </div>
        </div>
      </div>

      <!-- RIGHT: Google Ads -->
      <div
        data-animate
        class='relative rounded-2xl border overflow-hidden'
        style='background: rgba(250,234,177,0.03); border-color: rgba(250,234,177,0.15);'>

        <!-- Top accent bar -->
        <div class='absolute top-0 inset-x-0 h-[3px] bg-gradient-to-r from-sand/40 via-sand/25 to-transparent rounded-t-2xl'></div>

        <!-- Ghost watermark -->
        <div
          class='pointer-events-none absolute -bottom-3 -right-3 select-none leading-none'
          aria-hidden='true'
          style='font-size: 7rem; line-height: 1; opacity: 0.05;'>
          ∞
        </div>

        <div class='p-7 sm:p-8'>
          <!-- Card header -->
          <div class='flex items-center gap-3 mb-7'>
            <div class='flex h-9 w-9 items-center justify-center rounded-xl shrink-0' style='background: rgba(250,234,177,0.1); border: 1px solid rgba(250,234,177,0.2);'>
              {(() => { const Icon = iconByKey[rightColumn.icon]; return <Icon class='size-4.5 text-sand' aria-hidden='true' /> })()}
            </div>
            <div>
              <p class='label-ui text-sand/60 leading-none mb-0.5'>Canal alquilado</p>
              <p class='text-[1.05rem] font-bold text-white leading-tight' style='font-family: "Titan One", cursive;'>{rightColumn.title}</p>
            </div>
          </div>

          <ul class='space-y-4 mb-7'>
            {rightColumn.bullets.map((bullet) => {
              const BulletIcon = iconByKey[bullet.icon]
              return (
                <li class='flex items-start gap-3.5'>
                  <span class='shrink-0 mt-0.5 flex h-6 w-6 items-center justify-center rounded-full' style='background: rgba(250,234,177,0.08); border: 1px solid rgba(250,234,177,0.18);'>
                    <BulletIcon class='size-3 text-sand' aria-hidden='true' />
                  </span>
                  <p class='text-base text-white/75 leading-relaxed pt-0.5'>
                    <strong class='text-white/90 font-semibold'>{bullet.emphasis}</strong>{' '}{bullet.text}
                  </p>
                </li>
              )
            })}
          </ul>

          <!-- Note -->
          <div class='rounded-xl px-4 py-3.5' style='background: rgba(250,234,177,0.05); border: 1px solid rgba(250,234,177,0.12);'>
            <p class='text-base text-white/75 leading-relaxed'>
              <Fragment set:html={rightColumn.note} />
            </p>
          </div>

          <!-- Flat bars -->
          <div class='mt-5 rounded-xl px-4 pt-3.5 pb-4' style='background: rgba(250,234,177,0.03); border: 1px solid rgba(250,234,177,0.09);'>
            <p class='label-ui text-sand/50 mb-2.5'>Coste por visibilidad · 12 meses</p>
            <div class='flex items-end gap-1 h-8'>
              {[30,30,30,30,30,30,30,30,30,30,30,30].map(() => (
                <div
                  class='flex-1 rounded-sm'
                  style='height: 26px; background: rgba(250,234,177,0.18);'>
                </div>
              ))}
            </div>
            <p class='text-[0.6rem] text-sand/40 mt-1.5'>Mismo coste, mes 1 que mes 12</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Conclusion + CTA strip ───────────────────────────────────── -->
    <div data-animate class='flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 rounded-2xl border px-7 py-6' style='background: rgba(250,234,177,0.05); border-color: rgba(250,234,177,0.15);'>
      <p class='text-sm md:text-base text-white/75 leading-relaxed max-w-[52ch]'>
        <Fragment set:html={conclusion} />
      </p>
      <WhatsAppButton
        text='Analiza mi web'
        href={waHref}
        class='shrink-0 px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-sky-500/20 hover:shadow-sky-500/30 transition-shadow'
      />
    </div>

  </div>
</section>
