---
import CalButton from '../../CalButton.astro'

interface ComparisonBullet {
  emphasis: string
  text: string
}

interface ComparisonColumn {
  title: string
  label: string
  note: string
  bullets: ComparisonBullet[]
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  leftColumn?: ComparisonColumn
  rightColumn?: ComparisonColumn
  conclusion?: string
}

const defaultLeftColumn: ComparisonColumn = {
  title: 'SEO local',
  label: 'Canal propio',
  note: '<strong>Ideal para:</strong> negocios locales que buscan estabilidad, crecimiento a medio plazo y reducir la dependencia de la publicidad de pago.',
  bullets: [
    {
      emphasis: 'Activo acumulativo.',
      text: 'Cada mes de ejecución refuerza tu posición. El tráfico cualificado llega sin pagar por cada clic.',
    },
    {
      emphasis: 'Coste decreciente por lead.',
      text: 'A medida que las posiciones escalan, el coste de adquisición baja. La inversión de hoy genera clientes durante meses.',
    },
    {
      emphasis: 'Confianza del usuario.',
      text: 'El 70-80 % de los usuarios ignoran los anuncios y hacen clic en resultados orgánicos.',
    },
  ],
}

const defaultRightColumn: ComparisonColumn = {
  title: 'Google Ads',
  label: 'Canal alquilado',
  note: '<strong>Ideal para:</strong> emergencias de visibilidad, promociones temporales o sectores donde necesitas resultados mientras el SEO consolida posiciones.',
  bullets: [
    {
      emphasis: 'Resultados inmediatos.',
      text: 'Apareces en la primera posición desde el día uno.',
    },
    {
      emphasis: 'Coste constante por clic.',
      text: 'Cuando cortas el presupuesto, desapareces al instante de los resultados.',
    },
    {
      emphasis: 'Visibilidad vinculada al presupuesto.',
      text: 'Sin inversión, sin impresiones. El canal funciona mientras hay dinero asignado.',
    },
  ],
}

const {
  upheading = 'Comparativa SEO local y publicidad en Google',
  heading = 'SEO local vs Google Ads',
  intro = 'Ambas estrategias captan clientes, pero <strong>funcionan de forma muy distinta</strong>. Entiende qué te aporta cada una antes de decidir dónde poner tu dinero.',
  leftColumn = defaultLeftColumn,
  rightColumn = defaultRightColumn,
  conclusion = '<strong>La combinación más rentable</strong> para negocios locales en Barcelona: construir SEO local como base y complementar con Ads solo cuando el sector o la urgencia lo requieran.',
} = Astro.props
---

<section class='relative overflow-hidden py-24 md:py-32' style="background: linear-gradient(160deg, color-mix(in srgb, var(--color-cream) 85%, white) 0%, var(--color-cream) 50%, color-mix(in srgb, var(--color-cream) 85%, var(--color-surface)) 100%);">

  <div class="font-heading pointer-events-none absolute -left-8 top-1/2 -translate-y-1/2 select-none leading-none hidden lg:block" aria-hidden="true" style="font-size: clamp(10rem, 20vw, 16rem); color: rgba(52,101,109,0.06); text-transform: capitalize;">
    Vs
  </div>

  <div class='relative container-site'>

    <!-- ── Header ── -->
    <div class='mb-12 max-w-2xl' data-animate>
      <h2 class='text-xs font-bold tracking-[0.18em] uppercase text-sage'>{upheading}</h2>
      <p class='font-heading mt-4 text-h2 text-base leading-[1.1]'>{heading}</p>
      <p class='mt-5 text-base text-surface leading-relaxed max-w-[50ch]'>
        <Fragment set:html={intro} />
      </p>
    </div>

    <!-- ── Comparison ── -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-px bg-surface/10 rounded-2xl overflow-hidden mb-8' data-animate>

      <!-- LEFT: SEO local -->
      <div class='bg-base flex flex-col gap-6 p-8'>
        <div>
          <p class='text-xs font-bold tracking-widest uppercase text-cream-50 mb-1'>{leftColumn.label}</p>
          <p class='font-heading text-h4 text-cream leading-snug'>{leftColumn.title}</p>
        </div>

        <ul class='flex flex-col gap-3'>
          {leftColumn.bullets.map((bullet) => (
            <li class='flex items-start gap-2.5'>
              <span class='mt-2 shrink-0 size-1.5 rounded-full bg-sage/60' aria-hidden='true'></span>
              <p class='text-base text-cream-70 leading-relaxed'>
                <strong class='text-cream font-semibold'>{bullet.emphasis}</strong>{' '}{bullet.text}
              </p>
            </li>
          ))}
        </ul>

        <p class='text-base text-cream-60 leading-relaxed border-l-2 border-sage/40 pl-4 py-0.5'>
          <Fragment set:html={leftColumn.note} />
        </p>
      </div>

      <!-- RIGHT: Google Ads -->
      <div class='bg-cream/60 flex flex-col gap-6 p-8'>
        <div>
          <p class='text-xs font-bold tracking-widest uppercase text-surface/50 mb-1'>{rightColumn.label}</p>
          <p class='font-heading text-h4 text-base leading-snug'>{rightColumn.title}</p>
        </div>

        <ul class='flex flex-col gap-3'>
          {rightColumn.bullets.map((bullet) => (
            <li class='flex items-start gap-2.5'>
              <span class='mt-2 shrink-0 size-1.5 rounded-full bg-surface/30' aria-hidden='true'></span>
              <p class='text-base text-surface leading-relaxed'>
                <strong class='text-base font-semibold'>{bullet.emphasis}</strong>{' '}{bullet.text}
              </p>
            </li>
          ))}
        </ul>

        <p class='text-base text-surface/70 leading-relaxed border-l-2 border-surface/20 pl-4 py-0.5'>
          <Fragment set:html={rightColumn.note} />
        </p>
      </div>

    </div>

    <!-- ── Conclusion + CTA ── -->
    <div
      class='flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6'
      data-animate>
      <p class='text-base text-surface leading-relaxed max-w-[52ch]'>
        <Fragment set:html={conclusion} />
      </p>
      <CalButton color='base' class='shrink-0 px-6 py-3' />
    </div>

  </div>
</section>
