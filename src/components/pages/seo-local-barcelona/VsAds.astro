---
import { TrendingUp, Zap, Clock, Repeat, PiggyBank, ShieldCheck } from '@lucide/astro'
import WhatsAppButton from '../../WhatsAppButton.astro'
import { buildWhatsAppHref } from '../../../data/site'

const waHref = buildWhatsAppHref()

type IconKey = 'trendingUp' | 'zap' | 'clock' | 'repeat' | 'piggyBank' | 'shieldCheck'

interface ComparisonBullet {
  icon: IconKey
  emphasis: string
  text: string
}

interface ComparisonColumn {
  title: string
  icon: IconKey
  accentClass: string
  ringClass?: string
  noteClass?: string
  note: string
  bullets: ComparisonBullet[]
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  leftColumn?: ComparisonColumn
  rightColumn?: ComparisonColumn
  conclusion?: string
}

const iconByKey = {
  trendingUp: TrendingUp,
  zap: Zap,
  clock: Clock,
  repeat: Repeat,
  piggyBank: PiggyBank,
  shieldCheck: ShieldCheck,
} as const

const defaultLeftColumn: ComparisonColumn = {
  title: 'SEO local',
  icon: 'trendingUp',
  accentClass: 'bg-sky-600',
  note: '<strong>Ideal para:</strong> negocios que buscan estabilidad, rentabilidad a medio plazo y reducir la dependencia de la publicidad de pago.',
  bullets: [
    {
      icon: 'repeat',
      emphasis: 'Activo acumulativo.',
      text: 'Cada mes que trabajas, tu posición se refuerza. El tráfico llega sin pagar por cada clic.',
    },
    {
      icon: 'piggyBank',
      emphasis: 'Coste decreciente por lead.',
      text: 'A medida que subes posiciones, el coste de adquisición baja. La inversión de hoy genera clientes durante meses.',
    },
    {
      icon: 'shieldCheck',
      emphasis: 'Confianza del usuario.',
      text: 'El 70-80 % de los usuarios ignoran los anuncios y hacen clic en resultados orgánicos. Estar en el mapa genera más credibilidad.',
    },
  ],
}

const defaultRightColumn: ComparisonColumn = {
  title: 'Google Ads',
  icon: 'zap',
  accentClass: 'bg-gray-500',
  note: '<strong>Ideal para:</strong> emergencias de visibilidad, promociones temporales o sectores donde necesitas resultados mientras el SEO local consolida posiciones.',
  bullets: [
    {
      icon: 'clock',
      emphasis: 'Resultados inmediatos.',
      text: 'Apareces en la primera posición desde el día uno. Útil para campañas puntuales o lanzamientos.',
    },
    {
      icon: 'piggyBank',
      emphasis: 'Coste constante por clic.',
      text: 'Cada visita tiene un precio fijo. Cuando cortas el presupuesto, desapareces al instante de los resultados.',
    },
    {
      icon: 'shieldCheck',
      emphasis: 'Percepción de anuncio.',
      text: 'Los usuarios saben que es publicidad. La tasa de clic en anuncios es significativamente menor que en resultados orgánicos y Maps.',
    },
  ],
}

const {
  upheading = 'Comparativa SEO local y publicidad en Google',
  heading = 'SEO local vs Google Ads: qué le conviene más a tu negocio',
  intro = 'Ambas estrategias captan clientes, pero <strong>funcionan de forma muy distinta</strong>. Entiende qué te aporta cada una antes de decidir dónde poner tu dinero.',
  leftColumn = defaultLeftColumn,
  rightColumn = defaultRightColumn,
  conclusion = '<strong>La combinación más rentable</strong> para negocios locales en Barcelona: construir SEO local como base y complementar con Ads solo cuando el sector o la urgencia lo requieran. Cada euro invertido en posicionamiento orgánico <strong>sigue generando clientes meses después</strong>.',
} = Astro.props

const headingParts = heading.split(' o ')
const headingFirst = headingParts[0] ?? heading
const headingSecond = headingParts[1] ?? ''
---

<section class='relative overflow-hidden bg-petrol-900 py-24 md:py-32'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 30px 30px;'>
  </div>

  <!-- Diagonal tension lines -->
  <svg
    class='pointer-events-none absolute inset-0 w-full h-full'
    aria-hidden='true'
    preserveAspectRatio='none'
    xmlns='http://www.w3.org/2000/svg'>
    <line x1='42%' y1='0%' x2='58%' y2='100%' stroke='rgba(249,115,22,0.05)' stroke-width='1'></line>
    <line x1='48%' y1='0%' x2='66%' y2='100%' stroke='rgba(14,165,233,0.04)' stroke-width='1'></line>
  </svg>

  <!-- Large ghosted watermark -->
  <div
    class='pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 select-none leading-none'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(12rem, 25vw, 20rem); color: rgba(249,115,22,0.04); line-height: 1; white-space: nowrap;'>
    CANAL
  </div>

  <!-- Radial ambient top-left -->
  <div
    class='pointer-events-none absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full'
    aria-hidden='true'
    style='background: radial-gradient(circle, rgba(14,165,233,0.05) 0%, transparent 65%);'>
  </div>

  <!-- Top / bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-orange-500/30 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-orange-500/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-7xl px-6 lg:px-8'>

    <!-- ── Section header ──────────────────────────────────────────────── -->
    <div class='mb-14 md:mb-18 max-w-3xl'>
      <div data-animate class='flex items-center gap-3 mb-8'>
        <span class='block h-px w-10 bg-orange-500' aria-hidden='true'></span>
        <h2 class='label-section text-orange-400'>
          {upheading}
        </h2>
      </div>

      <p
        data-animate
        style='font-family: "Titan One", cursive;'
        class='leading-[0.92] tracking-tight'>
        {headingSecond ? (
          <>
            <span class='block text-[clamp(1.8rem,4vw,3rem)] text-white/45 mb-1'>
              {headingFirst}
            </span>
            <span class='block text-[clamp(3rem,6.5vw,5rem)] text-white'>
              o <span class='text-orange-400'>{headingSecond}</span>
            </span>
          </>
        ) : (
          <span class='block text-[clamp(3rem,6.5vw,5rem)] text-white'>{heading}</span>
        )}
      </p>

      <div data-animate class='mt-6 flex items-center'>
        <div class='h-[3px] w-16 bg-orange-500 rounded-full'></div>
        <div class='h-px w-24 bg-gradient-to-r from-orange-500/40 to-transparent'></div>
      </div>

      <p data-animate class='mt-6 max-w-[52ch] text-base md:text-lg text-white/55 leading-relaxed text-pretty'>
        <Fragment set:html={intro} />
      </p>
    </div>

    <!-- ── Comparison cards ─────────────────────────────────────────── -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-5 mb-14'>

      <!-- LEFT: SEO local — recommended -->
      <div
        data-animate
        class='relative rounded-2xl border overflow-hidden'
        style='background: rgba(14,165,233,0.05); border-color: rgba(56,189,248,0.22);'>

        <!-- Recommended badge -->
        <div class='absolute top-5 right-5 flex items-center gap-1.5 rounded-full px-2.5 py-1' style='background: rgba(14,165,233,0.15); border: 1px solid rgba(56,189,248,0.3);'>
          <span class='block w-1.5 h-1.5 rounded-full bg-sky-400' style='animation: pulse-glow 1.8s ease-in-out infinite;'></span>
          <span class='text-[0.58rem] font-bold uppercase tracking-wider text-sky-300'>Recomendado</span>
        </div>

        <!-- Top accent bar -->
        <div class='absolute top-0 inset-x-0 h-[3px] bg-gradient-to-r from-sky-500/60 via-sky-400/40 to-transparent rounded-t-2xl'></div>

        <!-- Ghost watermark -->
        <div
          class='pointer-events-none absolute -bottom-3 -right-3 select-none leading-none'
          aria-hidden='true'
          style='font-family: "Titan One", cursive; font-size: 7rem; color: rgba(14,165,233,0.06); line-height: 1;'>
          ↗
        </div>

        <div class='p-7 sm:p-8'>
          <!-- Card header -->
          <div class='flex items-center gap-3 mb-7 pr-24'>
            <div class='flex h-9 w-9 items-center justify-center rounded-xl shrink-0' style='background: rgba(14,165,233,0.12); border: 1px solid rgba(56,189,248,0.25);'>
              {(() => { const Icon = iconByKey[leftColumn.icon]; return <Icon class='size-4.5 text-sky-400' aria-hidden='true' /> })()}
            </div>
            <div>
              <p class='label-ui text-sky-400/60 leading-none mb-0.5'>Canal propio</p>
              <p class='text-[1.05rem] font-bold text-white leading-tight' style='font-family: "Titan One", cursive;'>{leftColumn.title}</p>
            </div>
          </div>

          <ul class='space-y-4 mb-7'>
            {leftColumn.bullets.map((bullet) => {
              const BulletIcon = iconByKey[bullet.icon]
              return (
                <li class='flex items-start gap-3.5'>
                  <span class='shrink-0 mt-0.5 flex h-6 w-6 items-center justify-center rounded-full' style='background: rgba(14,165,233,0.1); border: 1px solid rgba(56,189,248,0.25);'>
                    <BulletIcon class='size-3 text-sky-400' aria-hidden='true' />
                  </span>
                  <p class='text-sm text-white/60 leading-relaxed pt-0.5'>
                    <strong class='text-white/90 font-semibold'>{bullet.emphasis}</strong>{' '}{bullet.text}
                  </p>
                </li>
              )
            })}
          </ul>

          <!-- Note -->
          <div class='rounded-xl px-4 py-3.5' style='background: rgba(14,165,233,0.06); border: 1px solid rgba(56,189,248,0.13);'>
            <p class='text-sm text-white/50 leading-relaxed'>
              <Fragment set:html={leftColumn.note} />
            </p>
          </div>

          <!-- Growth bars -->
          <div class='mt-5 rounded-xl px-4 pt-3.5 pb-4' style='background: rgba(14,165,233,0.04); border: 1px solid rgba(56,189,248,0.1);'>
            <p class='label-ui text-sky-400/50 mb-2.5'>Efecto acumulativo · 12 meses</p>
            <div class='flex items-end gap-1 h-8'>
              {[1,2,3,4,5,8,11,15,19,24,29,35].map((h) => (
                <div
                  class='flex-1 rounded-sm'
                  style={`height: ${Math.min(h / 35 * 30, 30)}px; background: rgba(14,165,233,${0.15 + (h/35) * 0.4});`}>
                </div>
              ))}
            </div>
            <p class='text-[0.6rem] text-sky-300/40 mt-1.5'>Cada mes genera más que el anterior</p>
          </div>
        </div>
      </div>

      <!-- RIGHT: Google Ads -->
      <div
        data-animate
        class='relative rounded-2xl border overflow-hidden'
        style='background: rgba(249,115,22,0.03); border-color: rgba(249,115,22,0.15);'>

        <!-- Top accent bar -->
        <div class='absolute top-0 inset-x-0 h-[3px] bg-gradient-to-r from-orange-500/40 via-orange-400/25 to-transparent rounded-t-2xl'></div>

        <!-- Ghost watermark -->
        <div
          class='pointer-events-none absolute -bottom-3 -right-3 select-none leading-none'
          aria-hidden='true'
          style='font-size: 7rem; line-height: 1; opacity: 0.05;'>
          ∞
        </div>

        <div class='p-7 sm:p-8'>
          <!-- Card header -->
          <div class='flex items-center gap-3 mb-7'>
            <div class='flex h-9 w-9 items-center justify-center rounded-xl shrink-0' style='background: rgba(249,115,22,0.1); border: 1px solid rgba(249,115,22,0.2);'>
              {(() => { const Icon = iconByKey[rightColumn.icon]; return <Icon class='size-4.5 text-orange-400' aria-hidden='true' /> })()}
            </div>
            <div>
              <p class='label-ui text-orange-400/60 leading-none mb-0.5'>Canal alquilado</p>
              <p class='text-[1.05rem] font-bold text-white leading-tight' style='font-family: "Titan One", cursive;'>{rightColumn.title}</p>
            </div>
          </div>

          <ul class='space-y-4 mb-7'>
            {rightColumn.bullets.map((bullet) => {
              const BulletIcon = iconByKey[bullet.icon]
              return (
                <li class='flex items-start gap-3.5'>
                  <span class='shrink-0 mt-0.5 flex h-6 w-6 items-center justify-center rounded-full' style='background: rgba(249,115,22,0.08); border: 1px solid rgba(249,115,22,0.18);'>
                    <BulletIcon class='size-3 text-orange-400' aria-hidden='true' />
                  </span>
                  <p class='text-sm text-white/60 leading-relaxed pt-0.5'>
                    <strong class='text-white/90 font-semibold'>{bullet.emphasis}</strong>{' '}{bullet.text}
                  </p>
                </li>
              )
            })}
          </ul>

          <!-- Note -->
          <div class='rounded-xl px-4 py-3.5' style='background: rgba(249,115,22,0.05); border: 1px solid rgba(249,115,22,0.12);'>
            <p class='text-sm text-white/50 leading-relaxed'>
              <Fragment set:html={rightColumn.note} />
            </p>
          </div>

          <!-- Flat bars -->
          <div class='mt-5 rounded-xl px-4 pt-3.5 pb-4' style='background: rgba(249,115,22,0.03); border: 1px solid rgba(249,115,22,0.09);'>
            <p class='label-ui text-orange-400/50 mb-2.5'>Coste por visibilidad · 12 meses</p>
            <div class='flex items-end gap-1 h-8'>
              {[30,30,30,30,30,30,30,30,30,30,30,30].map(() => (
                <div
                  class='flex-1 rounded-sm'
                  style='height: 26px; background: rgba(249,115,22,0.18);'>
                </div>
              ))}
            </div>
            <p class='text-[0.6rem] text-orange-300/40 mt-1.5'>Mismo coste, mes 1 que mes 12</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Tipping-point chart ──────────────────────────────────────── -->
    <div data-animate class='mb-14 rounded-2xl overflow-hidden border' style='background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.06);'>
      <div class='px-6 pt-6 pb-2 flex items-center justify-between flex-wrap gap-3'>
        <p class='label-section text-white/35'>Evolución comparada · 18 meses</p>
        <div class='flex items-center gap-5'>
          <div class='flex items-center gap-2'>
            <div class='h-px w-8 bg-sky-400/60'></div>
            <span class='text-[0.63rem] font-semibold text-white/35'>SEO local</span>
          </div>
          <div class='flex items-center gap-2'>
            <div class='h-px w-8 bg-orange-400/50'></div>
            <span class='text-[0.63rem] font-semibold text-white/35'>Google Ads</span>
          </div>
        </div>
      </div>
      <div class='px-6 pb-6 pt-2'>
        <svg
          viewBox='0 0 600 160'
          class='w-full'
          preserveAspectRatio='none'
          style='height: clamp(90px, 16vw, 148px);'
          aria-hidden='true'
          xmlns='http://www.w3.org/2000/svg'>

          <!-- Grid lines -->
          <line x1='0' y1='40' x2='600' y2='40' stroke='rgba(255,255,255,0.04)' stroke-width='1'/>
          <line x1='0' y1='80' x2='600' y2='80' stroke='rgba(255,255,255,0.04)' stroke-width='1'/>
          <line x1='0' y1='120' x2='600' y2='120' stroke='rgba(255,255,255,0.04)' stroke-width='1'/>

          <!-- Ads: flat, slight cost creep -->
          <path
            d='M 0 100 L 50 99 L 100 100 L 150 98 L 200 99 L 250 97 L 300 98 L 350 96 L 400 97 L 450 95 L 500 96 L 550 94 L 600 93'
            fill='none'
            stroke='rgba(249,115,22,0.5)'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'/>

          <!-- SEO: S-curve compound growth -->
          <path
            d='M 0 130 C 80 128, 140 122, 180 114 C 220 106, 260 94, 300 80 C 340 65, 380 46, 430 30 C 470 18, 530 10, 600 5'
            fill='none'
            stroke='rgba(56,189,248,0.65)'
            stroke-width='2.5'
            stroke-linecap='round'/>

          <!-- SEO fill -->
          <path
            d='M 0 130 C 80 128, 140 122, 180 114 C 220 106, 260 94, 300 80 C 340 65, 380 46, 430 30 C 470 18, 530 10, 600 5 L 600 160 L 0 160 Z'
            fill='url(#seo-fill-grad)'
            opacity='0.07'/>

          <defs>
            <linearGradient id='seo-fill-grad' x1='0' y1='0' x2='0' y2='1'>
              <stop offset='0%' stop-color='rgb(56,189,248)'/>
              <stop offset='100%' stop-color='rgb(56,189,248)' stop-opacity='0'/>
            </linearGradient>
          </defs>

          <!-- Inflection annotation -->
          <line x1='230' y1='18' x2='230' y2='142' stroke='rgba(255,255,255,0.07)' stroke-width='1' stroke-dasharray='4 3'/>
          <text x='235' y='32' fill='rgba(255,255,255,0.25)' font-size='9' font-family='system-ui,sans-serif'>Punto de</text>
          <text x='235' y='43' fill='rgba(255,255,255,0.25)' font-size='9' font-family='system-ui,sans-serif'>inflexión</text>

          <!-- Month labels -->
          {['', '3m', '6m', '9m', '12m', '15m', '18m'].map((label, i) => (
            <text
              x={i * 100}
              y='158'
              fill='rgba(255,255,255,0.18)'
              font-size='8'
              font-family='system-ui,sans-serif'
              text-anchor='middle'>
              {label}
            </text>
          ))}
        </svg>
      </div>
    </div>

    <!-- ── Conclusion + CTA strip ───────────────────────────────────── -->
    <div data-animate class='flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 rounded-2xl border px-7 py-6' style='background: rgba(14,165,233,0.05); border-color: rgba(56,189,248,0.15);'>
      <p class='text-sm md:text-base text-white/60 leading-relaxed max-w-[52ch]'>
        <Fragment set:html={conclusion} />
      </p>
      <WhatsAppButton
        text='Analiza mi web'
        href={waHref}
        class='shrink-0 px-6 py-3 text-[0.9375rem] font-bold shadow-lg shadow-sky-500/20 hover:shadow-sky-500/30 transition-shadow'
      />
    </div>

  </div>
</section>
