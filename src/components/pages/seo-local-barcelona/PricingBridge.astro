---
import WhatsAppButton from '../../WhatsAppButton.astro'
import { buildWhatsAppHref } from '../../../data/site'

const waHref = buildWhatsAppHref()

interface Guarantee {
  title: string
  description: string
}

interface Props {
  upheading: string
  heading: string
  priceHighlight?: string
  intro: string
  guarantees: Guarantee[]
  quote: string
  quoteAuthor: string
}

const {
  upheading,
  heading,
  priceHighlight,
  intro,
  guarantees,
  quote,
  quoteAuthor,
} = Astro.props

// Split heading on " y " for two-tone treatment
const headingParts = heading.split(' y ')
const headingFirst = headingParts[0] ?? heading
const headingRest  = headingParts.slice(1).join(' y ')

const ordinals = ['01', '02', '03', '04', '05', '06']
---

<section class='relative overflow-hidden bg-surface py-24 md:py-32'>

  <!-- Dot-grid -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'>
  </div>

  <!-- Diagonal tension lines -->
  <svg class='pointer-events-none absolute inset-0 w-full h-full' aria-hidden='true' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'>
    <line x1='55%' y1='0%' x2='72%' y2='100%' stroke='rgba(250,234,177,0.05)' stroke-width='1'/>
    <line x1='60%' y1='0%' x2='80%' y2='100%' stroke='rgba(250,234,177,0.03)' stroke-width='1'/>
  </svg>

  <!-- Watermark -->
  <div class="font-heading pointer-events-none absolute -right-12 top-1/2 -translate-y-1/2 select-none leading-none"
    aria-hidden='true'>
    €€
  </div>

  <!-- Radial glow bottom-left -->
  <div
    class='pointer-events-none absolute -bottom-40 -left-40 w-[500px] h-[500px] rounded-full'
    aria-hidden='true'>
  </div>

  <!-- Top / bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/30 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-sand/15 to-transparent' aria-hidden='true'></div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <!-- ── Main two-column layout ──────────────────────────────────── -->
    <div class='grid lg:grid-cols-[1fr_1.1fr] gap-14 lg:gap-20 items-start'>

      <!-- ── LEFT: Price anchor (sticky) ──────────────────────────── -->
      <div class='lg:sticky lg:top-28'>

        <!-- Eyebrow -->
        <div data-animate class='flex items-center gap-3 mb-8'>
          <span class='block h-px w-10 bg-sand' aria-hidden='true'></span>
          <h2 class='text-[0.65rem] font-bold tracking-[0.18em] uppercase text-sand'>
            {upheading}
          </h2>
        </div>

        <!-- Heading -->
        <p
          data-animate

          class='font-heading text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-[1.05] leading-[1.05] tracking-tight text-white text-pretty mb-6'>
          {headingRest ? (
            <>{headingFirst} y lo que cuesta <span class='text-sand'>no hacerlo</span>.</>
          ) : (
            <>{heading}</>
          )}
        </p>

        <!-- Accent rule -->
        <div data-animate class='flex items-center mb-8'>
          <div class='h-[3px] w-16 bg-sand rounded-full'></div>
          <div class='h-px w-24 bg-gradient-to-r from-sand/40 to-transparent'></div>
        </div>

        <!-- Giant price -->
        {priceHighlight && (
          <div data-animate class='mb-6'>
            <div class='flex items-end gap-3 leading-none mb-3'>
              <span class="font-heading text-white leading-none tabular-nums">
                Desde
              </span>
            </div>
            <div class='flex items-end gap-3 leading-none mb-1'>
              <span class="font-heading text-sand leading-none tabular-nums">
                350€
              </span>
              <span class="font-heading text-white/30 leading-none mb-2">
                /mes
              </span>
            </div>
          </div>
        )}

        <!-- Divider -->
        <div data-animate class='h-px bg-gradient-to-r from-white/10 to-transparent mb-8'></div>

        <!-- Intro text -->
        <p data-animate class='text-base md:text-lg text-white/75 leading-relaxed text-pretty max-w-[42ch]'>
          <Fragment set:html={intro} />
        </p>

        <!-- Invisible cost callout -->
        <div data-animate class='mt-8 rounded-2xl border overflow-hidden'>
          <div class='px-5 py-4 border-b'>
            <p class='text-[0.6rem] font-semibold tracking-[0.12em] uppercase text-sand/70'>El coste invisible</p>
          </div>
          <ul class='divide-y'>
            {[
              { label: 'Clientes que no te encontraron', value: 'esta semana' },
              { label: 'Búsquedas que fue a tu competencia', value: 'cada día' },
              { label: 'Meses sin capitalizar la demanda local', value: 'acumulados' },
            ].map(row => (
              <li class='flex items-center justify-between gap-4 px-5 py-3.5'>
                <span class='text-[0.78rem] text-white/75 leading-snug'>{row.label}</span>
                <span class='shrink-0 text-[0.68rem] font-bold text-sand/70 text-right'>{row.value}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <!-- ── RIGHT: Guarantees + Quote ─────────────────────────────── -->
      <div class='flex flex-col gap-4 mt-2'>

        {guarantees.map((item, idx) => (
          <div
            data-animate
            data-animate-delay={idx * 80}
            class='guarantee-card group relative rounded-2xl border border-white/[0.07] bg-white/[0.03] px-6 py-5 transition-all duration-300 hover:border-sand/25 hover:bg-white/[0.055] overflow-hidden cursor-default'>

            <!-- Left accent bar -->
            <div class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sand scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100' aria-hidden='true'></div>

            <!-- Ghost ordinal -->
            <div class="font-heading pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 select-none leading-none"
              aria-hidden='true'>
              {ordinals[idx]}
            </div>

            <!-- Check badge + content -->
            <div class='relative flex items-start gap-4'>
              <div class='shrink-0 mt-0.5 flex h-7 w-7 items-center justify-center rounded-full bg-sand/10 ring-1 ring-sand/20 transition-all duration-300 group-hover:bg-sand/18 group-hover:ring-sand/40'>
                <svg class='h-3.5 w-3.5 text-sand' viewBox='0 0 12 10' fill='none' aria-hidden='true'>
                  <path d='M1 5l3.5 3.5L11 1' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/>
                </svg>
              </div>
              <div class='min-w-0'>
                <p class='text-[0.9375rem] font-bold text-white/90 mb-1.5 leading-snug transition-colors duration-300 group-hover:text-white'>
                  {item.title}
                </p>
                <p class='text-sm text-white/45 leading-relaxed text-pretty transition-colors duration-300 group-hover:text-white/60'>
                  {item.description}
                </p>
              </div>
            </div>
          </div>
        ))}


      </div>
    </div>

  </div>
</section>
