---
import Upheading from '../../Upheading.astro'
import CalButton from '../../CalButton.astro'

interface PricingFeature {
  text: string
  included: boolean
}

interface PricingCategory {
  name: string
  features: PricingFeature[]
}

interface Props {
  upheading: string
  heading: string
  intro: string
  priceText: string
  priceUnit: string
  priceNote: string
  ctaText: string
  ctaHref?: string
  categories: PricingCategory[]
  quote: string
  quoteAuthor: string
}

const {
  upheading,
  heading,
  intro,
  priceText,
  priceUnit,
  priceNote,
  ctaText,
  ctaHref,
  categories,
  quote,
  quoteAuthor,
} = Astro.props
---

<div class='py-24 sm:py-32'>
  <div class='container-site'>
    <div class='mx-auto max-w-4xl text-center'>
      <Upheading as='h2' text={upheading} class='text-center' />
      <p class='mt-2 text-h2 font-semibold tracking-tight text-balance text-cream sm:text-h1'>
        {heading}
      </p>
    </div>
    <p class='mx-auto mt-6 max-w-2xl text-center text-h6 font-medium text-pretty text-cream/70 sm:text-h5'>
      <Fragment set:html={intro} />
    </p>

    <!-- 2-column layout -->
    <div class='mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 items-start lg:grid-cols-5'>
      <!-- Price card — sticky -->
      <div class='lg:col-span-2 bg-white border-2 border-sage/30 rounded-xl p-8 lg:sticky lg:top-24'>
        <h3 class='text-h6 font-semibold text-sage'>
          Servicio de SEO local
        </h3>
        <p class='mt-4 flex items-baseline gap-x-2'>
          <span class='text-h1 font-semibold tracking-tight text-cream'>{priceText}</span>
          <span class='text-base font-semibold text-cream/70'>{priceUnit}</span>
        </p>
        <p class='mt-2 text-base text-cream/70'>
          {priceNote}
        </p>
        <div class='mt-8'>
          {ctaHref ? (
            <a
              href={ctaHref}
              target='_blank'
              rel='noopener noreferrer nofollow'
              class='block rounded-md bg-teal px-3.5 py-2.5 text-center text-base font-bold text-white shadow-sm hover:bg-[#3d7880] active:bg-[#2b565d] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal'>
              {ctaText}
            </a>
          ) : (
            <CalButton text={ctaText} class='w-full justify-center' variant="sage" />
          )}
        </div>
      </div>

      <!-- Feature table -->
      <div class='lg:col-span-3'>
        <table class='w-full text-left'>
          <caption class='sr-only'>Qué incluye el servicio de SEO local</caption>
          <tbody>
            {categories.map((category) => (
              <>
                <tr>
                  <th
                    scope='colgroup'
                    colspan='2'
                    class='pt-6 pb-3 text-base/6 font-semibold text-cream'>
                    <div class='bg-surface/5 rounded-lg px-4 py-2'>
                      {category.name}
                    </div>
                  </th>
                </tr>
                {category.features.map((feature) => (
                  <tr>
                    <th scope='row' class='py-3 px-4 text-base/6 font-normal text-cream/70'>
                      {feature.text}
                      <div class='mt-3 h-px bg-surface/5'></div>
                    </th>
                    <td class='py-3 pl-4 text-right'>
                      {feature.included ? (
                        <svg viewBox='0 0 20 20' fill='currentColor' aria-hidden='true' class='inline size-5 text-maps-green'>
                          <path d='M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z' clip-rule='evenodd' fill-rule='evenodd' />
                        </svg>
                      ) : (
                        <svg viewBox='0 0 20 20' fill='currentColor' aria-hidden='true' class='inline size-5 text-gray-400'>
                          <path d='M4 10a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H4.75A.75.75 0 0 1 4 10Z' clip-rule='evenodd' fill-rule='evenodd' />
                        </svg>
                      )}
                    </td>
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Quote — full width -->
    <div class='mx-auto mt-16 max-w-3xl'>
      <figure>
        <blockquote class='border-l-4 border-sage/30 pl-6 text-h6 italic text-cream text-pretty text-left'>
          <p>"{quote}"</p>
        </blockquote>
        <figcaption class='mt-4 pl-6 text-base text-cream/70'>
          <Fragment set:html={quoteAuthor} />
        </figcaption>
      </figure>
    </div>
  </div>
</div>
