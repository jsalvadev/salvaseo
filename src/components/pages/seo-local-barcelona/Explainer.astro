---
import { MapPin, Search, LayoutGrid } from '@lucide/astro'

type IconKey = 'mapPin' | 'search' | 'layoutGrid'

interface ExplainerItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  items?: ExplainerItem[]
  mockupCaption?: string
}

const iconByKey = {
  mapPin: MapPin,
  search: Search,
  layoutGrid: LayoutGrid,
} as const

const defaultItems: ExplainerItem[] = [
  {
    icon: 'search',
    title: 'SEO local vs posicionamiento web tradicional.',
    description:
      'El SEO tradicional posiciona tu web en resultados orgánicos generales. El SEO local te coloca en <strong>Google Maps, el Local Pack y las búsquedas geolocalizadas</strong> — donde están los usuarios que compran hoy, no mañana.',
  },
  {
    icon: 'layoutGrid',
    title: 'El Local Pack de Google captura la mayoría de clics.',
    description:
      'Es el bloque con mapa y tres negocios que aparece antes de los resultados orgánicos. Aparecer en el Local Pack equivale a <strong>tener un escaparate en la calle principal de Google</strong>. Sin optimización local, ese escaparate lo ocupa otro.',
  },
  {
    icon: 'mapPin',
    title: 'Relevancia, distancia y prominencia.',
    description:
      'Google decide quién sale en el mapa combinando tres factores: lo relevante que es tu negocio para la búsqueda, la distancia al usuario y tu <strong>reputación online</strong> (reseñas, autoridad, actividad). Los tres se trabajan con SEO local.',
  },
]

const {
  upheading = 'SEO local en Barcelona',
  heading = 'Qué es el SEO local y por qué decide quién se lleva al cliente',
  intro = 'El <strong>46 % de las búsquedas en Google tienen intención local</strong>. Cuando alguien escribe "dentista Barcelona" o "taller cerca de mí", Google muestra primero el mapa con tres resultados. Si no estás ahí, el cliente va directo a tu competencia.',
  items = defaultItems,
  mockupCaption = 'Así se ve el Local Pack de Google: <strong>3 negocios, un mapa, el 44 % de los clics.</strong>',
} = Astro.props

---

<section
  class='relative overflow-hidden py-24 md:py-32 bg-cream'
  style="background-image: radial-gradient(circle, rgba(105,117,101,0.12) 1px, transparent 1px); background-size: 24px 24px;">

  <!-- Watermark -->
  <div class="font-heading pointer-events-none absolute -left-16 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-base/[0.05]"
    aria-hidden='true'>
    MAPA
  </div>

  <div class='relative container-site text-center'>

    <!-- ── Section header ──────────────────────────────────────────── -->
    <div class='mb-14 lg:mb-18'>
      <div data-animate class='flex items-center justify-center gap-2'>
        <MapPin class='size-3.5 text-sage' aria-hidden='true' />
        <p class='text-xs font-bold tracking-[0.18em] uppercase text-sage'>
          {upheading}
        </p>
      </div>

      <h2
        data-animate
        class='mt-5 font-heading text-h2 font-bold leading-tight tracking-tight text-pretty mx-auto max-w-4xl text-base'>
        {heading}
      </h2>

    </div>

    <!-- ── Items list ──────────────────────────────────────────── -->
    <div class='max-w-3xl mx-auto'>
      <div>

        <p class='text-base text-surface leading-relaxed mb-10 text-pretty mx-auto md:mx-0 md:text-left max-w-[46ch]' data-animate>
          <Fragment set:html={intro} />
        </p>

        <ol class='grid grid-cols-1 md:grid-cols-2 gap-4 text-left'>
          {items.map((item, idx) => {
            const Icon = iconByKey[item.icon]
            const num  = String(idx + 1).padStart(2, '0')
            const isHero = idx === 0
            return (
              <li
                class={`item-card group relative overflow-hidden rounded-2xl border border-sage-20 border-t-2 border-t-sage/30 bg-white/50 px-5 py-5 transition-all duration-300 hover:border-sage-30 hover:border-t-sage/70 hover:shadow-md hover:shadow-base/5 hover:bg-sage/5 cursor-default${isHero ? ' md:col-span-2' : ''}`}
                data-animate
                data-animate-delay={idx * 110}>

                <!-- Ghost ordinal -->
                <div class="font-heading pointer-events-none absolute bottom-2 right-3 select-none leading-none text-[8rem] text-base/[0.1] transition-opacity duration-300"
                  aria-hidden='true'>
                  {num}
                </div>

                <div class='relative flex items-start gap-3.5'>
                  <!-- Icon badge -->
                  <div class={`shrink-0 mt-0.5 flex items-center justify-center rounded-xl bg-sage/10 ring-1 ring-sage/20 transition-all duration-300 group-hover:bg-sage/20 group-hover:ring-sage/30${isHero ? ' h-12 w-12' : ' h-10 w-10'}`}>
                    <Icon class={`text-sage${isHero ? ' size-6' : ' size-5'}`} aria-hidden='true' />
                  </div>

                  <div class='min-w-0'>
                    <!-- Expanding underline -->
                    <div class='h-0.5 w-5 bg-sage rounded-full transition-all duration-300 group-hover:w-10 mb-2'></div>
                    <dt class={`font-bold text-base leading-snug mb-1.5${isHero ? ' text-lg' : ' text-sm'}`}>
                      {item.title}
                    </dt>
                    <dd class='text-base text-surface leading-relaxed text-pretty'>
                      <Fragment set:html={item.description} />
                    </dd>
                  </div>
                </div>
              </li>
            )
          })}
        </ol>
      </div>

    </div>
  </div>
</section>
