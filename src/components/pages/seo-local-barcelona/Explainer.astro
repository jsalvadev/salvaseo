---
import { MapPin, Search, LayoutGrid } from '@lucide/astro'

type IconKey = 'mapPin' | 'search' | 'layoutGrid'

interface ExplainerItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  items?: ExplainerItem[]
  mockupCaption?: string
}

const iconByKey = {
  mapPin: MapPin,
  search: Search,
  layoutGrid: LayoutGrid,
} as const

const defaultItems: ExplainerItem[] = [
  {
    icon: 'search',
    title: 'SEO local vs posicionamiento web tradicional.',
    description:
      'El SEO tradicional posiciona tu web en resultados orgánicos generales. El SEO local te coloca en <strong>Google Maps, el Local Pack y las búsquedas geolocalizadas</strong> — donde están los usuarios que compran hoy, no mañana.',
  },
  {
    icon: 'layoutGrid',
    title: 'El Local Pack de Google captura la mayoría de clics.',
    description:
      'Es el bloque con mapa y tres negocios que aparece antes de los resultados orgánicos. Aparecer en el Local Pack equivale a <strong>tener un escaparate en la calle principal de Google</strong>. Sin optimización local, ese escaparate lo ocupa otro.',
  },
  {
    icon: 'mapPin',
    title: 'Relevancia, distancia y prominencia.',
    description:
      'Google decide quién sale en el mapa combinando tres factores: lo relevante que es tu negocio para la búsqueda, la distancia al usuario y tu <strong>reputación online</strong> (reseñas, autoridad, actividad). Los tres se trabajan con SEO local.',
  },
]

const {
  upheading = 'SEO local en Barcelona',
  heading = 'Qué es el SEO local y por qué decide quién se lleva al cliente',
  intro = 'El <strong>46 % de las búsquedas en Google tienen intención local</strong>. Cuando alguien escribe "dentista Barcelona" o "taller cerca de mí", Google muestra primero el mapa con tres resultados. Si no estás ahí, el cliente va directo a tu competencia.',
  items = defaultItems,
  mockupCaption = 'Así se ve el Local Pack de Google: <strong>3 negocios, un mapa, el 44 % de los clics.</strong>',
} = Astro.props

---

<section class='relative overflow-hidden py-24 md:py-32 bg-cream'>

  <!-- Watermark -->
  <div class="font-heading pointer-events-none absolute -left-8 top-1/2 -translate-y-1/2 select-none leading-none text-wm font-bold text-base/[0.04]"
    aria-hidden='true'>
    MAPA
  </div>

  <!-- Right accent bar -->
  <div
    class='pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-32 bg-sage rounded-l-full'
    aria-hidden='true'>
  </div>

  <div class='relative container-site text-center'>

    <!-- ── Section header ──────────────────────────────────────────── -->
    <div class='mb-14 lg:mb-18'>
      <div data-animate class='flex items-center justify-center gap-3'>
        <h2 class='text-xs font-bold tracking-[0.18em] uppercase text-sage'>
          {upheading}
        </h2>
      </div>

      <p
        data-animate
        class='mt-5 font-heading text-h2 font-bold leading-tight tracking-tight text-pretty mx-auto max-w-4xl text-base'>
        {heading}
      </p>

    </div>

    <!-- ── Items list ──────────────────────────────────────────── -->
    <div class='max-w-2xl mx-auto'>
      <div>

        <p class='text-base text-surface leading-relaxed mb-10 text-pretty mx-auto max-w-[46ch]' data-animate>
          <Fragment set:html={intro} />
        </p>

        <ol class='flex flex-col gap-4 text-left'>
          {items.map((item, idx) => {
            const Icon = iconByKey[item.icon]
            const num  = String(idx + 1).padStart(2, '0')
            return (
              <li
                class='item-card group relative overflow-hidden rounded-2xl border border-sage-20 bg-white/50 px-5 py-5 transition-all duration-300 hover:border-sage-30 hover:shadow-md hover:shadow-base/5 cursor-default'
                data-animate
                data-animate-delay={idx * 110}>

                <!-- Left accent bar -->
                <div class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-sage scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100' aria-hidden='true'></div>

                <!-- Ghost ordinal -->
                <div class="font-heading pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 select-none leading-none text-base/[0.08] text-[3rem] transition-opacity duration-300"
                  aria-hidden='true'>
                  {num}
                </div>

                <div class='relative flex items-start gap-3.5'>
                  <!-- Icon badge -->
                  <div class='shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-xl bg-sage/10 ring-1 ring-sage/20 transition-all duration-300 group-hover:bg-sage/20 group-hover:ring-sage/30'>
                    <Icon class='size-4 text-sage' aria-hidden='true' />
                  </div>

                  <div class='min-w-0'>
                    <!-- Expanding underline -->
                    <div class='h-0.5 w-5 bg-sage rounded-full transition-all duration-300 group-hover:w-10 mb-2'></div>
                    <dt class='text-[0.9rem] font-bold text-base leading-snug mb-1.5'>
                      {item.title}
                    </dt>
                    <dd class='text-base text-surface leading-relaxed text-pretty'>
                      <Fragment set:html={item.description} />
                    </dd>
                  </div>
                </div>
              </li>
            )
          })}
        </ol>
      </div>

    </div>
  </div>
</section>
