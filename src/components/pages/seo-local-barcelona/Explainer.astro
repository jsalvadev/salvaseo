---
import { MapPin, Search, LayoutGrid } from '@lucide/astro'

type IconKey = 'mapPin' | 'search' | 'layoutGrid'

interface ExplainerItem {
  icon: IconKey
  title: string
  description: string
}

interface Props {
  upheading?: string
  heading?: string
  intro?: string
  items?: ExplainerItem[]
  mockupCaption?: string
}

const iconByKey = {
  mapPin: MapPin,
  search: Search,
  layoutGrid: LayoutGrid,
} as const

const defaultItems: ExplainerItem[] = [
  {
    icon: 'search',
    title: 'SEO local vs posicionamiento web tradicional.',
    description:
      'El SEO tradicional posiciona tu web en resultados orgánicos generales. El SEO local te coloca en <strong>Google Maps, el Local Pack y las búsquedas geolocalizadas</strong> — donde están los usuarios que compran hoy, no mañana.',
  },
  {
    icon: 'layoutGrid',
    title: 'El Local Pack de Google captura la mayoría de clics.',
    description:
      'Es el bloque con mapa y tres negocios que aparece antes de los resultados orgánicos. Aparecer en el Local Pack equivale a <strong>tener un escaparate en la calle principal de Google</strong>. Sin optimización local, ese escaparate lo ocupa otro.',
  },
  {
    icon: 'mapPin',
    title: 'Relevancia, distancia y prominencia.',
    description:
      'Google decide quién sale en el mapa combinando tres factores: lo relevante que es tu negocio para la búsqueda, la distancia al usuario y tu <strong>reputación online</strong> (reseñas, autoridad, actividad). Los tres se trabajan con SEO local.',
  },
]

const {
  upheading = 'SEO local en Barcelona',
  heading = 'Qué es el SEO local y por qué decide quién se lleva al cliente',
  intro = 'El <strong>46 % de las búsquedas en Google tienen intención local</strong>. Cuando alguien escribe "dentista Barcelona" o "taller cerca de mí", Google muestra primero el mapa con tres resultados. Si no estás ahí, el cliente va directo a tu competencia.',
  items = defaultItems,
  mockupCaption = 'Así se ve el Local Pack de Google: <strong>3 negocios, un mapa, el 44 % de los clics.</strong>',
} = Astro.props

// Two-size Titan One split: break at ". " between statement and question
const periodIdx = heading.indexOf('. ')
const headingFirst  = periodIdx !== -1 ? heading.slice(0, periodIdx + 1) : heading
const headingSecond = periodIdx !== -1 ? heading.slice(periodIdx + 2)    : ''
---

<section class='relative overflow-hidden py-24 md:py-32'>

  <!-- Dot-grid texture -->
  <div
    class='pointer-events-none absolute inset-0'
    aria-hidden='true'
    style='background-image: radial-gradient(circle, rgba(52,101,109,0.06) 1px, transparent 1px); background-size: 28px 28px;'>
  </div>

  <!-- Titan One watermark -->
  <div
    class='pointer-events-none absolute -left-8 top-1/2 -translate-y-1/2 select-none leading-none hidden lg:block'
    aria-hidden='true'
    style='font-family: "Titan One", cursive; font-size: clamp(12rem, 24vw, 20rem); color: rgba(52,101,109,0.06); line-height: 1; white-space: nowrap;'>
    MAPA
  </div>

  <!-- Top / bottom hairlines -->
  <div class='pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-charcoal/10 to-transparent' aria-hidden='true'></div>
  <div class='pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-charcoal/10 to-transparent' aria-hidden='true'></div>

  <!-- Orange right accent bar -->
  <div
    class='pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-32 bg-teal rounded-l-full'
    aria-hidden='true'>
  </div>

  <div class='relative mx-auto max-w-[1280px] px-5'>

    <!-- ── Section header ──────────────────────────────────────────── -->
    <div class='mb-14 lg:mb-18'>
      <div data-animate class='flex items-center gap-3 mb-8'>
        <span class='block h-px w-10 bg-teal' aria-hidden='true'></span>
        <h2 class='label-section text-teal'>
          {upheading}
        </h2>
      </div>

      <p
        data-animate
        style='font-family: "Titan One", cursive;'
        class='leading-[0.95] tracking-tight text-pretty max-w-4xl'>
        {headingSecond ? (
          <>
            <span class='block text-[clamp(1.2rem,2.4vw,1.8rem)] text-charcoal/55 mb-1'>{headingFirst}</span>
            <span class='block text-[clamp(1.55rem,3.1vw,2.49rem)] text-charcoal'>{headingSecond.replace(/\?$/, '')}<span class='text-teal'>?</span></span>
          </>
        ) : (
          <span class='block text-[clamp(1.55rem,3.1vw,2.49rem)] text-charcoal'>{heading}</span>
        )}
      </p>

      <div data-animate class='mt-6 flex items-center'>
        <div class='h-[3px] w-16 bg-teal rounded-full'></div>
        <div class='h-px w-24 bg-gradient-to-r from-teal/40 to-transparent'></div>
      </div>
    </div>

    <!-- ── Items list ──────────────────────────────────────────── -->
    <div class='max-w-2xl'>
      <div>

        <p class='text-base md:text-lg text-charcoal/70 leading-relaxed mb-10 text-pretty max-w-[46ch]' data-animate>
          <Fragment set:html={intro} />
        </p>

        <ol class='flex flex-col gap-4'>
          {items.map((item, idx) => {
            const Icon = iconByKey[item.icon]
            const num  = String(idx + 1).padStart(2, '0')
            return (
              <li
                class='item-card group relative overflow-hidden rounded-2xl border border-charcoal/10 bg-white px-5 py-5 transition-all duration-300 hover:border-teal/30 hover:shadow-md hover:shadow-charcoal/5 cursor-default'
                data-animate
                data-animate-delay={idx * 110}>

                <!-- Left accent bar -->
                <div class='pointer-events-none absolute left-0 top-0 h-full w-[3px] bg-teal scale-y-0 origin-top rounded-r-full transition-transform duration-300 group-hover:scale-y-100' aria-hidden='true'></div>

                <!-- Ghost ordinal -->
                <div
                  class='pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 select-none leading-none transition-opacity duration-300'
                  aria-hidden='true'
                  style={`font-family: "Titan One", cursive; font-size: 3.8rem; color: rgba(52,101,109,0.05); line-height: 1;`}>
                  {num}
                </div>

                <div class='relative flex items-start gap-3.5'>
                  <!-- Icon badge -->
                  <div class='shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-xl bg-teal/5 ring-1 ring-teal/15 transition-all duration-300 group-hover:bg-teal/10 group-hover:ring-teal/25'>
                    <Icon class='size-4 text-teal' aria-hidden='true' />
                  </div>

                  <div class='min-w-0'>
                    <!-- Expanding underline -->
                    <div class='h-0.5 w-5 bg-teal rounded-full transition-all duration-300 group-hover:w-10 mb-2'></div>
                    <dt class='text-[0.9rem] font-bold text-charcoal leading-snug mb-1.5 transition-colors duration-300 group-hover:text-charcoal'>
                      {item.title}
                    </dt>
                    <dd class='text-base text-charcoal/70 leading-relaxed text-pretty'>
                      <Fragment set:html={item.description} />
                    </dd>
                  </div>
                </div>
              </li>
            )
          })}
        </ol>
      </div>

    </div>
  </div>
</section>
