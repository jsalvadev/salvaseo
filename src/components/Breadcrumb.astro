---
import { ChevronRight } from '@lucide/astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
  dark?: boolean
}

const { items, dark = false } = Astro.props
---

<nav aria-label='Breadcrumb' class='container-site pt-[calc(var(--navbar-height)+1rem)]'>
  <ol class={`flex items-center gap-1.5 text-sm ${dark ? 'text-white/60' : 'text-teal'}`}>
    {items.map((item, idx) => (
      <li class='flex items-center gap-1.5'>
        {idx > 0 && (
          <ChevronRight class={`size-3.5 shrink-0 ${dark ? 'text-white/30' : 'text-teal/40'}`} aria-hidden='true' />
        )}
        {item.href ? (
          <a
            href={item.href}
            class={`transition-colors ${dark ? 'hover:text-white' : 'hover:text-sage'}`}>
            {item.label}
          </a>
        ) : (
          <span class={`font-medium ${dark ? 'text-white' : 'text-cream'}`} aria-current='page'>
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
