---
import { ChevronRight } from '@lucide/astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
  dark?: boolean
}

const { items, dark = false } = Astro.props
---

<nav aria-label='Breadcrumb' class='mx-auto max-w-[1280px] px-5 pt-[calc(var(--navbar-height)+1rem)]'>
  <ol class={`flex items-center gap-1.5 text-sm ${dark ? 'text-white/60' : 'text-petrol-600'}`}>
    {items.map((item, idx) => (
      <li class='flex items-center gap-1.5'>
        {idx > 0 && (
          <ChevronRight class={`size-3.5 shrink-0 ${dark ? 'text-white/30' : 'text-petrol-300'}`} aria-hidden='true' />
        )}
        {item.href ? (
          <a
            href={item.href}
            class={`transition-colors ${dark ? 'hover:text-white' : 'hover:text-teal'}`}>
            {item.label}
          </a>
        ) : (
          <span class={`font-medium ${dark ? 'text-white' : 'text-petrol-900'}`} aria-current='page'>
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
