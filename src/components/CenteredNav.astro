---
import { siteConfig } from '../data/site'

const { contact, navigation } = siteConfig
---

<header class="absolute inset-x-0 top-0 z-50">
  <nav aria-label="Navegación principal" class="container-site flex items-center justify-between py-4">

    <!-- Left: brand -->
    <div class="hidden lg:flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 font-heading text-sm/6 font-bold tracking-widest text-cream uppercase">SALVASEO</a>
    </div>

    <!-- Mobile hamburger -->
    <div class="flex lg:hidden ml-auto">
      <button
        type="button"
        command="show-modal"
        commandfor="mobile-menu"
        class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-cream">
        <span class="sr-only">Abrir menú</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>

    <!-- Center: desktop nav links -->
    <div class="hidden lg:flex lg:gap-x-10 lg:items-center">
      {navigation.primary.slice(0, 1).map((link) => (
        <a href={link.href} class="text-sm/6 font-semibold text-cream/80 hover:text-cream">
          {link.label}
        </a>
      ))}

      <div class="relative group">
        <button type="button" class="flex items-center gap-x-1 text-sm/6 font-semibold text-cream/80 hover:text-cream">
          Servicios
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4 transition-transform duration-200">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"></path>
          </svg>
        </button>
        <div class="absolute left-0 z-10 w-64 pt-3 hidden group-hover:block">
          <div class="overflow-hidden rounded-lg bg-surface shadow-xl ring-1 ring-white/10 py-1.5">
            {navigation.services.map((service) => (
              <a href={service.href} class="flex items-center gap-3 px-4 py-2.5 text-sm text-cream/80 hover:bg-white/5 hover:text-cream">
                <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-sage"></span>
                {service.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      {navigation.primary.slice(1).map((link) => (
        <a href={link.href} class="text-sm/6 font-semibold text-cream/80 hover:text-cream">
          {link.label}
        </a>
      ))}

      <a href="/#calculadora" class="text-sm/6 font-semibold text-cream/80 hover:text-cream inline-flex items-center gap-1.5">
        Calculadora
        <span class="rounded-full bg-cream/10 px-2 py-0.5 text-xs font-semibold text-cream">Nuevo</span>
      </a>
    </div>

    <!-- Right: phone CTA -->
    <div class="hidden lg:flex lg:flex-1 lg:justify-end">
      <a href={`tel:${contact.phone.e164}`} class="inline-flex items-center gap-1.5 text-sm/6 font-semibold text-cream">
        <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        {contact.phone.display}
      </a>
    </div>
  </nav>

  <!-- Mobile menu dialog -->
  <el-dialog>
    <dialog id="mobile-menu" class="backdrop:bg-transparent lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline-none">
        <el-dialog-panel class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-base p-6 sm:max-w-sm sm:ring-1 sm:ring-white/10">
          <div class="flex items-center justify-end">
            <button
              type="button"
              command="close"
              commandfor="mobile-menu"
              class="-m-2.5 rounded-md p-2.5 text-cream">
              <span class="sr-only">Cerrar menú</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
          <div class="mt-6 flow-root">
            <div class="-my-6 divide-y divide-white/10">
              <div class="space-y-2 py-6">
                {navigation.primary.slice(0, 1).map((link) => (
                  <a href={link.href} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-cream hover:bg-white/5">
                    {link.label}
                  </a>
                ))}
                <details>
                  <summary class="-mx-3 flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 text-base/7 font-semibold text-cream hover:bg-white/5">
                    Servicios
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
                      <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"></path>
                    </svg>
                  </summary>
                  <div class="mt-1 ml-3 border-l border-white/10 pl-3 space-y-0.5">
                    {navigation.services.map((service) => (
                      <a href={service.href} class="block rounded-lg px-3 py-2 text-sm font-semibold text-cream/70 hover:bg-white/5 hover:text-cream">
                        {service.label}
                      </a>
                    ))}
                  </div>
                </details>
                {navigation.primary.slice(1).map((link) => (
                  <a href={link.href} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-cream hover:bg-white/5">
                    {link.label}
                  </a>
                ))}
                <a href="/#calculadora" class="-mx-3 flex items-center gap-2 rounded-lg px-3 py-2 text-base/7 font-semibold text-cream hover:bg-white/5">
                  Calculadora
                  <span class="rounded-full bg-cream/10 px-2 py-0.5 text-xs font-semibold text-cream">Nuevo</span>
                </a>
              </div>
              <div class="py-6">
                <a href={`tel:${contact.phone.e164}`} class="-mx-3 flex items-center gap-2.5 rounded-lg px-3 py-2.5 text-base/7 font-semibold text-cream hover:bg-white/5">
                  <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  {contact.phone.display}
                </a>
              </div>
            </div>
          </div>
        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>
