---
import { siteConfig } from '../data/site'

const { brand, contact, social, navigation, footer } = siteConfig
const currentYear = new Date().getFullYear()
---

<footer class='relative overflow-hidden bg-charcoal'>
  <!-- Sand top accent bar -->
  <div class='h-px w-full bg-gradient-to-r from-sand via-sand/60 to-transparent' aria-hidden='true'></div>

  <!-- Watermark background -->
  <div
    class='pointer-events-none absolute bottom-0 left-0 select-none overflow-hidden leading-none'
    aria-hidden='true'>
    <span
      style='font-family: "Titan One", cursive; font-size: clamp(10rem, 22vw, 19rem); color: rgba(255,255,255,0.025); line-height: 1; white-space: nowrap; display: block; transform: translateY(15%);'>
      SALVASEO
    </span>
  </div>

  <div class='relative mx-auto max-w-[1280px] px-5 pt-14 pb-0'>

    <!-- Brand statement -->
    <div class='mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between'>
      <div>
        <div class='flex items-center gap-3 mb-2'>
          <span class='block h-px w-8 shrink-0 bg-sand' aria-hidden='true'></span>
          <p class='label-section text-sand'>Consultor SEO · Barcelona</p>
        </div>
        <p style='font-family: "Titan One", cursive; font-weight: 400;' class='heading-display leading-tight text-white'>
          Tu negocio,<br>
          <span class='text-sand'>visible en Google.</span>
        </p>
        <!-- Accent rule -->
        <div class='mt-5 flex items-center'>
          <div class='h-px w-16 bg-sand'></div>
          <div class='h-px w-24 bg-gradient-to-r from-sand/40 to-transparent'></div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class='h-px w-full bg-gradient-to-r from-white/10 via-white/5 to-transparent mb-10' aria-hidden='true'></div>

    <!-- 4-column info grid -->
    <div class='grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4'>

      <!-- Col 1: Navegación -->
      <div>
        <p class='mb-5 text-xs font-semibold uppercase tracking-[0.15em] text-sand'>
          Navegación
        </p>
        <ul class='space-y-2.5'>
          {navigation.services.map((link) => (
            <li>
              <a
                href={link.href}
                class='group flex items-center gap-2.5 text-sm text-white/75 transition-all duration-200 hover:text-white focus-visible:text-white focus-visible:outline-none'>
                <span class='h-px w-3 flex-shrink-0 bg-white/20 transition-all duration-200 group-hover:w-5 group-hover:bg-sand group-focus-visible:w-5 group-focus-visible:bg-sand'></span>
                {link.label}
              </a>
            </li>
          ))}
          {navigation.primary.map((link) => (
            <li>
              <a
                href={link.href}
                class='group flex items-center gap-2.5 text-sm text-white/75 transition-all duration-200 hover:text-white focus-visible:text-white focus-visible:outline-none'>
                <span class='h-px w-3 flex-shrink-0 bg-white/20 transition-all duration-200 group-hover:w-5 group-hover:bg-sand group-focus-visible:w-5 group-focus-visible:bg-sand'></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 2: Contacto -->
      <div>
        <p class='mb-5 text-xs font-semibold uppercase tracking-[0.15em] text-sand'>
          Contacto
        </p>
        <div class='space-y-3.5'>
          <a
            href={`tel:${contact.phone.e164}`}
            class='group flex items-center gap-3 text-sm text-white/75 transition-all duration-200 hover:text-white focus-visible:text-white focus-visible:outline-none'>
            <span class='flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-base bg-white/10 transition-all duration-200 group-hover:bg-sand/20'>
              <svg class='h-3.5 w-3.5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'></path>
              </svg>
            </span>
            {contact.phone.shortDisplay}
          </a>
          <a
            href={`mailto:${contact.email}`}
            class='group flex items-center gap-3 text-sm text-white/75 transition-all duration-200 hover:text-white focus-visible:text-white focus-visible:outline-none'>
            <span class='flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-base bg-white/10 transition-all duration-200 group-hover:bg-sand/20'>
              <svg class='h-3.5 w-3.5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path>
              </svg>
            </span>
            {contact.email}
          </a>
        </div>
      </div>

      <!-- Col 3: Zona de trabajo -->
      <div>
        <p class='mb-5 text-xs font-semibold uppercase tracking-[0.15em] text-sand'>
          Zona de trabajo
        </p>
        <div class='space-y-2.5'>
          {footer.workAreas.map((area) => (
            <p class='flex items-center gap-2.5 text-sm text-white/75'>
              <span class='h-1.5 w-1.5 flex-shrink-0 rounded-full bg-sand'></span>
              {area}
            </p>
          ))}
        </div>
        <p class='mt-4 text-xs leading-relaxed text-white/40'>
          {footer.schedule[0]}
        </p>
      </div>

      <!-- Col 4: Redes sociales -->
      <div>
        <p class='mb-5 text-xs font-semibold uppercase tracking-[0.15em] text-sand'>
          Sígueme
        </p>
        <div class='space-y-2.5'>
          <a
            href={social.linkedin}
            target='_blank'
            rel='noopener noreferrer'
            class='group flex items-center gap-3 text-sm text-white/75 transition-all duration-200 hover:text-white focus-visible:text-white focus-visible:outline-none'
            aria-label='LinkedIn de Salvador Jesús'>
            <span class='flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-base bg-white/10 transition-all duration-200 group-hover:bg-sand/20'>
              <svg class='h-4 w-4' fill='currentColor' viewBox='0 0 24 24'>
                <path d='M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z'></path>
                <circle cx='4' cy='4' r='2'></circle>
              </svg>
            </span>
            LinkedIn
          </a>
          <a
            href={social.googleBusiness}
            target='_blank'
            rel='noopener noreferrer'
            class='group flex items-center gap-3 text-sm text-white/75 transition-all duration-200 hover:text-white focus-visible:text-white focus-visible:outline-none'
            aria-label='Ficha de Google Business de SalvaSEO'>
            <span class='flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-base bg-white/10 transition-all duration-200 group-hover:bg-sand/20'>
              <svg class='h-4 w-4' fill='currentColor' viewBox='0 0 24 24'>
                <path d='M12 10.2v3.9h5.5c-.2 1.2-1.5 3.5-5.5 3.5-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.1.8 4 1.6l2.9-2.9C17.2 2.7 14.8 1.8 12 1.8 6.3 1.8 1.8 6.3 1.8 12S6.3 22.2 12 22.2c6 0 9.9-4.2 9.9-10.1 0-.7-.1-1.2-.2-1.9H12z'></path>
              </svg>
            </span>
            Google
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class='mt-12 flex flex-col items-center gap-3 border-t border-white/10 py-6 sm:flex-row sm:justify-between'>
      <p class='text-xs text-white/40'>
        &copy; {currentYear} {brand.fullName}
      </p>
      <nav class='flex flex-wrap justify-center gap-x-5 gap-y-1' aria-label='Aviso legal'>
        {navigation.legal.map((link) => (
          <a
            href={link.href}
            class='text-xs text-white/40 underline-offset-2 transition-colors duration-200 hover:text-white hover:underline focus-visible:text-white focus-visible:outline-none'>
            {link.label}
          </a>
        ))}
        <a
          href='https://salvaseo.com/sitemap-index.xml'
          class='text-xs text-white/40 underline-offset-2 transition-colors duration-200 hover:text-white hover:underline focus-visible:text-white focus-visible:outline-none'>
          Sitemap
        </a>
      </nav>
    </div>
  </div>
</footer>
