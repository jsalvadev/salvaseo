---
import Layout from '../layouts/Layout.astro'
import presupuestoHeroImage from '../assets/presupuesto-hero.jpg'
import Hero from '../components/pages/presupuesto-seo-barcelona/Hero.astro'
import PricingCards from '../components/pages/presupuesto-seo-barcelona/PricingCards.astro'
import FeatureComparison from '../components/pages/presupuesto-seo-barcelona/FeatureComparison.astro'
import Faq from '../components/pages/posicionamiento-web-barcelona/Faq.astro'
import TrustBanner from '../components/pages/posicionamiento-web-barcelona/TrustBanner.astro'
import Cta from '../components/pages/presupuesto-seo-barcelona/Cta.astro'
import { faqPresupuestoItems } from '../data/faq-presupuesto'

const DATE_MODIFIED = "2026-03-03"
---

<Layout
  title='Presupuesto SEO Barcelona — Precio, Tarifas y Paquetes Mensuales | SalvaSEO'
  description='Presupuesto SEO en Barcelona desde 350 €/mes + IVA. Paquetes mensuales para Google Maps, posicionamiento web o ambos. Precio cerrado tras diagnóstico inicial.'
  canonicalUrl='https://salvaseo.com/presupuesto-seo-barcelona/'
  preloadImageHref={presupuestoHeroImage.src}>
  <!-- 1. HERO -->
  <Hero
    upheading='Presupuesto SEO en Barcelona'
    heading='Tu negocio merece más visibilidad'
    description='Escala posiciones en Google desde 350€/mes. Incluimos diagnóstico inicial gratuito para trazar tu hoja de ruta.'
    primaryCtaText='Solicita tu diagnóstico gratuito'
    secondaryCtaText='Ver paquetes y precios'
    secondaryCtaHref='#paquetes'
  />

  <!-- 1b. TRUST SIGNALS -->
  <TrustBanner
    items={[
      { icon: 'users', value: 'Ejecución directa', label: 'comunicación con quien implementa' },
      {
        icon: 'badgeCheck',
        value: 'Diagnóstico incluido',
        label: 'antes de cualquier inversión'
      },
      {
        icon: 'calendarClock',
        value: 'Contratación mensual',
        label: 'el compromiso se renueva con resultados'
      },
      {
        icon: 'trendingUp',
        value: 'Tracción en 3-6 meses',
        label: 'según sector y competencia'
      }
    ]}
  />

  <!-- 2. PRICING CARDS -->
  <PricingCards />

  <!-- 3. FEATURE COMPARISON -->
  <FeatureComparison />

  <!-- 4. FAQ -->
  <Faq
    upheading='Preguntas frecuentes sobre presupuesto y precio SEO'
    heading=''
    idPrefix='faq-precios'
    items={faqPresupuestoItems}
    class='!bg-white'
  />

  <!-- 5. CTA FINAL -->
  <Cta />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#webpage',
          url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
          name: 'Presupuesto SEO Barcelona — Precio, Tarifas y Paquetes Mensuales | SalvaSEO',
          description:
            'Presupuesto SEO en Barcelona desde 350 €/mes + IVA. Paquetes mensuales para Google Maps, posicionamiento web o ambos. Precio cerrado tras diagnóstico inicial.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          datePublished: '2026-02-28',
          dateModified: DATE_MODIFIED,
          author: {
            '@id': 'https://salvaseo.com/#founder'
          },
          inLanguage: 'es',
          breadcrumb: {
            '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#breadcrumb'
          }
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#breadcrumb',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Inicio',
              item: 'https://salvaseo.com/'
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Presupuesto SEO Barcelona',
              item: 'https://salvaseo.com/presupuesto-seo-barcelona/'
            }
          ]
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#service',
          serviceType: 'Consultoría SEO',
          name: 'Presupuesto SEO en Barcelona',
          description:
            'Paquetes mensuales de consultoría SEO para negocios locales en Barcelona. Ficha de Google, posicionamiento web o ambos con descuento. Contratación mensual flexible.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: {
            '@type': 'City',
            name: 'Barcelona',
            sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
          },
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Paquetes SEO Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                name: 'Solo Ficha',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
                description:
                  'Optimización de Google Business Profile: auditoría local, directorios NAP, publicaciones y gestión de reseñas.',
                priceSpecification: {
                  '@type': 'UnitPriceSpecification',
                  priceCurrency: 'EUR',
                  price: '350',
                  unitText: 'mes'
                }
              },
              {
                '@type': 'Offer',
                name: 'Solo Web',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
                description:
                  'Posicionamiento web: auditoría SEO, palabras clave transaccionales, páginas de servicio, Core Web Vitals y schema markup.',
                priceSpecification: {
                  '@type': 'UnitPriceSpecification',
                  priceCurrency: 'EUR',
                  price: '550',
                  unitText: 'mes'
                }
              },
              {
                '@type': 'Offer',
                name: 'Ficha + Web',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
                description:
                  'Paquete completo: Google Business Profile + posicionamiento web con análisis cruzado, enlazado interno y seguimiento unificado. Descuento de 100 €/mes.',
                priceSpecification: {
                  '@type': 'UnitPriceSpecification',
                  priceCurrency: 'EUR',
                  price: '800',
                  unitText: 'mes'
                }
              }
            ]
          }
        }
      ]
    })}
  />
</Layout>
