          }
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#breadcrumb',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Inicio',
              item: 'https://salvaseo.com/'
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Presupuesto SEO Barcelona',
              item: 'https://salvaseo.com/presupuesto-seo-barcelona/'
            }
          ]
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#service',
          serviceType: 'Consultoría SEO',
          name: 'Presupuesto SEO en Barcelona',
          description:
            'Paquetes mensuales de consultoría SEO para negocios locales en Barcelona. Ficha de Google, posicionamiento web o ambos con descuento. Contratación mensual flexible.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: [
            {
              '@type': 'City',
              name: 'Barcelona',
              sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
            },
            {
              '@type': 'AdministrativeArea',
              name: 'Area Metropolitana de Barcelona'
            }
          ],
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Paquetes SEO Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                name: 'Visibilidad Local',
                price: '350',
                priceCurrency: 'EUR',
                availability: 'https://schema.org/InStock',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Local Google Maps',
                  description:
                    'Optimizacion de Google Business Profile, auditoria local, directorios NAP y gestion de reseñas. Desde 350 euros/mes.'
                }
              },
              {
                '@type': 'Offer',
                name: 'Visibilidad Total',
                price: '550',
                priceCurrency: 'EUR',
                availability: 'https://schema.org/InStock',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Local y Posicionamiento Web',
                  description:
                    'Posicionamiento web completo: auditoria SEO, palabras clave, paginas de servicio, Google Business Profile y Core Web Vitals. Desde 550 euros/mes.'
