---
import Layout from '../layouts/Layout.astro'
import presupuestoHeroImage from '../assets/presupuesto-hero.jpg'
import Hero from '../components/pages/presupuesto-seo-barcelona/Hero.astro'
import PricingCards from '../components/pages/presupuesto-seo-barcelona/PricingCards.astro'
import FeatureComparison from '../components/pages/presupuesto-seo-barcelona/FeatureComparison.astro'
import Faq from '../components/pages/home/Faq.astro'
import { faqPresupuestoItems } from '../data/faq-presupuesto'
const DATE_MODIFIED = "2026-03-03"
---

<Layout
  title='Presupuesto SEO Barcelona [2026]: 2 paquetes desde 350 €/mes · Sin permanencia'
  description='Desde 350 €/mes hasta 550 €/mes + IVA. Compara 2 paquetes SEO para Barcelona, sin permanencia y con diagnóstico previo gratuito. Llama al 692 051 399.'
  canonicalUrl='https://salvaseo.com/presupuesto-seo-barcelona/'
  preloadImageHref={presupuestoHeroImage.src}>
  <!-- 1. HERO -->
  <Hero
    upheading='Presupuesto SEO en Barcelona'
    heading='Tu negocio merece más visibilidad'
    description='Estar en la sombra en una ciudad como Barcelona tiene un precio demasiado alto en ventas perdidas. Ser invisible te está saliendo caro hoy mismo. Elige tu estrategia y deja de regalarle mercado a tu competencia.'
    primaryCtaText='Analiza mi web'
    secondaryCtaText='Ver paquetes y precios'
    secondaryCtaHref='#paquetes'
    breadcrumbItems={[{ label: 'Inicio', href: '/' }, { label: 'Presupuesto SEO Barcelona' }]}
  />

  <!-- 2. PRICING CARDS -->
  <PricingCards />

  <!-- 3. FEATURE COMPARISON -->
  <FeatureComparison />

  <!-- 4. FAQ -->
  <Faq
    upheading='Preguntas frecuentes sobre presupuesto y precio SEO'
    heading='Tus dudas sobre precios'
    idPrefix='faq-precios'
    items={faqPresupuestoItems}
    upheadingColor='var(--color-teal)'
  />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#webpage',
          url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
          name: 'Presupuesto SEO Barcelona — Precio, Tarifas y Paquetes Mensuales | SalvaSEO',
          description:
            'Presupuesto SEO en Barcelona desde 350 €/mes + IVA. Paquetes mensuales para Google Maps, posicionamiento web o ambos. Precio cerrado tras diagnóstico inicial.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          datePublished: '2026-02-28',
          dateModified: DATE_MODIFIED,
          author: {
            '@id': 'https://salvaseo.com/#founder'
          },
          inLanguage: 'es',
          breadcrumb: {
            '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#breadcrumb'
          }
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#breadcrumb',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Inicio',
              item: 'https://salvaseo.com/'
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Presupuesto SEO Barcelona',
              item: 'https://salvaseo.com/presupuesto-seo-barcelona/'
            }
          ]
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#service',
          serviceType: 'Consultoría SEO',
          name: 'Presupuesto SEO en Barcelona',
          description:
            'Paquetes mensuales de consultoría SEO para negocios locales en Barcelona. Ficha de Google, posicionamiento web o ambos con descuento. Contratación mensual flexible.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: {
            '@type': 'City',
            name: 'Barcelona',
            sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
          },
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Paquetes SEO Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                name: 'Visibilidad Local',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
                description:
                  'Optimización de Google Business Profile: auditoría local, directorios NAP, publicaciones y gestión de reseñas.',
                priceSpecification: {
                  '@type': 'UnitPriceSpecification',
                  priceCurrency: 'EUR',
                  price: '350',
                  unitText: 'mes'
                }
              },
              {
                '@type': 'Offer',
                name: 'Visibilidad Total',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/presupuesto-seo-barcelona/',
                description:
                  'Posicionamiento web completo: auditoría SEO, palabras clave transaccionales, páginas de servicio, Google Business Profile, Core Web Vitals y schema markup.',
                priceSpecification: {
                  '@type': 'UnitPriceSpecification',
                  priceCurrency: 'EUR',
                  price: '550',
                  unitText: 'mes'
                }
              }
            ]
          }
        }
      ]
    })}
  />
</Layout>
