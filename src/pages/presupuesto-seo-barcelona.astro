---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/pages/presupuesto-seo-barcelona/Hero.astro'
import PricingCards from '../components/pages/presupuesto-seo-barcelona/PricingCards.astro'
import FeatureComparison from '../components/pages/presupuesto-seo-barcelona/FeatureComparison.astro'
import Faq from '../components/pages/home/Faq.astro'

const DATE_MODIFIED = "2026-03-03"

const faqPresupuestoItems = [
  {
    question: '¿Qué incluye el diagnóstico inicial?',
    answer: `<p class="text-base/7 text-surface">Análisis de tu ficha de Google Business Profile, tu web y la competencia directa en tu zona de Barcelona. El resultado es un informe con oportunidades concretas y un <strong>presupuesto SEO local</strong> basado en datos reales de tu mercado — incluido el coste estimado de posicionamiento en Google para tu sector.</p>`,
  },
  {
    question: '¿Cuánto cuesta un servicio SEO en Barcelona?',
    answer: `<p class="text-base/7 text-surface">Hay dos planes con precio fijo, IVA incluido. El <strong>Plan Visibilidad Local</strong> (<a href="/seo-local-barcelona/" class="text-sage font-medium hover:text-sage/80 underline decoration-sage/30 underline-offset-2 transition-colors">SEO local en Google Maps</a>) son <strong>350 €/mes</strong>. El <strong>Plan Visibilidad Total</strong> (<a href="/posicionamiento-web-barcelona/" class="text-sage font-medium hover:text-sage/80 underline decoration-sage/30 underline-offset-2 transition-colors">posicionamiento web</a> + Google Maps) son <strong>550 €/mes</strong>. El diagnóstico inicial gratuito ayuda a identificar qué plan encaja mejor con tu negocio.</p>`,
  },
  {
    question: '¿Hay permanencia o compromiso contractual?',
    answer: `<p class="text-base/7 text-surface">La contratación es mensual. Cada presupuesto de posicionamiento SEO tiene un <strong>periodo mínimo recomendado</strong> (3 a 6 meses según el servicio) porque la estrategia SEO necesita tiempo para consolidar tracción, pero no es una obligación contractual.</p>`,
  },
  {
    question: '¿Qué pasa si necesito un presupuesto SEO personalizado?',
    answer: `<p class="text-base/7 text-surface">Cada paquete admite configuración a medida. Contenido adicional, una landing page nueva, consultoría SEO puntual, diseño web o cualquier acción extra se evalúa en la llamada de seguimiento y se presupuesta como <strong>complemento específico</strong>.</p>`,
  },
  {
    question: '¿Cuándo voy a ver resultados?',
    answer: `<p class="text-base/7 text-surface">Los primeros indicadores de tracción suelen aparecer entre <strong>1 y 3 meses</strong>: mejoras en Google Maps, primeras posiciones orgánicas y aumento de tráfico cualificado. La consolidación con llamadas y solicitudes de presupuesto recurrentes se valida entre los <strong>4 y 6 meses</strong>, según la competencia del sector en Barcelona.</p>`,
  },
  {
    question: '¿Se puede cambiar de plan?',
    answer: `<p class="text-base/7 text-surface">Sí. Es posible empezar con el <strong>Plan Visibilidad Local</strong> (solo Google Maps) y <strong>pasar al Plan Visibilidad Total</strong> cuando tenga sentido. El cambio se hace al inicio del siguiente mes, sin coste adicional ni trámite.</p>`,
  },
  {
    question: '¿Los precios incluyen IVA?',
    answer: `<p class="text-base/7 text-surface">No. Los <strong>350 €/mes y 550 €/mes son precios sin IVA</strong>. El IVA (21%) se añade en factura. Sin costes ocultos ni conceptos adicionales.</p>`,
  },
  {
    question: '¿Por qué el precio del SEO es mensual y no por acciones sueltas?',
    answer: `<p class="text-base/7 text-surface">El posicionamiento SEO es una <strong>estrategia acumulativa</strong>: cada mes se implementan optimizaciones de contenidos, enlaces y autoridad que construyen sobre las anteriores. Una intervención puntual puede generar tracción inicial, pero sin continuidad los resultados se diluyen. El precio SEO mensual refleja esa realidad — es la vía más efectiva para escalar posiciones en Google y mantenerlas.</p>`,
  },
]
---

<Layout
  title='Presupuesto SEO Barcelona [2026]: 2 paquetes desde 350 €/mes · Sin permanencia'
  description='Desde 350 €/mes hasta 550 €/mes + IVA. Compara 2 paquetes SEO para Barcelona, sin permanencia y con diagnóstico previo gratuito. Llama al 692 051 399.'
  canonicalUrl='https://salvaseo.com/presupuesto-seo-barcelona/'
>
  <!-- 1. HERO -->

  <!-- 2. PRICING CARDS -->
  <PricingCards />

  <!-- 3. FEATURE COMPARISON -->
  <FeatureComparison />

  <!-- 4. FAQ -->
  <Faq
    upheading='Preguntas frecuentes sobre presupuesto y precio SEO'
    heading='Tus dudas sobre precios'
    idPrefix='faq-precios'
    items={faqPresupuestoItems}
  />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/presupuesto-seo-barcelona/#webpage',
