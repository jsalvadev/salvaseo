      { icon: 'barChart3', emphasis: 'Demanda local real.', text: 'Las búsquedas geolocalizadas con mayor potencial de captación en tu mercado.' },
      { icon: 'badgeCheck', emphasis: 'Bloqueos identificados.', text: 'Los fallos de ficha, NAP y web que hoy frenan tu visibilidad en Maps.' },
    ],
