      },
      {
        name: 'Seguimiento y reporting',
        features: [
          { text: 'Informe mensual de posiciones, tráfico y conversiones', included: true },
          { text: 'Seguimiento de llamadas y formularios por zona', included: true },
          { text: 'Acceso directo al consultor (sin intermediarios)', included: true },
          { text: 'Ajuste continuo de estrategia según resultados', included: true },
        ]
      },
    ]}
    quote='La visibilidad local solo cuenta cuando se traduce en clientes, llamadas y facturación.'
    quoteAuthor='— Salvador Jesús, Consultor SEO Local en Barcelona'
  />

