            'Servicio profesional de SEO local para negocios en Barcelona. Optimización de Google Business Profile, posicionamiento en Google Maps, gestión de reseñas y estrategia de visibilidad local. Sin contratos de permanencia.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: {
            '@type': 'City',
            name: 'Barcelona',
            sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
          },
          offers: {
            '@type': 'Offer',
            priceSpecification: {
              '@type': 'UnitPriceSpecification',
              priceCurrency: 'EUR',
              price: String(MIN_MONTHLY_PRICE_EUR),
