        name: 'Autoridad y reputación',
        features: [
          { text: 'Gestión de citaciones NAP en directorios clave', included: true },
          { text: 'Estrategia de captación de reseñas', included: true },
          { text: 'Link building local y menciones de zona', included: true },
          { text: 'Respuesta activa a opiniones en Google', included: true },
