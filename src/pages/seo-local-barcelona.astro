---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/pages/seo-local-barcelona/Hero.astro'
import CalButton from '../components/CalButton.astro'
import localPackImg from '../assets/local-pack-fontanero-barcelona.avif'
import LocalSeoExplainer from '../components/pages/seo-local-barcelona/Explainer.astro'
import LocalSeoServices from '../components/pages/seo-local-barcelona/Services.astro'
import Timeline from '../components/pages/seo-local-barcelona/Timeline.astro'
import LocalSeoVsAds from '../components/pages/seo-local-barcelona/VsAds.astro'
import LocalBusinessTypes from '../components/pages/seo-local-barcelona/BusinessTypes.astro'
import Faq from '../components/shared/Faq.astro'
import LocalSeoCta from '../components/pages/seo-local-barcelona/Cta.astro'
import RelatedServices from '../components/shared/RelatedServices.astro'
import type { RelatedCard } from '../components/shared/RelatedServices.astro'
import GoogleMapEmbed from '../components/shared/GoogleMapEmbed.astro'
import { faqSeoLocalItems } from '../data/faqs'
import {
  seoLocalExplainerItems,
  seoLocalServices,
  seoLocalTimelinePhases,
  seoLocalVsAdsLeftColumn,
  seoLocalVsAdsRightColumn,
  seoLocalBusinessTypes,
} from '../data/seo-local'

const DATE_MODIFIED = new Date().toISOString().split('T')[0]

const relatedCards: RelatedCard[] = [
  {
    iconKey: 'globe',
    label: 'Visibilidad en buscadores',
    title: 'Posicionamiento Web en Barcelona',
    description: 'Más allá de Google Maps, haz que tu web aparezca en los resultados orgánicos cuando tus clientes buscan tus servicios. Auditoría, estrategia on page y off page para escalar posiciones.',
    href: '/posicionamiento-web-barcelona/',
    cta: 'Ver posicionamiento web',
    ordinal: '01',
  },
  {
    iconKey: 'receipt',
    label: 'Tarifas y paquetes',
    title: 'Presupuesto SEO Barcelona',
    description: 'Dos paquetes con precio fijo mensual, sin permanencia. Consulta qué incluye cada plan y elige la inversión que se ajusta al tamaño y objetivos de tu negocio.',
    href: '/presupuesto-seo-barcelona/',
    cta: 'Ver precios',
    ordinal: '02',
  },
]

---

<Layout
  title='SEO Local en Barcelona desde 350 €/mes - SalvaSEO'
  description='SEO local en Barcelona. Optimizacion de tu ficha de Google Maps para aparecer en primeras posiciones. Desde 350 euros/mes sin permanencia.'
  canonicalUrl='https://salvaseo.com/seo-local-barcelona/'
  preloadImageHref={localPackImg.src}
>

  <!-- 1. HERO -->
  <Hero
    preheader='CONSULTOR SEO LOCAL EN BARCELONA'
    h1='Cuando alguien busca tu oficio en Barcelona, que te llamen a ti.'
    description='Ahora mismo hay gente en Barcelona buscando en Google Maps un fontanero, un cerrajero, un pintor. Alguien recibe esa llamada. Puede ser tú. <strong>Tu cliente ya está buscando ahora mismo.</strong>'
    image={localPackImg}
    imageAlt='Resultados del Local Pack de Google para "fontanero urgente barcelona"'
    imageCaption='Captura real de Google · Local Pack para "fontanero urgente barcelona"'
  >
    <CalButton slot='cta' color='cream' text='Agenda una llamada gratis' />
  </Hero>

  <!-- 2. QUÉ ES EL SEO LOCAL -->
  <LocalSeoExplainer
    upheading='Consultoría SEO local'
    heading='Google muestra el mapa antes que los resultados web.'
    intro='Cuando alguien busca en Google Maps, aparecen tres negocios antes que cualquier web. O estás en esos tres, o ese cliente llama a otro.'
    items={seoLocalExplainerItems}
    mockupCaption='Así se ve el Local Pack de Google: <strong>3 negocios, un mapa, el 44 % de los clics.</strong>'
  />

  <!-- 3. SERVICIOS DE SEO LOCAL -->
  <LocalSeoServices
    upheading='Servicios de SEO local en Barcelona'
    heading='Lo que hago para que aparezcas en Google Maps.'
    services={seoLocalServices}
    ctaText='Descubre qué incluye cada plan'
    ctaHref='/presupuesto-seo-barcelona/#paquetes'
  />

  <!-- 4. PROCESO / TIMELINE -->
  <Timeline
    upheading='Posicionamiento web local en Barcelona'
    heading='De no aparecer en el mapa a recibir llamadas cada semana'
    subtitle='Trabajo en cuatro fases. Cada una tiene un objetivo concreto y al final de cada mes ves exactamente qué ha cambiado.'
    phases={seoLocalTimelinePhases}
    ctaHeading='Tus clientes ya te buscan, descubre si te encuentran'
    ctaText='Miro gratis tu ficha de Google Maps y tu web y te digo por qué no te están llamando.'
    ctaLabel='Analiza mi web'
  />

  <!-- 5. TIPOS DE NEGOCIO -->
  <LocalBusinessTypes
    upheading='SEO local para negocios en Barcelona'
    heading='Tu negocio ya tiene clientes buscándolo.'
    intro='Si alguien en Barcelona busca en Google tu oficio, ya hay demanda real. Solo falta que aparezcas tú. Esto funciona en casi cualquier negocio local.'
    businessTypes={seoLocalBusinessTypes}
  />

  <!-- 6. SEO LOCAL vs GOOGLE ADS -->
  <LocalSeoVsAds
    upheading='SEO local vs Google Ads'
    heading='Pagar cada vez que te llaman o que te llamen solos.'
    intro='Las dos opciones traen clientes. La diferencia es qué pasa cuando paras de pagar.'
    leftColumn={seoLocalVsAdsLeftColumn}
    rightColumn={seoLocalVsAdsRightColumn}
    conclusion='Lo más habitual para un autónomo en Barcelona: empezar con SEO local como base y usar Google Ads solo si necesitas clientes esta semana mientras el SEO arranca.'
  />

  <!-- 8. FAQs -->
  <Faq
    upheading='CONSULTORIA SEO LOCAL EN BARCELONA'
    heading='¿El SEO local funciona para tu negocio?'
    idPrefix='faq-local'
    items={faqSeoLocalItems}
  />

  <!-- 9. MAPA -->
  <GoogleMapEmbed ariaLabelledbyId='mapa-seo-local-barcelona' />

  <!-- 10. RELATED SERVICES -->
  <RelatedServices
    upheading='MÁS SERVICIOS SEO EN BARCELONA'
    heading='Completa tu estrategia SEO'
    cards={relatedCards}
  />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/seo-local-barcelona/#webpage',
          url: 'https://salvaseo.com/seo-local-barcelona/',
          name: 'SEO Local en Barcelona | Consultor SEO Local — Más Clientes desde Google Maps | SalvaSEO',
          description:
            'Servicio de SEO local en Barcelona: estrategia de posicionamiento local para que tu negocio aparezca en los primeros resultados de Google Maps. Consultor SEO local especializado en captar clientes potenciales y tráfico cualificado.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          about: {
            '@id': 'https://salvaseo.com/seo-local-barcelona/#service'
          },
          datePublished: '2025-02-24',
          dateModified: DATE_MODIFIED,
          author: {
            '@id': 'https://salvaseo.com/#founder'
          },
          mainEntity: {
            '@id': 'https://salvaseo.com/seo-local-barcelona/#service'
          },
          inLanguage: 'es'
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/seo-local-barcelona/#service',
          serviceType: 'SEO Local',
          name: 'SEO Local en Barcelona',
          description:
            'Servicio profesional de SEO local para negocios locales en Barcelona. Consultoría SEO local: optimización de Google Business Profile, posicionamiento en Google Maps, gestión de reseñas, investigación de palabras clave locales y estrategia orientada a captación de clientes potenciales y retorno de inversión.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: [
            {
              '@type': 'City',
              name: 'Barcelona',
              sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
            },
            {
              '@type': 'AdministrativeArea',
              name: 'Area Metropolitana de Barcelona'
            }
          ],
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Servicios de SEO Local en Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                price: '350',
                priceCurrency: 'EUR',
                availability: 'https://schema.org/InStock',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Local en Google Maps',
                  description:
                    'Optimizacion completa de tu ficha de Google Maps para aparecer en primeras posiciones. Desde 350 euros/mes.'
                }
              },
              {
                '@type': 'Offer',
                price: '550',
                priceCurrency: 'EUR',
                availability: 'https://schema.org/InStock',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Local y Posicionamiento Web',
                  description:
                    'SEO local + posicionamiento web para negocios en Barcelona. Fichas de Google Maps y web optimizadas. Desde 550 euros/mes.'
                }
              }
            ]
          }
        }
      ]
    })}
  />
</Layout>
