        ]
      },
      {
        name: 'Autoridad y reputación',
        features: [
          { text: 'Gestión de citaciones NAP en directorios clave', included: true },
          { text: 'Estrategia de captación de reseñas', included: true },
          { text: 'Link building local y menciones de zona', included: true },
          { text: 'Respuesta activa a opiniones en Google', included: true },
        ]
      },
      {
        name: 'Seguimiento y reporting',
        features: [
          { text: 'Informe mensual de posiciones, tráfico y conversiones', included: true },
          { text: 'Seguimiento de llamadas y formularios por zona', included: true },
          { text: 'Canal directo de comunicación y decisiones sin intermediarios', included: true },
          { text: 'Ajuste continuo de estrategia según resultados', included: true },
        ]
      },
    ]}
    quote='La visibilidad local solo cuenta cuando se traduce en clientes, llamadas y facturación.'
    quoteAuthor='— Salvador Jesús, Consultor SEO Local en Barcelona'
  />

  <!-- 8. FAQs -->
  <LocalSeoFaq
    upheading='FAQ SEO local en Barcelona'
    heading='Todavía tienes dudas — aquí van las respuestas'
    intro='Si operas un negocio físico en Barcelona, estas respuestas te ayudan a validar plazos, potencial de captación y retorno del SEO local.'
