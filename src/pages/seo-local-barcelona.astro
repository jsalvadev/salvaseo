const seoLocalTimelinePhases = [
  {
    title: 'Auditoría local y diagnóstico inicial',
    intro:
      'Analizamos tu ficha, tu web y tu mercado para detectar por qué no apareces cuando tus clientes buscan en tu zona.',
    bullets: [
      { icon: 'scale', emphasis: 'Evalúa tu punto de partida.', text: 'Compara tu visibilidad actual frente a negocios de tu mismo barrio o ciudad.' },
      { icon: 'barChart3', emphasis: 'Mide demanda local real.', text: 'Detecta qué búsquedas geolocalizadas tienen potencial de captación.' },
      { icon: 'badgeCheck', emphasis: 'Detecta bloqueos críticos.', text: 'Encuentra fallos de ficha, NAP y web que frenan tu posicionamiento.' },
    ],
    outro: 'Obtienes una hoja de ruta priorizada para saber qué acciones impactan antes en Maps.'
  },
  {
    title: 'Optimización de Google Business Profile',
    intro:
      'Trabajamos tu perfil para aumentar relevancia, confianza y conversiones en búsquedas con intención inmediata.',
    bullets: [
      { icon: 'target', emphasis: 'Afina categorías y servicios.', text: 'Define el encaje exacto con lo que busca tu cliente en Google.' },
      { icon: 'calendarClock', emphasis: 'Activa señales de frescura.', text: 'Planifica publicaciones, fotos y actualizaciones con frecuencia realista.' },
      { icon: 'trendingUp', emphasis: 'Mejora interacción.', text: 'Optimiza descripción, llamadas y elementos que elevan clics y contactos.' },
