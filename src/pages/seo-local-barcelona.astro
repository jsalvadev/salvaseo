const MIN_MONTHLY_PRICE_EUR = 350
const MIN_MONTHLY_PRICE_TEXT = `${MIN_MONTHLY_PRICE_EUR} €/mes`
const DATE_MODIFIED = new Date().toISOString().split('T')[0]
const seoLocalExplainerItems = [
