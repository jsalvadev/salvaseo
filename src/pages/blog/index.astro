---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const blogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': 'https://salvaseo.com/blog/#blog',
      'name': 'Blog SEO | SalvaSEO',
      'description': 'Respuestas a las preguntas más frecuentes sobre SEO. Consejos prácticos para negocios locales en Barcelona.',
      'url': 'https://salvaseo.com/blog/',
      'publisher': { '@id': 'https://salvaseo.com/#business' },
      'inLanguage': 'es',
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': 'https://salvaseo.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog SEO', 'item': 'https://salvaseo.com/blog/' },
      ],
    },
  ],
};
---

<Layout
  title="Blog SEO · SalvaSEO — Consultor SEO en Barcelona"
  description="Consejos prácticos de SEO para autónomos y negocios locales. Sin tecnicismos. Todo lo que necesitas saber para que tus clientes te encuentren en Google."
  canonicalUrl="https://salvaseo.com/blog/"
  darkNav={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <!-- ── Dark hero header ─────────────────────────────────── -->
  <header class="blog-hero">
    <div class="hero-inner">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span>Blog SEO</span>
      </nav>

      <div class="hero-display">
        <span class="hero-watermark" aria-hidden="true">BLOG SEO</span>
        <div class="hero-text">
          <h1>Blog SEO</h1>
          <p class="hero-subtitle">
            Consejos prácticos de posicionamiento web<br />
            para negocios locales en Barcelona.
          </p>
          <p class="hero-count">{posts.length} artículos</p>
        </div>
      </div>
    </div>
  </header>

  <!-- ── Articles list ────────────────────────────────────── -->
  <section class="articles-section">
    <div class="articles-inner">
      {posts.length === 0 ? (
        <p class="no-posts">No hay artículos todavía.</p>
      ) : (
        <ol class="post-list">
          {posts.map((post, i) => {
            const num = String(i + 1).padStart(2, '0');
            const dateFormatted = post.data.pubDate.toLocaleDateString('es-ES', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            });
            const delay = `${i * 80}ms`;
            return (
              <li class="post-item" style={`animation-delay: ${delay}`}>
                <a href={`/blog/${post.slug}/`} class="post-link" aria-label={post.data.title}>
                  <article class="post-card">
                    <span class="post-num" aria-hidden="true">{num}</span>

                    <div class="post-body">
                      <div class="post-meta">
                        <div class="post-tags">
                          {(post.data.tags ?? []).slice(0, 2).map((tag: string) => (
                            <span class="post-tag">{tag}</span>
                          ))}
                        </div>
                        <div class="post-meta-right">
                          <time datetime={post.data.pubDate.toISOString()} class="post-date">
                            {dateFormatted}
                          </time>
                          {post.data.readingTime && (
                            <span class="post-time">{post.data.readingTime} min</span>
                          )}
                        </div>
                      </div>

                      <h2 class="post-title">{post.data.title}</h2>
                      <p class="post-desc">{post.data.description}</p>

                      <span class="post-cta">
                        Leer artículo
                        <span class="post-arrow" aria-hidden="true">→</span>
                      </span>
                    </div>
                  </article>
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </div>
  </section>
</Layout>

<style>
  /* ── Hero header ─────────────────────────────────────────── */
  .blog-hero {
    background: var(--color-base);
    position: relative;
    overflow: hidden;
    padding-block: 8rem 5rem;
  }

  .blog-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(236, 223, 204, 0.032) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* Breadcrumb */
  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    margin-bottom: 3rem;
    animation: fadeSlideUp 0.5s ease both;
  }

  .hero-breadcrumb a {
    color: var(--color-sage);
    text-decoration: none;
    transition: color 0.15s;
    opacity: 0.7;
  }

  .hero-breadcrumb a:hover {
    opacity: 1;
  }

  .hero-breadcrumb span:last-child {
    opacity: 1;
  }

  .hero-breadcrumb span:not(:last-child) {
    opacity: 0.4;
    font-size: 0.8rem;
    font-weight: 400;
  }

  /* Watermark + text stack */
  .hero-display {
    position: relative;
  }

  .hero-watermark {
    position: absolute;
    top: 50%;
    left: -0.5rem;
    transform: translateY(-50%);
    font-family: var(--font-heading);
    font-size: clamp(5rem, 18vw, 11rem);
    line-height: 1;
    color: rgba(236, 223, 204, 0.06);
    letter-spacing: -0.02em;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  .hero-text {
    position: relative;
    z-index: 1;
    animation: fadeSlideUp 0.6s ease 0.1s both;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 1.08;
    color: var(--color-cream);
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(236, 223, 204, 0.55);
    margin-bottom: 2.5rem;
  }

  .hero-count {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    border: 1px solid rgba(105, 117, 101, 0.35);
    padding: 0.3rem 0.85rem;
    border-radius: 99px;
    animation: fadeSlideUp 0.6s ease 0.18s both;
  }

  /* ── Articles section ────────────────────────────────────── */
  .articles-section {
    background: var(--color-cream);
    padding-block: 0 5rem;
  }

  .articles-inner {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .no-posts {
    padding-top: 4rem;
    font-size: var(--text-sm);
    color: var(--color-sage);
  }

  /* Post list */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    opacity: 0;
    animation: fadeSlideUp 0.55s ease both;
  }

  /* Each post link wraps the whole card */
  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card {
    position: relative;
    padding-block: 3rem;
    border-top: 1px solid rgba(105, 117, 101, 0.18);
    transition: border-color 0.2s;
  }

  .post-link:hover .post-card {
    border-color: rgba(105, 117, 101, 0.4);
  }

  /* Decorative number */
  .post-num {
    position: absolute;
    top: 2rem;
    right: 0;
    font-family: var(--font-heading);
    font-size: clamp(4rem, 10vw, 7rem);
    line-height: 1;
    color: rgba(105, 117, 101, 0.1);
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
    transition: color 0.2s;
  }

  .post-link:hover .post-num {
    color: rgba(105, 117, 101, 0.18);
  }

  @media (max-width: 639px) {
    .hero-watermark,
    .post-num {
      display: none;
    }
  }

  .post-body {
    position: relative;
    z-index: 1;
    max-width: 560px;
  }

  /* Meta row */
  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .post-tag {
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    border: 1px solid rgba(105, 117, 101, 0.35);
    padding: 0.18rem 0.55rem;
    border-radius: 99px;
  }

  .post-meta-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .post-date {
    font-size: 0.72rem;
    color: rgba(60, 61, 55, 0.55);
    letter-spacing: 0.02em;
  }

  .post-time {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-sage);
    background: rgba(105, 117, 101, 0.1);
    padding: 0.18rem 0.55rem;
    border-radius: 99px;
  }

  /* Title */
  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.65rem);
    line-height: 1.25;
    color: var(--color-base);
    margin-bottom: 0.85rem;
    transition: color 0.2s;
  }

  .post-link:hover .post-title {
    color: var(--color-sage);
  }

  /* Description */
  .post-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(60, 61, 55, 0.65);
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CTA text */
  .post-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-sage);
    transition: gap 0.2s;
  }

  .post-link:hover .post-cta {
    gap: 0.65rem;
  }

  .post-arrow {
    transition: transform 0.2s;
  }

  .post-link:hover .post-arrow {
    transform: translateX(3px);
  }

  /* Last item — bottom border */
  .post-item:last-child .post-card {
    border-bottom: 1px solid rgba(105, 117, 101, 0.18);
  }

  /* ── Animation ───────────────────────────────────────────── */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 580px) {
    .post-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-watermark {
      opacity: 0.04;
    }

    .post-num {
      top: 1.5rem;
      font-size: 4.5rem;
    }
  }
</style>
