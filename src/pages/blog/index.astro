---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const category = Astro.url.searchParams.get('categoria') ?? '';
const filteredPosts = category
  ? posts.filter(p => p.data.category === category)
  : posts;

const categoryLabels: Record<string, string> = {
  'fundamentos-seo': 'Fundamentos SEO',
  'seo-local': 'SEO Local',
  'tecnico': 'SEO Técnico',
  'contenidos': 'Contenido y Keywords',
  'herramientas': 'Herramientas SEO',
};

const allCategories = [...new Set(posts.map(p => p.data.category))];

const blogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': 'https://salvaseo.com/blog/#blog',
      'name': 'Blog SEO | SalvaSEO',
      'description': 'Respuestas a las preguntas más frecuentes sobre SEO. Consejos prácticos para negocios locales en Barcelona.',
      'url': 'https://salvaseo.com/blog/',
      'publisher': { '@id': 'https://salvaseo.com/#business' },
      'inLanguage': 'es',
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': 'https://salvaseo.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog SEO', 'item': 'https://salvaseo.com/blog/' },
      ],
    },
  ],
};
---

<Layout
  title="Blog SEO | SalvaSEO — Consultor SEO en Barcelona"
  description="Respuestas a las preguntas más frecuentes sobre SEO. Consejos prácticos sobre posicionamiento web y SEO local para negocios en Barcelona."
  canonicalUrl="https://salvaseo.com/blog/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <!-- ── Hero header ──────────────────────────────── -->
  <div class="relative bg-base">
    <div class="mx-auto max-w-2xl lg:max-w-4xl px-6 lg:px-8 pt-40 pb-20">
      <h1 class="font-heading text-h4 font-normal tracking-tight text-pretty text-white text-center">SalvaSEO Blog</h1>
    </div>
  </div>

  <!-- ── Category filter ─────────────────────────── -->
  {allCategories.length > 1 && (
    <div class="sticky top-0 z-10 border-b border-sage/15 bg-base">
      <div class="mx-auto max-w-2xl lg:max-w-4xl px-6 lg:px-8 py-3 flex flex-wrap gap-2">
        <a href="/blog/" class:list={['filter-pill', { active: !category }]}>Todos</a>
        {allCategories.map(cat => (
          <a href={`/blog/?categoria=${cat}`} class:list={['filter-pill', { active: category === cat }]}>
            {categoryLabels[cat] ?? cat}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- ── Posts list ───────────────────────────────── -->
  <div class="bg-base py-16 sm:py-24">
    <div class="mx-auto max-w-2xl lg:max-w-4xl px-6 lg:px-8">
      {filteredPosts.length === 0 ? (
        <p class="text-cream/40 text-sm">No hay artículos en esta categoría todavía.</p>
      ) : (
        <div class="space-y-16 lg:space-y-20">
          {filteredPosts.map(post => {
            const cat = categoryLabels[post.data.category] ?? post.data.category;
            const dateFormatted = post.data.pubDate.toLocaleDateString('es-ES', {
              day: 'numeric',
              month: 'short',
              year: 'numeric',
            });
            return (
              <article class="relative isolate flex flex-col gap-8 lg:flex-row">
                <a href={`/blog/${post.slug}/`} class="relative aspect-video sm:aspect-2/1 lg:aspect-auto lg:w-64 lg:shrink-0 lg:self-stretch">
                  {post.data.image ? (
                    <img
                      src={post.data.image.src}
                      alt={post.data.image.alt}
                      class="absolute inset-0 size-full rounded-2xl bg-surface/40 object-cover"
                      width="256"
                      height="256"
                      loading="lazy"
                    />
                  ) : (
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-surface to-base flex items-center justify-center">
                      <span class="text-cream/20 font-heading text-5xl font-normal select-none">SEO</span>
                    </div>
                  )}
                  <div class="absolute inset-0 rounded-2xl inset-ring inset-ring-white/10"></div>
                </a>
                <div>
                  <div class="flex items-center gap-x-4 text-xs">
                    <time datetime={post.data.pubDate.toISOString()} class="text-cream/45">
                      {dateFormatted}
                    </time>
                    <a
                      href={`/blog/?categoria=${post.data.category}`}
                      class="relative z-10 rounded-full bg-sage/15 px-3 py-1.5 font-semibold text-cream/70 hover:bg-sage/25 transition-colors border border-sage/20"
                    >{cat}</a>
                    {post.data.readingTime && (
                      <span class="text-cream/35">{post.data.readingTime} min</span>
                    )}
                  </div>
                  <div class="group relative max-w-xl">
                    <h2 class="mt-3 font-heading text-xl/7 font-normal text-cream group-hover:text-white transition-colors">
                      <a href={`/blog/${post.slug}/`}>
                        <span class="absolute inset-0"></span>
                        {post.data.title}
                      </a>
                    </h2>
                    <p class="mt-4 text-sm/6 text-cream/55">{post.data.description}</p>
                  </div>
                  <div class="mt-6 flex border-t border-sage/15 pt-6">
                    <div class="relative flex items-center gap-x-4">
                      <img
                        src="/about-me.png"
                        alt="Salvador Jesús, Consultor SEO"
                        class="size-10 rounded-full bg-surface/40 object-cover"
                        width="40"
                        height="40"
                        loading="lazy"
                      />
                      <div class="text-sm/6">
                        <p class="font-semibold text-cream/90">
                          <a href="/#sobre-mi">
                            <span class="absolute inset-0"></span>
                            Salvador Jesús
                          </a>
                        </p>
                        <p class="text-cream/45">Consultor SEO · Barcelona</p>
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </div>

</Layout>

<style>
  .filter-pill {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 99px;
    border: 1px solid rgba(105, 117, 101, 0.2);
    color: rgba(236, 223, 204, 0.5);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .filter-pill:hover {
    background: rgba(105, 117, 101, 0.15);
    color: rgba(236, 223, 204, 0.85);
  }
  .filter-pill.active {
    background: rgba(105, 117, 101, 0.2);
    border-color: rgba(105, 117, 101, 0.4);
    color: rgba(236, 223, 204, 0.9);
    font-weight: 600;
  }
</style>
