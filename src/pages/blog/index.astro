---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const blogSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': 'https://salvaseo.com/blog/#blog',
      'name': 'Blog SEO | SalvaSEO',
      'description': 'Respuestas a las preguntas más frecuentes sobre SEO. Consejos prácticos para negocios locales en Barcelona.',
      'url': 'https://salvaseo.com/blog/',
      'publisher': { '@id': 'https://salvaseo.com/#business' },
      'inLanguage': 'es',
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': 'https://salvaseo.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog SEO', 'item': 'https://salvaseo.com/blog/' },
      ],
    },
  ],
};
---

<Layout
  title="Blog SEO | SalvaSEO — Consultor SEO en Barcelona"
  description="Respuestas a las preguntas más frecuentes sobre SEO. Consejos prácticos sobre posicionamiento web y SEO local para negocios en Barcelona."
  canonicalUrl="https://salvaseo.com/blog/"
  darkNav={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <div class="py-24 sm:py-32" style="background: linear-gradient(160deg, var(--color-cream) 0%, color-mix(in srgb, var(--color-sage) 8%, var(--color-cream)) 100%)">
    <div class="mx-auto max-w-2xl px-6 lg:px-8">
      <h1 class="font-heading text-4xl font-normal tracking-tight text-pretty text-base">SalvaSEO Blog</h1>
      <p class="mt-2 text-lg/8 text-base/55">Consejos prácticos de posicionamiento web para negocios locales.</p>

      {posts.length === 0 ? (
        <p class="mt-10 text-sm text-base/40">No hay artículos todavía.</p>
      ) : (
        <div class="mt-10 space-y-16 border-t border-sage/20 pt-10 sm:mt-16 sm:pt-16">
          {posts.map(post => {
            const dateFormatted = post.data.pubDate.toLocaleDateString('es-ES', {
              day: 'numeric',
              month: 'short',
              year: 'numeric',
            });
            return (
              <article class="flex max-w-xl flex-col items-start justify-between">
                <div class="flex items-center gap-x-4 text-xs">
                  <time datetime={post.data.pubDate.toISOString()} class="text-base/45">
                    {dateFormatted}
                  </time>
                  {post.data.readingTime && (
                    <>
                      <span class="text-base/30" aria-hidden="true">·</span>
                      <span class="text-base/35">{post.data.readingTime} min</span>
                    </>
                  )}
                </div>
                <div class="group relative">
                  <h2 class="mt-3 font-heading text-lg/6 font-normal text-base group-hover:text-sage transition-colors">
                    <a href={`/blog/${post.slug}/`}>
                      <span class="absolute inset-0"></span>
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="mt-5 line-clamp-3 text-sm/6 text-base/55">{post.data.description}</p>
                </div>
                <div class="relative mt-8 flex items-center gap-x-4">
                  <img
                    src="/about-me.png"
                    alt="Salvador Jesús"
                    class="size-10 rounded-full bg-surface/40 object-cover"
                    width="40"
                    height="40"
                    loading="lazy"
                  />
                  <div class="text-sm/6">
                    <p class="font-semibold text-base/90">
                      <a href="/#sobre-mi">
                        <span class="absolute inset-0"></span>
                        Salvador Jesús
                      </a>
                    </p>
                    <p class="text-base/45">Consultor SEO · Barcelona</p>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </div>

</Layout>
