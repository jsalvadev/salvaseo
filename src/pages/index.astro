---
import AboutMe from '../components/pages/home/AboutMe.astro'
import EstoEsParaTi from '../components/pages/home/EstoEsParaTi.astro'
import Servicios from '../components/pages/home/Servicios.astro'
import TicketCalculator from '../components/pages/home/TicketCalculator.astro'
import CanBeSolved from '../components/pages/home/CanBeSolved.astro'
import CtaEmail from '../components/pages/home/CtaEmail.astro'
import Resenas from '../components/pages/home/Resenas.astro'
import Faq from '../components/pages/home/Faq.astro'
import { faqHomeItems } from '../data/faq-home'
import Hero from '../components/pages/home/Hero.astro'
import MapSection from '../components/pages/home/MapSection.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout hideNavbar>
  <Hero />
  <CanBeSolved />
  <EstoEsParaTi />
  <Servicios />
  <AboutMe />
  <TicketCalculator />
  <CtaEmail />
  <Resenas />
  <Faq
    upheading='Consultor SEO: preguntas frecuentes'
    heading='Aún tienes dudas'
    items={faqHomeItems}
    upheadingColor='var(--color-teal)'
  />
  <MapSection />
</Layout>
