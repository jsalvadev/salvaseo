---
import AboutMe from '../components/pages/home/AboutMe.astro'
import ContactForm from '../components/pages/home/ContactForm.astro'
import CtaEmail from '../components/pages/home/CtaEmail.astro'
import DarkBandSeparator from '../components/pages/home/DarkBandSeparator.astro'
import Faq from '../components/pages/home/Faq.astro'
import { faqHomeItems } from '../data/faq-home'
import Hero from '../components/pages/home/Hero.astro'
import MapSection from '../components/pages/home/MapSection.astro'
import ServiceArea from '../components/pages/home/ServiceArea.astro'
import WorkWithMe from '../components/pages/home/WorkWithMe.astro'
import Layout from '../layouts/Layout.astro'
import heroImage from '../assets/hero.webp'
---

<Layout preloadImageHref={heroImage.src}>
  <Hero />
  <AboutMe />
  <CtaEmail />
  <DarkBandSeparator />
  <WorkWithMe />
  <ServiceArea />
  <ContactForm />
  <Faq
    upheading='Todo sobre consultores SEO en Barcelona'
    heading='Aún tienes dudas'
    items={faqHomeItems}
    upheadingColor='var(--color-orange-500)'
  />
  <MapSection />
</Layout>
