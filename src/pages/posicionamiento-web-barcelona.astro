---
import Layout from '../layouts/Layout.astro'
import Services from '../components/pages/posicionamiento-web-barcelona/Services.astro'
import Timeline from '../components/pages/posicionamiento-web-barcelona/Timeline.astro'
import HeroLanding from '../components/pages/posicionamiento-web-barcelona/Hero.astro'
import TrustBanner from '../components/pages/posicionamiento-web-barcelona/TrustBanner.astro'
import PricingBridge from '../components/pages/posicionamiento-web-barcelona/PricingBridge.astro'
import FreelancerVsAgency from '../components/pages/posicionamiento-web-barcelona/FreelancerVsAgency.astro'
import LocalAreas from '../components/pages/posicionamiento-web-barcelona/LocalAreas.astro'
import Faq from '../components/pages/posicionamiento-web-barcelona/Faq.astro'
import { faqBarcelonaItems } from '../data/faq-barcelona'
import Cta from '../components/pages/posicionamiento-web-barcelona/Cta.astro'

const MIN_MONTHLY_PRICE_EUR = 350
const MIN_MONTHLY_PRICE_TEXT = `${MIN_MONTHLY_PRICE_EUR} €/mes`
const DATE_MODIFIED = new Date().toISOString().split('T')[0]
---

<Layout
  title='Posicionamiento Web en Barcelona | SalvaSEO'
  description='Consultor SEO en Barcelona. Estrategia de captación orgánica para empresas locales y pymes. Presupuestos desde 350 €/mes.'
  canonicalUrl='https://salvaseo.com/posicionamiento-web-barcelona/'>
  <HeroLanding
    upheading='Posicionamiento web en Barcelona'
    heading='Deja de perder clientes frente a tu competencia'
    description='En Barcelona, o eres el primero o eres el secreto de tu competencia. Domina las búsquedas de Google, multiplica tus contactos y pon tu web a trabajar de verdad. Si te buscan, que te encuentren a ti primero.'
    primaryCtaText='Analiza mi web ahora'
    secondaryCtaText='Descubre el proceso'
    secondaryCtaHref='#proceso'
  />
  <TrustBanner />
  <Timeline
    upheading='Informe de posicionamiento web y auditoría SEO'
    heading='Tu camino a la primera página empieza con un plan'
  />
  <Services
    upheading='Servicios de posicionamiento web en Barcelona'
    heading='Tu web tiene que trabajar para ti'
    subtitle='Conecta con la intención de búsqueda real de tu mercado en Barcelona. Localiza <strong>los fallos que reducen tu visibilidad en Google</strong> y activa tu captación de clientes con datos reales para aumentar tu facturación.'
  />
  <LocalAreas
    upheading='Posicionamiento web en Cataluña'
    heading='Cataluña es tu territorio'
    intro='<p class="mt-6 text-base/7 text-petrol-700">La visibilidad en el buscador cambia según la ubicación del usuario. Si tu negocio no responde a la <strong>intención de búsqueda de tu zona</strong>, el tráfico se desvía hacia la competencia.</p><p class="mt-4 text-base/7 text-petrol-700">Captura la demanda real en los mercados con mayor potencial de conversión:</p>'
    areas={[
      { stat: '170 búsquedas/mes', title: 'Posicionamiento web en Sabadell', description: 'Una de las zonas con mayor actividad comercial del Vallès. Escalar posiciones aquí abre la puerta a liderar tu sector a nivel comarcal.' },
      { stat: '90 búsquedas/mes', title: 'Posicionamiento web en Badalona', description: 'Alta intención de compra local. El cliente que busca proximidad convierte más rápido, y ganar visibilidad aquí evita que tu negocio se diluya entre los resultados de la capital.' },
      { stat: '90 búsquedas/mes', title: 'Posicionamiento web en Terrassa', description: 'Menor saturación competitiva que Barcelona ciudad. Una estrategia orgánica sólida captura esta demanda de forma recurrente y sin coste por clic.' },
      { stat: '70 búsquedas/mes', title: 'Posicionamiento web en Lleida', description: 'Baja competencia técnica en el entorno. La optimización profesional genera aquí resultados de liderazgo en plazos más cortos que en mercados saturados.' },
    ]}
  />
  <FreelancerVsAgency />
  <PricingBridge
    upheading='Precios de posicionamiento web en Barcelona'
    heading='Solo inviertes en lo que funciona'
    priceHighlight={`Desde ${MIN_MONTHLY_PRICE_TEXT}`}
    intro={`Los presupuestos parten de <strong>${MIN_MONTHLY_PRICE_TEXT} + IVA</strong> y se definen según tu competencia, el estado técnico de tu web y la velocidad de crecimiento que necesites.`}
    guarantees={[
      { title: 'No inviertes a ciegas.', description: 'El análisis inicial confirma si el SEO es rentable para tu sector. Si no hay demanda o la competencia es inalcanzable, lo sabrás antes de gastar un euro.' },
      { title: 'Los primeros cambios llegan en semanas.', description: 'Entre las 4 y 8 semanas ya hay movimiento. La consolidación real viene entre los 3 y 6 meses.' },
      { title: 'Sin contratos de permanencia.', description: 'Todo el trabajo realizado queda en tu web. Es tuyo, independientemente de lo que decidas después.' },
      { title: 'Ejecución técnica directa.', description: 'Capacidad limitada a pocos proyectos simultáneos. Tu web recibe atención especializada, no tareas delegadas.' },
    ]}
    quote='Cada euro invertido se justifica con datos antes de comprometerse. Esa es la única forma de que la inversión tenga sentido.'
    quoteAuthor='— Salvador Jesús, Consultor SEO en Barcelona'
  />
  <Faq
    upheading='Posicionamiento web profesional para empresas en Barcelona'
    heading='Todavía te lo estás pensando'
    idPrefix='faq-pw'
    items={faqBarcelonaItems}
  />
  <Cta
    layout='centered'
    upheading='Posicionamiento web para pymes en Barcelona'
    heading='El primer paso es gratis'
    text='Accede a un estudio de mercado y una auditoría técnica de tu web <strong>sin coste ni compromiso</strong>. Verifica la rentabilidad de la inversión antes de tomar cualquier decisión.'
    primaryCtaText='Solicita tu análisis gratuito'
    secondaryCtaText='O rellena el formulario'
    secondaryCtaHref='/#contacto'
  />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebSite',
          '@id': 'https://salvaseo.com/#website',
          url: 'https://salvaseo.com/',
          name: 'SalvaSEO',
          description:
            'Consultor SEO en Barcelona especializado en posicionamiento web para empresas locales y pymes.',
          publisher: {
            '@id': 'https://salvaseo.com/#business'
          },
          inLanguage: 'es'
        },
        {
          '@type': 'ProfessionalService',
          '@id': 'https://salvaseo.com/#business',
          name: 'SalvaSEO - Consultor SEO en Barcelona',
          url: 'https://salvaseo.com/',
          telephone: '+34692051399',
          email: 'salvadorjesus.seo@gmail.com',
          image: 'https://salvaseo.com/og-image.jpg',
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Barcelona',
            addressRegion: 'Cataluña',
            addressCountry: 'ES'
          },
          geo: {
            '@type': 'GeoCoordinates',
            latitude: 41.392668,
            longitude: 2.140189
          },
          openingHoursSpecification: {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
            opens: '09:00',
            closes: '18:00'
          },
          sameAs: [
            'https://www.instagram.com/salva_seo/',
            'https://www.tiktok.com/@consultorseobarcelona',
            'https://www.google.com/maps/place/SalvaSEO+-+Consultor+SEO+en+Barcelona/@41.3926387,2.0577883,12z'
          ],
          priceRange: `Desde ${MIN_MONTHLY_PRICE_TEXT}`
        },
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#webpage',
          url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
          name: 'Posicionamiento Web en Barcelona | SalvaSEO',
          description:
            'Consultor SEO en Barcelona. Estrategia de captación orgánica para empresas locales y pymes. Presupuestos desde 350 €/mes.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          about: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          datePublished: '2025-02-01',
          dateModified: DATE_MODIFIED,
          mainEntity: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          inLanguage: 'es',
          breadcrumb: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#breadcrumb'
          }
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#breadcrumb',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Inicio',
              item: 'https://salvaseo.com/'
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Posicionamiento Web en Barcelona',
              item: 'https://salvaseo.com/posicionamiento-web-barcelona/'
            }
          ]
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service',
          serviceType: 'Posicionamiento Web SEO',
          name: 'Posicionamiento Web en Barcelona',
          description:
            'Servicios profesionales de posicionamiento web para empresas y negocios en Barcelona. Auditoría SEO, estrategia on page y off page. Sin contratos de permanencia.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: [
            {
              '@type': 'City',
              name: 'Barcelona',
              sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
            },
            {
              '@type': 'City',
              name: 'Sabadell',
              sameAs: 'https://es.wikipedia.org/wiki/Sabadell'
            },
            {
              '@type': 'City',
              name: 'Badalona',
              sameAs: 'https://es.wikipedia.org/wiki/Badalona'
            },
            {
              '@type': 'City',
              name: 'Terrassa',
              sameAs: 'https://es.wikipedia.org/wiki/Tarrasa'
            },
            {
              '@type': 'City',
              name: 'Lleida',
              sameAs: 'https://es.wikipedia.org/wiki/L%C3%A9rida'
            }
          ],
          offers: {
            '@type': 'Offer',
            priceSpecification: {
              '@type': 'UnitPriceSpecification',
              priceCurrency: 'EUR',
              price: String(MIN_MONTHLY_PRICE_EUR),
              unitText: 'mes',
              description: `Presupuesto desde ${MIN_MONTHLY_PRICE_TEXT}, definido tras diagnóstico gratuito`
            }
          },
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Servicios de Posicionamiento Web en Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                itemOffered: {
                  '@type': 'Service',
                  name: 'Análisis inicial y auditoría SEO',
                  description:
                    'Auditoría técnica completa, keyword research, análisis de competencia y arquitectura web para identificar problemas y oportunidades de mejora.'
                }
              },
              {
                '@type': 'Offer',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO On Page',
                  description:
                    'Optimización de intención de búsqueda, contenidos de negocio, interlinking estratégico, control de indexación y Core Web Vitals.'
                }
              },
              {
                '@type': 'Offer',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Off Page',
                  description:
                    'Link building de calidad, auditoría de backlinks, link baiting, reputación online y estrategia de autoridad de dominio.'
                }
              }
            ]
          }
        },
        {
          '@type': 'FAQPage',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#faq',
          mainEntity: [
            {
              '@type': 'Question',
              name: '¿Cuánto tarda en funcionar el posicionamiento web?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'Los primeros movimientos en el rastreo de Google se detectan entre las 4 y 8 semanas: páginas que empiezan a indexarse correctamente, mejoras en la velocidad de carga y correcciones técnicas que ya están activas. Los resultados visibles en posiciones y visitas desde Google suelen consolidarse entre los 3 y 6 meses, dependiendo de la competencia en tu sector y del estado inicial de tu web.'
              }
            },
            {
              '@type': 'Question',
              name: '¿Posicionamiento web o publicidad en Google?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'La publicidad en Google (SEM) te da visibilidad inmediata, pero desapareces en cuanto dejas de pagar. El posicionamiento web construye un activo que se mantiene y se refuerza con el tiempo. Para negocios locales en Barcelona, la combinación más rentable suele ser arrancar con posicionamiento web como base y complementar con campañas puntuales de pago si el sector lo requiere. Cada euro invertido en posicionamiento web sigue generando visitas meses después.'
              }
            },
            {
              '@type': 'Question',
              name: '¿Cómo se mide el resultado del posicionamiento web?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'Con datos de negocio, no solo con gráficos de tráfico. En cada informe mensual verás tres cosas concretas: posiciones reales de tus palabras clave objetivo en Google, visitas desde Google que llegan sin coste por clic, y conversiones (llamadas, formularios completados o acciones que generan clientes). El objetivo no es que tu web reciba más visitas. Es que reciba las visitas que se convierten en clientes.'
              }
            },
            {
              '@type': 'Question',
              name: '¿Necesito rediseñar mi web para mejorar el posicionamiento?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'En la mayoría de los casos, no. Lo habitual es optimizar lo que ya tienes: corregir la estructura, mejorar la velocidad de carga y ajustar el contenido para que Google entienda qué ofreces y dónde lo ofreces. Solo se recomienda un rediseño cuando la base técnica impide el rastreo o cuando la web no convierte visitas en contactos. Eso se detecta en el diagnóstico inicial, antes de invertir en nada.'
              }
            },
            {
              '@type': 'Question',
              name: '¿Qué pasa si dejo de invertir en posicionamiento web?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'No desapareces de Google de un día para otro. El posicionamiento web es un activo acumulado: las mejoras técnicas, el contenido optimizado y la autoridad que has construido siguen trabajando para ti. Pero sin mantenimiento, la competencia avanza y Google actualiza sus criterios. Con el tiempo, las posiciones se erosionan. Por eso la continuidad se basa en resultados: sigues porque el retorno lo justifica.'
              }
            }
          ]
        }
      ]
    })}
  />
</Layout>
