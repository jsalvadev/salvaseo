---
import Layout from '../layouts/Layout.astro'
import Services from '../components/pages/posicionamiento-web-barcelona/Services.astro'
import Timeline from '../components/pages/posicionamiento-web-barcelona/Timeline.astro'
import HeroLanding from '../components/pages/posicionamiento-web-barcelona/Hero.astro'
import PricingBridge from '../components/pages/posicionamiento-web-barcelona/PricingBridge.astro'
import FreelancerVsAgency from '../components/pages/posicionamiento-web-barcelona/FreelancerVsAgency.astro'
import LocalAreas from '../components/pages/posicionamiento-web-barcelona/LocalAreas.astro'
import Faq from '../components/pages/posicionamiento-web-barcelona/Faq.astro'
import { faqBarcelonaItems } from '../data/faq-barcelona'
import Cta from '../components/pages/posicionamiento-web-barcelona/Cta.astro'
import barcelonaImage from '../assets/barcelona.webp'
const MIN_MONTHLY_PRICE_EUR = 350
const MIN_MONTHLY_PRICE_TEXT = `${MIN_MONTHLY_PRICE_EUR} €/mes`
const DATE_MODIFIED = "2026-03-03"
---

<Layout
  title='▷ Posicionamiento Web en Barcelona desde 350 € - SalvaSEO'
  description='¿Quieres más visitas desde Google? Posicionamiento web en Barcelona ☎ 692 051 399 🔵 Desde 350 €/mes ⭐ Sin permanencia. ¡Contacta ya!'
  canonicalUrl='https://salvaseo.com/posicionamiento-web-barcelona/'
  preloadImageHref={barcelonaImage.src}>
  <HeroLanding
    upheading='Posicionamiento web en Barcelona'
    primaryCtaText='Analiza mi web ahora'
    secondaryCtaText='Descubre el proceso'
    secondaryCtaHref='#proceso'
    breadcrumbItems={[{ label: 'Inicio', href: '/' }, { label: 'Posicionamiento Web Barcelona' }]}
  />
  <Timeline
    upheading='Informe de posicionamiento web y auditoría SEO'
    heading='Tu camino a la primera página empieza con un plan'
  />
  <Services
    upheading='Servicios de posicionamiento web en Barcelona'
    heading='Tu web tiene que trabajar para ti'
    subtitle='Conecta con la intención de búsqueda real de tu mercado en Barcelona. Localiza <strong>los fallos que reducen tu visibilidad en Google</strong> y activa tu captación de clientes con datos reales para aumentar tu facturación.'
  />
  <LocalAreas
    upheading='Posicionamiento web en Cataluña'
    heading='Cataluña es tu territorio'
    intro='<p class="mt-6 text-base/7 text-petrol-700">La visibilidad en el buscador cambia según la ubicación del usuario. Si tu negocio depende de clientes de tu barrio, el <a href="/seo-local-barcelona/" class="text-sky-600 font-medium hover:text-sky-700 underline decoration-sky-200 underline-offset-2 transition-colors">SEO local en Barcelona</a> trabaja tu ficha de Google Maps para captar esa demanda antes que tu competencia.</p><p class="mt-4 text-base/7 text-petrol-700">Captura la demanda real en los mercados con mayor potencial de conversión:</p>'
    areas={[
      { stat: '170 búsquedas/mes', title: 'Posicionamiento web en Sabadell', description: 'Una de las zonas con mayor actividad comercial del Vallès. Escalar posiciones aquí abre la puerta a liderar tu sector a nivel comarcal.' },
      { stat: '90 búsquedas/mes', title: 'Posicionamiento web en Badalona', description: 'Alta intención de compra local. El cliente que busca proximidad convierte más rápido, y ganar visibilidad aquí evita que tu negocio se diluya entre los resultados de la capital.' },
      { stat: '90 búsquedas/mes', title: 'Posicionamiento web en Terrassa', description: 'Menor saturación competitiva que Barcelona ciudad. Una estrategia orgánica sólida captura esta demanda de forma recurrente y sin coste por clic.' },
      { stat: '70 búsquedas/mes', title: 'Posicionamiento web en Lleida', description: 'Baja competencia técnica en el entorno. La optimización profesional genera aquí resultados de liderazgo en plazos más cortos que en mercados saturados.' },
    ]}
  />
  <FreelancerVsAgency />
  <PricingBridge
    upheading='Precios de posicionamiento web en Barcelona'
    heading='Solo inviertes en lo que funciona'
    priceHighlight={`Desde ${MIN_MONTHLY_PRICE_TEXT}`}
    intro={`Los presupuestos parten de <strong>${MIN_MONTHLY_PRICE_TEXT} + IVA</strong> y se definen según tu competencia, el estado técnico de tu web y la velocidad de crecimiento que necesites.`}
    guarantees={[
      { title: 'No inviertes a ciegas.', description: 'El análisis inicial confirma si el SEO es rentable para tu sector. Si no hay demanda o la competencia es inalcanzable, lo sabrás antes de gastar un euro.' },
      { title: 'Los primeros cambios llegan en semanas.', description: 'Entre las 4 y 8 semanas ya hay movimiento. La consolidación real viene entre los 3 y 6 meses.' },
      { title: 'Sin contratos de permanencia.', description: 'Todo el trabajo realizado queda en tu web. Es tuyo, independientemente de lo que decidas después.' },
      { title: 'Ejecución técnica directa.', description: 'Capacidad limitada a pocos proyectos simultáneos. Tu web recibe atención especializada, no tareas delegadas.' },
    ]}
    quote='Cada euro invertido se justifica con datos antes de comprometerse. Esa es la única forma de que la inversión tenga sentido.'
    quoteAuthor='— Salvador Jesús, Consultor SEO en Barcelona'
  />
  <Faq
    upheading='Posicionamiento web profesional para empresas en Barcelona'
    heading='Todavía te lo estás pensando'
    idPrefix='faq-pw'
    items={faqBarcelonaItems}
  />
  <Cta
    layout='centered'
    upheading='Posicionamiento web para pymes en Barcelona'
    heading='El primer paso es gratis'
    text='Accede a un estudio de mercado y una auditoría técnica de tu web <strong>sin coste ni compromiso</strong>. Verifica la rentabilidad de la inversión antes de tomar cualquier decisión.'
    primaryCtaText='Solicita tu análisis gratuito'
    secondaryCtaText='O rellena el formulario'
    secondaryCtaHref='/#contacto'
  />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@id': 'https://salvaseo.com/#website'
        },
        {
          '@id': 'https://salvaseo.com/#business'
        },
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#webpage',
          url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
          name: 'Posicionamiento Web en Barcelona | SalvaSEO',
          description:
            'Consultor SEO en Barcelona. Estrategia de captación orgánica para empresas locales y pymes. Presupuestos desde 350 €/mes.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          about: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          datePublished: '2025-02-01',
          dateModified: DATE_MODIFIED,
          author: {
            '@id': 'https://salvaseo.com/#founder'
          },
          mainEntity: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          inLanguage: 'es',
          breadcrumb: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#breadcrumb'
          }
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#breadcrumb',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Inicio',
              item: 'https://salvaseo.com/'
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Posicionamiento Web en Barcelona',
              item: 'https://salvaseo.com/posicionamiento-web-barcelona/'
            }
          ]
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service',
          serviceType: 'Posicionamiento Web SEO',
          name: 'Posicionamiento Web en Barcelona',
          description:
            'Servicios profesionales de posicionamiento web para empresas y negocios en Barcelona. Auditoría SEO, estrategia on page y off page. Sin contratos de permanencia.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: [
            {
              '@type': 'City',
              name: 'Barcelona',
              sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
            },
            {
              '@type': 'City',
              name: 'Sabadell',
              sameAs: 'https://es.wikipedia.org/wiki/Sabadell'
            },
            {
              '@type': 'City',
              name: 'Badalona',
              sameAs: 'https://es.wikipedia.org/wiki/Badalona'
            },
            {
              '@type': 'City',
              name: 'Terrassa',
              sameAs: 'https://es.wikipedia.org/wiki/Tarrasa'
            },
            {
              '@type': 'City',
              name: 'Lleida',
