---
import Layout from '../layouts/Layout.astro'
import Services from '../components/pages/posicionamiento-web-barcelona/Services.astro'
import Timeline from '../components/pages/posicionamiento-web-barcelona/Timeline.astro'
import WhatIs from '../components/pages/posicionamiento-web-barcelona/WhatIs.astro'
import PricingBridge from '../components/pages/posicionamiento-web-barcelona/PricingBridge.astro'
import RelatedServices from '../components/shared/RelatedServices.astro'
import type { RelatedCard } from '../components/shared/RelatedServices.astro'
import Faq from '../components/shared/Faq.astro'
import barcelonaImage from '../assets/fisioterapia-barcelona.avif'
import { faqPwItems } from '../data/faqs'
import { siteConfig } from '../data/site'

const MIN_MONTHLY_PRICE_TEXT = `${siteConfig.pricing.local} €/mes`
const DATE_MODIFIED = new Date().toISOString().split('T')[0]

const relatedCards: RelatedCard[] = [
  {
    iconKey: 'mapPin',
    label: 'Visibilidad en Google Maps',
    title: 'SEO Local en Barcelona',
    description: 'Si tu negocio tiene dirección física, Google Maps es lo primero que ve tu cliente cuando busca en su zona. Optimizo tu ficha para que aparezcas tú antes que tu competencia.',
    href: '/seo-local-barcelona/',
    cta: 'Ver SEO local',
    ordinal: '01',
  },
  {
    iconKey: 'receipt',
    label: 'Tarifas y paquetes',
    title: 'Presupuesto Posicionamiento Web Barcelona',
    description: 'Dos opciones con precio fijo mensual, sin permanencia. Sin letra pequeña. Elige la que encaja con lo que necesitas.',
    href: '/presupuesto-seo-barcelona/',
    cta: 'Ver precios',
    ordinal: '02',
  },
]
---

<Layout
  title='Posicionamiento Web en Barcelona · Más llamadas, menos dependencia · SalvaSEO'
  description='Te posiciono en Google para que tus clientes te encuentren antes que a tu competencia. Sin contratos largos, sin tecnicismos. Desde 350 €/mes. Diagnóstico gratuito incluido.'
  canonicalUrl='https://salvaseo.com/posicionamiento-web-barcelona/'
  preloadImageHref={barcelonaImage.src}
>
  <WhatIs />
  <Timeline
    upheading='INFORME DE POSICIONAMIENTO WEB Y AUDITORÍA SEO'
    heading='Cómo consigo que Google <span class="text-cream">te muestre</span>'
  />
  <Services
    upheading='SERVICIOS DE POSICIONAMIENTO WEB EN BARCELONA'
    heading='Tu web tiene que <span class="text-sage">trabajar para ti</span>'
    subtitle='Localizo por qué tu web no aparece en Google. Lo corrijo. Y consigo que cuando alguien busque tu oficio en Barcelona, llegue a ti y no a tu competencia.'
  />
<PricingBridge
    upheading='PRECIOS DE POSICIONAMIENTO WEB EN BARCELONA'
    heading='Solo pagas por lo que da <span class="accent">resultados.</span>'
    priceHighlight={`Desde ${MIN_MONTHLY_PRICE_TEXT}`}
    intro='Posicionamiento web para pymes y autónomos en Barcelona: dos opciones claras, sin letra pequeña. 350 €/mes para SEO local y Google Maps, o 550 €/mes con tu web incluida. Sin sorpresas, sin permanencia.'
    guarantees={[
      { title: 'No inviertes a ciegas.', description: 'Antes de empezar, analizo si tiene sentido invertir en SEO en tu caso. Si no lo tiene, te lo digo — sin cobrarte nada.' },
      { title: 'Los primeros resultados llegan en semanas.', description: 'Entre la 4.ª y 8.ª semana ya hay movimiento visible. Los resultados de verdad llegan entre los 3 y 6 meses.' },
      { title: 'Sin contratos de permanencia.', description: 'Puedes irte cuando quieras. Todo el trabajo hecho en tu web se queda contigo — siempre.' },
    ]}
    quote=''
    quoteAuthor=''
  />
  <Faq
    upheading='POSICIONAMIENTO WEB PRECIOS Y SERVICIOS EN BARCELONA'
    heading='¿Dudas sobre el posicionamiento web?'
    idPrefix='faq-pw'
    items={faqPwItems}
  />
  <RelatedServices
    upheading='POSICIONAMIENTO WEB PARA PYMES Y EMPRESAS EN BARCELONA'
    heading='Más formas de <span>aparecer en Google.</span>'
    cards={relatedCards}
  />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@id': 'https://salvaseo.com/#website'
        },
        {
          '@id': 'https://salvaseo.com/#business'
        },
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#webpage',
          url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
          name: 'Posicionamiento Web en Barcelona | SalvaSEO',
          description:
            'Consultor SEO en Barcelona. Estrategia de captación orgánica para empresas locales y pymes. Presupuestos desde 350 €/mes.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          about: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          datePublished: '2025-02-01',
          dateModified: DATE_MODIFIED,
          author: {
            '@id': 'https://salvaseo.com/#founder'
          },
          mainEntity: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          inLanguage: 'es'
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service',
          serviceType: 'Posicionamiento Web SEO',
          name: 'Posicionamiento Web en Barcelona',
          description:
            'Servicios profesionales de posicionamiento web para empresas y negocios en Barcelona. Auditoría SEO, estrategia on page y off page. Sin contratos de permanencia.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: [
            {
              '@type': 'City',
              name: 'Barcelona',
              sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
            },
            {
              '@type': 'AdministrativeArea',
              name: 'Area Metropolitana de Barcelona'
            }
          ],
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Servicios de Posicionamiento Web en Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                price: '550',
                priceCurrency: 'EUR',
                availability: 'https://schema.org/InStock',
                itemOffered: {
                  '@type': 'Service',
                  name: 'Posicionamiento Web Barcelona',
                  description:
                    'Optimizacion completa de tu web: auditoria SEO, estrategia on page, off page y contenido. Desde 550 euros/mes.'
                }
              },
              {
                '@type': 'Offer',
                price: '350',
                priceCurrency: 'EUR',
                availability: 'https://schema.org/InStock',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Local y Google Maps',
                  description:
                    'Optimizacion de perfil de Google Maps y SEO local para negocios en Barcelona. Desde 350 euros/mes.'
                }
              }
            ]
          }
        }
      ]
    })}
  />
</Layout>
