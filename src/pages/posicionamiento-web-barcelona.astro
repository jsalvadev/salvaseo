---
import Layout from '../layouts/Layout.astro'
import Services from '../components/pages/posicionamiento-web-barcelona/Services.astro'
import Timeline from '../components/pages/posicionamiento-web-barcelona/Timeline.astro'
import WhatIs from '../components/pages/posicionamiento-web-barcelona/WhatIs.astro'
import PricingBridge from '../components/pages/posicionamiento-web-barcelona/PricingBridge.astro'
import RelatedServices from '../components/pages/posicionamiento-web-barcelona/RelatedServices.astro'
import Faq from '../components/pages/home/Faq.astro'
import barcelonaImage from '../assets/fisioterapia-barcelona.avif'

const MIN_MONTHLY_PRICE_EUR = 350
const MIN_MONTHLY_PRICE_TEXT = `${MIN_MONTHLY_PRICE_EUR} €/mes`
const DATE_MODIFIED = "2026-03-03"

const faqPwItems = [
  {
    question: '¿Cuánto tarda en funcionar el posicionamiento web?',
    answer: `<p class="text-base/7 text-surface">Entre la <strong>4ª y 8ª semana</strong> empiezas a ver movimiento en Google. Los resultados de verdad — más llamadas, más visitas — llegan entre los <strong>3 y 6 meses</strong>. Depende de tu zona y de cuánta competencia tienes. Te lo digo antes de empezar.</p>`,
  },
  {
    question: '¿Posicionamiento web o publicidad en Google?',
    answer: `<p class="text-base/7 text-surface">La publicidad en Google te da clientes rápido, pero en cuanto dejas de pagar, desapareces. El SEO tarda más, pero una vez que subes, sigues recibiendo llamadas sin pagar por cada una.</p>`,
  },
  {
    question: '¿Cómo se mide el resultado del posicionamiento web?',
    answer: `<p class="text-base/7 text-surface">Con datos de negocio, no solo con gráficos de tráfico. En cada informe mensual verás tres cosas concretas:</p><ul class="mt-2 list-disc pl-6 text-base/7 text-surface"><li><strong>Posiciones reales</strong>: en qué posición apareces en Google cuando buscan tu oficio.</li><li><strong>Visitas desde Google</strong> que llegan a tu web sin coste por clic.</li><li><strong>Conversiones</strong>: llamadas y contactos que llegan desde Google.</li></ul><p class="mt-2 text-base/7 text-surface">El objetivo no es que tu web reciba más visitas. Es que reciba <strong>las visitas que se convierten en clientes</strong>.</p>`,
  },
  {
    question: '¿Necesito rediseñar mi web para mejorar el posicionamiento?',
    answer: `<p class="text-base/7 text-surface">En la mayoría de los casos, <strong>no</strong>. Lo habitual es optimizar lo que ya tienes: corregir la estructura, mejorar la velocidad de carga y ajustar el contenido para que Google entienda qué ofreces y dónde lo ofreces.</p><p class="mt-2 text-base/7 text-surface">Solo hace falta rediseñar cuando tu web está tan mal construida que Google directamente no la puede leer. Eso es poco habitual y te lo digo gratis antes de empezar.</p>`,
  },
  {
    question: '¿Qué pasa si dejo de invertir en posicionamiento web?',
    answer: `<p class="text-base/7 text-surface">No desapareces de Google de un día para otro. El posicionamiento web es un <strong>activo acumulado</strong>: las mejoras técnicas, el contenido optimizado y la autoridad que has construido siguen trabajando para ti.</p><p class="mt-2 text-base/7 text-surface">Pero sin mantenimiento, la competencia avanza y Google actualiza sus criterios. Con el tiempo, las posiciones se erosionan. Por eso la continuidad se basa en resultados: <strong>sigues porque el retorno lo justifica</strong>.</p>`,
  },
]
---

<Layout
  title='Posicionamiento Web en Barcelona desde 350 € - SalvaSEO'
  description='¿Quieres más visitas desde Google? Posicionamiento web en Barcelona ☎ 692 051 399 🔵 Desde 350 €/mes ⭐ Sin permanencia. ¡Contacta ya!'
  canonicalUrl='https://salvaseo.com/posicionamiento-web-barcelona/'
  preloadImageHref={barcelonaImage.src}
>
  <WhatIs />
  <Timeline
    upheading='INFORME DE POSICIONAMIENTO WEB Y AUDITORÍA SEO'
    heading='Tu camino a la <span class="text-cream">primera página</span>'
  />
  <Services
    upheading='SERVICIOS DE POSICIONAMIENTO WEB EN BARCELONA'
    heading='Tu web tiene que <span class="text-sage">trabajar para ti</span>'
    subtitle='Localizo por qué tu web no aparece en Google. Lo corrijo. Y consigo que cuando alguien busque tu oficio en Barcelona, llegue a ti y no a tu competencia.'
  />
<PricingBridge
    upheading='PRECIOS DE POSICIONAMIENTO WEB EN BARCELONA'
    heading='Solo pagas por <span>lo que te da resultados</span>'
    priceHighlight={`Desde ${MIN_MONTHLY_PRICE_TEXT}`}
    intro='Posicionamiento web para pymes y autónomos en Barcelona: dos opciones claras, sin letra pequeña. 350 €/mes para SEO local y Google Maps, o 550 €/mes con tu web incluida. Sin sorpresas, sin permanencia.'
    guarantees={[
      { title: 'No inviertes a ciegas.', description: 'Antes de empezar, analizo si tiene sentido invertir en SEO en tu caso. Si no lo tiene, te lo digo — sin cobrarte nada.' },
      { title: 'Los primeros resultados llegan en semanas.', description: 'Entre la 4.ª y 8.ª semana ya hay movimiento visible. Los resultados de verdad llegan entre los 3 y 6 meses.' },
      { title: 'Sin contratos de permanencia.', description: 'Puedes irte cuando quieras. Todo el trabajo hecho en tu web se queda contigo — siempre.' },
    ]}
    quote=''
    quoteAuthor=''
  />
  <Faq
    upheading='POSICIONAMIENTO WEB PROFESIONAL PARA EMPRESAS EN BARCELONA'
    heading='Todavía te lo estás pensando'
    idPrefix='faq-pw'
    items={faqPwItems}
  />
  <RelatedServices />

  <!-- JSON-LD Structured Data -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@id': 'https://salvaseo.com/#website'
        },
        {
          '@id': 'https://salvaseo.com/#business'
        },
        {
          '@type': 'WebPage',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#webpage',
          url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
          name: 'Posicionamiento Web en Barcelona | SalvaSEO',
          description:
            'Consultor SEO en Barcelona. Estrategia de captación orgánica para empresas locales y pymes. Presupuestos desde 350 €/mes.',
          isPartOf: {
            '@id': 'https://salvaseo.com/#website'
          },
          about: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          datePublished: '2025-02-01',
          dateModified: DATE_MODIFIED,
          author: {
            '@id': 'https://salvaseo.com/#founder'
          },
          mainEntity: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service'
          },
          inLanguage: 'es',
          breadcrumb: {
            '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#breadcrumb'
          }
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#breadcrumb',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Inicio',
              item: 'https://salvaseo.com/'
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Posicionamiento Web en Barcelona',
              item: 'https://salvaseo.com/posicionamiento-web-barcelona/'
            }
          ]
        },
        {
          '@type': 'Service',
          '@id': 'https://salvaseo.com/posicionamiento-web-barcelona/#service',
          serviceType: 'Posicionamiento Web SEO',
          name: 'Posicionamiento Web en Barcelona',
          description:
            'Servicios profesionales de posicionamiento web para empresas y negocios en Barcelona. Auditoría SEO, estrategia on page y off page. Sin contratos de permanencia.',
          provider: {
            '@id': 'https://salvaseo.com/#business'
          },
          areaServed: {
            '@type': 'City',
            name: 'Barcelona',
            sameAs: 'https://es.wikipedia.org/wiki/Barcelona'
          },
          offers: {
            '@type': 'Offer',
            priceSpecification: {
              '@type': 'UnitPriceSpecification',
              priceCurrency: 'EUR',
              price: String(MIN_MONTHLY_PRICE_EUR),
              unitText: 'mes',
              description: `Presupuesto desde ${MIN_MONTHLY_PRICE_TEXT}, definido tras diagnóstico gratuito`
            }
          },
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'Servicios de Posicionamiento Web en Barcelona',
            itemListElement: [
              {
                '@type': 'Offer',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
                itemOffered: {
                  '@type': 'Service',
                  name: 'Análisis inicial y auditoría SEO',
                  description:
                    'Auditoría técnica completa, keyword research, análisis de competencia y arquitectura web para identificar problemas y oportunidades de mejora.'
                }
              },
              {
                '@type': 'Offer',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO On Page',
                  description:
                    'Optimización de intención de búsqueda, contenidos de negocio, interlinking estratégico, control de indexación y Core Web Vitals.'
                }
              },
              {
                '@type': 'Offer',
                availability: 'https://schema.org/InStock',
                url: 'https://salvaseo.com/posicionamiento-web-barcelona/',
                itemOffered: {
                  '@type': 'Service',
                  name: 'SEO Off Page',
                  description:
                    'Link building de calidad, auditoría de backlinks, link baiting, reputación online y estrategia de autoridad de dominio.'
                }
              }
            ]
          }
        }
      ]
    })}
  />
</Layout>
