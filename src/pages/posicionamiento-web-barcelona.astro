---
import Layout from '../layouts/Layout.astro'
import Services from '../components/pages/posicionamiento-web-barcelona/Services.astro'
import Timeline from '../components/pages/posicionamiento-web-barcelona/Timeline.astro'
import WhatIs from '../components/pages/posicionamiento-web-barcelona/WhatIs.astro'
import PricingBridge from '../components/pages/posicionamiento-web-barcelona/PricingBridge.astro'
import RelatedServices from '../components/pages/posicionamiento-web-barcelona/RelatedServices.astro'
import Faq from '../components/pages/home/Faq.astro'
import barcelonaImage from '../assets/fisioterapia-barcelona.avif'

const MIN_MONTHLY_PRICE_EUR = 350
const MIN_MONTHLY_PRICE_TEXT = `${MIN_MONTHLY_PRICE_EUR} €/mes`
const DATE_MODIFIED = "2026-03-03"

const faqPwItems = [
  {
    question: '¿Cuánto tarda en funcionar el posicionamiento web?',
    answer: `<p class="text-base/7 text-surface">Los primeros movimientos en el rastreo de Google se detectan entre las <strong>4 y 8 semanas</strong>: páginas que empiezan a indexarse correctamente, mejoras en la velocidad de carga y correcciones técnicas que ya están activas.</p><p class="mt-2 text-base/7 text-surface">Los resultados visibles en posiciones y visitas desde Google suelen consolidarse entre los <strong>3 y 6 meses</strong>, dependiendo de la competencia en tu sector y del estado inicial de tu web. Es un proceso técnico con plazos reales que se definen en el diagnóstico inicial.</p>`,
  },
  {
    question: '¿Posicionamiento web o publicidad en Google?',
    answer: `<p class="text-base/7 text-surface">La publicidad en Google (SEM) te da visibilidad inmediata, pero <strong>desapareces en cuanto dejas de pagar</strong>. El posicionamiento web construye un activo que se mantiene y se refuerza con el tiempo.</p><p class="mt-2 text-base/7 text-surface">Para negocios locales en Barcelona, la combinación más rentable suele ser arrancar con posicionamiento web como base y, si el sector lo requiere, complementar con campañas puntuales de pago. La diferencia clave: <strong>cada euro invertido en posicionamiento web sigue generando visitas meses después</strong>. En publicidad, cada clic tiene un coste que se repite.</p>`,
  },
  {
    question: '¿Cómo se mide el resultado del posicionamiento web?',
    answer: `<p class="text-base/7 text-surface">Con datos de negocio, no solo con gráficos de tráfico. En cada informe mensual verás tres cosas concretas:</p><ul class="mt-2 list-disc pl-6 text-base/7 text-surface"><li><strong>Posiciones reales</strong> de tus palabras clave objetivo en Google.</li><li><strong>Visitas desde Google</strong> que llegan a tu web sin coste por clic.</li><li><strong>Conversiones</strong>: llamadas, formularios completados o acciones que generan clientes.</li></ul><p class="mt-2 text-base/7 text-surface">El objetivo no es que tu web reciba más visitas. Es que reciba <strong>las visitas que se convierten en clientes</strong>.</p>`,
  },
  {
    question: '¿Necesito rediseñar mi web para mejorar el posicionamiento?',
    answer: `<p class="text-base/7 text-surface">En la mayoría de los casos, <strong>no</strong>. Lo habitual es optimizar lo que ya tienes: corregir la estructura, mejorar la velocidad de carga y ajustar el contenido para que Google entienda qué ofreces y dónde lo ofreces.</p><p class="mt-2 text-base/7 text-surface">Solo se recomienda un rediseño cuando la base técnica impide el rastreo o cuando la web no convierte visitas en contactos. Eso se detecta en el diagnóstico inicial, antes de invertir en nada.</p>`,
  },
  {
    question: '¿Qué pasa si dejo de invertir en posicionamiento web?',
    answer: `<p class="text-base/7 text-surface">No desapareces de Google de un día para otro. El posicionamiento web es un <strong>activo acumulado</strong>: las mejoras técnicas, el contenido optimizado y la autoridad que has construido siguen trabajando para ti.</p><p class="mt-2 text-base/7 text-surface">Pero sin mantenimiento, la competencia avanza y Google actualiza sus criterios. Con el tiempo, las posiciones se erosionan. Por eso la continuidad se basa en resultados: <strong>sigues porque el retorno lo justifica</strong>.</p>`,
  },
]
---

<Layout
  title='Posicionamiento Web en Barcelona desde 350 € - SalvaSEO'
  description='¿Quieres más visitas desde Google? Posicionamiento web en Barcelona ☎ 692 051 399 🔵 Desde 350 €/mes ⭐ Sin permanencia. ¡Contacta ya!'
  canonicalUrl='https://salvaseo.com/posicionamiento-web-barcelona/'
  preloadImageHref={barcelonaImage.src}
>
  <WhatIs />
  <Timeline
    upheading='Informe de posicionamiento web y auditoría SEO'
    heading='Tu camino a la primera página'
    headingAccent='empieza con un plan.'
  />
  <Services
    upheading='Servicios de posicionamiento web en Barcelona'
    heading='Tu web tiene que <span class="text-teal">trabajar para ti</span>'
    subtitle='Localiza los fallos que frenan tu visibilidad en Google. Corríjelos. Y haz que cada búsqueda de tu sector acabe en tu web, no en la de tu competencia.'
  />
<PricingBridge
    upheading='Precios de posicionamiento web en Barcelona'
    heading='Solo inviertes en lo que funciona'
    priceHighlight={`Desde ${MIN_MONTHLY_PRICE_TEXT}`}
    intro={`Dos precios fijos, sin IVA. <strong>350 €/mes</strong> si solo necesitas Google Maps optimizado. <strong>550 €/mes</strong> si incluye tu web. O <a href='/presupuesto-seo-barcelona/' class='text-teal font-medium hover:text-sage/80 underline decoration-teal/30 underline-offset-2 transition-colors'>consulta todos los paquetes y precios</a>.`}
    guarantees={[
      { title: 'No inviertes a ciegas.', description: 'El análisis inicial confirma si el SEO es rentable para tu sector. Si no hay demanda o la competencia es inalcanzable, lo sabrás antes de gastar un euro.' },
      { title: 'Los primeros cambios llegan en semanas.', description: 'Entre las 4 y 8 semanas ya hay movimiento. La consolidación real viene entre los 3 y 6 meses.' },
      { title: 'Sin contratos de permanencia.', description: 'Todo el trabajo realizado queda en tu web. Es tuyo, independientemente de lo que decidas después.' },
    ]}
    quote=''
    quoteAuthor=''
  />
  <Faq
    upheading='Posicionamiento web profesional para empresas en Barcelona'
    heading='Todavía te lo estás pensando'
    idPrefix='faq-pw'
    items={faqPwItems}
  />
  <RelatedServices />

