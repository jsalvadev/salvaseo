---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import WaChatWidget from "../components/WaChatWidget.astro";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    noindex?: boolean;
    ogImage?: string;
    ogType?: string;
    canonicalUrl?: string;
    preloadImageHref?: string;
}

const {
    title = "Consultor SEO en Barcelona | SalvaSEO",
    description = "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
    noindex = false,
    ogImage = "https://salvaseo.com/og-image.jpg",
    ogType = "website",
    canonicalUrl = "https://salvaseo.com/",
    preloadImageHref,
} = Astro.props;

const isProd = import.meta.env.PROD;
const isHomePage = canonicalUrl === "https://salvaseo.com/" && !noindex;
---

<!doctype html>
<html lang="es">
    <head>
        <!-- Google Tag Manager -->
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
        </script>

        <script
            type="text/partytown"
            src="https://www.googletagmanager.com/gtm.js?id=GTM-P6LRQRXS"
        ></script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.ico" sizes="any">
        <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/site.webmanifest">
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        {preloadImageHref && (
            <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
        )}
        <link rel="alternate" hreflang="es-ES" href={canonicalUrl} />
        <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
        <meta
            name="robots"
            content={noindex
                ? "noindex, nofollow"
                : "index, follow, max-snippet:-1, max-image-preview:large"}
        />

        <!-- Open Graph / Facebook / LinkedIn / WhatsApp -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="SalvaSEO" />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta
            property="og:image:alt"
            content="SalvaSEO - Consultor SEO Local en Barcelona"
        />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@salva_seo" />
        <meta name="twitter:creator" content="@salva_seo" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <meta
            name="twitter:image:alt"
            content="SalvaSEO - Consultor SEO Local en Barcelona"
        />

        {isHomePage && (
            <>
        <!-- JSON-LD Structured Data for SEO -->
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "ProfessionalService",
                        "@id": "https://salvaseo.com/#business",
                        "name": "SalvaSEO — Salvador Jesús",
                        "alternateName": "SalvaSEO",
                        "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                        "url": "https://salvaseo.com/",
                        "telephone": "+34 692 051 399",
                        "email": "salvadorjesus.seo@gmail.com",
                        "priceRange": "€€",
                        "image": "https://salvaseo.com/logo.png",
                        "logo": "https://salvaseo.com/logo.png",
                        "areaServed": {
                            "@type": "City",
                            "name": "Barcelona",
                            "sameAs": "https://es.wikipedia.org/wiki/Barcelona"
                        },
                        "address": {
                            "@type": "PostalAddress",
                            "addressLocality": "Barcelona",
                            "addressRegion": "Cataluña",
                            "addressCountry": "ES"
                        },
                        "geo": {
                            "@type": "GeoCoordinates",
                            "latitude": 41.392668,
                            "longitude": 2.140189
                        },
                        "contactPoint": {
                            "@type": "ContactPoint",
                            "telephone": "+34 692 051 399",
                            "email": "salvadorjesus.seo@gmail.com",
                            "contactType": "customer service",
                            "availableLanguage": ["Spanish"]
                        },
                        "founder": {
                            "@type": "Person",
                            "@id": "https://salvaseo.com/#founder",
                            "name": "Salvador Jesús",
                            "jobTitle": "Consultor SEO Local",
                            "url": "https://salvaseo.com/",
                            "worksFor": {
                                "@id": "https://salvaseo.com/#business"
                            },
                            "email": "salvadorjesus.seo@gmail.com",
                            "telephone": "+34 692 051 399",
                            "image": "https://salvaseo.com/about-me.png",
                            "sameAs": [
                                "https://www.instagram.com/salva_seo/",
                                "https://www.tiktok.com/@consultorseobarcelona"
                            ]
                        },
                        "hasOfferCatalog": {
                            "@type": "OfferCatalog",
                            "name": "Servicios de Consultoría SEO",
                            "itemListElement": [
                                {
                                    "@type": "Offer",
                                    "itemOffered": {
                                        "@type": "Service",
                                        "name": "Auditoría SEO y estrategia de posicionamiento",
                                        "description": "Análisis completo de tu web, competencia y oportunidades. Plan de acción personalizado para mejorar tu visibilidad en Google."
                                    }
                                },
                                {
                                    "@type": "Offer",
                                    "itemOffered": {
                                        "@type": "Service",
                                        "name": "SEO On Page y contenido optimizado",
                                        "description": "Optimización de estructura, contenido y elementos técnicos de tu web para posicionar por las palabras clave de tu negocio."
                                    }
                                },
                                {
                                    "@type": "Offer",
                                    "itemOffered": {
                                        "@type": "Service",
                                        "name": "SEO Off Page y autoridad de dominio",
                                        "description": "Estrategia de enlaces de calidad, citaciones y señales de relevancia para aumentar la autoridad de tu web en Google."
                                    }
                                }
                            ]
                        },
                        "sameAs": [
                            "https://www.instagram.com/salva_seo/",
                            "https://www.tiktok.com/@consultorseobarcelona",
                            "https://www.google.com/maps/place/SalvaSEO+-+Consultor+SEO+en+Barcelona/@41.3926387,2.0577883,12z/data=!4m15!1m8!3m7!1s0x47b687095c96ad7:0x4a8991093774db69!2sSalvaSEO+-+Consultor+SEO+en+Barcelona!8m2!3d41.392668!4d2.140189!10e1!16s%2Fg%2F11y_x5bbp3!3m5!1s0x47b687095c96ad7:0x4a8991093774db69!8m2!3d41.392668!4d2.140189!16s%2Fg%2F11y_x5bbp3?entry=ttu&g_ep=EgoyMDI2MDIxMS4wIKXMDSoASAFQAw%3D%3D"
                        ]
                    },
                    {
                        "@type": "WebSite",
                        "@id": "https://salvaseo.com/#website",
                        "url": "https://salvaseo.com/",
                        "name": "SalvaSEO — Consultor SEO Local en Barcelona",
                        "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                        "publisher": {
                            "@id": "https://salvaseo.com/#business"
                        },
                        "inLanguage": "es"
                    },
                    {
                        "@type": "WebPage",
                        "@id": "https://salvaseo.com/#webpage",
                        "url": "https://salvaseo.com/",
                        "name": "Consultor SEO Local en Barcelona | SalvaSEO",
                        "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                        "isPartOf": {
                            "@id": "https://salvaseo.com/#website"
                        },
                        "about": {
                            "@id": "https://salvaseo.com/#business"
                        },
                        "datePublished": "2025-01-15",
                        "dateModified": "2026-02-16",
                        "mainEntity": { "@id": "https://salvaseo.com/#faq" },
                        "inLanguage": "es"
                    }
                ]
            }
        </script>

        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "@id": "https://salvaseo.com/#faq",
                "mainEntityOfPage": { "@id": "https://salvaseo.com/#webpage" },
                "mainEntity": [
                    {
                        "@type": "Question",
                        "name": "¿Qué diferencia hay entre un consultor SEO freelance y una agencia SEO en Barcelona?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Con un freelance, la comunicación es directa con quien ejecuta tu proyecto. Al mantener una cartera reducida, tu negocio recibe más horas de análisis y ejecución. Además, los costes operativos son más ajustados y la capacidad de adaptación, más rápida."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Qué es un consultor SEO y qué funciones tiene exactamente?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Un consultor SEO analiza, optimiza y posiciona tu web en Google para que tus clientes potenciales te encuentren. Tu negocio obtiene un diagnóstico de por qué no aparece en Google y las soluciones necesarias. Auditoría técnica de velocidad, estructura y rendimiento de tu web. Investigación de qué buscan tus clientes en Google y con qué frecuencia. Optimización de contenido para las búsquedas que generan negocio. Optimización de tu ficha de Google Maps para captar clientes locales. Estrategia para aumentar la reputación de tu web ante Google. Análisis de competencia local. Seguimiento semanal y ajustes continuos con métricas de captación. Tu web aparece cuando un cliente potencial busca lo que ofreces."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Cuánto cobra un consultor SEO en Barcelona? (Precio y tarifas 2026)",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "El precio en Barcelona varía según el mercado y la complejidad del proyecto: entre 50€-150€/hora o desde 500€/mes. El modelo puede ser por proyecto, planes mensuales o servicios puntuales según lo que necesites. Antes de presupuestar, tu negocio recibe un análisis inicial de la situación actual. Después, el coste exacto adaptado a tu caso."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Cómo encontrar un buen consultor SEO en Barcelona?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Tres señales clave: que demuestre resultados reales con casos verificables, que explique el proceso con claridad antes de presupuestar, y que conozca tu mercado local. El indicador más fiable es un plan realista adaptado a tu negocio, con métricas y plazos concretos."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Cómo sé si necesito un consultor SEO profesional?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Señales habituales: tu web no recibe visitas desde Google, tu competencia aparece antes que tú, tu ficha de Google Maps no genera llamadas, o tu negocio depende de publicidad de pago para conseguir visibilidad. Si tu facturación depende de que te encuentren online y ahora mismo no apareces, el posicionamiento orgánico es la solución. En la consultoría inicial se valida si tu caso tiene recorrido."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Por qué necesito un especialista SEO para mi negocio en Barcelona?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Porque Google no posiciona una web solo porque el servicio sea bueno. El posicionamiento orgánico requiere trabajo técnico especializado. El resultado: tu web se convierte en un canal constante de captación de clientes. Mientras tu equipo se centra en el negocio, tu web capta solicitudes de presupuesto y llamadas. Si tu competencia recibe las llamadas que podrían ser tuyas, el posicionamiento orgánico redirige esa demanda a tu negocio."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Cómo encontrar un consultor SEO cerca de mi negocio en Barcelona?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Dos criterios clave: que conozca tu zona y que no presupueste antes de analizar tu caso. La ventaja de trabajar con alguien del área metropolitana de Barcelona es la posibilidad de visitar tu local, analizar la competencia sobre el terreno y entender la dinámica comercial de tu barrio."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "¿Vale la pena contratar un consultor SEO para mi negocio local?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Si pierdes clientes que buscan lo que ofreces pero encuentran a tu competencia, tu web necesita posicionamiento. Tu página se convierte en un canal de captación de clientes con intención de compra. Los resultados tardan 3-6 meses, pero a partir de ahí tu web genera visitas y llamadas sin depender de publicidad mensual. La pregunta es ¿cuánta facturación pierde tu negocio cada mes por no aparecer en Google?"
                        }
                    }
                ]
            }
        </script>
            </>
        )}

<script>
            import "@tailwindplus/elements";
            import "../scripts/cookieconsent.js";
            import "../scripts/scroll-animations.js";
        </script>
    </head>
    <body class="relative isolate">
        <!-- Google Tag Manager (noscript) -->
        <noscript
            ><iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-P6LRQRXS"
                height="0"
                width="0"
                style="display:none;visibility:hidden"></iframe></noscript
        >
        <!-- End Google Tag Manager (noscript) -->
        <div class="pointer-events-none absolute top-0 z-[-2] h-screen w-screen bg-white bg-[radial-gradient(100%_50%_at_50%_0%,rgba(0,163,255,0.13)_0,rgba(0,163,255,0)_50%,rgba(0,163,255,0)_100%)]"></div>
        <div class="relative z-0">
            <Navbar />
            <main>
                <slot />
            </main>
            <Footer />
            <WaChatWidget />
        </div>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
