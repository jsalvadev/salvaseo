---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import WaChatWidget from "../components/WaChatWidget.astro";
import "../styles/global.css";
import titanOneUrl from "@fontsource/titan-one/files/titan-one-latin-400-normal.woff2";

interface Props {
    title?: string;
    description?: string;
    noindex?: boolean;
    ogImage?: string;
    ogType?: string;
    canonicalUrl?: string;
    preloadImageHref?: string;
    navScrolled?: boolean;
}

const {
    title = "▷ Consultor SEO en Barcelona · Análisis Gratis - SalvaSEO",
    description = "¿Buscas un consultor SEO en Barcelona? ☎ 692 051 399 🔵 Diagnóstico gratis ⭐ Más clientes desde Google. Sin permanencia. ¡Contacta ya!",
    noindex = false,
    ogImage = "https://salvaseo.com/og-image.jpg",
    ogType = "website",
    canonicalUrl = "https://salvaseo.com/",
    preloadImageHref,
    navScrolled = false,
} = Astro.props;

const isProd = import.meta.env.PROD;
const isHomePage = canonicalUrl === "https://salvaseo.com/" && !noindex;
const DATE_MODIFIED = "2026-03-30";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preload" as="font" type="font/woff2" href={titanOneUrl} crossorigin />
        <!-- Google Tag Manager -->
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            // Consent Mode v2 — estado por defecto denegado (antes de que GTM cargue)
            gtag('consent', 'default', {
                analytics_storage: 'denied',
                ad_storage: 'denied',
                wait_for_update: 500
            });
        </script>

        <script
            async
            src="https://www.googletagmanager.com/gtm.js?id=GTM-P6LRQRXS"
        ></script>
        <!-- End Google Tag Manager -->
        <link rel="icon" href="/favicon.ico" sizes="any">
        <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/site.webmanifest">
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        {preloadImageHref && (
            <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
        )}
        <link rel="alternate" hreflang="es-ES" href={canonicalUrl} />
        <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
        <meta
            name="robots"
            content={noindex
                ? "noindex, nofollow"
                : "index, follow, max-snippet:-1, max-image-preview:large"}
        />

        <!-- Open Graph / Facebook / LinkedIn / WhatsApp -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="SalvaSEO" />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta
            property="og:image:alt"
            content="SalvaSEO - Consultor SEO Local en Barcelona"
        />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@salva_seo" />
        <meta name="twitter:creator" content="@salva_seo" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <meta
            name="twitter:image:alt"
            content="SalvaSEO - Consultor SEO Local en Barcelona"
        />

{isHomePage && (
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "ProfessionalService",
                    "@id": "https://salvaseo.com/#business",
                    "name": "SalvaSEO — Salvador Jesús",
                    "alternateName": "SalvaSEO",
                    "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                    "url": "https://salvaseo.com/",
                    "telephone": "+34692051399",
                    "email": "info@salvaseo.com",
                    "priceRange": "€€",
                    "image": {
                        "@type": "ImageObject",
                        "url": "https://salvaseo.com/logo.webp",
                        "width": 144,
                        "height": 146
                    },
                    "logo": {
                        "@type": "ImageObject",
                        "url": "https://salvaseo.com/logo.webp",
                        "width": 144,
                        "height": 146
                    },
                    "areaServed": {
                        "@type": "City",
                        "name": "Barcelona",
                        "sameAs": "https://es.wikipedia.org/wiki/Barcelona"
                    },
                    "address": {
                        "@type": "PostalAddress",
                        "streetAddress": "Carrer de Pelai, 8",
                        "addressLocality": "Barcelona",
                        "postalCode": "08001",
                        "addressRegion": "Cataluña",
                        "addressCountry": "ES"
                    },
                    "geo": {
                        "@type": "GeoCoordinates",
                        "latitude": 41.392668,
                        "longitude": 2.140189
                    },
                    "openingHoursSpecification": [{
                        "@type": "OpeningHoursSpecification",
                        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                        "opens": "09:00",
                        "closes": "18:00"
                    }],
                    "contactPoint": {
                        "@type": "ContactPoint",
                        "telephone": "+34692051399",
                        "email": "info@salvaseo.com",
                        "contactType": "customer service",
                        "availableLanguage": ["es"]
                    },
                    "founder": {
                        "@type": "Person",
                        "@id": "https://salvaseo.com/#founder",
                        "name": "Salvador Jesús",
                        "jobTitle": "Consultor SEO Local",
                        "url": "https://salvaseo.com/",
                        "worksFor": {
                            "@id": "https://salvaseo.com/#business"
                        },
                        "email": "info@salvaseo.com",
                        "telephone": "+34692051399",
                        "image": {
                            "@type": "ImageObject",
                            "url": "https://salvaseo.com/about-me.png",
                            "width": 800,
                            "height": 800
                        },
                        "sameAs": [
                            "https://www.linkedin.com/in/salvadorjesus",
                            "https://www.instagram.com/salva_seo/",
                            "https://www.tiktok.com/@consultorseobarcelona"
                        ]
                    },
                    "hasOfferCatalog": {
                        "@type": "OfferCatalog",
                        "name": "Servicios de Consultoría SEO",
                        "itemListElement": [
                            {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "Auditoría SEO y estrategia de posicionamiento",
                                    "description": "Análisis completo de tu web, competencia y oportunidades. Plan de acción personalizado para mejorar tu visibilidad en Google."
                                }
                            },
                            {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "SEO On Page y contenido optimizado",
                                    "description": "Optimización de estructura, contenido y elementos técnicos de tu web para posicionar por las palabras clave de tu negocio."
                                }
                            },
                            {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "SEO Off Page y autoridad de dominio",
                                    "description": "Estrategia de enlaces de calidad, citaciones y señales de relevancia para aumentar la autoridad de tu web en Google."
                                }
                            }
                        ]
                    },
                    "sameAs": [
                        "https://www.linkedin.com/in/salvadorjesus",
                        "https://www.instagram.com/salva_seo/",
                        "https://www.tiktok.com/@consultorseobarcelona",
                        "https://www.google.com/maps/place/?cid=5370983499387165545"
                    ]
                },
                {
                    "@type": "WebSite",
                    "@id": "https://salvaseo.com/#website",
                    "url": "https://salvaseo.com/",
                    "name": "SalvaSEO — Consultor SEO Local en Barcelona",
                    "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                    "publisher": {
                        "@id": "https://salvaseo.com/#business"
                    },
                    "inLanguage": "es"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://salvaseo.com/#webpage",
                    "url": "https://salvaseo.com/",
                    "name": "Consultor SEO Local en Barcelona | SalvaSEO",
                    "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                    "isPartOf": {
                        "@id": "https://salvaseo.com/#website"
                    },
                    "about": {
                        "@id": "https://salvaseo.com/#business"
                    },
                    "mainEntity": {
                        "@id": "https://salvaseo.com/#business"
                    },
                    "datePublished": "2025-01-15",
                    "dateModified": DATE_MODIFIED,
                    "inLanguage": "es",
                    "speakable": {
                        "@type": "SpeakableSpecification",
                        "cssSelector": ["h1", "[data-speakable]"]
                    }
                },
                {
                    "@type": "BreadcrumbList",
                    "@id": "https://salvaseo.com/#breadcrumb",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Inicio",
                            "item": "https://salvaseo.com/"
                        }
                    ]
                }
            ]
        })} />
        )}

<script>
            import "@tailwindplus/elements";
            import "../scripts/cookieconsent.js";
            import "../scripts/scroll-animations.js";
        </script>
    </head>
    <body class="relative isolate">
        <!-- Google Tag Manager (noscript) -->
        <noscript
            ><iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-P6LRQRXS"
                height="0"
                width="0"
                style="display:none;visibility:hidden"></iframe></noscript
        >
        <!-- End Google Tag Manager (noscript) -->
        <div class="pointer-events-none absolute top-0 z-[-2] h-screen w-screen bg-cream bg-[radial-gradient(100%_50%_at_50%_0%,rgba(52,101,109,0.07)_0,rgba(52,101,109,0)_50%,rgba(52,101,109,0)_100%)]"></div>
        <div class="relative z-0">
            <Navbar forceScrolled={navScrolled} />
            <main>
                <slot />
            </main>
            <Footer />
            <WaChatWidget />
        </div>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
