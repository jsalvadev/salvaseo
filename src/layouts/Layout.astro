---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import WaChatWidget from "../components/WaChatWidget.astro";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    noindex?: boolean;
    ogImage?: string;
    ogType?: string;
    canonicalUrl?: string;
    preloadImageHref?: string;
    navScrolled?: boolean;
}

const {
    title = "▷ Consultor SEO en Barcelona · Análisis Gratis - SalvaSEO",
    description = "¿Buscas un consultor SEO en Barcelona? ☎ 692 051 399 🔵 Diagnóstico gratis ⭐ Más clientes desde Google. Sin permanencia. ¡Contacta ya!",
    noindex = false,
    ogImage = "https://salvaseo.com/og-image.jpg",
    ogType = "website",
    canonicalUrl = "https://salvaseo.com/",
    preloadImageHref,
    navScrolled = false,
} = Astro.props;

const isProd = import.meta.env.PROD;
const canonicalUrlNormalized = canonicalUrl.endsWith("/") ? canonicalUrl : canonicalUrl + "/";
const isHomePage = canonicalUrlNormalized === "https://salvaseo.com/" && !noindex;
const DATE_MODIFIED = "2026-03-03";
---

<!doctype html>
<html lang="es">
    <head>
        <!-- Google Tag Manager -->
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            // Consent Mode v2 — estado por defecto denegado (antes de que GTM cargue)
            gtag('consent', 'default', {
                analytics_storage: 'denied',
                ad_storage: 'denied',
                wait_for_update: 500
            });
        </script>

        <script
            async
            src="https://www.googletagmanager.com/gtm.js?id=GTM-P6LRQRXS"
        ></script>
        <!-- End Google Tag Manager -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" href="/favicon.ico" sizes="any">
        <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/site.webmanifest">
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrlNormalized} />
        {preloadImageHref && (
            <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" />
        )}
        <link rel="alternate" hreflang="es-ES" href={canonicalUrlNormalized} />
        <link rel="alternate" hreflang="x-default" href={canonicalUrlNormalized} />
        <meta
            name="robots"
            content={noindex
                ? "noindex, nofollow"
                : "index, follow, max-snippet:-1, max-image-preview:large"}
        />

        <!-- Open Graph / Facebook / LinkedIn / WhatsApp -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="SalvaSEO" />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:url" content={canonicalUrlNormalized} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta
            property="og:image:alt"
            content="SalvaSEO - Consultor SEO Local en Barcelona"
        />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@salva_seo" />
        <meta name="twitter:creator" content="@salva_seo" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <meta
            name="twitter:image:alt"
            content="SalvaSEO - Consultor SEO Local en Barcelona"
        />

{isHomePage && (
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "ProfessionalService",
                    "@id": "https://salvaseo.com/#business",
                    "name": "SalvaSEO — Salvador Jesús",
                    "alternateName": "SalvaSEO",
                    "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                    "url": "https://salvaseo.com/",
                    "telephone": "+34692051399",
                    "email": "info@salvaseo.com",
                    "priceRange": "€€",
                    "image": "https://salvaseo.com/logo.webp",
                    "logo": "https://salvaseo.com/logo.webp",
                    "areaServed": {
                        "@type": "City",
                        "name": "Barcelona",
                        "sameAs": "https://es.wikipedia.org/wiki/Barcelona"
                    },
                    "address": {
                        "@type": "PostalAddress",
                        "streetAddress": "Carrer de Pelai, 8",
                        "addressLocality": "Barcelona",
                        "postalCode": "08001",
                        "addressRegion": "Cataluña",
                        "addressCountry": "ES"
                    },
                    "geo": {
                        "@type": "GeoCoordinates",
                        "latitude": 41.392668,
                        "longitude": 2.140189
                    },
                    "openingHoursSpecification": [{
                        "@type": "OpeningHoursSpecification",
                        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                        "opens": "09:00",
                        "closes": "18:00"
                    }],
                    "contactPoint": {
                        "@type": "ContactPoint",
                        "telephone": "+34692051399",
                        "email": "info@salvaseo.com",
                        "contactType": "customer service",
                        "availableLanguage": ["es"]
                    },
                    "founder": {
                        "@type": "Person",
                        "@id": "https://salvaseo.com/#founder",
                        "name": "Salvador Jesús",
                        "jobTitle": "Consultor SEO Local",
                        "url": "https://salvaseo.com/",
                        "worksFor": {
                            "@id": "https://salvaseo.com/#business"
                        },
                        "email": "info@salvaseo.com",
                        "telephone": "+34692051399",
                        "image": "https://salvaseo.com/about-me.png",
                        "sameAs": [
                            "https://www.linkedin.com/in/salvadorjesus",
                            "https://www.instagram.com/salva_seo/",
                            "https://www.tiktok.com/@consultorseobarcelona"
                        ]
                    },
                    "hasOfferCatalog": {
                        "@type": "OfferCatalog",
                        "name": "Servicios de Consultoría SEO",
                        "itemListElement": [
                            {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "Auditoría SEO y estrategia de posicionamiento",
                                    "description": "Análisis completo de tu web, competencia y oportunidades. Plan de acción personalizado para mejorar tu visibilidad en Google."
                                }
                            },
                            {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "SEO On Page y contenido optimizado",
                                    "description": "Optimización de estructura, contenido y elementos técnicos de tu web para posicionar por las palabras clave de tu negocio."
                                }
                            },
                            {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "SEO Off Page y autoridad de dominio",
                                    "description": "Estrategia de enlaces de calidad, citaciones y señales de relevancia para aumentar la autoridad de tu web en Google."
                                }
                            }
                        ]
                    },
                    "sameAs": [
                        "https://www.linkedin.com/in/salvadorjesus",
                        "https://www.instagram.com/salva_seo/",
                        "https://www.tiktok.com/@consultorseobarcelona",
                        "https://www.google.com/maps/place/SalvaSEO+-+Consultor+SEO+en+Barcelona/@41.3926387,2.0577883,12z/data=!4m15!1m8!3m7!1s0x47b687095c96ad7:0x4a8991093774db69!2sSalvaSEO+-+Consultor+SEO+en+Barcelona!8m2!3d41.392668!4d2.140189!10e1!16s%2Fg%2F11y_x5bbp3!3m5!1s0x47b687095c96ad7:0x4a8991093774db69!8m2!3d41.392668!4d2.140189!16s%2Fg%2F11y_x5bbp3"
                    ]
                },
                {
                    "@type": "WebSite",
                    "@id": "https://salvaseo.com/#website",
                    "url": "https://salvaseo.com/",
                    "name": "SalvaSEO — Consultor SEO Local en Barcelona",
                    "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                    "publisher": {
                        "@id": "https://salvaseo.com/#business"
                    },
                    "inLanguage": "es"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://salvaseo.com/#webpage",
                    "url": "https://salvaseo.com/",
                    "name": "Consultor SEO Local en Barcelona | SalvaSEO",
                    "description": "Consultor SEO en Barcelona especializado en negocios locales. Trabajo solo con empresas de la zona para que tus clientes te encuentren en Google. Análisis inicial gratis.",
                    "isPartOf": {
                        "@id": "https://salvaseo.com/#website"
                    },
                    "about": {
                        "@id": "https://salvaseo.com/#business"
                    },
                    "mainEntity": {
                        "@id": "https://salvaseo.com/#business"
                    },
                    "datePublished": "2025-01-15",
                    "dateModified": DATE_MODIFIED,
                    "inLanguage": "es"
                },
                {
                    "@type": "BreadcrumbList",
                    "@id": "https://salvaseo.com/#breadcrumb",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Inicio",
                            "item": "https://salvaseo.com/"
                        }
                    ]
                }
            ]
        })} />
        )}

<script>
            import "@tailwindplus/elements";
            import "../scripts/cookieconsent.js";
            import "../scripts/scroll-animations.js";
        </script>
    </head>
    <body class="relative isolate">
        <!-- Google Tag Manager (noscript) -->
        <noscript
            ><iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-P6LRQRXS"
                height="0"
                width="0"
                style="display:none;visibility:hidden"></iframe></noscript
        >
        <!-- End Google Tag Manager (noscript) -->
        <div class="pointer-events-none absolute top-0 z-[-2] h-screen w-screen bg-cream bg-[radial-gradient(100%_50%_at_50%_0%,rgba(52,101,109,0.07)_0,rgba(52,101,109,0)_50%,rgba(52,101,109,0)_100%)]"></div>
        <div class="relative z-0">
            <Navbar forceScrolled={navScrolled} />
            <main>
                <slot />
            </main>
            <Footer />
            <WaChatWidget />
        </div>

        <!-- Cal.com element-click embed -->
        <script is:inline>
          (function (C, A, L) {
            let p = function (a, ar) { a.q.push(ar); };
            let d = C.document;
            C.Cal = C.Cal || function () {
              let cal = C.Cal; let ar = arguments;
              if (!cal.loaded) {
                cal.ns = {}; cal.q = cal.q || [];
                d.head.appendChild(d.createElement("script")).src = A;
                cal.loaded = true;
              }
              if (ar[0] === L) {
                const api = function () { p(api, arguments); };
                const namespace = ar[1];
                api.q = api.q || [];
                if (typeof namespace === "string") {
                  cal.ns[namespace] = cal.ns[namespace] || api;
                  p(cal.ns[namespace], ar);
                  p(cal, ["initNamespace", namespace]);
                } else p(cal, ar);
                return;
              }
              p(cal, ar);
            };
          })(window, "https://app.cal.com/embed/embed.js", "init");

          Cal("init", "30min", { origin: "https://app.cal.com" });
          Cal.ns["30min"]("ui", { hideEventTypeDetails: false, layout: "month_view" });
        </script>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
