---
import Layout from './Layout.astro';

interface RelatedService {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  readingTime?: number;
  image?: { src: string; alt: string };
  relatedServices?: RelatedService[];
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  readingTime,
  image,
  relatedServices = [],
  slug,
} = Astro.props;

const canonicalUrl = `https://salvaseo.com/blog/${slug}/`;
const ogImage = image?.src
  ? `https://salvaseo.com${image.src}`
  : 'https://salvaseo.com/og-image.jpg';

const pubDateISO = pubDate.toISOString();
const modifiedDateISO = (updatedDate ?? pubDate).toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      'headline': title,
      'description': description,
      'datePublished': pubDateISO,
      'dateModified': modifiedDateISO,
      'url': canonicalUrl,
      'inLanguage': 'es',
      'author': {
        '@type': 'Person',
        '@id': 'https://salvaseo.com/#founder',
        'name': 'Salvador Jesús Galliano Molina',
      },
      'publisher': {
        '@id': 'https://salvaseo.com/#business',
      },
      'mainEntityOfPage': {
        '@type': 'WebPage',
        '@id': `${canonicalUrl}#webpage`,
      },
      ...(image ? { 'image': `https://salvaseo.com${image.src}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': 'https://salvaseo.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog SEO', 'item': 'https://salvaseo.com/blog/' },
        { '@type': 'ListItem', 'position': 3, 'name': title, 'item': canonicalUrl },
      ],
    },
  ],
};

const pubDateFormatted = pubDate.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const updatedDateFormatted = updatedDate?.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout
  title={`${title} | Blog SalvaSEO`}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImage={ogImage}
  darkNav={false}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDateISO} />
    <meta property="article:modified_time" content={modifiedDateISO} />
    <meta property="article:author" content="Salvador Jesús Galliano Molina" />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <div id="reading-progress" aria-hidden="true"></div>

  <article class="blog-post">

    <!-- ── Header ─────────────────────────────────────── -->
    <header class="post-header">
      <div class="header-inner">

        <nav class="post-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span aria-hidden="true">›</span>
          <a href="/blog/">Blog SEO</a>
        </nav>

        {tags.length > 0 && (
          <div class="header-tags">
            {tags.map(tag => <span class="header-tag">{tag}</span>)}
          </div>
        )}

        <h1>{title}</h1>

        <p class="post-lead">{description}</p>

        <div class="post-meta">
          <div class="author-info">
            <img
              src="/about-me.png"
              alt="Salvador Jesús"
              class="author-avatar"
              width="44"
              height="44"
              loading="eager"
            />
            <div>
              <span class="author-name">Salvador Jesús</span>
              <span class="author-role">Consultor SEO · Barcelona</span>
            </div>
          </div>
          <div class="meta-right">
            <time datetime={pubDateISO} class="meta-date">{pubDateFormatted}</time>
            {readingTime && <span class="meta-time">{readingTime} min de lectura</span>}
            {updatedDate && (
              <span class="meta-updated">
                Actualizado: <time datetime={modifiedDateISO}>{updatedDateFormatted}</time>
              </span>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- ── Hero image ────────────────────────────────── -->
    {image && (
      <div class="hero-image-wrap">
        <img
          src={image.src}
          alt={image.alt}
          width="1200"
          height="630"
          loading="eager"
          fetchpriority="high"
          class="hero-img"
        />
      </div>
    )}

    <!-- ── Article body ───────────────────────────────── -->
    <div class="prose-wrap" id="article-body">
      <div class="prose">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="tags-footer">
          <span class="tags-label">Temas</span>
          {tags.map(tag => <span class="tag-pill">{tag}</span>)}
        </div>
      )}
    </div>

    <!-- ── Related services CTA ───────────────────────── -->
    {relatedServices.length > 0 && (
      <aside class="related-cta">
        <div class="related-cta-inner">
          <p class="cta-eyebrow">¿Te ha sido útil?</p>
          <p class="cta-heading">Así es como trabajo con negocios en Barcelona</p>
          <div class="cta-links">
            {relatedServices.map(service => (
              <a href={service.href} class="cta-link">
                {service.label}
                <span class="cta-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    )}

  </article>

  <script>
    const bar = document.getElementById('reading-progress');
    const body = document.getElementById('article-body');
    if (bar && body) {
      const update = () => {
        const scrolled = Math.max(0, -(body.getBoundingClientRect().top));
        const total = body.offsetHeight - window.innerHeight;
        const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 100;
        bar.style.width = `${pct}%`;
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
  </script>
</Layout>

<style>
  /* ── Reading progress ─────────────────────────────── */
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: var(--color-sage);
    z-index: 9999;
    transition: width 0.08s linear;
    pointer-events: none;
  }

  /* ── Post header ──────────────────────────────────── */
  .post-header {
    background: linear-gradient(
      155deg,
      var(--color-cream) 0%,
      color-mix(in srgb, var(--color-sage) 7%, var(--color-cream)) 100%
    );
    padding-block: 8rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .post-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(105,117,101,0.055) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .header-inner {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* Breadcrumb */
  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 2.25rem;
    animation: fadeSlideUp 0.5s ease both;
  }

  .post-breadcrumb a {
    color: var(--color-sage);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-breadcrumb a:hover {
    color: var(--color-base);
  }

  .post-breadcrumb span {
    color: rgba(105, 117, 101, 0.45);
    font-size: 0.8rem;
    font-weight: 400;
  }

  /* Tags strip */
  .header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    animation: fadeSlideUp 0.5s ease 0.07s both;
  }

  .header-tag {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    border: 1px solid rgba(105, 117, 101, 0.4);
    padding: 0.22rem 0.65rem;
    border-radius: 2px;
  }

  /* H1 */
  h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    line-height: 1.16;
    color: var(--color-base);
    margin-bottom: 1.25rem;
    animation: fadeSlideUp 0.6s ease 0.12s both;
  }

  /* Lead description */
  .post-lead {
    font-size: 1.15rem;
    line-height: 1.72;
    color: var(--color-surface);
    margin-bottom: 2.5rem;
    animation: fadeSlideUp 0.6s ease 0.18s both;
  }

  /* Meta bar */
  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(105, 117, 101, 0.2);
    animation: fadeSlideUp 0.6s ease 0.24s both;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(105, 117, 101, 0.25);
    flex-shrink: 0;
  }

  .author-name {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-base);
  }

  .author-role {
    display: block;
    font-size: 0.7rem;
    color: var(--color-sage);
    letter-spacing: 0.04em;
    margin-top: 0.1rem;
  }

  .meta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.18rem;
    text-align: right;
  }

  .meta-date {
    font-size: 0.8rem;
    color: var(--color-surface);
    font-weight: 500;
  }

  .meta-time {
    font-size: 0.7rem;
    color: var(--color-sage);
    letter-spacing: 0.04em;
  }

  .meta-updated {
    font-size: 0.67rem;
    color: var(--color-sage);
    font-style: italic;
  }

  /* ── Hero image ───────────────────────────────────── */
  .hero-image-wrap {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-top: 3rem;
    padding-bottom: 0.5rem;
  }

  .hero-img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
    box-shadow: 0 4px 32px rgba(24, 28, 20, 0.1);
  }

  /* ── Prose wrap ───────────────────────────────────── */
  .prose-wrap {
    max-width: 680px;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-block: 3.5rem 4.5rem;
    background: var(--color-cream);
  }

  /* ── Prose ────────────────────────────────────────── */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--color-base);
    counter-reset: section;
  }

  /* Drop cap on first paragraph */
  .prose :global(> p:first-of-type::first-letter) {
    font-family: var(--font-heading);
    font-size: 4em;
    line-height: 0.82;
    float: left;
    margin-right: 0.1em;
    margin-top: 0.07em;
    color: var(--color-sage);
  }

  /* H2 — numbered with left accent */
  .prose :global(h2) {
    counter-increment: section;
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    line-height: 1.25;
    color: var(--color-base);
    margin-top: 3.75rem;
    margin-bottom: 1rem;
    padding-left: 1rem;
    border-left: 2.5px solid var(--color-sage);
  }

  .prose :global(h2::before) {
    content: counter(section, decimal-leading-zero);
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-sage);
    font-family: var(--font-text);
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  /* H3 */
  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-h5);
    line-height: 1.3;
    color: var(--color-base);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  /* H4 */
  .prose :global(h4) {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-surface);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  /* Lists — em-dash style */
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.5rem 0;
    padding-left: 0;
    list-style: none;
  }

  .prose :global(ul li) {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(ul li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-sage);
    font-weight: 700;
    font-size: 0.9em;
  }

  .prose :global(ol) {
    counter-reset: list-counter;
  }

  .prose :global(ol li) {
    counter-increment: list-counter;
    position: relative;
    padding-left: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(ol li::before) {
    content: counter(list-counter, decimal-leading-zero);
    position: absolute;
    left: 0;
    font-size: 0.67rem;
    font-weight: 700;
    color: var(--color-sage);
    font-family: var(--font-text);
    letter-spacing: 0.06em;
    top: 0.32em;
  }

  /* Blockquote — editorial pull-quote */
  .prose :global(blockquote) {
    position: relative;
    margin: 2.5rem -1.5rem;
    padding: 2rem 2.5rem 2rem 3rem;
    background: color-mix(in srgb, var(--color-sage) 9%, var(--color-cream));
    border: none;
    border-top: 1px solid rgba(105, 117, 101, 0.18);
    border-bottom: 1px solid rgba(105, 117, 101, 0.18);
  }

  .prose :global(blockquote::before) {
    content: '\201C';
    position: absolute;
    top: -0.15rem;
    left: 0.85rem;
    font-family: var(--font-heading);
    font-size: 5.5rem;
    line-height: 1;
    color: var(--color-sage);
    opacity: 0.28;
    font-style: normal;
    pointer-events: none;
  }

  .prose :global(blockquote p) {
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-surface);
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }

  .prose :global(strong) {
    color: var(--color-base);
    font-weight: 700;
  }

  .prose :global(em) {
    color: var(--color-surface);
  }

  .prose :global(a) {
    color: var(--color-base);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(105, 117, 101, 0.45);
    transition: text-decoration-color 0.15s, color 0.15s;
  }

  .prose :global(a:hover) {
    color: var(--color-surface);
    text-decoration-color: var(--color-sage);
  }

  .prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(105, 117, 101, 0.32), transparent);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    border-radius: 8px;
    margin: 2rem 0;
    width: 100%;
    height: auto;
  }

  /* Code */
  .prose :global(code) {
    background: rgba(105, 117, 101, 0.12);
    border-radius: 3px;
    padding: 0.12em 0.38em;
    font-size: 0.87em;
    color: var(--color-base);
  }

  .prose :global(pre) {
    background: var(--color-base);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.88em;
    color: var(--color-cream);
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.92rem;
  }

  .prose :global(th) {
    font-size: 0.66rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    text-align: left;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid rgba(105, 117, 101, 0.25);
  }

  .prose :global(td) {
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid rgba(105, 117, 101, 0.1);
    color: var(--color-base);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Tags footer */
  .tags-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(105, 117, 101, 0.15);
  }

  .tags-label {
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    margin-right: 0.2rem;
  }

  .tag-pill {
    font-size: 0.63rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-surface);
    background: rgba(105, 117, 101, 0.1);
    border: 1px solid rgba(105, 117, 101, 0.18);
    padding: 0.25rem 0.65rem;
    border-radius: 2px;
  }

  /* ── Related CTA — dark reversal ─────────────────── */
  .related-cta {
    background: var(--color-base);
    padding-block: 4.5rem;
  }

  .related-cta-inner {
    max-width: 680px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .cta-eyebrow {
    font-size: 0.67rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
    margin-bottom: 0.85rem;
  }

  .cta-heading {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    color: var(--color-cream);
    line-height: 1.25;
    margin-bottom: 2rem;
  }

  .cta-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1.5px solid rgba(236, 223, 204, 0.22);
    color: var(--color-cream);
    text-decoration: none;
    padding: 0.75rem 1.4rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .cta-link:hover {
    border-color: rgba(236, 223, 204, 0.5);
    background: rgba(236, 223, 204, 0.06);
  }

  .cta-arrow {
    transition: transform 0.2s ease;
  }

  .cta-link:hover .cta-arrow {
    transform: translateX(3px);
  }

  /* ── Entrance animations ──────────────────────────── */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 600px) {
    .post-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .meta-right {
      align-items: flex-start;
      text-align: left;
    }

    .prose :global(blockquote) {
      margin-inline: -1rem;
      padding-inline: 1.5rem 1.5rem;
    }

    .prose :global(blockquote::before) {
      left: 0.5rem;
    }
  }
</style>
