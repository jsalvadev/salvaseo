---
import Layout from './Layout.astro';
import Watermark from '../components/Watermark.astro';

interface RelatedService {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  readingTime?: number;
  image?: { src: string; alt: string };
  relatedServices?: RelatedService[];
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  readingTime,
  image,
  relatedServices = [],
  slug,
} = Astro.props;

const canonicalUrl = `https://salvaseo.com/blog/${slug}/`;
const ogImage = image?.src
  ? `https://salvaseo.com${image.src}`
  : 'https://salvaseo.com/og-image.jpg';

const pubDateISO = pubDate.toISOString();
const modifiedDateISO = (updatedDate ?? pubDate).toISOString();

const categoryLabels: Record<string, string> = {
  'fundamentos-seo': 'Fundamentos SEO',
  'seo-local': 'SEO Local',
  'tecnico': 'SEO Técnico',
  'contenidos': 'Contenido y Keywords',
  'herramientas': 'Herramientas SEO',
};

const categoryLabel = categoryLabels[category] ?? category;

const articleSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      'headline': title,
      'description': description,
      'datePublished': pubDateISO,
      'dateModified': modifiedDateISO,
      'url': canonicalUrl,
      'inLanguage': 'es',
      'author': {
        '@type': 'Person',
        '@id': 'https://salvaseo.com/#founder',
        'name': 'Salvador Jesús Galliano Molina',
      },
      'publisher': {
        '@id': 'https://salvaseo.com/#business',
      },
      'mainEntityOfPage': {
        '@type': 'WebPage',
        '@id': `${canonicalUrl}#webpage`,
      },
      ...(image ? { 'image': `https://salvaseo.com${image.src}` } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': 'https://salvaseo.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog SEO', 'item': 'https://salvaseo.com/blog/' },
        { '@type': 'ListItem', 'position': 3, 'name': title, 'item': canonicalUrl },
      ],
    },
  ],
};

const pubDateFormatted = pubDate.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout
  title={`${title} | Blog SalvaSEO`}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImage={ogImage}
  darkNav={false}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDateISO} />
    <meta property="article:modified_time" content={modifiedDateISO} />
    <meta property="article:author" content="Salvador Jesús Galliano Molina" />
    <meta property="article:section" content={categoryLabel} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <article class="blog-post bg-cream">
    <header class="post-header relative bg-cream">

      <div class="post-header-inner relative z-10">
        <h1>{title}</h1>
        <p class="post-lead">{description}</p>
        <div class="post-meta">
          <time datetime={pubDateISO}>{pubDateFormatted}</time>
          {updatedDate && (
            <>
              <span class="separator">·</span>
              <span>Actualizado: <time datetime={modifiedDateISO}>{updatedDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</time></span>
            </>
          )}
          {readingTime && (
            <>
              <span class="separator">·</span>
              <span>{readingTime} min de lectura</span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Hero image -->
    {image && (
      <div class="hero-image-wrap">
        <img
          src={image.src}
          alt={image.alt}
          width="1200"
          height="630"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )}

    <!-- Article body -->
    <div class="prose-wrap bg-cream">
      <div class="prose">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="tags-row">
          {tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Related services CTA -->
    {relatedServices.length > 0 && (
      <aside class="related-cta">
        <div class="related-cta-inner">
          <p class="related-cta-eyebrow">¿Te ha sido útil?</p>
          <p class="related-cta-heading">Así es como trabajo con negocios en Barcelona</p>
          <div class="related-cta-links">
            {relatedServices.map(service => (
              <a href={service.href} class="cta-link">{service.label} →</a>
            ))}
          </div>
        </div>
      </aside>
    )}
  </article>
</Layout>

<style>
  /* Post header */
  .post-header-inner {
    max-width: 680px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-block: 6.5rem 5rem;
  }

  .category-pill {
    display: inline-block;
    margin-bottom: 1.25rem;
  }
  .category-pill a {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid rgba(60, 61, 55, 0.3);
    color: var(--color-cream);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
  }
  .category-pill a:hover {
    background: var(--color-sage);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    line-height: 1.2;
    color: var(--color-base);
    margin-bottom: 0.75rem;
  }

  .post-lead {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--color-surface);
    margin-bottom: 1.5rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-surface);
    opacity: 0.8;
  }
  .post-meta .separator {
    color: var(--color-sage);
  }
  .post-meta time {
    color: var(--color-surface);
  }

  /* Hero image */
  .hero-image-wrap {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    margin-bottom: 3rem;
  }
  .hero-image-wrap img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
  }

  /* Prose container */
  .prose-wrap {
    max-width: 680px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-bottom: 4rem;
    padding-block: 3rem;
  }

  /* Prose styles */
  .prose {
    font-size: var(--text-p);
    line-height: 1.85;
    color: var(--color-base);
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    line-height: 1.25;
    color: var(--color-base);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-h5);
    line-height: 1.3;
    color: var(--color-base);
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h4) {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-base);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.5rem 0;
    padding-left: 1.6rem;
  }

  .prose :global(ul) { list-style-type: disc; }
  .prose :global(ol) { list-style-type: decimal; }

  .prose :global(li) {
    margin-bottom: 0.45rem;
    padding-left: 0.25rem;
  }

  .prose :global(li::marker) {
    color: var(--color-sage);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-surface);
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: var(--color-surface);
    font-style: italic;
  }

  .prose :global(strong) {
    color: var(--color-base);
    font-weight: 700;
  }

  .prose :global(em) {
    color: var(--color-surface);
  }

  .prose :global(a) {
    color: var(--color-base);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose :global(a:hover) {
    color: var(--color-surface);
  }

  .prose :global(code) {
    background: var(--color-sage);
    opacity: 0.2;
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.88em;
    color: var(--color-base);
  }

  .prose :global(pre) {
    background: var(--color-sage);
    opacity: 0.15;
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.9em;
    color: var(--color-base);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-surface);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    border-radius: 8px;
    margin: 2rem 0;
    width: 100%;
    height: auto;
  }

  /* Markdown tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.95rem;
  }
  .prose :global(th) {
    background: var(--color-sage);
    opacity: 0.15;
    color: var(--color-base);
    font-weight: 600;
    text-align: left;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid rgba(105, 117, 101, 0.25);
  }
  .prose :global(td) {
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--color-surface);
    color: var(--color-base);
    opacity: 0.75;
  }
  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Tags */
  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-surface);
  }
  .tag {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-sage);
    color: var(--color-base);
    font-size: var(--text-xs);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
  }

  /* ── Related CTA ────────────────────────────────── */
  .related-cta {
    border-top: 1px solid rgba(105, 117, 101, 0.2);
    padding-block: 3rem;
    margin-top: 1rem;
  }
  .related-cta-inner {
    max-width: 680px;
    margin-inline: auto;
    padding-inline: 1.25rem;
  }
  .related-cta-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-surface);
    margin-bottom: 0.5rem;
  }
  .related-cta-heading {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    color: var(--color-base);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }
  .related-cta-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cta-link {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-sage);
    color: var(--color-base);
    text-decoration: none;
    padding: 0.65rem 1.25rem;
    border-radius: 6px;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
  }
  .cta-link:hover {
    background: var(--color-sage);
    color: var(--color-cream);
  }
</style>
